                    {% set _register_url = app.request.attributes.get('_route') is defined and (app.request.attributes.get('_route') starts with 'user_appointment') ? path('register', { _target_path: _return_uri }) : path('register') %}
                    <a href="{{ _register_url }}" class="flex items-center gap-2 px-5 py-2.5 rounded-xl bg-[#A8BBA3] text-white font-medium hover:bg-[#94B08E] focus:outline focus:ring-2 focus:ring-[#CDB4DB]/50 shadow-pastel transition-colors whitespace-nowrap">
                        <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
                        </svg>
                        S'inscrire
                    </a>
                {% endif %}
            </div>
            </div>
        </div>

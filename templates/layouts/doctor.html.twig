{% extends 'base.html.twig' %}

{% block body %}
<div class="min-h-screen flex bg-[#f8fafc] dark:bg-gray-800 transition-colors duration-200">
    {# Sidebar style dashboard moderne #}
    <aside class="w-64 shrink-0 flex flex-col bg-[#E8DCF0] dark:bg-gray-700 border-r border-[#E8DED5]/50 dark:border-gray-600 transition-colors duration-200">
        <div class="p-4 border-b border-[#E8DED5]/50 dark:border-gray-600">
            <a href="{{ path('doctor_dashboard') }}" class="flex items-center gap-2 text-[#4B3D6B] dark:text-white font-bold text-lg tracking-tight">
                <img src="{{ asset('images/logo.png') }}" alt="AutiCare" class="h-10 w-auto object-contain" />
                AutiCare
            </a>
        </div>
        <div class="p-3">
            <a href="{{ path('doctor_availability_new') }}" class="flex items-center justify-center gap-2 w-full py-3 rounded-xl bg-gradient-to-r from-[#CDB4DB] to-[#B8A4CC] dark:from-[#9B7BB8] dark:to-[#7B5B9E] text-white font-semibold text-sm shadow-lg shadow-[#CDB4DB]/30 hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
                Nouveau créneau
            </a>
        </div>
        <nav class="p-3 flex-1" aria-label="Navigation principale">
            <ul class="space-y-1">
                <li><a href="{{ path('doctor_dashboard') }}" class="flex items-center gap-3 px-4 py-3 rounded-xl text-[#5C4B6B] dark:text-gray-300 hover:bg-white/50 dark:hover:bg-gray-600 hover:text-[#4B3D6B] dark:hover:text-white focus:outline focus:ring-2 focus:ring-[#CDB4DB]/50 transition-colors {{ app.request.get('_route') == 'doctor_dashboard' ? 'bg-gradient-to-r from-[#CDB4DB]/30 to-[#A8BBA3]/20 dark:from-[#CDB4DB]/40 dark:to-[#93C5FD]/20 text-[#4B3D6B] dark:text-white font-semibold shadow-sm' : '' }}">
                    <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" /></svg>
                    Tableau de bord
                </a></li>
                <li><a href="{{ path('doctor_availability') }}" class="flex items-center gap-3 px-4 py-3 rounded-xl text-[#5C4B6B] dark:text-gray-300 hover:bg-white/50 dark:hover:bg-gray-600 hover:text-[#4B3D6B] dark:hover:text-white focus:outline focus:ring-2 focus:ring-[#CDB4DB]/50 transition-colors {{ app.request.get('_route') in ['doctor_availability', 'doctor_availability_new', 'doctor_availability_edit'] ? 'bg-gradient-to-r from-[#CDB4DB]/30 to-[#A8BBA3]/20 dark:from-[#CDB4DB]/40 dark:to-[#93C5FD]/20 text-[#4B3D6B] dark:text-white font-semibold shadow-sm' : '' }}">
                    <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    Disponibilités
                </a></li>
                <li><a href="{{ path('doctor_notes') }}" data-turbo="false" class="flex items-center gap-3 px-4 py-3 rounded-xl text-[#5C4B6B] dark:text-gray-300 hover:bg-white/50 dark:hover:bg-gray-600 hover:text-[#4B3D6B] dark:hover:text-white focus:outline focus:ring-2 focus:ring-[#CDB4DB]/50 transition-colors {{ app.request.get('_route') == 'doctor_notes' ? 'bg-gradient-to-r from-[#CDB4DB]/30 to-[#A8BBA3]/20 dark:from-[#CDB4DB]/40 dark:to-[#93C5FD]/20 text-[#4B3D6B] dark:text-white font-semibold shadow-sm' : '' }}">
                    <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
                    Notes
                </a></li>
                <li><a href="{{ path('doctor_rendezvous') }}" class="flex items-center gap-3 px-4 py-3 rounded-xl text-[#5C4B6B] dark:text-gray-300 hover:bg-white/50 dark:hover:bg-gray-600 hover:text-[#4B3D6B] dark:hover:text-white focus:outline focus:ring-2 focus:ring-[#CDB4DB]/50 transition-colors {{ app.request.get('_route') is defined and 'doctor_rendezvous' in app.request.get('_route') ? 'bg-gradient-to-r from-[#CDB4DB]/30 to-[#A8BBA3]/20 dark:from-[#CDB4DB]/40 dark:to-[#93C5FD]/20 text-[#4B3D6B] dark:text-white font-semibold shadow-sm' : '' }}">
                    <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
                    Rendez-vous
                </a></li>
                <li><a href="{{ path('doctor_notifications') }}" class="flex items-center gap-3 px-4 py-3 rounded-xl text-[#5C4B6B] dark:text-gray-300 hover:bg-white/50 dark:hover:bg-gray-600 hover:text-[#4B3D6B] dark:hover:text-white focus:outline focus:ring-2 focus:ring-[#CDB4DB]/50 transition-colors {{ app.request.get('_route') == 'doctor_notifications' ? 'bg-gradient-to-r from-[#CDB4DB]/30 to-[#A8BBA3]/20 dark:from-[#CDB4DB]/40 dark:to-[#93C5FD]/20 text-[#4B3D6B] dark:text-white font-semibold shadow-sm' : '' }}">
                    <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" /></svg>
                    Notifications
                    {% if notif_count|default(0) > 0 %}<span class="ml-auto flex items-center justify-center min-w-[1.25rem] h-5 px-1 rounded-full bg-red-500 text-white text-xs font-medium">{{ notif_count }}</span>{% endif %}
                </a></li>
            </ul>
        </nav>
        <div class="p-3 border-t border-[#E8DED5]/50 dark:border-gray-600">
            <div class="rounded-xl bg-white/60 dark:bg-gray-600/60 p-4 border border-[#E8DED5]/50 dark:border-gray-500">
                <p class="text-[#4B3D6B] dark:text-gray-200 font-semibold text-sm mb-1">Espace médecin</p>
                <p class="text-[#6B5B7B] dark:text-gray-400 text-xs mb-3">Gérez vos créneaux et rendez-vous.</p>
                <a href="{{ path('home') }}" class="inline-flex items-center gap-1.5 text-[#CDB4DB] dark:text-[#93C5FD] text-xs font-medium hover:underline">
                    Retour au site
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                </a>
                <a href="{{ path('app_logout') }}" class="mt-2 inline-flex items-center gap-1.5 text-red-600 dark:text-red-400 text-xs font-medium hover:underline">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
                    Se déconnecter
                </a>
            </div>
        </div>
    </aside>

    <div class="flex-1 flex flex-col min-h-0">
        {# Barre supérieure : titre + recherche + icônes #}
        <header class="shrink-0 flex items-center justify-between gap-4 px-6 py-4 bg-white dark:bg-gray-700/80 border-b border-[#e2e8f0] dark:border-gray-600 shadow-sm">
            <h1 class="text-xl font-bold text-[#1e293b] dark:text-white tracking-tight">Tableau de bord</h1>
            <div class="flex-1 max-w-md mx-4">
                <form method="get" action="{{ path('doctor_search') }}" id="doctor-search-form" class="relative" role="search" data-dashboard-url="{{ path('doctor_dashboard') }}">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-[#94a3b8] pointer-events-none">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" /></svg>
                    </span>
                    <input type="search" name="q" id="doctor-search-input" value="{{ app.request.query.get('q', '')|e('html_attr') }}" placeholder="Rechercher…" class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-[#e2e8f0] dark:border-gray-500 bg-[#f8fafc] dark:bg-gray-600/50 text-[#1e293b] dark:text-gray-100 placeholder-[#94a3b8] focus:outline-none focus:ring-2 focus:ring-[#CDB4DB] focus:border-transparent text-sm transition-all" autocomplete="off">
                </form>
            </div>
            <div class="flex items-center gap-2">
                <button type="button" id="theme-toggle" aria-label="Mode nuit / jour" class="p-2.5 rounded-xl text-[#64748b] dark:text-gray-300 hover:bg-[#E8DCF0]/50 dark:hover:bg-gray-600 transition-colors" title="Mode nuit / jour">
                    <span class="hidden dark:inline-block"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" /></svg></span>
                    <span class="inline-block dark:hidden"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" /></svg></span>
                </button>
                <a href="{{ path('doctor_notifications') }}" class="relative p-2.5 rounded-xl text-[#64748b] dark:text-gray-300 hover:bg-[#E8DCF0]/50 dark:hover:bg-gray-600 transition-colors" aria-label="Notifications">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" /></svg>
                    {% if notif_count|default(0) > 0 %}<span class="absolute top-1 right-1 min-w-[1.25rem] h-5 px-1 rounded-full bg-red-500 text-white text-xs font-medium flex items-center justify-center">{{ notif_count }}</span>{% endif %}
                </a>
                <a href="{{ path('doctor_profile') }}" class="flex items-center gap-2 pl-2 border-l border-[#e2e8f0] dark:border-gray-500" title="Mon profil">
                    <span class="flex items-center justify-center w-9 h-9 rounded-xl overflow-hidden bg-gradient-to-br from-[#CDB4DB] to-[#A8BBA3] text-white font-semibold text-sm shrink-0">{% if app.user and app.user.image %}<img src="{{ asset(app.user.image) }}" alt="" class="w-full h-full object-cover">{% else %}{{ app.user ? (app.user.prenom|slice(0,1) ~ app.user.nom|slice(0,1))|upper : 'DR' }}{% endif %}</span>
                    <div class="hidden sm:block text-left">
                        <p class="font-medium text-[#1e293b] dark:text-gray-100 text-sm leading-tight">{{ app.user ? app.user.prenom ~ ' ' ~ app.user.nom : 'Médecin' }}</p>
                        <p class="text-[#64748b] dark:text-gray-400 text-xs">Profil</p>
                    </div>
                </a>
            </div>
        </header>
        <main class="flex-1 overflow-auto p-6 bg-[#f8fafc] dark:bg-gray-800/50 transition-colors duration-200">
            {% include 'partials/_flash_messages.html.twig' %}
            {% block doctor_content %}{% endblock %}
        </main>
    </div>
</div>
<script>
window.noteEditorSavedRange = null;
window.noteEditorSaveSel = function(editorId) {
    editorId = editorId || 'note_editor_content';
    var editor = document.getElementById(editorId);
    var sel = window.getSelection();
    if (!editor || !sel.rangeCount) return;
    try {
        var range = sel.getRangeAt(0);
        if (editor.contains(range.commonAncestorContainer)) window.noteEditorSavedRange = range.cloneRange();
    } catch (e) {}
};
window.noteEditorCmd = function(cmd, editorId, fieldId) {
    editorId = editorId || 'note_editor_content';
    fieldId = fieldId || 'note_contenu_field';
    var editor = document.getElementById(editorId);
    if (!editor) return;
    editor.focus();
    var sel = window.getSelection();
    if (window.noteEditorSavedRange) {
        try { sel.removeAllRanges(); sel.addRange(window.noteEditorSavedRange); } catch (e) {}
        window.noteEditorSavedRange = null;
    }
    function doCmd() {
        if (cmd === 'link') {
            var u = prompt('URL du lien :');
            if (u) document.execCommand('createLink', false, u);
        } else {
            document.execCommand(cmd, false, null);
        }
    }
    requestAnimationFrame(function() { doCmd(); });
};
window.noteEditorCmdWithValue = function(cmd, value, editorId) {
    editorId = editorId || 'note_editor_content';
    var editor = document.getElementById(editorId);
    if (!editor || !value) return;
    editor.focus();
    var sel = window.getSelection();
    if (window.noteEditorSavedRange) {
        try { sel.removeAllRanges(); sel.addRange(window.noteEditorSavedRange); } catch (e) {}
        window.noteEditorSavedRange = null;
    }
    document.execCommand(cmd, false, value);
};
function noteEditorSyncToField(editor, field) {
    if (editor && field) field.value = editor.innerHTML;
}
function noteEditorInit() {
    var editor = document.getElementById('note_editor_content');
    var field = document.getElementById('note_contenu_field');
    if (editor && field) {
        if (field.value && field.value.trim()) editor.innerHTML = field.value;
        editor.addEventListener('blur', function() { noteEditorSaveSel('note_editor_content'); noteEditorSyncToField(editor, field); });
        editor.addEventListener('input', function() { noteEditorSyncToField(editor, field); });
        editor.addEventListener('paste', function() { setTimeout(function() { noteEditorSyncToField(editor, field); }, 0); });
        var form = field.closest('form');
        if (form) form.addEventListener('submit', function() { noteEditorSyncToField(editor, field); });
    }
    var editorEdit = document.getElementById('note_editor_edit_content');
    var fieldEdit = document.getElementById('note_contenu_field_edit');
    if (editorEdit && fieldEdit) {
        if (fieldEdit.value && fieldEdit.value.trim()) editorEdit.innerHTML = fieldEdit.value;
        editorEdit.addEventListener('blur', function() { noteEditorSaveSel('note_editor_edit_content'); noteEditorSyncToField(editorEdit, fieldEdit); });
        editorEdit.addEventListener('input', function() { noteEditorSyncToField(editorEdit, fieldEdit); });
        editorEdit.addEventListener('paste', function() { setTimeout(function() { noteEditorSyncToField(editorEdit, fieldEdit); }, 0); });
        var formEdit = fieldEdit.closest('form');
        if (formEdit) formEdit.addEventListener('submit', function() { noteEditorSyncToField(editorEdit, fieldEdit); });
    }
}
if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', noteEditorInit);
else noteEditorInit();
document.addEventListener('turbo:load', noteEditorInit);

document.addEventListener('submit', function(e) {
    var form = e.target;
    if (form.tagName !== 'FORM') return;
    var editorId = form.getAttribute('data-note-editor-id');
    var fieldId = form.getAttribute('data-note-field-id');
    if (!editorId || !fieldId) return;
    var editor = document.getElementById(editorId);
    var field = document.getElementById(fieldId);
    if (editor && field) field.value = editor.innerHTML;
}, true);

document.addEventListener('change', function(e) {
    var sel = e.target.closest && e.target.closest('.note-toolbar-select');
    if (sel) {
        var w = sel.closest('.note-rich-editor-wrapper');
        var editorId = w ? w.getAttribute('data-note-editor-id') : 'note_editor_content';
        var cmd = sel.getAttribute('data-cmd');
        var val = sel.value;
        if (cmd && val && typeof window.noteEditorCmdWithValue === 'function') {
            window.noteEditorCmdWithValue(cmd, val, editorId);
            sel.selectedIndex = 0;
        }
        return;
    }
    var input = e.target;
    if (!input.classList || !input.classList.contains('note-attachment-input')) return;
    var file = input.files && input.files[0];
    if (!file) return;
    var wrapper = input.closest('.note-rich-editor-wrapper');
    var editorId = wrapper ? wrapper.getAttribute('data-note-editor-id') : 'note_editor_content';
    var uploadUrl = input.getAttribute('data-upload-url');
    if (!uploadUrl) return;
    var editor = document.getElementById(editorId);
    if (!editor) return;
    editor.focus();
    var sel = window.getSelection();
    if (window.noteEditorSavedRange) {
        try { sel.removeAllRanges(); sel.addRange(window.noteEditorSavedRange); } catch (e) {}
        window.noteEditorSavedRange = null;
    }
    var fd = new FormData();
    fd.append('file', file);
    var csrf = input.getAttribute('data-csrf-token');
    if (csrf) fd.append('_token', csrf);
    fetch(uploadUrl, { method: 'POST', body: fd, headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(function(r) {
            var ct = (r.headers.get('Content-Type') || '');
            if (ct.indexOf('application/json') === -1) {
                return { ok: false, json: { error: r.status === 403 ? 'Session expirée ou non autorisé.' : 'Réponse serveur invalide (' + r.status + ').' } };
            }
            return r.json().then(function(j) { return { ok: r.ok, json: j }; }).catch(function() { return { ok: false, json: { error: 'Réponse invalide.' } }; });
        })
        .then(function(res) {
            if (!res.ok) { alert(res.json && res.json.error ? res.json.error : 'Erreur lors de l\'envoi.'); input.value = ''; return; }
            var url = res.json.url;
            var name = res.json.name || file.name;
            var isImg = /^image\//i.test(file.type);
            if (isImg) {
                document.execCommand('insertImage', false, url);
            } else {
                var safeUrl = url.replace(/&/g, '&amp;').replace(/"/g, '&quot;');
                var safeName = (name || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
                document.execCommand('insertHTML', false, '<a href="' + safeUrl + '" target="_blank" rel="noopener">' + safeName + '</a> ');
            }
            input.value = '';
        })
        .catch(function() { alert('Erreur réseau.'); input.value = ''; });
});
</script>
<script>
(function() {
    var btn = document.getElementById('theme-toggle');
    if (btn) btn.addEventListener('click', function() {
        var isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('auticare-theme', isDark ? 'dark' : 'light');
    });
})();
</script>
<script>
(function() {
    var form = document.getElementById('doctor-search-form');
    var input = document.getElementById('doctor-search-input');
    if (!form || !input) return;
    var searchUrl = form.action || (form.getAttribute('action'));
    var dashboardUrl = form.getAttribute('data-dashboard-url') || searchUrl.replace(/\/recherche.*$/, '') || '/medecin';
    var debounceTimer = null;
    var debounceMs = 400;
    function doSearch() {
        var q = (input.value || '').trim();
        if (q.length === 0) {
            window.location.href = dashboardUrl;
            return;
        }
        var url = searchUrl + (searchUrl.indexOf('?') !== -1 ? '&' : '?') + 'q=' + encodeURIComponent(q);
        window.location.href = url;
    }
    input.addEventListener('input', function() {
        clearTimeout(debounceTimer);
        var q = (input.value || '').trim();
        if (q.length === 0) {
            debounceTimer = setTimeout(function() { window.location.href = dashboardUrl; }, debounceMs);
            return;
        }
        debounceTimer = setTimeout(doSearch, debounceMs);
    });
    form.addEventListener('submit', function(e) {
        e.preventDefault();
        clearTimeout(debounceTimer);
        doSearch();
    });
})();
</script>
{% endblock %}
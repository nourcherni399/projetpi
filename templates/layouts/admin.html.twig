                    <div class="absolute right-0 mt-2 w-80 rounded-xl bg-white dark:bg-gray-600 shadow-lg border border-[#e2e8f0] dark:border-gray-500 py-2 z-50">
                        <div class="px-4 py-2 border-b border-[#e2e8f0] dark:border-gray-500"><p class="font-medium text-[#1e293b] dark:text-gray-100 text-sm">Notifications</p></div>
                        {% if admin_unread_event_messages_count|default(0) > 0 %}
                        {% set _event_id_unread = admin_first_event_id_with_unread_messages|default(null) %}
                        <a href="{{ _event_id_unread ? path('admin_evenement_show', { id: _event_id_unread }) : path('admin_evenement_index') }}" class="block px-4 py-3 border-b border-[#e2e8f0] dark:border-gray-500 bg-sky-50/50 dark:bg-sky-900/20 hover:bg-sky-100/70 dark:hover:bg-sky-900/30 transition-colors">
                            <p class="text-xs text-[#64748b] dark:text-gray-400 mb-1">Messages événements</p>
                            <span class="flex items-center gap-2 text-sm font-medium text-sky-700 dark:text-sky-300">{{ admin_unread_event_messages_count }} message(s) non lu(s)</span>
                        </a>
                        {% endif %}
                        <div class="px-4 py-2 border-b border-[#e2e8f0] dark:border-gray-500"><p class="font-medium text-[#1e293b] dark:text-gray-100 text-sm">Demandes d'inscription</p></div>
                        {% if admin_pending_inscriptions|default([]) is empty %}
                        <p class="px-4 py-3 text-[#64748b] dark:text-gray-400 text-sm">Aucune demande en attente.</p>
                        {% else %}
                        {% for ins in admin_pending_inscriptions %}
                        <a href="{{ path('admin_evenement_show', { id: ins.evenement.id }) }}" class="block px-4 py-3 hover:bg-[#f8fafc] dark:hover:bg-gray-500 text-sm text-[#1e293b] dark:text-gray-200">{{ ins.user.prenom }} {{ ins.user.nom }} – {{ ins.evenement.title }}</a>
                        {% endfor %}
                        {% endif %}
                    </div>
                </details>
                <a href="{{ path('admin_profile') }}" class="flex items-center gap-2 pl-2 border-l border-[#e2e8f0] dark:border-gray-500" title="Mon profil">
                    <span class="flex items-center justify-center w-9 h-9 rounded-xl overflow-hidden bg-gradient-to-br from-[#CDB4DB] to-[#A8BBA3] text-white font-semibold text-sm shrink-0">{% if app.user and app.user.image %}<img src="{{ asset(app.user.image) }}" alt="" class="w-full h-full object-cover">{% else %}{{ app.user ? (app.user.prenom|slice(0,1) ~ app.user.nom|slice(0,1))|upper : 'AD' }}{% endif %}</span>
                    <div class="hidden sm:block text-left">
                        <p class="font-medium text-[#1e293b] dark:text-gray-100 text-sm leading-tight">{{ app.user ? app.user.prenom ~ ' ' ~ app.user.nom : 'Admin' }}</p>
                        <p class="text-[#64748b] dark:text-gray-400 text-xs">Profil</p>
                    </div>
                </a>
            </div>
        </header>
        <main class="flex-1 overflow-auto p-6 bg-[#f8fafc] dark:bg-gray-800/50 transition-colors duration-200">
            {% include 'partials/_flash_messages.html.twig' %}
            {% block admin_content %}{% endblock %}
        </main>
    </div>
</div>
<script>
(function() {
    var btn = document.getElementById('theme-toggle');
    if (btn) btn.addEventListener('click', function() {
        var isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('auticare-theme', isDark ? 'dark' : 'light');
    });
})();
</script>
{% endblock %}
                </a></li>
                <li><a href="{{ path('admin_dashboard') }}" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-[#5C4B6B] dark:text-gray-300 hover:bg-white/50 dark:hover:bg-gray-600 transition-colors {{ _route == 'admin_module_index' or _route starts with 'admin_module' ? 'bg-gradient-to-r from-[#CDB4DB]/30 to-[#A8BBA3]/20 dark:from-[#CDB4DB]/40 dark:to-[#93C5FD]/20 text-[#4B3D6B] dark:text-white font-semibold shadow-sm' : '' }}">

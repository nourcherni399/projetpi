                    <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
                    Événements
                    {% if admin_unread_event_messages_count|default(0) > 0 %}<span class="absolute right-3 flex h-5 min-w-[1.25rem] items-center justify-center rounded-full bg-amber-500 px-1.5 text-xs font-medium text-white">{{ admin_unread_event_messages_count > 99 ? '99+' : admin_unread_event_messages_count }}</span>{% endif %}
                </a></li>
                <li><a href="{{ path('admin_thematique_index') }}" class="flex items-center gap-3 px-4 py-2.5 rounded-xl text-[#5C4B6B] dark:text-gray-300 hover:bg-white/50 dark:hover:bg-gray-600 transition-colors {{ _route starts with 'admin_thematique' ? 'bg-gradient-to-r from-[#CDB4DB]/30 to-[#A8BBA3]/20 dark:from-[#CDB4DB]/40 dark:to-[#93C5FD]/20 text-[#4B3D6B] dark:text-white font-semibold shadow-sm' : '' }}">
                    <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z" /></svg>

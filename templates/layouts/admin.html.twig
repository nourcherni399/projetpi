        </nav>
        <div class="p-3 border-t border-[#E8DED5]/50 dark:border-gray-600">
            <div class="rounded-xl bg-white/60 dark:bg-gray-600/60 p-4 border border-[#E8DED5]/50 dark:border-gray-500">
                <p class="text-[#4B3D6B] dark:text-gray-200 font-semibold text-sm mb-1">Espace admin</p>
                <p class="text-[#6B5B7B] dark:text-gray-400 text-xs mb-3">Gérez utilisateurs, contenu et commandes.</p>
                <a href="{{ path('home') }}" class="inline-flex items-center gap-1.5 text-[#CDB4DB] dark:text-[#93C5FD] text-xs font-medium hover:underline">Retour au site <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg></a>
                <a href="{{ path('app_logout') }}" class="mt-2 block text-red-600 dark:text-red-400 text-xs font-medium hover:underline">Se déconnecter</a>
            </div>
        </div>
    </aside>

    <div class="flex-1 flex flex-col min-h-0">
        <header class="shrink-0 flex items-center justify-between gap-4 px-6 py-4 bg-white dark:bg-gray-700/80 border-b border-[#e2e8f0] dark:border-gray-600 shadow-sm">
            <h1 class="text-xl font-bold text-[#1e293b] dark:text-white tracking-tight">Tableau de bord</h1>
            <div class="flex-1 max-w-md mx-4">
                <div class="relative">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-[#94a3b8]"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" /></svg></span>
                    <input type="search" placeholder="Rechercher…" class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-[#e2e8f0] dark:border-gray-500 bg-[#f8fafc] dark:bg-gray-600/50 text-[#1e293b] dark:text-gray-100 placeholder-[#94a3b8] focus:outline-none focus:ring-2 focus:ring-[#CDB4DB] focus:border-transparent text-sm transition-all">
                </div>
            </div>
            <div class="flex items-center gap-2">

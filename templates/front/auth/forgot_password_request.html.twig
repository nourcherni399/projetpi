{% extends 'layouts/user.html.twig' %}

{% block title %}Mot de passe oublié - AutiCare{% endblock %}

{% block user_content %}
<div class="max-w-5xl mx-auto py-8 px-4">
    <div class="bg-white rounded-2xl shadow-2xl border border-[#E5E0D8] overflow-hidden">
        <div class="grid md:grid-cols-2">
            <div class="bg-[#F3F4F6] p-8 md:p-10 flex flex-col justify-between min-h-[520px]">
                <p class="text-[#4B5563] text-lg">Welcome!</p>
                <div class="flex items-center justify-center py-8">
                    <img src="{{ asset('images/logo.png') }}" alt="AutiCare" class="h-64 w-auto object-contain" />
                </div>
                <p class="text-sm text-[#6B7280]">
                    Pas encore membre ?
                    <a href="{{ path('register') }}" class="font-semibold text-[#111827] hover:underline">Register now</a>
                </p>
            </div>

            <div class="p-8 md:p-10">
                <h1 class="text-3xl font-bold text-[#23262F] mb-2">Forgot your password</h1>
                <p class="text-sm text-[#6B7280] mb-6">Enter your email address and we will send you a code to reset your password.</p>

                {% for message in app.flashes('error') %}
                    <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-600 text-sm">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('info') %}
                    <div class="mb-4 p-3 bg-blue-50 border border-blue-200 rounded-lg text-blue-800 text-sm">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('success') %}
                    <div class="mb-4 p-3 bg-green-50 border border-green-200 rounded-lg text-green-600 text-sm">{{ message }}</div>
                {% endfor %}

                {% if not sent %}
                <form method="post" action="{{ path('app_forgot_password_request') }}" class="space-y-5" novalidate>
                    <div>
                        <label for="email" class="block text-xs uppercase tracking-wide text-[#9CA3AF] mb-1">Email or username (*)</label>
                        <input type="text" id="email" name="email" value="{{ email }}" placeholder="Email or Username" autocomplete="email"
                            class="w-full px-4 py-3 rounded-lg border border-[#E5E7EB] bg-white text-[#374151] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#A7C7E7]">
                    </div>
                    <button type="submit" class="w-full py-3 rounded-lg bg-[#1F2937] text-white font-semibold hover:bg-[#111827] transition">Reset password</button>
                </form>
                {% endif %}

                <p class="mt-8 text-center">
                    <a href="{{ path('app_login') }}" class="text-[#4B5563] font-semibold hover:underline">Back</a>
                </p>

                {% if sent %}
                <div class="mt-6 p-4 bg-[#F9FAFB] rounded-xl border border-[#E5E7EB]">
                    <p class="text-[#4B5563] font-medium mb-3">Next step</p>
                    <a href="{{ path('app_forgot_password_verify_pin', { email: email }) }}" class="block w-full py-3 rounded-lg bg-[#1F2937] text-white font-semibold text-center hover:bg-[#111827] transition">
                        Enter PIN code
                    </a>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}

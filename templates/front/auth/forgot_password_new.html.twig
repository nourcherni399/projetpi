{% extends 'layouts/user.html.twig' %}

{% block title %}Nouveau mot de passe - AutiCare{% endblock %}

{% block user_content %}
<div class="max-w-5xl mx-auto py-8 px-4">
    <div class="bg-white rounded-2xl shadow-2xl border border-[#E5E0D8] overflow-hidden">
        <div class="grid md:grid-cols-2">
            <div class="bg-[#F3F4F6] p-8 md:p-10 flex flex-col justify-between min-h-[520px]">
                <p class="text-[#4B5563] text-lg">Welcome!</p>
                <div class="flex items-center justify-center py-8">
                    <img src="{{ asset('images/logo.png') }}" alt="AutiCare" class="h-64 w-auto object-contain" />
                </div>
                <p class="text-sm text-[#6B7280]">
                    Need a new code?
                    <a href="{{ path('app_forgot_password_request', { email: email }) }}" class="font-semibold text-[#111827] hover:underline">Restart flow</a>
                </p>
            </div>

            <div class="p-8 md:p-10">
                <h1 class="text-3xl font-bold text-[#23262F] mb-2">Set new password</h1>
                <p class="text-sm text-[#6B7280] mb-6">Choose a secure new password for your account.</p>

                {% for message in app.flashes('success') %}
                    <div class="mb-4 p-3 bg-green-50 border border-green-200 rounded-lg text-green-600 text-sm">{{ message }}</div>
                {% endfor %}
                {% if error %}
                    <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-600 text-sm">{{ error }}</div>
                {% endif %}

                <form method="post" action="{{ path('app_forgot_password_new') }}" class="space-y-5" novalidate>
                    <input type="hidden" name="email" value="{{ email }}">
                    <input type="hidden" name="pin" value="{{ pin }}">
                    
                    <div class="p-3 bg-green-50 border border-green-200 rounded-lg">
                        <p class="text-green-700 text-sm font-medium">PIN code verified</p>
                        <p class="text-green-600 text-xs mt-1">You can now set your new password.</p>
                    </div>

                    <div>
                        <label for="password" class="block text-xs uppercase tracking-wide text-[#9CA3AF] mb-1">New password (*)</label>
                        <input type="password" id="password" name="password" placeholder="At least 6 characters" autocomplete="new-password"
                            class="w-full px-4 py-3 rounded-lg border border-[#E5E7EB] bg-white text-[#374151] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#A7C7E7]">
                        <div class="mt-2 space-y-1 text-xs">
                            <p id="pwd-rule-len" class="text-[#9CA3AF]">- Au moins 6 caractères</p>
                            <p id="pwd-rule-upper" class="text-[#9CA3AF]">- Au moins une lettre majuscule</p>
                            <p id="pwd-rule-digit" class="text-[#9CA3AF]">- Au moins un chiffre</p>
                        </div>
                    </div>
                    <div>
                        <label for="password_confirm" class="block text-xs uppercase tracking-wide text-[#9CA3AF] mb-1">Repeat password (*)</label>
                        <input type="password" id="password_confirm" name="password_confirm" placeholder="Repeat password" autocomplete="new-password"
                            class="w-full px-4 py-3 rounded-lg border border-[#E5E7EB] bg-white text-[#374151] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#A7C7E7]">
                    </div>
                    <button type="submit" class="w-full py-3 rounded-lg bg-[#1F2937] text-white font-semibold hover:bg-[#111827] transition">Reset password</button>
                </form>

                <p class="mt-8 text-center">
                    <a href="{{ path('app_login') }}" class="text-[#4B5563] font-semibold hover:underline">Back</a>
                </p>
            </div>
        </div>
    </div>
</div>
<script>
(function() {
    var passwordInput = document.getElementById('password');
    var lenEl = document.getElementById('pwd-rule-len');
    var upperEl = document.getElementById('pwd-rule-upper');
    var digitEl = document.getElementById('pwd-rule-digit');
    if (!passwordInput || !lenEl || !upperEl || !digitEl) return;

    function setRuleState(el, ok) {
        el.classList.toggle('text-green-600', ok);
        el.classList.toggle('text-[#9CA3AF]', !ok);
    }

    function validate() {
        var value = passwordInput.value || '';
        setRuleState(lenEl, value.length >= 6);
        setRuleState(upperEl, /[A-Z]/.test(value));
        setRuleState(digitEl, /\d/.test(value));
    }

    passwordInput.addEventListener('input', validate);
    validate();
})();
</script>
{% endblock %}

{% extends 'layouts/user.html.twig' %}

{% block title %}Connexion - AutiCare{% endblock %}

{% block user_content %}
<div class="max-w-5xl mx-auto py-8 px-4">
    <div class="bg-white rounded-2xl shadow-2xl border border-[#E5E0D8] overflow-hidden">
        <div class="grid md:grid-cols-2">
            <div class="bg-[#F3F4F6] p-8 md:p-10 flex flex-col justify-between min-h-[520px]">
                <p class="text-[#4B5563] text-lg">Welcome!</p>
                <div class="flex items-center justify-center py-8">
                    <img src="{{ asset('images/logo.png') }}" alt="AutiCare" class="h-64 w-auto object-contain" />
                </div>
                <p class="text-sm text-[#6B7280]">
                    Pas encore membre ?
                    <a href="{{ path('register') }}" class="font-semibold text-[#111827] hover:underline">Créer maintenant</a>
                </p>
            </div>

            <div class="p-8 md:p-10">
                <h1 class="text-3xl font-bold text-[#23262F] mb-2">Log in</h1>
                <p class="text-sm text-[#6B7280] mb-6">Connectez-vous à votre compte</p>

                {% if error %}
                    <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg">
                        <p class="text-red-600 text-sm">{{ error.messageKey|trans(error.messageData, 'security') }}</p>
                    </div>
                {% endif %}

                {% if app.flashes('error') %}
                    <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg">
                        {% for message in app.flashes('error') %}
                            <p class="text-red-600 text-sm">{{ message }}</p>
                        {% endfor %}
                    </div>
                {% endif %}

                {% if app.flashes('success') %}
                    <div class="mb-4 p-3 bg-green-50 border border-green-200 rounded-lg">
                        {% for message in app.flashes('success') %}
                            <p class="text-green-600 text-sm">{{ message }}</p>
                        {% endfor %}
                    </div>
                {% endif %}

                <form method="post" action="{{ path('app_login') }}" class="space-y-4" novalidate>
                    <div>
                        <label for="email" class="block text-xs uppercase tracking-wide text-[#9CA3AF] mb-1">Email ou username</label>
                        <input
                            type="text"
                            id="email"
                            name="email"
                            value="{{ last_username }}"
                            placeholder="Email ou Username"
                            autocomplete="email"
                            class="w-full px-4 py-3 rounded-lg border border-[#E5E7EB] bg-white text-[#374151] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#A7C7E7] {% if errors.email is defined %}border-red-500 ring-2 ring-red-200{% endif %}"
                        >
                        {% if errors.email is defined %}
                        <p class="mt-1 text-sm text-red-600">{{ errors.email }}</p>
                        {% endif %}
                    </div>

                    <div>
                        <div class="flex items-center justify-between mb-1">
                            <label for="password" class="block text-xs uppercase tracking-wide text-[#9CA3AF]">Password</label>
                            <a href="{{ path('app_forgot_password_request') }}" class="text-xs text-[#6B7280] hover:underline">Forgot your password?</a>
                        </div>
                        <div class="relative">
                            <input
                                type="password"
                                id="password"
                                name="password"
                                placeholder="Password"
                                autocomplete="current-password"
                                class="w-full px-4 py-3 rounded-lg border border-[#E5E7EB] bg-white text-[#374151] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#A7C7E7] pr-10 {% if errors.password is defined %}border-red-500 ring-2 ring-red-200{% endif %}"
                            >
                            <button type="button" id="toggle-password" class="absolute right-3 top-1/2 -translate-y-1/2 text-[#6B7280] hover:text-[#4B5563] focus:outline-none" aria-label="Afficher le mot de passe" title="Afficher le mot de passe">
                                <svg id="icon-eye-open" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                                <svg id="icon-eye-closed" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" /></svg>
                            </button>
                        </div>
                        {% if errors.password is defined %}
                        <p class="mt-1 text-sm text-red-600">{{ errors.password }}</p>
                        {% endif %}
                    </div>

                    <div id="captcha-block" class="{% if errors.captcha is not defined %}hidden{% endif %}">
                        <label for="captcha_answer" class="block text-xs uppercase tracking-wide text-[#9CA3AF] mb-1">Verification anti-robot</label>
                        <div class="flex items-center gap-2 mb-2">
                            <img id="login-captcha-image" src="{{ captcha_image_url }}" alt="Captcha anti-robot" class="h-12 rounded-lg border border-[#E5E7EB] bg-[#F3F4F6] px-2 py-1" />
                            <button type="button" id="refresh-captcha" class="px-3 py-2 rounded-lg border border-[#E5E7EB] text-xs text-[#4B5563] hover:bg-[#F9FAFB] transition">
                                Rafraichir
                            </button>
                        </div>
                        <input
                            type="text"
                            id="captcha_answer"
                            name="captcha_answer"
                            placeholder="Saisir le code de l'image"
                            {% if errors.captcha is not defined %}disabled{% endif %}
                            class="w-full px-4 py-3 rounded-lg border border-[#E5E7EB] bg-white text-[#374151] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#A7C7E7] {% if errors.captcha is defined %}border-red-500 ring-2 ring-red-200{% endif %}"
                        >
                        {% if errors.captcha is defined %}
                        <p class="mt-1 text-sm text-red-600">{{ errors.captcha }}</p>
                        {% endif %}
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                    {% if target_path|default('') is not empty %}
                    <input type="hidden" name="_target_path" value="{{ target_path }}">
                    {% endif %}

                    <button type="submit" class="w-full py-3 rounded-lg bg-[#1F2937] text-white font-semibold hover:bg-[#111827] transition">Log in now</button>

                    <div class="pt-4">
                        <p class="text-xs text-[#9CA3AF] mb-3">Ou sign in with</p>
                        <div class="grid grid-cols-2 gap-3">
                            <a href="{{ path('app_connect_google_start') }}" class="inline-flex items-center justify-center gap-2 py-2.5 rounded-lg border border-[#E5E7EB] bg-white text-[#4B5563] text-sm hover:bg-[#F9FAFB]">
                                <svg class="w-4 h-4" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
                                Google
                            </a>
                            <a href="{{ path('app_login_face', target_path|default('') is not empty ? {'_target_path': target_path} : {}) }}" class="inline-flex items-center justify-center gap-2 py-2.5 rounded-lg border border-[#E5E7EB] bg-white text-[#4B5563] text-sm hover:bg-[#F9FAFB]">
                                <span aria-hidden="true">📷</span>
                                Face ID
                            </a>
                        </div>
                    </div>
                </form>

                <script>
                (function() {
                    var emailInput = document.getElementById('email');
                    var input = document.getElementById('password');
                    var btn = document.getElementById('toggle-password');
                    var iconOpen = document.getElementById('icon-eye-open');
                    var iconClosed = document.getElementById('icon-eye-closed');
                    if (btn && input) {
                        btn.addEventListener('click', function() {
                            var isPassword = input.type === 'password';
                            input.type = isPassword ? 'text' : 'password';
                            iconOpen.classList.toggle('hidden', !isPassword);
                            iconClosed.classList.toggle('hidden', isPassword);
                            btn.setAttribute('aria-label', isPassword ? 'Masquer le mot de passe' : 'Afficher le mot de passe');
                            btn.setAttribute('title', isPassword ? 'Masquer le mot de passe' : 'Afficher le mot de passe');
                        });
                    }

                    var captchaImg = document.getElementById('login-captcha-image');
                    var refreshCaptcha = document.getElementById('refresh-captcha');
                    var captchaBlock = document.getElementById('captcha-block');
                    var captchaInput = document.getElementById('captcha_answer');
                    if (captchaImg && refreshCaptcha) {
                        refreshCaptcha.addEventListener('click', function() {
                            var base = captchaImg.src.split('?')[0];
                            captchaImg.src = base + '?_t=' + Date.now();
                        });
                    }

                    function updateCaptchaVisibility() {
                        if (!emailInput || !input || !captchaBlock || !captchaInput) {
                            return;
                        }

                        var hasEmail = emailInput.value.trim() !== '';
                        var hasPassword = input.value.trim() !== '';
                        var shouldShow = hasEmail && hasPassword;

                        captchaBlock.classList.toggle('hidden', !shouldShow);
                        captchaInput.disabled = !shouldShow;

                        if (!shouldShow) {
                            captchaInput.value = '';
                        }
                    }

                    if (emailInput) {
                        emailInput.addEventListener('input', updateCaptchaVisibility);
                    }
                    if (input) {
                        input.addEventListener('input', updateCaptchaVisibility);
                    }
                    updateCaptchaVisibility();
                })();
                </script>
            </div>
        </div>
    </div>
</div>
{% endblock %}
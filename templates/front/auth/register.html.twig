{% extends 'layouts/user.html.twig' %}

{% block title %}Créer un compte - AutiCare{% endblock %}

{% block user_content %}
<div class="max-w-6xl mx-auto py-8 px-4">
    <div class="bg-white rounded-2xl shadow-2xl border border-[#E5E0D8] overflow-hidden">
        <div class="grid md:grid-cols-2">
            <div class="bg-[#F3F4F6] p-8 md:p-10 flex flex-col justify-between min-h-[600px]">
                <p class="text-[#4B5563] text-lg">Welcome!</p>
                <div class="flex items-center justify-center py-8">
                    <img src="{{ asset('images/logo.png') }}" alt="AutiCare" class="h-64 w-auto object-contain" />
                </div>
                <p class="text-sm text-[#6B7280]">
                    Déjà membre ?
                    <a href="{{ path('app_login') }}" class="font-semibold text-[#111827] hover:underline">Log in now</a>
                </p>
            </div>

            <div class="p-8 md:p-10 md:max-h-[84vh] md:overflow-y-auto md:pr-4">
                <h1 class="text-3xl font-bold text-[#23262F] mb-2">Register with your e-mail</h1>
                <p class="text-sm text-[#6B7280] mb-6">Créez votre compte pour rejoindre AutiCare</p>

                {{ form_start(form, { attr: { class: 'space-y-4', novalidate: 'novalidate' } }) }}
                    {{ form_errors(form) }}
                    {% if target_path|default('') is not empty %}
                    <input type="hidden" name="_target_path" value="{{ target_path }}">
                    {% endif %}

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            {{ form_label(form.prenom, 'Prénom', {'label_attr': {'class': 'block text-xs uppercase tracking-wide text-[#9CA3AF] mb-1'}}) }}
                            {{ form_widget(form.prenom, {'attr': {'class': 'w-full px-4 py-3 rounded-lg border border-[#E5E7EB] bg-white text-[#374151] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#A7C7E7]', 'placeholder': 'Prénom'}}) }}
                            {{ form_errors(form.prenom) }}
                        </div>
                        <div>
                            {{ form_label(form.nom, 'Nom', {'label_attr': {'class': 'block text-xs uppercase tracking-wide text-[#9CA3AF] mb-1'}}) }}
                            {{ form_widget(form.nom, {'attr': {'class': 'w-full px-4 py-3 rounded-lg border border-[#E5E7EB] bg-white text-[#374151] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#A7C7E7]', 'placeholder': 'Nom'}}) }}
                            {{ form_errors(form.nom) }}
                        </div>
                    </div>

                    <div>
                        {{ form_label(form.email, 'Email', {'label_attr': {'class': 'block text-xs uppercase tracking-wide text-[#9CA3AF] mb-1'}}) }}
                        {{ form_widget(form.email, {'attr': {'class': 'w-full px-4 py-3 rounded-lg border border-[#E5E7EB] bg-white text-[#374151] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#A7C7E7]', 'placeholder': 'Email'}}) }}
                        {{ form_errors(form.email) }}
                    </div>

                    <div>
                        {{ form_label(form.telephone, 'Téléphone', {'label_attr': {'class': 'block text-xs uppercase tracking-wide text-[#9CA3AF] mb-1'}}) }}
                        {{ form_widget(form.telephone, {'attr': {'class': 'w-full px-4 py-3 rounded-lg border border-[#E5E7EB] bg-white text-[#374151] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#A7C7E7]', 'placeholder': 'Téléphone'}}) }}
                        {{ form_errors(form.telephone) }}
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            {{ form_label(form.password.first, 'Password', {'label_attr': {'class': 'block text-xs uppercase tracking-wide text-[#9CA3AF] mb-1'}}) }}
                            {{ form_widget(form.password.first, {'attr': {'class': 'w-full px-4 py-3 rounded-lg border border-[#E5E7EB] bg-white text-[#374151] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#A7C7E7]', 'placeholder': 'Password'}}) }}
                            {{ form_errors(form.password.first) }}
                            <div class="mt-2 space-y-1 text-xs">
                                <p id="reg-pwd-rule-len" class="text-[#9CA3AF]">- Au moins 6 caractères</p>
                                <p id="reg-pwd-rule-upper" class="text-[#9CA3AF]">- Au moins une lettre majuscule</p>
                                <p id="reg-pwd-rule-digit" class="text-[#9CA3AF]">- Au moins un chiffre</p>
                            </div>
                        </div>
                        <div>
                            {{ form_label(form.password.second, 'Repeat password', {'label_attr': {'class': 'block text-xs uppercase tracking-wide text-[#9CA3AF] mb-1'}}) }}
                            {{ form_widget(form.password.second, {'attr': {'class': 'w-full px-4 py-3 rounded-lg border border-[#E5E7EB] bg-white text-[#374151] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#A7C7E7]', 'placeholder': 'Repeat password'}}) }}
                            {{ form_errors(form.password.second) }}
                        </div>
                    </div>

                    <div>
                        {{ form_label(form.role, 'Vous êtes', {'label_attr': {'class': 'block text-xs uppercase tracking-wide text-[#9CA3AF] mb-1'}}) }}
                        {{ form_widget(form.role, {'attr': {'class': 'w-full px-4 py-3 rounded-lg border border-[#E5E7EB] bg-white text-[#374151] focus:outline-none focus:ring-2 focus:ring-[#A7C7E7]', 'data-role-select': '1'}}) }}
                        {{ form_errors(form.role) }}
                    </div>

                    <div id="parent-fields" style="display: none;">
                        {{ form_row(form.relationAvecPatient, {
                            'label': 'Relation avec le patient',
                            'label_attr': {'class': 'block text-xs uppercase tracking-wide text-[#9CA3AF] mb-1'},
                            'attr': {'class': 'w-full px-4 py-3 rounded-lg border border-[#E5E7EB] bg-white text-[#374151] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#A7C7E7]', 'placeholder': 'Ex. Père, Mère, Tuteur'}
                        }) }}
                    </div>

                    <div id="patient-fields" style="display: none;">
                        {{ form_row(form.dateNaissance, {
                            'label': 'Date de naissance',
                            'label_attr': {'class': 'block text-xs uppercase tracking-wide text-[#9CA3AF] mb-1'},
                            'attr': {'class': 'w-full px-4 py-3 rounded-lg border border-[#E5E7EB] bg-white text-[#374151] focus:outline-none focus:ring-2 focus:ring-[#A7C7E7]'}
                        }) }}

                        {{ form_row(form.adresse, {
                            'label': 'Adresse',
                            'label_attr': {'class': 'block text-xs uppercase tracking-wide text-[#9CA3AF] mb-1'},
                            'attr': {'class': 'w-full px-4 py-3 rounded-lg border border-[#E5E7EB] bg-white text-[#374151] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#A7C7E7]', 'placeholder': 'Adresse'}
                        }) }}

                        {{ form_row(form.sexe, {
                            'label': 'Sexe',
                            'label_attr': {'class': 'block text-xs uppercase tracking-wide text-[#9CA3AF] mb-1'},
                            'attr': {'class': 'w-full px-4 py-3 rounded-lg border border-[#E5E7EB] bg-white text-[#374151] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#A7C7E7]', 'placeholder': 'Sexe'}
                        }) }}
                    </div>

                    <div class="rounded-lg border border-[#E5E7EB] p-4 bg-[#F9FAFB]">
                        <p class="text-sm font-medium text-[#23262F] mb-2">Option biométrique (facultatif)</p>
                        <p class="text-xs text-[#6B7280] mb-3">Ajoutez une photo visage nette pour préparer la connexion faciale.</p>
                        <input id="face-photo-upload" type="file" accept="image/*" class="block w-full text-sm text-[#4B5563]">
                        <p id="face-register-status" class="mt-2 text-xs text-[#6B7280]"></p>
                    </div>

                    {{ form_widget(form.dataFaceApi) }}

                    {{ form_widget(form.submit, {'attr': {'class': 'w-full py-3 rounded-lg bg-[#1F2937] text-white font-semibold hover:bg-[#111827] transition cursor-pointer'}}) }}
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>

{% block javascripts %}
    {{ parent() }}
    <script defer src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
    <script defer src="{{ asset('js/register.js') }}"></script>
    <script>
    function initRoleFields() {
        const roleSelect = document.querySelector('[data-role-select="1"]');
        const parentFields = document.getElementById('parent-fields');
        const patientFields = document.getElementById('patient-fields');

        if (!roleSelect) return;

        function toggleFields() {
            const selectedRole = roleSelect.value;
            if (parentFields) parentFields.style.display = 'none';
            if (patientFields) patientFields.style.display = 'none';
            if (selectedRole === 'ROLE_PARENT' && parentFields) {
                parentFields.style.display = 'block';
            } else if (selectedRole === 'ROLE_PATIENT' && patientFields) {
                patientFields.style.display = 'block';
            }
        }

        roleSelect.removeEventListener('change', toggleFields);
        roleSelect.addEventListener('change', toggleFields);
        toggleFields();
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initRoleFields);
    } else {
        initRoleFields();
    }
    setTimeout(initRoleFields, 100);

    (function initPasswordHints() {
        const passwordInput = document.getElementById('inscription_password_first');
        const lenEl = document.getElementById('reg-pwd-rule-len');
        const upperEl = document.getElementById('reg-pwd-rule-upper');
        const digitEl = document.getElementById('reg-pwd-rule-digit');
        if (!passwordInput || !lenEl || !upperEl || !digitEl) return;

        function setRuleState(el, ok) {
            el.classList.toggle('text-green-600', ok);
            el.classList.toggle('text-[#9CA3AF]', !ok);
        }

        function validate() {
            const value = passwordInput.value || '';
            setRuleState(lenEl, value.length >= 6);
            setRuleState(upperEl, /[A-Z]/.test(value));
            setRuleState(digitEl, /\d/.test(value));
        }

        passwordInput.addEventListener('input', validate);
        validate();
    })();
    </script>
{% endblock %}
{% endblock %}

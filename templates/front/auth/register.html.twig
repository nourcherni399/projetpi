{% extends 'layouts/user.html.twig' %}

{% block title %}Créer un compte - AutiCare{% endblock %}

{% block user_content %}
<div class="min-h-[calc(100vh-8rem)] flex items-center justify-center py-8 px-4" style="background-color: #F5F0EB;">
    <div class="w-full max-w-4xl flex flex-col lg:flex-row rounded-2xl overflow-hidden bg-white shadow-xl border border-gray-100">
        {# Colonne gauche : Welcome + branding #}
        <div class="lg:w-[42%] min-h-[240px] lg:min-h-[520px] flex flex-col p-8 lg:p-10">
            <p class="text-[#374151] font-semibold text-lg mb-auto pt-0">Welcome!</p>
            <div class="flex flex-col items-center justify-center flex-1 py-8">
                <img src="{{ asset('images/logo.png') }}" alt="AutiCare" class="h-56 sm:h-72 w-auto max-w-full object-contain">
            </div>
            <p class="text-[#6B7280] text-sm mt-auto pb-0">
                Déjà membre ? <a href="{{ path('app_login') }}{% if target_path|default('') is not empty %}?_target_path={{ target_path|url_encode }}{% endif %}" class="text-[#1e3a5f] font-semibold hover:underline">Se connecter</a>
            </p>
        </div>

        {# Colonne droite : formulaire #}
        <div class="flex-1 p-8 lg:p-10 flex flex-col justify-center overflow-auto">
            <h1 class="text-2xl lg:text-3xl font-bold text-[#374151] tracking-tight mb-1">S'inscrire</h1>
            <p class="text-[#6B7280] text-sm mb-6">Créez votre compte AutiCare</p>

            {{ form_start(form, { attr: { class: 'space-y-4', novalidate: 'novalidate' } }) }}
                {{ form_errors(form) }}
                {% if target_path|default('') is not empty %}
                    <input type="hidden" name="_target_path" value="{{ target_path }}">
                {% endif %}

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        {{ form_label(form.prenom, null, {'label_attr': {'class': 'block text-[#374151] font-medium mb-1.5 text-xs uppercase tracking-wider'}}) }}
                        {{ form_widget(form.prenom, {'attr': {'class': 'w-full px-4 py-3 rounded-lg border border-gray-200 bg-white text-[#374151] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#1e3a5f]/30 focus:border-[#1e3a5f] text-sm', 'placeholder': 'Prénom'}}) }}
                        {{ form_errors(form.prenom) }}
                    </div>
                    <div>
                        {{ form_label(form.nom, null, {'label_attr': {'class': 'block text-[#374151] font-medium mb-1.5 text-xs uppercase tracking-wider'}}) }}
                        {{ form_widget(form.nom, {'attr': {'class': 'w-full px-4 py-3 rounded-lg border border-gray-200 bg-white text-[#374151] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#1e3a5f]/30 focus:border-[#1e3a5f] text-sm', 'placeholder': 'Nom'}}) }}
                        {{ form_errors(form.nom) }}
                    </div>
                </div>

                <div>
                    {{ form_label(form.email, null, {'label_attr': {'class': 'block text-[#374151] font-medium mb-1.5 text-xs uppercase tracking-wider'}}) }}
                    {{ form_widget(form.email, {'attr': {'class': 'w-full px-4 py-3 rounded-lg border border-gray-200 bg-white text-[#374151] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#1e3a5f]/30 focus:border-[#1e3a5f] text-sm', 'placeholder': 'exemple@email.com'}}) }}
                    {{ form_errors(form.email) }}
                </div>

                <div>
                    {{ form_label(form.telephone, null, {'label_attr': {'class': 'block text-[#374151] font-medium mb-1.5 text-xs uppercase tracking-wider'}}) }}
                    {{ form_widget(form.telephone, {'attr': {'class': 'w-full px-4 py-3 rounded-lg border border-gray-200 bg-white text-[#374151] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#1e3a5f]/30 focus:border-[#1e3a5f] text-sm', 'placeholder': '612345678'}}) }}
                    {{ form_errors(form.telephone) }}
                </div>

                <div>
                    {{ form_label(form.password.first, null, {'label_attr': {'class': 'block text-[#374151] font-medium mb-1.5 text-xs uppercase tracking-wider'}}) }}
                    {{ form_widget(form.password.first, {'attr': {'class': 'w-full px-4 py-3 rounded-lg border border-gray-200 bg-white text-[#374151] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#1e3a5f]/30 focus:border-[#1e3a5f] text-sm', 'placeholder': 'Minimum 6 caractères'}}) }}
                    {{ form_errors(form.password.first) }}
                </div>

                <div>
                    {{ form_label(form.password.second, null, {'label_attr': {'class': 'block text-[#374151] font-medium mb-1.5 text-xs uppercase tracking-wider'}}) }}
                    {{ form_widget(form.password.second, {'attr': {'class': 'w-full px-4 py-3 rounded-lg border border-gray-200 bg-white text-[#374151] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#1e3a5f]/30 focus:border-[#1e3a5f] text-sm', 'placeholder': 'Confirmer le mot de passe'}}) }}
                    {{ form_errors(form.password.second) }}
                </div>

                <div>
                    {{ form_label(form.role, null, {'label_attr': {'class': 'block text-[#374151] font-medium mb-1.5 text-xs uppercase tracking-wider'}}) }}
                    {{ form_widget(form.role, {'attr': {'class': 'w-full px-4 py-3 rounded-lg border border-gray-200 bg-white text-[#374151] focus:outline-none focus:ring-2 focus:ring-[#1e3a5f]/30 focus:border-[#1e3a5f] text-sm', 'data-role-select': '1'}}) }}
                    {{ form_errors(form.role) }}
                </div>

                <div id="parent-fields" style="display: none;">
                    {{ form_row(form.relationAvecPatient, {
                        'label_attr': {'class': 'block text-[#374151] font-medium mb-1.5 text-xs uppercase tracking-wider'},
                        'attr': {'class': 'w-full px-4 py-3 rounded-lg border border-gray-200 bg-white text-[#374151] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#1e3a5f]/30 focus:border-[#1e3a5f] text-sm', 'placeholder': 'Ex. Père, Mère, Tuteur'}
                    }) }}
                </div>

                <div id="patient-fields" style="display: none;">
                    {{ form_row(form.dateNaissance, {
                        'label_attr': {'class': 'block text-[#374151] font-medium mb-1.5 text-xs uppercase tracking-wider'},
                        'attr': {'class': 'w-full px-4 py-3 rounded-lg border border-gray-200 bg-white text-[#374151] focus:outline-none focus:ring-2 focus:ring-[#1e3a5f]/30 focus:border-[#1e3a5f] text-sm'}
                    }) }}
                    {{ form_row(form.adresse, {
                        'label_attr': {'class': 'block text-[#374151] font-medium mb-1.5 text-xs uppercase tracking-wider'},
                        'attr': {'class': 'w-full px-4 py-3 rounded-lg border border-gray-200 bg-white text-[#374151] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#1e3a5f]/30 focus:border-[#1e3a5f] text-sm', 'placeholder': 'Adresse'}
                    }) }}
                    {{ form_row(form.sexe, {
                        'label_attr': {'class': 'block text-[#374151] font-medium mb-1.5 text-xs uppercase tracking-wider'},
                        'attr': {'class': 'w-full px-4 py-3 rounded-lg border border-gray-200 bg-white text-[#374151] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#1e3a5f]/30 focus:border-[#1e3a5f] text-sm'}
                    }) }}
                </div>

                {{ form_widget(form.submit, {'attr': {'class': 'w-full py-3.5 rounded-lg bg-[#1e3a5f] hover:bg-[#152a47] text-white font-bold text-sm focus:outline-none focus:ring-2 focus:ring-[#1e3a5f] focus:ring-offset-2 transition-colors cursor-pointer'}}) }}
            {{ form_end(form) }}
        </div>
    </div>
</div>

{% block javascripts %}
    {{ parent() }}
    <script>
    function initRoleFields() {
        const roleSelect = document.querySelector('[data-role-select="1"]');
        const parentFields = document.getElementById('parent-fields');
        const patientFields = document.getElementById('patient-fields');

        if (!roleSelect) return;

        function toggleFields() {
            const selectedRole = roleSelect.value;
            if (parentFields) parentFields.style.display = 'none';
            if (patientFields) patientFields.style.display = 'none';
            if (selectedRole === 'ROLE_PARENT' && parentFields) {
                parentFields.style.display = 'block';
            } else if (selectedRole === 'ROLE_PATIENT' && patientFields) {
                patientFields.style.display = 'block';
            }
        }

        roleSelect.removeEventListener('change', toggleFields);
        roleSelect.addEventListener('change', toggleFields);
        toggleFields();
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initRoleFields);
    } else {
        initRoleFields();
    }
    setTimeout(initRoleFields, 100);
    </script>
{% endblock %}
{% endblock %}

{% extends 'layouts/user.html.twig' %}

{% block title %}Saisir le code PIN - AutiCare{% endblock %}

{% block user_content %}
<div class="max-w-md mx-auto py-12">
    <div class="bg-white rounded-2xl shadow-lg border border-[#E5E0D8] p-8">
        <div class="flex justify-center mb-6">
            <span class="flex items-center justify-center w-14 h-14 rounded-full bg-[#A7C7E7] text-white">
                <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                </svg>
            </span>
        </div>
        <h1 class="text-2xl font-bold text-[#4B5563] text-center mb-1">Saisir le code PIN</h1>
        <p class="text-[#6B7280] text-center text-sm mb-6">Entrez le code PIN à 6 chiffres que vous avez reçu par e-mail.</p>

        {% for message in app.flashes('error') %}
            <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-600 text-sm">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('info') %}
            <div class="mb-4 p-3 bg-blue-50 border border-blue-200 rounded-lg text-blue-800 text-sm font-medium">{{ message }}</div>
        {% endfor %}

        <form method="post" action="{{ path('app_forgot_password_verify_pin') }}" class="space-y-4">
            <div>
                <label for="email" class="block text-[#4B5563] font-medium mb-1">Adresse e-mail</label>
                <input type="email" id="email" name="email" value="{{ email }}" required placeholder="exemple@email.com" autocomplete="email"
                    class="w-full px-4 py-2.5 rounded-lg border border-[#E5E0D8] bg-[#F5F1EB] text-[#6B7280] placeholder-[#9CA3AF] focus:outline focus:ring-2 focus:ring-[#A7C7E7]">
            </div>
            <div>
                <label for="pin" class="block text-[#4B5563] font-medium mb-1">Code PIN (reçu par e-mail)</label>
                <input type="text" id="pin" name="pin" value="{{ pin }}" required placeholder="123456" maxlength="6" pattern="[0-9]{6}" autocomplete="one-time-code"
                    class="w-full px-4 py-2.5 rounded-lg border border-[#E5E0D8] bg-[#F5F1EB] text-[#6B7280] placeholder-[#9CA3AF] focus:outline focus:ring-2 focus:ring-[#A7C7E7] tracking-widest text-center text-xl">
                <p class="mt-2 text-xs text-[#6B7280]">Le code PIN est valide pendant 15 minutes.</p>
            </div>
            <button type="submit" class="w-full py-3 rounded-lg bg-[#A7C7E7] text-white font-medium hover:bg-[#B8D4ED] focus:outline focus:ring-2 focus:ring-[#A7C7E7]">Vérifier le code PIN</button>
        </form>

        <div class="mt-6 space-y-3">
            <p class="text-center text-[#6B7280] text-sm">
                <a href="{{ path('app_forgot_password_request', { email: email }) }}" class="text-[#A7C7E7] hover:underline font-medium">Renvoyer le code PIN</a>
            </p>
            <p class="text-center text-[#6B7280] text-sm">
                <a href="{{ path('app_login') }}" class="text-[#A7C7E7] hover:underline font-medium">Retour à la connexion</a>
            </p>
        </div>
    </div>
</div>
{% endblock %}

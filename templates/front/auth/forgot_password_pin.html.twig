{% extends 'layouts/user.html.twig' %}

{% block title %}Saisir le code PIN - AutiCare{% endblock %}

{% block user_content %}
<div class="max-w-5xl mx-auto py-8 px-4">
    <div class="bg-white rounded-2xl shadow-2xl border border-[#E5E0D8] overflow-hidden">
        <div class="grid md:grid-cols-2">
            <div class="bg-[#F3F4F6] p-8 md:p-10 flex flex-col justify-between min-h-[520px]">
                <p class="text-[#4B5563] text-lg">Welcome!</p>
                <div class="flex items-center justify-center py-8">
                    <img src="{{ asset('images/logo.png') }}" alt="AutiCare" class="h-64 w-auto object-contain" />
                </div>
                <p class="text-sm text-[#6B7280]">
                    Déjà un code ?
                    <a href="{{ path('app_forgot_password_request', { email: email }) }}" class="font-semibold text-[#111827] hover:underline">Resend PIN</a>
                </p>
            </div>

            <div class="p-8 md:p-10">
                <h1 class="text-3xl font-bold text-[#23262F] mb-2">Verify PIN code</h1>
                <p class="text-sm text-[#6B7280] mb-6">Enter the 6-digit code sent to your email.</p>

                {% for message in app.flashes('error') %}
                    <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-600 text-sm">{{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('info') %}
                    <div class="mb-4 p-3 bg-blue-50 border border-blue-200 rounded-lg text-blue-800 text-sm">{{ message }}</div>
                {% endfor %}

                <form method="post" action="{{ path('app_forgot_password_verify_pin') }}" class="space-y-5" novalidate>
                    <div>
                        <label for="email" class="block text-xs uppercase tracking-wide text-[#9CA3AF] mb-1">Email or username (*)</label>
                        <input type="text" id="email" name="email" value="{{ email }}" placeholder="Email or Username" autocomplete="email"
                            class="w-full px-4 py-3 rounded-lg border border-[#E5E7EB] bg-white text-[#374151] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#A7C7E7]">
                    </div>
                    <div>
                        <label for="pin" class="block text-xs uppercase tracking-wide text-[#9CA3AF] mb-1">PIN code (*)</label>
                        <input type="text" id="pin" name="pin" value="{{ pin }}" placeholder="123456" maxlength="6" autocomplete="one-time-code"
                            class="w-full px-4 py-3 rounded-lg border border-[#E5E7EB] bg-white text-[#374151] placeholder-[#9CA3AF] focus:outline-none focus:ring-2 focus:ring-[#A7C7E7] tracking-[0.35em] text-center text-xl">
                        <p class="mt-2 text-xs text-[#6B7280]">Le code PIN est valide pendant 15 minutes.</p>
                    </div>
                    <button type="submit" class="w-full py-3 rounded-lg bg-[#1F2937] text-white font-semibold hover:bg-[#111827] transition">Verify PIN</button>
                </form>

                <div class="mt-8 space-y-2">
                    <p class="text-center">
                        <a href="{{ path('app_forgot_password_request', { email: email }) }}" class="text-[#4B5563] font-semibold hover:underline">Resend code</a>
                    </p>
                    <p class="text-center">
                        <a href="{{ path('app_login') }}" class="text-[#4B5563] font-semibold hover:underline">Back</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% extends 'layouts/user.html.twig' %}

{% block title %}Prendre un rendez-vous - AutiCare{% endblock %}

{% block user_content %}
<div class="bg-white/95 dark:bg-gray-700/95 backdrop-blur-sm rounded-3xl shadow-pastel-md border-2 border-[#E8DED5] dark:border-gray-600 p-6 md:p-8">
<section class="mb-10">
    <h1 class="text-3xl md:text-4xl font-bold text-[#2D2D2D] dark:text-white mb-2">Prendre un rendez-vous</h1>
    <p class="text-[#4A4A4A] dark:text-gray-200 text-lg">Consultez nos médecins et spécialistes, puis réservez votre créneau en quelques clics.</p>
</section>

<div class="flex flex-col lg:flex-row gap-8">
    <aside class="lg:w-80 shrink-0">
        <div class="bg-white dark:bg-gray-600/80 rounded-2xl shadow-pastel-md border border-[#E8DED5] dark:border-gray-500 p-6 sticky top-4 transition-colors duration-200">
            <h2 class="font-bold text-[#3D3D3D] dark:text-gray-100 text-lg mb-6">Filtres</h2>
            <div class="space-y-5">
                <div>
                    <label for="filter-specialty" class="block font-semibold text-[#3D3D3D] dark:text-gray-200 mb-2">Spécialité</label>
                    <select id="filter-specialty" class="w-full px-4 py-3 rounded-xl border-2 border-[#E8DED5] dark:border-gray-500 bg-white dark:bg-gray-500/50 text-[#3D3D3D] dark:text-gray-100 focus:outline focus:ring-2 focus:ring-[#CDB4DB] focus:border-[#CDB4DB] dark:focus:ring-[#93C5FD] dark:focus:border-[#93C5FD] transition-colors">
                        <option value="">Toutes les spécialités</option>
                        {% for spec in specialites|default([]) %}
                        <option value="{{ spec }}">{{ spec }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label for="filter-place" class="block font-semibold text-[#3D3D3D] dark:text-gray-200 mb-2">Lieu</label>
                    <input type="text" id="filter-place" placeholder="Ville ou adresse..." class="w-full px-4 py-3 rounded-xl border-2 border-[#E8DED5] dark:border-gray-500 bg-white dark:bg-gray-500/50 text-[#3D3D3D] dark:text-gray-100 placeholder-[#9CA3AF] dark:placeholder-gray-400 focus:outline focus:ring-2 focus:ring-[#CDB4DB] focus:border-[#CDB4DB] dark:focus:ring-[#93C5FD] dark:focus:border-[#93C5FD] transition-colors">
                </div>
            </div>
            <div class="mt-6 p-4 rounded-xl bg-[#E8DCF0]/50 dark:bg-gray-500/30 border border-[#E8DED5] dark:border-gray-500">
                <h3 class="font-semibold text-[#3D3D3D] dark:text-gray-100 mb-2">Besoin d'aide ?</h3>
                <p class="text-[#5C5C5C] dark:text-gray-300 text-sm leading-relaxed">Choisissez un praticien puis cliquez sur « Prendre RDV » pour voir ses créneaux disponibles.</p>
            </div>
        </div>
    </aside>

    <div class="flex-1 min-w-0">
        <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
            <p class="text-[#5C5C5C] dark:text-gray-300">
                <span id="medecins-count" class="font-bold text-[#CDB4DB] dark:text-[#93C5FD]">{{ medecins|length }}</span> professionnel(s) disponible(s)
            </p>
        </div>
        <ul class="space-y-5" id="medecins-list">
            {% for medecin in medecins %}
            {% set spec = medecin.specialite|default('Spécialiste') %}
            {% set spec_class = spec matches '/psychiatre/i' or spec matches '/psychologue/i' ? 'bg-[#D4E5D0] dark:bg-gray-500 text-[#2D5A2A] dark:text-gray-100' : (spec matches '/orthophoniste/i' ? 'bg-[#DFEEF5] dark:bg-gray-500 text-[#1E4D6B] dark:text-gray-100' : 'bg-[#E8DCF0] dark:bg-gray-500 text-[#4B3D6B] dark:text-gray-100') %}
            {% set initiales = ((medecin.nom|slice(0, 1)) ~ (medecin.prenom|slice(0, 1)))|upper|default('DR') %}
            <li class="medecin-card bg-white dark:bg-gray-600/80 rounded-2xl shadow-pastel border-2 border-[#E8DED5] dark:border-gray-500 p-6 flex flex-col sm:flex-row gap-6 hover:shadow-pastel-md hover:border-[#CDB4DB]/50 dark:hover:border-gray-400 transition-all duration-200" data-specialty="{{ spec }}" data-address="{{ medecin.adresseCabinet|default('')|lower }}">
                <div class="flex items-center justify-center w-14 h-14 rounded-full bg-[#A8BBA3]/30 dark:bg-[#93C5FD]/30 text-[#3D3D3D] dark:text-gray-100 font-bold text-sm shrink-0">{{ initiales }}</div>
                <div class="flex-1 min-w-0">
                    <div class="flex flex-wrap items-center gap-2 mb-2">
                        <h3 class="font-bold text-[#3D3D3D] dark:text-gray-100 text-lg">Dr. {{ medecin.nom }} {{ medecin.prenom }}</h3>
                        <span class="px-3 py-1 rounded-full text-xs font-medium {{ spec_class }}">{{ spec }}</span>
                        {% set medecin_rating = ratings[medecin.id]|default(null) %}
                        {% set medecin_avg = medecin_rating ? medecin_rating.avg : 0 %}
                        {% set medecin_count = medecin_rating ? medecin_rating.count : 0 %}
                        {% set user_note = user_ratings[medecin.id]|default(null) %}
                        <span class="rating-display flex items-center gap-1 text-amber-500 dark:text-amber-400 text-sm {% if app.user %}cursor-pointer{% endif %}" data-medecin-id="{{ medecin.id }}" data-user-note="{{ user_note ?? '' }}" {% if app.user %}data-rate-url="{{ path('medecin_rate', { id: medecin.id }) }}"{% endif %} title="{{ app.user ? 'Cliquez pour noter' : (medecin_avg ~ ' / 5 - ' ~ medecin_count ~ ' avis') }}">
                            {% for i in 1..5 %}
                                <span class="star-display {% if app.user %}star-rate-clickable cursor-pointer hover:scale-110 transition-transform{% endif %}" data-note="{{ i }}" data-filled="{{ (medecin_avg >= i) or (medecin_avg >= i - 0.5) ? '1' : '0' }}" {% if app.user %}role="button" tabindex="0" aria-label="Donner {{ i }} étoile(s)"{% endif %}>
                                    <svg class="w-5 h-5 star-svg {% if user_note and user_note >= i %}fill-amber-500 dark:fill-amber-400{% elseif medecin_avg >= i %}fill-current{% elseif medecin_avg >= i - 0.5 %}fill-current opacity-60{% else %}fill-none stroke-current stroke-1 opacity-60 hover:opacity-100{% endif %}" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                                </span>
                            {% endfor %}
                            {% if medecin_count > 0 %}
                                <span class="rating-count text-[#5C5C5C] dark:text-gray-400 text-xs">({{ medecin_count }})</span>
                            {% endif %}
                        </span>
                    </div>
                    <p class="text-[#5C5C5C] dark:text-gray-300 text-sm mb-3">
                        {% if medecin.nomCabinet %}Cabinet : {{ medecin.nomCabinet }}.{% endif %}
                        {% if medecin.specialite %}Spécialité : {{ medecin.specialite }}.{% endif %}
                    </p>
                    <div class="flex flex-wrap gap-4 text-sm text-[#5C5C5C] dark:text-gray-300 mb-3">
                        {% if medecin.adresseCabinet %}
                        <span class="flex items-center gap-1.5">
                            <svg class="w-4 h-4 shrink-0 text-[#A8BBA3] dark:text-[#93C5FD]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /></svg>
                            {{ medecin.adresseCabinet }}
                        </span>
                        {% endif %}
                    </div>
                    <div class="flex flex-wrap gap-2">
                        {% if medecin.adresseCabinet %}
                        <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-xl border border-[#E8DED5] dark:border-gray-500 text-[#5C5C5C] dark:text-gray-300 text-sm bg-[#FDF8F5] dark:bg-gray-500/30">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z" /></svg>
                            Cabinet
                        </span>
                        {% endif %}
                    </div>
                </div>
                <div class="sm:text-right shrink-0 flex flex-col justify-center gap-3">
                    {% if medecin.telephoneCabinet or medecin.telephone %}
                    <p class="text-sm text-[#5C5C5C] dark:text-gray-300 flex items-center gap-1.5 sm:justify-end">
                        <svg class="w-4 h-4 shrink-0 text-[#A8BBA3] dark:text-[#93C5FD]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                        {{ medecin.telephoneCabinet|default(medecin.telephone) }}
                    </p>
                    {% endif %}
                    {% if medecin.tarifConsultation %}
                    <p class="font-semibold text-[#3D3D3D] dark:text-gray-100">{{ medecin.tarifConsultation|number_format(0, ',', ' ') }} DT</p>
                    {% endif %}
                    <a href="{{ path('user_appointment_book', { id: medecin.id }) }}" class="rdv-btn inline-flex items-center justify-center sm:justify-end gap-2 px-5 py-3 rounded-xl bg-[#A8BBA3] text-white font-semibold hover:bg-[#94B08E] focus:outline focus:ring-2 focus:ring-[#A8BBA3] focus:ring-offset-2 dark:focus:ring-offset-gray-600 shadow-pastel hover:scale-[1.02] transition-all duration-200">
                        Prendre RDV
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                    </a>
                </div>
            </li>
            {% else %}
            <li class="bg-white dark:bg-gray-600/80 rounded-2xl shadow-pastel border border-[#E8DED5] dark:border-gray-500 p-12 text-center">
                <p class="text-[#5C5C5C] dark:text-gray-300 mb-4 text-lg">Aucun médecin n'est encore enregistré sur la plateforme.</p>
                <p class="text-sm text-[#5C5C5C] dark:text-gray-400">Revenez plus tard ou contactez-nous pour être orienté.</p>
            </li>
            {% endfor %}
        </ul>
    </div>
</div>
</div>

<script>
(function() {
    var filterSpecialty = document.getElementById('filter-specialty');
    var filterPlace = document.getElementById('filter-place');
    var cards = document.querySelectorAll('.medecin-card');
    var countEl = document.getElementById('medecins-count');

    function updateList() {
        var spec = (filterSpecialty && filterSpecialty.value) ? filterSpecialty.value.toLowerCase() : '';
        var place = (filterPlace && filterPlace.value) ? filterPlace.value.trim().toLowerCase() : '';
        var visible = 0;
        cards.forEach(function(card) {
            var cardSpec = (card.getAttribute('data-specialty') || '').toLowerCase();
            var cardAddr = card.getAttribute('data-address') || '';
            var matchSpec = !spec || cardSpec.indexOf(spec) !== -1;
            var matchPlace = !place || cardAddr.indexOf(place) !== -1;
            var show = matchSpec && matchPlace;
            card.style.display = show ? '' : 'none';
            if (show) visible++;
        });
        if (countEl) countEl.textContent = visible;
    }
    if (filterSpecialty) filterSpecialty.addEventListener('change', updateList);
    if (filterPlace) filterPlace.addEventListener('input', updateList);

    // Notation des médecins - clic sur les étoiles (utilisateurs connectés)
    var csrfToken = {{ csrf_token('medecin_rate')|json_encode|raw }};

    function initRatingStars() {
        document.querySelectorAll('.rating-display[data-rate-url]').forEach(function(displayBlock) {
            if (displayBlock._ratingInit) return;
            displayBlock._ratingInit = true;

            var rateUrl = displayBlock.getAttribute('data-rate-url');
            var userNote = parseInt(displayBlock.getAttribute('data-user-note') || '0', 10);
            var stars = displayBlock.querySelectorAll('.star-display[data-note]');
            var countSpan = displayBlock.querySelector('.rating-count');

            function setStarsFilled(n) {
                stars.forEach(function(star, i) {
                    var svg = star.querySelector('.star-svg');
                    var idx = i + 1;
                    if (svg) {
                        svg.classList.toggle('fill-amber-500', idx <= n);
                        svg.classList.toggle('dark:fill-amber-400', idx <= n);
                        svg.classList.toggle('fill-current', idx <= n && n > 0);
                        svg.classList.toggle('fill-none', idx > n);
                        svg.classList.toggle('opacity-60', idx > n);
                        svg.classList.toggle('stroke-current', idx > n);
                    }
                });
            }
            setStarsFilled(userNote);

            stars.forEach(function(star) {
                star.addEventListener('click', function() {
                    var note = parseInt(star.getAttribute('data-note'), 10);
                    var fd = new FormData();
                    fd.append('note', note);
                    fd.append('_token', csrfToken);
                    fetch(rateUrl, {
                        method: 'POST',
                        body: fd,
                        credentials: 'same-origin',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    }).then(function(r) { return r.json(); }).then(function(data) {
                        if (data.success) {
                            userNote = note;
                            displayBlock.setAttribute('data-user-note', note);
                            setStarsFilled(note);
                            if (countSpan) {
                                countSpan.textContent = '(' + data.count + ')';
                                countSpan.style.display = data.count > 0 ? '' : 'none';
                            } else if (data.count > 0) {
                                var sp = document.createElement('span');
                                sp.className = 'rating-count text-[#5C5C5C] dark:text-gray-400 text-xs';
                                sp.textContent = '(' + data.count + ')';
                                displayBlock.appendChild(sp);
                            }
                        }
                    }).catch(function() {});
                });
                star.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter' || e.key === ' ') {
                        e.preventDefault();
                        star.click();
                    }
                });
            });
        });
    }
    initRatingStars();
    document.addEventListener('turbo:load', initRatingStars);
})();
</script>

{{ include('partials/_chat_help_widget.html.twig') }}
{% endblock %}

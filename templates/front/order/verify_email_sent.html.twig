{% extends 'layouts/user.html.twig' %}

{% block title %}Vérification de votre paiement par carte - AutiCare{% endblock %}

{% block user_content %}
<section class="text-center mb-10">
    <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-amber-100 text-amber-600 mb-4">
        <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
    </div>
    <h1 class="text-3xl font-bold text-[#4B5563] mb-3">Consultez votre boîte mail</h1>
    <p class="text-[#6B7280]">Un e-mail a été envoyé à <strong>{{ email }}</strong> pour vérifier que c'est bien vous qui effectuez le paiement par carte.</p>
    <p class="text-[#6B7280] mt-2">Cliquez sur le lien dans l'e-mail pour continuer vers le récapitulatif de votre commande. Le lien est valide 15 minutes.</p>
</section>

<div class="max-w-lg mx-auto bg-white rounded-xl shadow-sm border border-[#E5E0D8] p-6 mb-8">
    <p class="text-sm text-[#6B7280] mb-4">Si vous ne voyez pas l'e-mail, vérifiez vos spams ou indésirables.</p>
    <div class="flex flex-col sm:flex-row gap-3">
        <a href="{{ path('order_checkout') }}" class="flex-1 px-4 py-3 border border-[#E5E0D8] text-[#4B5563] rounded-lg font-medium text-center hover:bg-[#F5F1EB] transition">
            Modifier ma commande
        </a>
        <a href="{{ path('cart_index') }}" class="flex-1 px-4 py-3 border border-[#A7C7E7] text-[#A7C7E7] rounded-lg font-medium text-center hover:bg-[#A7C7E7]/10 transition">
            Retour au panier
        </a>
    </div>
</div>
{% endblock %}

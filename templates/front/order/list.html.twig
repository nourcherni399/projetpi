{% extends 'layouts/user.html.twig' %}

{% block title %}
    {% if commande.statut == 'en_attente' %}
        Commande en attente - AutiCare
    {% elseif commande.statut == 'annulée' %}
        Commande annulée - AutiCare
    {% else %}
        Commande confirmée - AutiCare
    {% endif %}
{% endblock %}

{% block user_content %}
<section class="text-center mb-12">
    {% if commande.statut == 'en_attente' %}
        <div class="inline-flex items-center justify-center w-24 h-24 rounded-3xl bg-amber-100 text-amber-600 mb-6 shadow-pastel">
            <svg class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
        </div>
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-amber-100/50 text-amber-700 text-sm font-medium mb-4">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            En attente de validation
        </div>
        <h1 class="text-3xl md:text-4xl font-bold text-[#3D3D3D] dark:text-gray-100 mb-3">Commande en attente</h1>
        <p class="text-[#5C5C5C] dark:text-gray-300 max-w-2xl mx-auto text-lg">Votre commande a bien été enregistrée. Elle reste sur cette page jusqu'à ce que l'administrateur accepte votre demande.</p>
        <p class="text-sm text-[#5C5C5C] dark:text-gray-300 mt-2">Vous pouvez revenir sur ce lien à tout moment pour suivre le statut.</p>
    
    {% elseif commande.statut == 'annulée' %}
        <div class="inline-flex items-center justify-center w-24 h-24 rounded-3xl bg-red-100 text-red-600 mb-6 shadow-pastel">
            <svg class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </div>
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-red-100/50 text-red-700 text-sm font-medium mb-4">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
            Commande annulée
        </div>
        <h1 class="text-3xl md:text-4xl font-bold text-[#3D3D3D] dark:text-gray-100 mb-3">Commande annulée</h1>
        <p class="text-[#5C5C5C] dark:text-gray-300 max-w-2xl mx-auto text-lg">Cette commande a été annulée.</p>
    
    {% else %}
        <div class="inline-flex items-center justify-center w-24 h-24 rounded-3xl bg-green-100 text-green-600 mb-6 shadow-pastel">
            <svg class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
        </div>
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-green-100/50 text-green-700 text-sm font-medium mb-4">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Commande confirmée
        </div>
        <h1 class="text-3xl md:text-4xl font-bold text-[#3D3D3D] dark:text-gray-100 mb-3">Commande acceptée</h1>
        <p class="text-[#5C5C5C] dark:text-gray-300 max-w-2xl mx-auto text-lg">L'administrateur a accepté votre commande. Merci pour votre achat.</p>
    {% endif %}
</section>

{% if commande.statut == 'annulée' %}
<div class="max-w-6xl mx-auto px-4 mb-8">
    <div class="p-4 rounded-2xl bg-red-50 border-2 border-red-200 text-red-800 flex items-start gap-3">
        <svg class="w-6 h-6 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <span><strong>Information :</strong> Cette commande n'est plus active.</span>
    </div>
</div>
{% endif %}

{% if commande.statut == 'en_attente' %}
<div class="max-w-6xl mx-auto px-4 mb-8">
    <div class="p-4 rounded-2xl bg-amber-50 border-2 border-amber-200 text-amber-800 flex items-start gap-3">
        <svg class="w-6 h-6 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div>
            <strong>En attente de validation.</strong> Votre commande reste ici jusqu'à ce que l'admin accepte la demande. Aucune action requise de votre part.
        </div>
    </div>
</div>
{% endif %}

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 max-w-6xl mx-auto px-4">
    <div class="lg:col-span-2">
        <!-- Détails de la commande -->
        <div class="bg-white dark:bg-gray-600/70 rounded-3xl border-2 border-[#E8DCF0] dark:border-gray-600 p-6 shadow-pastel mb-6">
            <h2 class="text-xl font-semibold text-[#3D3D3D] dark:text-gray-100 mb-4 flex items-center gap-2">
                <svg class="w-6 h-6 text-[#CDB4DB]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
                </svg>
                Détails de la Commande
            </h2>
            
            <div class="grid grid-cols-2 gap-6 mb-6 pb-6 border-b-2 border-[#E8DCF0] dark:border-gray-600">
                <div>
                    <p class="text-sm text-[#5C5C5C] dark:text-gray-300 mb-1">Numéro de Commande</p>
                    <p class="text-lg font-semibold text-[#3D3D3D] dark:text-gray-100">#{{ commande.id }}</p>
                </div>
                <div>
                    <p class="text-sm text-[#5C5C5C] dark:text-gray-300 mb-1">Date</p>
                    <p class="text-lg font-semibold text-[#3D3D3D] dark:text-gray-100">{{ commande.dateCreation|date('d/m/Y') }}</p>
                </div>
                <div>
                    <p class="text-sm text-[#5C5C5C] dark:text-gray-300 mb-1">Statut</p>
                    <p class="text-lg font-semibold 
                        {% if commande.statut == 'en_attente' %}text-amber-600
                        {% elseif commande.statut == 'recu' or commande.statut == 'confirmer' or commande.statut == 'livraison' %}text-emerald-600
                        {% elseif commande.statut == 'annulée' %}text-red-600
                        {% else %}text-[#3D3D3D] dark:text-gray-100{% endif %}">
                        {% if commande.statut == 'en_attente' %}En attente
                        {% elseif commande.statut == 'confirmer' %}Préparation
                        {% elseif commande.statut == 'livraison' %}En livraison
                        {% elseif commande.statut == 'recu' %}Reçu
                        {% elseif commande.statut == 'annulée' %}Annulée
                        {% elseif commande.statut == 'payée' %}Payée
                        {% elseif commande.statut == 'livrée' %}Livrée
                        {% else %}{{ commande.statut }}{% endif %}
                    </p>
                </div>
                <div>
                    <p class="text-sm text-[#5C5C5C] dark:text-gray-300 mb-1">Mode de Paiement</p>
                    <p class="text-lg font-semibold text-[#3D3D3D] dark:text-gray-100">
                        {% if commande.modePayment == 'a_la_livraison' or commande.modePayment == 'delivery' %}
                            À la livraison
                        {% elseif commande.modePayment starts with 'carte_' %}
                            Carte Bancaire
                        {% else %}
                            Livraison
                        {% endif %}
                    </p>
                </div>
            </div>

            <!-- Articles commandés -->
            <h3 class="font-semibold text-[#3D3D3D] dark:text-gray-100 mb-3 flex items-center gap-2">
                <svg class="w-5 h-5 text-[#A8BBA3]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                </svg>
                Articles Commandés
            </h3>
            <div class="space-y-3 mb-6 pb-6 border-b-2 border-[#E8DCF0] dark:border-gray-600">
                {% for ligne in commande.lignes %}
                <div class="flex justify-between items-center">
                    <div>
                        <p class="font-medium text-[#3D3D3D] dark:text-gray-100">{{ ligne.produit.nom }}</p>
                        <p class="text-sm text-[#5C5C5C] dark:text-gray-300">Quantité: {{ ligne.quantite }}</p>
                    </div>
                    <p class="font-semibold text-[#CDB4DB]">{{ ligne.sousTotal|number_format(2, ',', ' ') }} dt</p>
                </div>
                {% endfor %}
            </div>

            <div class="flex justify-between text-lg font-bold text-[#3D3D3D] dark:text-gray-100">
                <span>Montant Total:</span>
                <span class="text-[#CDB4DB]">{{ commande.total|number_format(2, ',', ' ') }} dt</span>
            </div>
        </div>

        <!-- Informations de livraison -->
        <div class="bg-white dark:bg-gray-600/70 rounded-3xl border-2 border-[#D4E5D0] dark:border-gray-600 p-6 shadow-pastel">
            <h2 class="text-xl font-semibold text-[#3D3D3D] dark:text-gray-100 mb-4 flex items-center gap-2">
                <svg class="w-6 h-6 text-[#A8BBA3]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                </svg>
                Adresse de Livraison
            </h2>
            
            <div class="space-y-2 text-[#5C5C5C] dark:text-gray-300">
                <p><strong class="text-[#3D3D3D] dark:text-gray-100">{{ commande.nom }}</strong></p>
                <p>{{ commande.adresse }}</p>
                <p>{{ commande.ville }}{% if commande.codePostal %} {{ commande.codePostal }}{% endif %}</p>
                <p class="mt-3"><strong class="text-[#3D3D3D] dark:text-gray-100">Email:</strong> {{ commande.email }}</p>
                <p><strong class="text-[#3D3D3D] dark:text-gray-100">Téléphone:</strong> {{ commande.telephone }}</p>
            </div>
        </div>
    </div>

    <!-- Prochaines étapes -->
    <div>
        <div class="bg-white dark:bg-gray-600/70 rounded-3xl border-2 border-[#FAEDE8] dark:border-gray-600 p-6 shadow-pastel sticky top-20">
            <h3 class="text-lg font-semibold text-[#3D3D3D] dark:text-gray-100 mb-4 flex items-center gap-2">
                <svg class="w-5 h-5 text-[#F0D5C8]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Prochaines Étapes
            </h3>
            
            {% set s = commande.statut %}
            {% set step1_done = true %}
            {% set step2_done = s != 'en_attente' and s != 'annulée' %}
            {% set step3_done = s == 'livraison' or s == 'recu' or s == 'payée' or s == 'livrée' %}
            {% set step4_done = s == 'recu' or s == 'livrée' %}
            
            <div class="space-y-4">
                <!-- Étape 1 -->
                <div class="flex gap-3">
                    <div class="w-8 h-8 rounded-xl bg-[#A8BBA3] text-white flex items-center justify-center flex-shrink-0 font-semibold shadow-pastel">✓</div>
                    <div>
                        <p class="font-semibold text-[#3D3D3D] dark:text-gray-100">1. Commande Reçue</p>
                        <p class="text-sm text-[#5C5C5C] dark:text-gray-300">Votre commande a été validée</p>
                    </div>
                </div>

                <!-- Étape 2 -->
                <div class="flex gap-3">
                    <div class="w-8 h-8 rounded-xl {{ step2_done ? 'bg-[#A8BBA3] text-white' : 'bg-[#FAEDE8] text-[#5C5C5C]' }} flex items-center justify-center flex-shrink-0 font-semibold shadow-pastel">{{ step2_done ? '✓' : '2' }}</div>
                    <div>
                        <p class="font-semibold text-[#3D3D3D] dark:text-gray-100">2. Vérification du stock</p>
                        <p class="text-sm text-[#5C5C5C] dark:text-gray-300">
                            {% if step2_done %}
                                Stock vérifié, commande acceptée par l'admin
                            {% else %}
                                En attente de validation par l'admin
                            {% endif %}
                        </p>
                    </div>
                </div>

                <!-- Étape 3 -->
                <div class="flex gap-3">
                    <div class="w-8 h-8 rounded-xl {{ step3_done ? 'bg-[#A8BBA3] text-white' : 'bg-[#FAEDE8] text-[#5C5C5C]' }} flex items-center justify-center flex-shrink-0 font-semibold shadow-pastel">{{ step3_done ? '✓' : '3' }}</div>
                    <div>
                        <p class="font-semibold text-[#3D3D3D] dark:text-gray-100">3. Suivi du produit</p>
                        <p class="text-sm text-[#5C5C5C] dark:text-gray-300">
                            {% if s == 'recu' or s == 'livrée' %}
                                Livré
                            {% elseif step3_done %}
                                Colis a quitté le magasin — En route
                            {% else %}
                                Colis a quitté le magasin → En route → Livré
                            {% endif %}
                        </p>
                    </div>
                </div>

                <!-- Étape 4 -->
                <div class="flex gap-3">
                    <div class="w-8 h-8 rounded-xl {{ step4_done ? 'bg-[#A8BBA3] text-white' : 'bg-[#FAEDE8] text-[#5C5C5C]' }} flex items-center justify-center flex-shrink-0 font-semibold shadow-pastel">{{ step4_done ? '✓' : '4' }}</div>
                    <div>
                        <p class="font-semibold text-[#3D3D3D] dark:text-gray-100">4. Reçu</p>
                        <p class="text-sm text-[#5C5C5C] dark:text-gray-300">Votre commande livrée</p>
                    </div>
                </div>
            </div>

            <div class="mt-6 p-4 bg-[#FAEDE8] dark:bg-gray-600/40 rounded-2xl border-2 border-[#F0D5C8]/50">
                <div class="flex items-start gap-2 mb-2">
                    <svg class="w-5 h-5 text-[#A8BBA3] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <p class="text-sm text-[#5C5C5C] dark:text-gray-300">
                        <strong>Délai de livraison:</strong> 2-3 jours ouvrables
                    </p>
                </div>
                <div class="flex items-start gap-2">
                    <svg class="w-5 h-5 text-[#B5D4E8] flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                    <p class="text-sm text-[#5C5C5C] dark:text-gray-300">
                        Un email de confirmation a été envoyé à <strong>{{ commande.email }}</strong>
                    </p>
                </div>
            </div>

            <div class="mt-6 space-y-3">
                {% set isPaiementEnLigne = commande.modePayment == 'carte_bancaire' or (commande.modePayment ?? '') starts with 'carte_' or commande.stripePaymentIntent %}
                
                <a href="{{ path('order_receipt', { id: commande.id }) }}" class="flex items-center justify-center gap-2 w-full px-4 py-3.5 rounded-2xl border-2 border-[#A8BBA3] text-[#A8BBA3] font-semibold hover:bg-[#A8BBA3]/10 transition-all" target="_blank" rel="noopener">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    {% if isPaiementEnLigne %}
                        Télécharger le bon à présenter au livreur (PDF)
                    {% else %}
                        Télécharger le bon de commande (PDF)
                    {% endif %}
                </a>
                
                <a href="{{ path('home') }}" class="block w-full px-4 py-3.5 rounded-2xl border-2 border-[#E8DED5] bg-white dark:bg-gray-700 text-[#5C5C5C] dark:text-gray-200 font-semibold text-center hover:bg-[#FFF8F0] dark:hover:bg-gray-600 transition-all">
                    Retour à l'accueil
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
{% extends 'layouts/user.html.twig' %}

{% block title %}{{ module.titre }} - AutiCare{% endblock %}

{% block user_content %}
<div class="mb-6">
    <a href="{{ path('user_modules') }}" class="inline-flex items-center gap-2 text-[#6B7280] hover:text-[#A7C7E7] focus:outline focus:ring-2 focus:ring-[#A7C7E7] rounded-lg text-sm font-medium">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Retour aux modules
    </a>
</div>

<div class="bg-white rounded-xl border border-[#E5E0D8] p-6 md:p-8 mb-8">
    <header class="mb-8">
        <div class="flex items-center gap-4 mb-4">
            <span class="inline-block px-3 py-1 rounded-lg bg-[#A7C7E7]/30 text-[#4B5563] text-sm font-medium">{{ module.niveau|capitalize }}</span>
            {% if module.categorie %}
                <span class="inline-block px-3 py-1 rounded-lg bg-[#95d7b5]/30 text-[#4B5563] text-sm font-medium">
                    {{ module.categorie.label() }}
                </span>
            {% endif %}
        </div>
        <h1 class="text-3xl font-bold text-[#4B5563] mb-3">{{ module.titre }}</h1>
        {% if module.dateCreation or module.contenu %}
            <div class="inline-flex items-center gap-2">
                {% if module.dateCreation %}
                    <p class="text-[#6B7280] text-sm">Publié le {{ module.dateCreation|date('d/m/Y') }}</p>
                {% endif %}
                {% if module.titre or module.description or module.contenu %}
                <button type="button"
                        class="module-tts-btn inline-flex items-center justify-center w-8 h-8 rounded-lg bg-green-50 text-green-600 hover:bg-green-100 focus:outline focus:ring-2 focus:ring-green-500 shrink-0"
                        data-tts-text="{{ [(module.titre ?? ''), (module.description ?? ''), (module.contenu ?? '')]|join(' ')|trim|striptags|e('html_attr') }}"
                        data-tts-lang="{{ app.session.get('blog_locale', 'fr') }}"
                        title="Écouter le module"
                        aria-label="Écouter le contenu du module">
                    <svg class="module-tts-icon-play w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                    <svg class="module-tts-icon-pause w-4 h-4" fill="currentColor" viewBox="0 0 24 24" style="display:none"><path d="M6 4h4v16H6zm8 0h4v16h-4z"/></svg>
                </button>
                {% endif %}
            </div>
        {% endif %}
    </header>

    {% if module.image %}
        <div class="mb-8">
            <img src="{{ asset(module.image) }}" alt="{{ module.titre }}" class="rounded-lg max-w-full h-auto">
        </div>
    {% endif %}

    <div class="prose prose-[#4B5563] max-w-none">
        <h2 class="text-xl font-semibold text-[#4B5563] mb-3">Description</h2>
        <p class="text-[#6B7280] mb-6">{{ module.description }}</p>
        
        <h2 class="text-xl font-semibold text-[#4B5563] mb-3">Contenu</h2>
        <div class="dict-content text-[#4B5563] whitespace-pre-wrap" data-dict-lang="{{ app.session.get('blog_locale', 'fr') }}">{{ module.contenu|blog_translate|raw }}</div>

        {# Lien Wikipedia - En savoir plus sur le module #}
        <div class="mt-6 pt-4 border-t border-[#E5E0D8]">
            <a href="{{ wikiUrl|default('https://fr.wikipedia.org/wiki/Autisme') }}"
               target="_blank"
               rel="noopener noreferrer"
               class="inline-flex items-center gap-2 text-[#1e3a5f] hover:text-[#0369A1] hover:underline font-medium text-sm transition-colors">
                {{ 'En savoir plus sur ce module'|blog_translate }}
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H18m0 0v4.5M18 6l-7.5 7.5M6 10.5V18h7.5" />
                </svg>
            </a>
        </div>
    </div>
</div>

<div class="flex gap-4">
    <a href="{{ path('user_modules') }}" class="px-5 py-2.5 rounded-lg border border-[#E5E0D8] text-[#6B7280] font-medium hover:bg-[#F5F1EB] focus:outline focus:ring-2 focus:ring-[#A7C7E7]">
        Retour à la liste
    </a>
    <a href="{{ path('user_module_edit', {'id': module.id}) }}" class="px-5 py-2.5 rounded-lg bg-[#A7C7E7] text-white font-medium hover:bg-[#B8D4ED] focus:outline focus:ring-2 focus:ring-[#A7C7E7]">
        Modifier
    </a>
    <form method="post" action="{{ path('user_module_delete', {'id': module.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce module ?');" class="inline">
        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ module.id) }}">
        <button type="submit" class="px-5 py-2.5 rounded-lg bg-red-50 text-red-600 font-medium hover:bg-red-100 focus:outline focus:ring-2 focus:ring-red-500">
            Supprimer
        </button>
    </form>
</div>
<script>
document.addEventListener('DOMContentLoaded', function () {
    function initModuleTTS() {
        document.querySelectorAll('.module-tts-btn').forEach(function (btn) {
            if (btn._ttsInit) return;
            btn._ttsInit = true;
            btn.addEventListener('click', function () {
                var text = this.getAttribute('data-tts-text');
                if (!text || !text.trim()) return;
                if (window.speechSynthesis.speaking && !window.speechSynthesis.paused) {
                    window.speechSynthesis.cancel();
                    this.classList.remove('module-tts-active');
                    return;
                }
                if (window.speechSynthesis.paused) {
                    window.speechSynthesis.resume();
                    this.classList.add('module-tts-active');
                    return;
                }
                var utterance = new SpeechSynthesisUtterance(text);
                var locale = this.getAttribute('data-tts-lang') || 'fr';
                var langMap = { fr: 'fr-FR', en: 'en-US', es: 'es-ES', ar: 'ar-SA', de: 'de-DE', it: 'it-IT', pt: 'pt-PT', ru: 'ru-RU', zh: 'zh-CN', nl: 'nl-NL', ja: 'ja-JP', ko: 'ko-KR', tr: 'tr-TR', pl: 'pl-PL', sv: 'sv-SE', vi: 'vi-VN', id: 'id-ID', th: 'th-TH', uk: 'uk-UA' };
                utterance.lang = langMap[locale] || (locale + '-' + locale.toUpperCase()) || 'fr-FR';
                utterance.rate = 1;
                utterance.pitch = 1;
                utterance.volume = 1;
                utterance.onstart = function () { btn.classList.add('module-tts-active'); };
                utterance.onend = function () { btn.classList.remove('module-tts-active'); };
                utterance.onerror = function () { btn.classList.remove('module-tts-active'); };
                window.speechSynthesis.speak(utterance);
            });
        });
    }
    initModuleTTS();
});
</script>
<style>
.module-tts-active { background-color: rgb(220 252 231) !important; color: rgb(22 163 74) !important; }
.module-tts-active .module-tts-icon-play { display: none !important; }
.module-tts-active .module-tts-icon-pause { display: block !important; }
</style>
{% endblock %}

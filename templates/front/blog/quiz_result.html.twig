{% extends 'layouts/user.html.twig' %}

{% block title %}Résultat - Quiz {{ module.titre }} - AutiCare{% endblock %}

{% block user_content %}
<div class="max-w-2xl mx-auto">
    <div class="mb-6">
        <a href="{{ path('user_blog_module', { id: module.id }) }}" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl border border-[#E8DED5] text-[#4B5563] font-medium hover:bg-[#F5F1EB] transition-colors w-fit">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
            {{ 'Retour au module'|blog_translate }}
        </a>
    </div>

    <div class="bg-[#FDF8F5] rounded-2xl border border-[#E8DED5] p-6 md:p-8 shadow-sm">
        {% if passed %}
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-[#D4E5D0] text-[#A8BBA3] mb-4">
                    <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                </div>
                <h1 class="text-2xl font-bold text-[#4B5563] mb-2">{{ 'Félicitations !'|blog_translate }}</h1>
                <p class="text-[#687280]">{{ 'Vous avez validé ce module.'|blog_translate }}</p>
            </div>
        {% else %}
            <div class="text-center mb-8">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-[#FAEDE8] text-[#A8BBA3] mb-4">
                    <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                    </svg>
                </div>
                <h1 class="text-2xl font-bold text-[#4B5563] mb-2">{{ 'Quiz non validé'|blog_translate }}</h1>
                <p class="text-[#687280]">{{ 'Il faut plus de 80% pour valider ce module.'|blog_translate }}</p>
            </div>
        {% endif %}

        <div class="rounded-xl border border-[#E8DED5] p-5 bg-white mb-8">
            <p class="text-lg font-semibold text-[#4B5563]">
                {{ 'Score'|blog_translate }} : <span class="{{ passed ? 'text-[#A8BBA3]' : 'text-[#E07C5A]' }}">{{ scorePercent }}%</span>
            </p>
            <p class="text-sm text-[#687280]">{{ correctCount }} / {{ totalCount }} {{ 'réponses correctes'|blog_translate }}</p>
        </div>

        {% if passed %}
            <p class="text-[#687280] mb-6">{{ 'Le niveau suivant est débloqué. Continuez votre progression !'|blog_translate }}</p>
            <a href="{{ path('user_blog_module', { id: module.id }) }}" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-[#A8BBA3] text-white font-semibold hover:bg-[#95B89E] transition-colors">
                {{ 'Retour au module'|blog_translate }}
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
            </a>
        {% else %}
            <p class="text-[#687280] mb-6">{{ 'Relisez le contenu du module et réessayez. Chaque tentative génère un nouveau quiz.'|blog_translate }}</p>
            <a href="{{ path('user_blog_quiz_start', { id: module.id }) }}" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-[#A7C7E7] text-white font-semibold hover:bg-[#95b8dc] transition-colors">
                {{ 'Réessayer le quiz'|blog_translate }}
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
            </a>
        {% endif %}
    </div>
</div>
{% endblock %}

    /* ====== Facebook-style Reactions ====== */
    var REACTION_EMOJIS = {like:'⭐', love:'❤️', haha:'😂', wow:'😮', sad:'😢', angry:'😡'};
    var REACTION_LABELS = {like:"J'aime", love:"J'adore", haha:'Haha', wow:'Wow', sad:'Quoi ?', angry:'Solidaire'};
    var REACTION_COLORS = {like:'#1877F2', love:'#F33E58', haha:'#F7B928', wow:'#F7B928', sad:'#F7B928', angry:'#E9710F'};

    function initReactionWrappers() {
        document.querySelectorAll('.reaction-wrapper').forEach(function (wrapper) {
            if (wrapper._reactionInit) return;
            wrapper._reactionInit = true;

            var mainBtn = wrapper.querySelector('.reaction-main-btn');
            var popup = wrapper.querySelector('.reaction-popup');
            var optionBtns = wrapper.querySelectorAll('.reaction-option-btn');
            var countsEl = wrapper.querySelector('.reaction-counts');
            var totalCountEl = wrapper.querySelector('.reaction-total-count');
            var hoverTimer, leaveTimer;

            function showPopup() {
                clearTimeout(leaveTimer);
                popup.classList.remove('opacity-0', 'pointer-events-none', 'scale-75');
                popup.classList.add('opacity-100', 'scale-100');
            }
            function hidePopup() {
                clearTimeout(hoverTimer);
                popup.classList.add('opacity-0', 'pointer-events-none', 'scale-75');
                popup.classList.remove('opacity-100', 'scale-100');
            }

            mainBtn.addEventListener('mouseenter', function () {
                hoverTimer = setTimeout(showPopup, 400);
            });
            mainBtn.addEventListener('mouseleave', function () {
                clearTimeout(hoverTimer);
                leaveTimer = setTimeout(hidePopup, 300);
            });
            popup.addEventListener('mouseenter', function () { clearTimeout(leaveTimer); });
            popup.addEventListener('mouseleave', function () { leaveTimer = setTimeout(hidePopup, 200); });

            function sendReaction(type) {
                hidePopup();
                var url = mainBtn.getAttribute('data-toggle-url');
                var csrf = mainBtn.getAttribute('data-csrf');
                var formData = new FormData();
                formData.append('_token', csrf);
                formData.append('type', type);

                fetch(url, {
                    method: 'POST',
                    body: formData,
                    credentials: 'same-origin',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    var userReaction = data.userReaction || null;
                    var total = data.total || 0;

                    mainBtn.setAttribute('data-current-reaction', userReaction || '');

                    var starIconUrl = wrapper.getAttribute('data-star-icon') || '';
                    var heartIconUrl = wrapper.getAttribute('data-heart-icon') || '';
                    var hahaIconUrl = wrapper.getAttribute('data-haha-icon') || '';
                    var wowIconUrl = wrapper.getAttribute('data-wow-icon') || '';
                    var sadIconUrl = wrapper.getAttribute('data-sad-icon') || '';
                    var angryIconUrl = wrapper.getAttribute('data-angry-icon') || '';
                    var emojiEl = mainBtn.querySelector('.reaction-main-emoji');
                    var displayType = userReaction || 'like';

                    if (userReaction) {
                        var color = REACTION_COLORS[userReaction] || '#1877F2';
                        mainBtn.style.background = color + '15';
                        mainBtn.style.borderColor = color;
                        mainBtn.style.color = color;
                        if (displayType === 'like' && starIconUrl) {
                            emojiEl.innerHTML = '<img src="' + starIconUrl + '" alt="J\'aime" class="w-7 h-7">';
                        } else if (displayType === 'love' && heartIconUrl) {
                            emojiEl.innerHTML = '<img src="' + heartIconUrl + '" alt="J\'adore" class="w-7 h-7">';
                        } else if (displayType === 'haha' && hahaIconUrl) {
                            emojiEl.innerHTML = '<img src="' + hahaIconUrl + '" alt="Haha" class="w-7 h-7">';
                        } else if (displayType === 'wow' && wowIconUrl) {
                            emojiEl.innerHTML = '<img src="' + wowIconUrl + '" alt="Wow" class="w-7 h-7">';
                        } else if (displayType === 'sad' && sadIconUrl) {
                            emojiEl.innerHTML = '<img src="' + sadIconUrl + '" alt="Quoi ?" class="w-7 h-7">';
                        } else if (displayType === 'angry' && angryIconUrl) {
                            emojiEl.innerHTML = '<img src="' + angryIconUrl + '" alt="Solidaire" class="w-7 h-7">';
                        } else {
                            emojiEl.textContent = REACTION_EMOJIS[userReaction] || '⭐';
                        }
                        mainBtn.querySelector('.reaction-main-label').textContent = REACTION_LABELS[userReaction] || "J'aime";
                    } else {
                        mainBtn.style.background = '';
                        mainBtn.style.borderColor = '';
                        mainBtn.style.color = '';
                        if (starIconUrl) {
                            emojiEl.innerHTML = '<img src="' + starIconUrl + '" alt="J\'aime" class="w-7 h-7">';
                        } else {
                            emojiEl.textContent = '⭐';
                        }
                        mainBtn.querySelector('.reaction-main-label').textContent = "J'aime";
                    }

                    if (totalCountEl) {
                        totalCountEl.textContent = total;
                        if (countsEl) countsEl.style.display = total > 0 ? '' : 'none';
                    }
                })
                .catch(function () {
                    showToast('Erreur, veuillez réessayer');
                });
            }

            mainBtn.addEventListener('click', function () {
                var current = mainBtn.getAttribute('data-current-reaction') || '';
                sendReaction(current || 'like');
            });

            optionBtns.forEach(function (btn) {
                btn.addEventListener('click', function () {
                    sendReaction(btn.getAttribute('data-type'));
                });
            });
        });
    }

    initReactionWrappers();

    /* ====== Text-to-Speech (Web Speech API) ====== */
    function initModuleTTS() {
        document.querySelectorAll('.module-tts-btn').forEach(function (btn) {
            if (btn._ttsInit) return;
            btn._ttsInit = true;
            btn.addEventListener('click', function () {
                var text = this.getAttribute('data-tts-text');
                if (!text || !text.trim()) return;
                if (window.speechSynthesis.speaking && !window.speechSynthesis.paused) {
                    window.speechSynthesis.cancel();
                    this.classList.remove('module-tts-active');
                    return;
                }
                if (window.speechSynthesis.paused) {
                    window.speechSynthesis.resume();
                    this.classList.add('module-tts-active');
                    return;
                }
                var utterance = new SpeechSynthesisUtterance(text);
                var locale = this.getAttribute('data-tts-lang') || 'fr';
                var langMap = { fr: 'fr-FR', en: 'en-US', es: 'es-ES', ar: 'ar-SA', de: 'de-DE', it: 'it-IT', pt: 'pt-PT', ru: 'ru-RU', zh: 'zh-CN', nl: 'nl-NL', ja: 'ja-JP', ko: 'ko-KR', tr: 'tr-TR', pl: 'pl-PL', sv: 'sv-SE', vi: 'vi-VN', id: 'id-ID', th: 'th-TH', uk: 'uk-UA' };
                utterance.lang = langMap[locale] || (locale + '-' + locale.toUpperCase()) || 'fr-FR';
                utterance.rate = 1;
                utterance.pitch = 1;
                utterance.volume = 1;
                utterance.onstart = function () { btn.classList.add('module-tts-active'); };
                utterance.onend = function () { btn.classList.remove('module-tts-active'); };
                utterance.onerror = function () { btn.classList.remove('module-tts-active'); };
                window.speechSynthesis.speak(utterance);
            });
        });
    }
    initModuleTTS();

    /* ====== Speech-to-Text (Dictée vocale) ====== */
    function initDictation() {
        var SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
        if (!SpeechRecognition) {
            document.querySelectorAll('.dictation-btn').forEach(function (btn) {
                btn.disabled = true;
                btn.title = 'Dictée non supportée (Chrome, Edge, Safari)';
                btn.classList.add('opacity-50', 'cursor-not-allowed');
            });
            return;
        }
        var recognition = new SpeechRecognition();
        recognition.lang = 'fr-FR';
        recognition.continuous = true;
        recognition.interimResults = true;
        var activeBtn = null;
        var activeTarget = null;
        var dictationStart = 0;
        var dictationLength = 0;
        recognition.onresult = function (event) {
            if (!activeTarget) return;
            var transcript = '';
            for (var i = event.resultIndex; i < event.results.length; i++) {
                if (event.results[i].isFinal) {
                    transcript = event.results[i][0].transcript;
                }
            }
            if (!transcript) return;
            var field = document.getElementById(activeTarget);
            if (!field) return;
            var before = field.value.substring(0, dictationStart);
            var after = field.value.substring(dictationStart + dictationLength);
            field.value = before + transcript + after;
            dictationLength = transcript.length;
            field.selectionStart = field.selectionEnd = dictationStart + dictationLength;
        };
        recognition.onerror = function (event) {
            if (event.error !== 'aborted') {
                var msg = event.error === 'not-allowed' ? 'Micro non autorisé' : event.error;
                var status = document.querySelector('.dictation-status[data-for="' + activeTarget + '"]');
                if (status) { status.textContent = 'Erreur : ' + msg; status.classList.remove('hidden'); }
            }
            stopDictation();
        };
        recognition.onend = function () {
            if (activeBtn) {
                try { recognition.start(); } catch (e) {}
            } else {
                document.querySelectorAll('.dictation-status').forEach(function (s) {
                    s.classList.add('hidden');
                });
            }
        };
        function stopDictation() {
            recognition.stop();
            activeBtn = null;
            activeTarget = null;
            dictationStart = 0;
            dictationLength = 0;
            document.querySelectorAll('.dictation-btn').forEach(function (b) {
                b.classList.remove('bg-red-100', 'text-red-600');
                b.classList.add('bg-[#F3F4F6]', 'text-[#687280]');
            });
            document.querySelectorAll('.dictation-status').forEach(function (s) {
                s.classList.add('hidden');
            });
        }
        document.querySelectorAll('.dictation-btn').forEach(function (btn) {
            if (btn._dictationInit) return;
            btn._dictationInit = true;
            btn.addEventListener('click', function () {
                var targetId = this.getAttribute('data-target');
                var statusEl = document.querySelector('.dictation-status[data-for="' + targetId + '"]');
                if (activeBtn === this) {
                    stopDictation();
                    this.title = 'Dictée vocale';
                    return;
                }
                if (activeBtn) stopDictation();
                try {
                    activeBtn = this;
                    activeTarget = targetId;
                    var field = document.getElementById(targetId);
                    dictationStart = field ? (field.selectionStart || field.value.length) : 0;
                    dictationLength = 0;
                    recognition.start();
                    this.classList.remove('bg-[#F3F4F6]', 'text-[#687280]');
                    this.classList.add('bg-red-100', 'text-red-600');
                    this.title = 'Arrêter la dictée';
                    if (statusEl) {
                        statusEl.textContent = 'Écoute en cours... Parlez.';
                        statusEl.classList.remove('hidden');
                    }
                } catch (e) {
                    if (statusEl) {
                        statusEl.textContent = 'Impossible de démarrer.';
                        statusEl.classList.remove('hidden');
                    }
                }
            });
        });
    }
    initDictation();

    /* ====== Vérification orthographique (Groq) - formulaire nouvel article ====== */
    var spellCheckUrl = '{{ path("user_blog_spell_check") }}';
    document.querySelectorAll('.spell-check-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var targetId = this.getAttribute('data-target');
            var field = document.getElementById(targetId);
            var resultEl = document.querySelector('.spell-check-result[data-for="' + targetId + '"]');
            if (!field || !resultEl) return;
            var text = field.value.trim();
            if (!text) {
                resultEl.innerHTML = '<p class="text-amber-600 text-sm">Veuillez saisir du texte.</p>';
                resultEl.classList.remove('hidden');
                return;
            }
            btn.disabled = true;
            resultEl.innerHTML = '<p class="text-[#687280] text-sm">Vérification en cours...</p>';
            resultEl.classList.remove('hidden');
            var formData = new FormData();
            formData.append('text', text);
            fetch(spellCheckUrl, { method: 'POST', body: formData, headers: { 'X-Requested-With': 'XMLHttpRequest' } })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                btn.disabled = false;
                if (data.error) {
                    resultEl.innerHTML = '<p class="text-red-600 text-sm">' + data.error + '</p>';
                } else if (data.corrections && data.corrections.length > 0) {
                    var html = '<div class="rounded-lg bg-amber-50 border border-amber-200 p-3 text-sm"><p class="font-medium text-amber-800 mb-2">Corrections proposées :</p><ul class="space-y-1 mb-3">';
                    data.corrections.forEach(function(c) {
                        html += '<li><span class="text-red-600">' + (c.original || '').replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</span> → <span class="text-emerald-600">' + (c.suggestion || '').replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</span></li>';
                    });
                    html += '</ul><button type="button" class="apply-spell-check px-3 py-1.5 rounded-lg bg-emerald-600 text-white text-sm font-medium hover:bg-emerald-700">Appliquer les corrections</button></div>';
                    resultEl.innerHTML = html;
                    var correctedText = data.corrected_text || '';
                    resultEl.querySelector('.apply-spell-check')?.addEventListener('click', function() {
                        var f = document.getElementById(targetId);
                        if (f && correctedText) { f.value = correctedText; resultEl.classList.add('hidden'); }
                    });
                } else {
                    resultEl.innerHTML = '<p class="text-emerald-600 text-sm">Aucune faute détectée.</p>';
                }
            })
            .catch(function() {
                btn.disabled = false;
                resultEl.innerHTML = '<p class="text-red-600 text-sm">Erreur lors de la vérification.</p>';
            });
        });
    });

    /* ====== Vérification orthographique - articles publiés (auteur) ====== */
    var articleSpellCheckModal = document.getElementById('article-spell-check-modal');
    var articleSpellCheckBackdrop = document.getElementById('article-spell-check-backdrop');
    var closeArticleSpellCheckBtn = document.getElementById('close-article-spell-check');
    var articleSpellCheckLoading = document.getElementById('article-spell-check-loading');
    var articleSpellCheckResult = document.getElementById('article-spell-check-result');
    var applySpellCheckUrl = '{{ path("user_blog_apply_spell_check") }}';
    var moduleId = {{ module.id|default(0) }};

    function closeArticleSpellCheckModal() {
        if (articleSpellCheckModal) articleSpellCheckModal.classList.add('hidden');
    }
    function openArticleSpellCheckModal() {
        if (articleSpellCheckModal) articleSpellCheckModal.classList.remove('hidden');
    }

    if (closeArticleSpellCheckBtn) closeArticleSpellCheckBtn.addEventListener('click', closeArticleSpellCheckModal);
    if (articleSpellCheckBackdrop) articleSpellCheckBackdrop.addEventListener('click', closeArticleSpellCheckModal);

    document.querySelectorAll('.article-spell-check-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var articleId = this.getAttribute('data-article-id');
            var titre = this.getAttribute('data-article-titre') || '';
            var contenu = this.getAttribute('data-article-contenu') || '';
            if (!articleId) return;
            var btn = this;

            openArticleSpellCheckModal();
            articleSpellCheckResult.classList.add('hidden');
            articleSpellCheckResult.innerHTML = '';
            articleSpellCheckLoading.classList.remove('hidden');

            function doSpellCheck(text) {
                if (!text || !text.trim()) return Promise.resolve({ corrections: [], corrected_text: text });
                var fd = new FormData();
                fd.append('text', text);
                return fetch(spellCheckUrl, { method: 'POST', body: fd, headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(function(r) { return r.json(); });
            }

            Promise.all([doSpellCheck(titre), doSpellCheck(contenu)]).then(function(results) {
                articleSpellCheckLoading.classList.add('hidden');
                var resTitre = results[0] || {};
                var resContenu = results[1] || {};
                var correctedTitre = resTitre.corrected_text !== undefined ? resTitre.corrected_text : titre;
                var correctedContenu = resContenu.corrected_text !== undefined ? resContenu.corrected_text : contenu;
                var hasCorrections = (resTitre.corrections && resTitre.corrections.length > 0) || (resContenu.corrections && resContenu.corrections.length > 0);

                if (resTitre.error || resContenu.error) {
                    articleSpellCheckResult.innerHTML = '<p class="text-red-600">' + (resTitre.error || resContenu.error || 'Erreur') + '</p>';
                } else if (hasCorrections) {
                    var html = '<div class="space-y-3"><p class="font-medium text-amber-800">Corrections proposées :</p><ul class="space-y-1 text-sm">';
                    (resTitre.corrections || []).forEach(function(c) {
                        html += '<li><span class="text-red-600">' + (c.original || '').replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</span> → <span class="text-emerald-600">' + (c.suggestion || '').replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</span></li>';
                    });
                    (resContenu.corrections || []).forEach(function(c) {
                        html += '<li><span class="text-red-600">' + (c.original || '').replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</span> → <span class="text-emerald-600">' + (c.suggestion || '').replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</span></li>';
                    });
                    var csrf = btn.getAttribute('data-article-csrf') || '';
                    html += '</ul><form method="post" action="' + applySpellCheckUrl + '" class="mt-4">';
                    var csrfEscaped = (csrf || '').replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
                    html += '<input type="hidden" name="_token" value="' + csrfEscaped + '">';
                    html += '<input type="hidden" name="article_id" value="' + articleId + '">';
                    html += '<input type="hidden" name="corrected_titre" value="">';
                    html += '<input type="hidden" name="corrected_contenu" value="">';
                    html += '<button type="submit" class="px-4 py-2 rounded-lg bg-emerald-600 text-white text-sm font-medium hover:bg-emerald-700">Appliquer et modifier l\'article</button></form></div>';
                    articleSpellCheckResult.innerHTML = html;
                    var form = articleSpellCheckResult.querySelector('form');
                    if (form) {
                        form.querySelector('input[name="corrected_titre"]').value = correctedTitre;
                        form.querySelector('input[name="corrected_contenu"]').value = correctedContenu;
                    }
                } else {
                    articleSpellCheckResult.innerHTML = '<p class="text-emerald-600">Aucune faute détectée.</p>';
                }
                articleSpellCheckResult.classList.remove('hidden');
            }).catch(function() {
                articleSpellCheckLoading.classList.add('hidden');
                articleSpellCheckResult.innerHTML = '<p class="text-red-600">Erreur lors de la vérification.</p>';
                articleSpellCheckResult.classList.remove('hidden');
            });
        });
    });
}
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initModulePage);
} else {
    initModulePage();
}
document.addEventListener('turbo:load', initModulePage);
</script>
<style>
.module-tts-active { background-color: rgb(220 252 231) !important; color: rgb(22 163 74) !important; }
.module-tts-active .module-tts-icon-play { display: none !important; }
.module-tts-active .module-tts-icon-pause { display: block !important; }
.summary-tts-active { background-color: #CDB4DB !important; color: #4B3D6B !important; }
.summary-tts-active .summary-tts-icon-play { display: none !important; }
.summary-tts-active .summary-tts-icon-pause { display: block !important; }
</style>
{% endblock %}

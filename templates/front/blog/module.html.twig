{% extends 'layouts/user.html.twig' %}

{% block title %}{{ module.titre }} - Blog AutiCare{% endblock %}

{% block user_content %}
<article class="max-w-7xl mx-auto">
    <div class="mb-6">
        <a href="{{ path('user_blog') }}" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl border border-[#E8DED5] text-[#4B5563] font-medium hover:bg-[#F5F1EB] transition-colors w-fit">
            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
            {{ 'Retour au blog'|blog_translate }}
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="mb-6 px-4 py-3 rounded-lg bg-[#D4E5D0] border border-[#A8BBA3] text-[#4B5563]">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="mb-6 px-4 py-3 rounded-lg bg-[#FAEDE8] border border-[#E8DED5] text-[#4B5563]">{{ message }}</div>
    {% endfor %}

    <div class="flex flex-col lg:flex-row gap-8 items-start">
    <!-- Colonne gauche : Contenu du module (cadre) -->
    <div class="w-full lg:w-2/5 lg:min-w-0 lg:sticky lg:top-8 flex-shrink-0 order-1 lg:order-1">
    <div class="bg-[#FDF8F5] rounded-xl border border-[#E8DED5] p-6 md:p-8 shadow-sm">
        <header class="mb-8">
            <div class="flex items-start justify-between gap-4 mb-3">
                <h1 class="text-3xl font-bold text-[#4B5563]">
                    {{ module.titre|blog_translate }}
                </h1>
                <span class="inline-block px-3 py-1 rounded-lg bg-[#A7C7E7]/30 text-[#4B5563] text-sm font-medium shrink-0">{{ module.niveau|capitalize }}</span>
            </div>
            {% if module.dateCreation %}
            <div class="inline-flex items-center gap-2">
                <p class="text-[#687280] text-sm">{{ 'Publié le'|blog_translate }} {{ module.dateCreation|date('d/m/Y') }}</p>
                {% if module.titre or module.description or module.contenu %}
                <button type="button"
                        class="module-tts-btn inline-flex items-center justify-center w-8 h-8 rounded-lg bg-[#D4E5D0] text-[#A8BBA3] hover:bg-[#C4DFBF] focus:outline focus:ring-2 focus:ring-[#A8BBA3] shrink-0"
                        data-tts-text="{{ [(module.titre ?? ''), (module.description ?? ''), (module.contenu ?? '')]|join(' ')|trim|striptags|e('html_attr') }}"
                        data-tts-lang="{{ app.session.get('blog_locale', 'fr') }}"
                        title="{{ 'Écouter le module'|blog_translate }}"
                        aria-label="Écouter le contenu du module">
                    <svg class="module-tts-icon-play w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M8 5v14l11-7z"/>
                    </svg>
                    <svg class="module-tts-icon-pause w-4 h-4" fill="currentColor" viewBox="0 0 24 24" style="display:none">
                        <path d="M6 4h4v16H6zm8 0h4v16h-4z"/>
                    </svg>
                </button>
                {% endif %}
                <a href="{{ path('user_blog_module_download', { id: module.id }) }}"
                   class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-[#E8F4FC] text-[#1e3a5f] hover:bg-[#D4E8F8] focus:outline focus:ring-2 focus:ring-[#A7C7E7] shrink-0"
                    title="{{ 'Télécharger le module'|blog_translate }}">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M8 12l4 4m0 0l4-4m-4 4V4" />
                    </svg>
                </a>
                {% if module.titre or module.description or module.contenu %}
                <button type="button"
                        id="module-summary-btn"
                        class="module-summary-btn inline-flex items-center justify-center w-8 h-8 rounded-lg bg-[#E8DCF0] text-[#4B3D6B] hover:bg-[#DDD0E8] focus:outline focus:ring-2 focus:ring-[#CDB4DB] shrink-0"
                        data-module-id="{{ module.id }}"
                        data-summary-url="{{ path('module_summary', { id: module.id }) }}"
                        title="{{ 'Résumer avec l\'IA'|blog_translate }}"
                        aria-label="{{ 'Résumer ce module avec l\'IA'|blog_translate }}">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 4.5l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423-1.423z" />
                    </svg>
                </button>
                {% endif %}
            </div>
            {% endif %}
        </header>

        {% if module.description %}
        <p class="text-lg text-[#687280] mb-6 whitespace-normal break-words">{{ module.description|blog_translate }}</p>
        {% endif %}

        {% if module.image %}
        <div class="mb-8">
            <img src="{{ asset(module.image) }}"
                 alt="{{ module.titre|blog_translate }}"
                 class="w-full max-w-[620px] aspect-[16/10] object-cover rounded-lg">
        </div>
        {% endif %}

        <div class="prose prose-[#4B5563] max-w-none mb-10 break-words">
            {% if module.contenu %}
            <div class="dict-content text-[#4B5563] whitespace-pre-wrap break-words" data-dict-lang="{{ app.session.get('blog_locale', 'fr') }}">{{ module.contenu|blog_translate|raw }}</div>
            {% else %}
            <p class="text-[#687280]">{{ 'Aucun contenu disponible.'|blog_translate }}</p>
            {% endif %}
        </div>

        {% set activeRessources = module.ressources|filter(ressource => ressource.isActive) %}
        {% set ressources = activeRessources|sort((a, b) => (a.ordre ?? 999999) <=> (b.ordre ?? 999999)) %}
        <div class="mb-8">
            <h2 class="text-xl font-semibold text-[#4B5563] mb-4">{{ 'Ressources du module'|blog_translate }}</h2>
            {% if ressources|length > 0 %}
                <div class="space-y-4">
                    {% for ressource in ressources %}
                        {% set contenuUrl = (ressource.contenu starts with 'http://') or (ressource.contenu starts with 'https://') ? ressource.contenu : asset(ressource.contenu) %}
                        {% set isRemoteResource = (ressource.contenu starts with 'http://') or (ressource.contenu starts with 'https://') %}
                        {% set embedUrl = video_embed_url(contenuUrl) %}
                        <div class="rounded-lg border border-[#E8DED5] p-4 bg-[#FAEDE8]">
                            <div class="flex flex-wrap items-center justify-between gap-2 mb-3">
                                <div class="flex items-center gap-2 min-w-0">
                                    <h3 class="font-medium text-[#4B5563] truncate">{{ ressource.titre|blog_translate }}</h3>
                                    <a href="{{ (ressource.typeRessource == 'url' or embedUrl) ? contenuUrl : path('ressource_download', { id: ressource.id }) }}"
                                       {% if ressource.typeRessource == 'url' or embedUrl %}target="_blank" rel="noopener noreferrer"{% else %}download{% endif %}
                                       class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-[#E8F4FC] text-[#1e3a5f] hover:bg-[#D4E8F8] transition-colors shrink-0"
                                       title="{{ embedUrl ? ('Ouvrir la vidéo'|blog_translate) : ('Télécharger cette ressource'|blog_translate) }}"
                                       aria-label="{{ embedUrl ? ('Ouvrir'|blog_translate) : ('Télécharger'|blog_translate) }} {{ ressource.titre|blog_translate }}">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v12m0 0l4-4m-4 4l-4-4m-5 8h18" />
                                        </svg>
                                    </a>
                                </div>
                                <span class="inline-flex px-2 py-1 text-xs font-medium rounded-full
                                    {% if ressource.typeRessource == 'url' %}bg-[#E8F4FC] text-[#1e3a5f]
                                    {% elseif ressource.typeRessource == 'video' %}bg-[#E8DCF0] text-[#4B3D6B]
                                    {% else %}bg-[#D4E5D0] text-[#4B5563]{% endif %}">
                                    {{ ressource.typeRessource|upper }}
                                </span>
                            </div>

                            {% if ressource.typeRessource == 'url' %}
                                <a href="{{ contenuUrl }}" target="_blank" rel="noopener noreferrer"
                                   class="inline-flex items-center gap-2 text-[#A7C7E7] hover:text-[#B8D4ED] font-medium text-sm">
                                    {{ 'Ouvrir la ressource'|blog_translate }}
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H18m0 0v4.5M18 6l-7.5 7.5M6 10.5V18h7.5" />
                                    </svg>
                                </a>
                            {% elseif ressource.typeRessource == 'video' %}
                                {% if embedUrl %}
                                    <div class="aspect-video rounded-lg overflow-hidden border border-[#E8DED5] bg-black/5">
                                        <iframe src="{{ embedUrl }}" class="w-full h-full" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy" title="{{ ressource.titre|blog_translate }}"></iframe>
                                    </div>
                                {% else %}
                                    <video controls preload="metadata" class="w-full rounded-lg border border-[#E8DED5] bg-black/5">
                                        <source src="{{ contenuUrl }}">
                                        Votre navigateur ne supporte pas la lecture vidéo.
                                    </video>
                                {% endif %}
                            {% elseif ressource.typeRessource == 'audio' %}
                                <audio controls preload="metadata" class="w-full">
                                    <source src="{{ contenuUrl }}">
                                    Votre navigateur ne supporte pas la lecture audio.
                                </audio>
                            {% else %}
                                <p class="text-sm text-[#687280]">{{ 'Type de ressource non supporté.'|blog_translate }}</p>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <p class="text-[#687280]">{{ 'Aucune ressource active pour ce module.'|blog_translate }}</p>
            {% endif %}
        </div>

        {# Barre d'icônes (favoris, ajouter, repost, partager) - au-dessus du lien En savoir plus #}
        {% if app.user %}
                {% set hasFormErrors = articleForm is defined and articleForm and not articleForm.vars.valid and articleForm.vars.submitted %}
                {% set showArticleForm = articleForm is defined and articleForm and (articleForm.vars.submitted or hasFormErrors) %}
                <div class="flex justify-center my-6">
                    <div class="module-actions-float inline-flex items-center gap-1 bg-[#FDF8F5] rounded-full shadow-xl border border-[#E8DED5] px-3 py-2.5">
                        <button type="button"
                                id="module-heart-btn"
                                class="inline-flex items-center justify-center w-10 h-10 rounded-full transition-colors {{ isModuleSaved is defined and isModuleSaved ? 'bg-[#BE185D] text-white' : 'bg-[#FCE7F3] text-[#BE185D]' }} hover:bg-[#FBCFE8]"
                                title="{{ isModuleSaved is defined and isModuleSaved ? 'Retirer des favoris' : 'Enregistrer le module' }}"
                                data-module-id="{{ module.id }}"
                                data-saved="{{ isModuleSaved is defined and isModuleSaved ? '1' : '0' }}"
                                data-toggle-url="{{ path('favoris_module_toggle', {id: module.id}) }}"
                                data-csrf="{{ csrf_token('toggle_module_favori_' ~ module.id) }}">
                            <svg class="w-8 h-8 shrink-0" fill="{{ isModuleSaved is defined and isModuleSaved ? 'currentColor' : 'none' }}" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
                            </svg>
                        </button>
                        <button type="button"
                                id="toggle-article-form"
                                class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#E8F4FC] text-[#1e3a5f] hover:bg-[#D4E8F8] transition-colors"
                                aria-expanded="{{ showArticleForm ? 'true' : 'false' }}"
                                aria-controls="article-form-panel"
                                title="Ajouter un article">
                            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14m-7-7h14" />
                            </svg>
                        </button>
                        <button type="button" id="repost-module" class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#E8F4FC] text-[#1e3a5f] hover:bg-[#D4E8F8] transition-colors" title="Copier le lien public" data-public-url="{{ url('module_public', { id: module.id }) }}">
                            <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M17 1l4 4-4 4M3 11V9a4 4 0 014-4h14M7 23l-4-4 4-4M21 13v2a4 4 0 01-4 4H3" />
                            </svg>
                        </button>
                        <button type="button"
                                id="share-module"
                                class="inline-flex items-center justify-center w-10 h-10 rounded-full bg-[#D4E5D0] text-[#4B5563] hover:bg-[#C4DFBF] transition-colors"
                                title="Partager"
                                data-share-url="{{ url('module_public', { id: module.id }) }}"
                                data-share-title="{{ module.titre|blog_translate }}"
                                data-share-text="{{ 'Je vous partage ce module sur AutiCare.'|blog_translate }}">
                            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.1">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 8.25L19.5 12m0 0L15 15.75M19.5 12H9.75c-2.9 0-5.25 2.35-5.25 5.25" />
                            </svg>
                        </button>
                    </div>
                </div>
        {% endif %}

        {# Lien Wikipedia - En savoir plus sur le module #}
        <div class="mt-4">
            <a href="{{ wikiUrl|default('https://fr.wikipedia.org/wiki/Autisme') }}"
               target="_blank"
               rel="noopener noreferrer"
               class="inline-flex items-center gap-2 text-[#1e3a5f] hover:text-[#0369A1] hover:underline font-medium text-sm transition-colors">
                {{ 'En savoir plus sur ce module'|blog_translate }}
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H18m0 0v4.5M18 6l-7.5 7.5M6 10.5V18h7.5" />
                </svg>
            </a>
        </div>

        {# Toast notification #}
        <div id="toast-notification" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 hidden">
            <div class="px-4 py-2.5 rounded-lg bg-[#4B5563] text-white text-sm font-medium shadow-lg">
                <span id="toast-message"></span>
            </div>
        </div>

        <div id="module-share-modal" class="fixed inset-0 z-[60] hidden">
            <div id="module-share-backdrop" class="absolute inset-0 bg-black/45"></div>
            <div class="relative z-10 h-full w-full flex items-center justify-center p-4">
                <div class="w-full max-w-md rounded-2xl bg-[#FDF8F5] border border-[#E8DED5] shadow-xl overflow-hidden">
                    <div class="flex items-center justify-between px-4 py-3 border-b border-[#E8DED5]">
                        <h3 class="text-lg font-semibold text-[#4B5563]">{{ 'Partager le module'|blog_translate }}</h3>
                        <button type="button" id="close-module-share" class="px-2 py-1 rounded-lg text-[#687280] hover:bg-[#F5F1EB]">{{ 'Fermer'|blog_translate }}</button>
                    </div>

                    <div class="p-4 space-y-4">
                        <div class="rounded-xl border border-[#E8DED5] bg-[#FAEDE8] p-3">
                            {% if module.image %}
                                <img src="{{ asset(module.image) }}" alt="{{ module.titre|blog_translate }}" class="w-full h-44 object-cover rounded-lg mb-3">
                            {% endif %}
                            <p class="font-semibold text-[#4B5563] line-clamp-2">{{ module.titre|blog_translate }}</p>
                            <p class="text-sm text-[#687280] line-clamp-2 mt-1">{{ (module.description ?: 'Découvrez ce module sur AutiCare.')|blog_translate }}</p>
                        </div>

                        <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
                            <button type="button" id="share-copy-link" class="px-3 py-2.5 rounded-xl bg-[#E8F4FC] text-[#1e3a5f] text-sm font-medium hover:bg-[#D4E8F8]">{{ 'Copier lien'|blog_translate }}</button>
                            <button type="button" id="share-native" class="px-3 py-2.5 rounded-xl bg-[#D4E5D0] text-[#4B5563] text-sm font-medium hover:bg-[#C4DFBF]">{{ 'Partager'|blog_translate }}</button>
                            <button type="button" id="share-facebook" class="px-3 py-2.5 rounded-xl bg-[#E8F4FC] text-[#1e3a5f] text-sm font-medium hover:bg-[#D4E8F8]">Facebook</button>
                            <button type="button" id="share-messenger" class="px-3 py-2.5 rounded-xl bg-[#E8DCF0] text-[#4B3D6B] text-sm font-medium hover:bg-[#DDD0E8]">Messenger</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {% if not app.user %}
        <div class="pt-3 border-t border-[#E8DED5]">
            <div class="bg-[#E8F4FC] border border-[#E8DED5] rounded-lg p-4">
                <p class="text-[#4B5563] mb-2">{{ 'Pour écrire un article, veuillez vous'|blog_translate }} <a href="{{ path('app_login') }}" class="text-[#A7C7E7] hover:text-[#95b8dc] underline">{{ 'connecter'|blog_translate }}</a>.</p>
            </div>
        </div>
        {% endif %}
    </div>
    </div>

    <!-- Colonne droite : Articles publiés pour ce module (cadre de l'article) -->
    <div class="w-full lg:flex-1 lg:min-w-0 order-2 lg:order-2">
    {# Articles publiés #}
    {% set allBlogs = module.blogs %}
    {% set articles = allBlogs|filter(blog => blog.isPublished) %}

    {# Brouillons de l'utilisateur connecté #}
    {% set drafts = [] %}
    {% if app.user %}
        {% set drafts = allBlogs|filter(blog => (not blog.isPublished) and blog.user and blog.user.id == app.user.id) %}
    {% endif %}

    {# Filtre de recherche sur le titre #}
    {% if searchTerm is defined and searchTerm is not empty %}
        {% set articles = articles|filter(blog => blog.titre is not empty and (searchTerm|lower in blog.titre|lower)) %}
        {% if app.user %}
            {% set drafts = drafts|filter(blog => blog.titre is not empty and (searchTerm|lower in blog.titre|lower)) %}
        {% endif %}
    {% endif %}

    {% set hasResults = (articles|length > 0) or (app.user and drafts|length > 0) %}

    {% if hasResults %}
        <div>
            <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-4">
                <h2 class="text-xl font-semibold text-[#4B5563]">{{ 'Articles publiés pour ce module'|blog_translate }}</h2>
                <form method="get" action="{{ path('user_blog_module', { id: module.id }) }}" class="w-full md:w-80">
                    <label for="search-article" class="block text-sm font-medium text-[#687280] mb-1"></label>
                    <div class="relative">
                        <input
                            type="text"
                            id="search-article"
                            name="q"
                            value="{{ searchTerm ?? '' }}"
                            placeholder="{{ 'Tapez un titre d\'article...'|blog_translate }}"
                            class="w-full rounded-lg border border-[#E8DED5] px-3 py-2 pl-9 text-sm text-[#4B5563] placeholder-[#687280] focus:outline-none focus:ring-2 focus:ring-[#A7C7E7] bg-[#FDF8F5]"
                        >
                        <span class="absolute inset-y-0 left-2 flex items-center pointer-events-none text-[#687280]">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M11 18a7 7 0 100-14 7 7 0 000 14z" />
                            </svg>
                        </span>
                    </div>
                </form>
            </div>

            {# Liste des articles publiés #}
            {% if articles|length > 0 %}
            <div class="space-y-4">
                {% for article in articles|sort((a, b) => b.dateCreation <=> a.dateCreation) %}
                    <div class="bg-[#FAE8E3] rounded-xl border border-[#E8DED5] p-6 hover:shadow-md transition-shadow relative">
                        <!-- Icônes d'action fixes dans le coin supérieur droit -->
                        <div class="absolute top-4 right-4 flex gap-1 shrink-0">
                            <a href="{{ path('user_blog_article_download', {'id': article.id}) }}"
                               class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-[#D4E5D0] text-[#4B5563] hover:bg-[#C4DFBF] transition-colors focus:outline focus:ring-2 focus:ring-[#A8BBA3]"
                               title="{{ 'Télécharger l\'article'|blog_translate }}">
                                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M8 12l4 4m0 0l4-4m-4 4V4" />
                                </svg>
                            </a>
                            {% if app.user and (article.user and article.user.id == app.user.id or is_granted('ROLE_ADMIN')) %}
                                <button type="button"
                                        class="article-spell-check-btn inline-flex items-center justify-center w-6 h-6 rounded-full bg-[#D4E5D0] text-[#4B5563] hover:bg-[#C4DFBF] transition-colors focus:outline focus:ring-2 focus:ring-[#A8BBA3]"
                                        title="{{ 'Vérifier l\'orthographe'|blog_translate }}"
                                        data-article-id="{{ article.id }}"
                                        data-article-csrf="{{ csrf_token('apply_spell_check_' ~ article.id) }}"
                                        data-article-titre="{{ article.titre|e('html_attr') }}"
                                        data-article-contenu="{{ article.contenu|e('html_attr') }}">
                                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                </button>
                                <a href="{{ path('user_blog_edit_article', {'id': article.id, 'moduleId': module.id}) }}" class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-[#E8F4FC] text-[#1e3a5f] hover:bg-[#D4E8F8] transition-colors focus:outline focus:ring-2 focus:ring-[#93C5FD]" title="{{ 'Modifier l\'article'|blog_translate }}">
                                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                    </svg>
                                </a>
                                <form method="post" action="{{ path('user_blog_delete_article', {'id': article.id, 'moduleId': module.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet article ?');" class="inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ article.id) }}">
                                    <button type="submit" class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-[#FEE2E2] text-[#DC2626] hover:bg-[#FECACA] transition-colors focus:outline focus:ring-2 focus:ring-[#FCA5A5]" title="{{ 'Supprimer l\'article'|blog_translate }}">
                                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                        </svg>
                                    </button>
                                </form>
                            {% endif %}
                        </div>

                        <div class="pr-32 min-w-0">
                            <div class="flex items-start gap-3 mb-3">
                                <!-- Image de l'article -->
                                {% if article.image %}
                                    <div class="flex-shrink-0">
                                        <img src="{{ asset(article.image) }}" alt="{{ article.titre|blog_translate }}" class="w-20 h-20 object-cover rounded-lg">
                                    </div>
                                {% endif %}
                                <div class="flex-1 min-w-0">
                                    <h3 class="text-lg font-semibold text-[#4B5563] mb-2 break-words">{{ article.titre|blog_translate }}</h3>
                                    <div class="flex items-center gap-4 text-sm text-[#687280] mb-3">
                                        <span class="inline-flex px-2 py-1 text-xs font-medium rounded-full
                                            {% if article.type == 'recommandation' %}bg-[#E8F4FC] text-[#1e3a5f]
                                            {% elseif article.type == 'plainte' %}bg-[#FAEDE8] text-[#4B5563]
                                            {% elseif article.type == 'question' %}bg-[#D4E5D0] text-[#4B5563]
                                            {% else %}bg-[#F5F1EB] text-[#4B5563]{% endif %}">
                                            {{ article.type|blog_translate_type }}
                                        </span>
                                        {% if article.isUrgent %}
                                            <span class="inline-flex px-2 py-1 text-xs font-medium rounded-full bg-[#FAEDE8] text-[#4B5563]">{{ 'Urgent'|blog_translate }}</span>
                                        {% endif %}
                                        <span>{{ 'Par'|blog_translate }} {{ article.user ? article.user.email : ('Anonyme'|blog_translate) }}</span>
                                        <span>{{ 'Le'|blog_translate }} {{ article.dateCreation|date('d/m/Y à H:i') }}</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="prose prose-[#4B5563] max-w-none">
                            <div class="dict-content text-[#4B5563] break-words whitespace-pre-wrap" data-dict-lang="{{ app.session.get('blog_locale', 'fr') }}">{{ article.contenu|blog_translate|raw }}</div>
                        </div>

                        {# --- Barre d'interaction de l'article --- #}
                        <div class="mt-4 pt-3 border-t border-[#E8DED5] flex items-center gap-4 text-sm text-[#687280]">
                            {% set isOwnArticle = app.user and article.user and article.user.id == app.user.id %}
                            {% set isArticleSaved = article.id in (savedArticleIds|default([])) %}

                            {% if app.user and not isOwnArticle %}
                                <button type="button"
                                        class="article-favorite-btn inline-flex items-center justify-center w-12 h-12 rounded-full transition-colors {{ isArticleSaved ? 'bg-[#BE185D] text-white' : 'bg-[#FCE7F3] text-[#BE185D]' }} hover:bg-[#FBCFE8]"
                                        title="{{ isArticleSaved ? 'Retirer des favoris' : 'Ajouter aux favoris' }}"
                                        data-article-id="{{ article.id }}"
                                        data-saved="{{ isArticleSaved ? '1' : '0' }}"
                                        data-toggle-url="{{ path('favoris_article_toggle', {id: article.id}) }}"
                                        data-csrf="{{ csrf_token('toggle_article_favori_' ~ article.id) }}"
                                        data-login-url="{{ path('app_login') }}">
                                    <svg class="w-7 h-7 shrink-0" fill="{{ isArticleSaved ? 'currentColor' : 'none' }}" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
                                    </svg>
                                </button>
                            {% endif %}

                            {# Commentaire - afficher inline au clic #}
                            <button type="button"
                                    class="comment-toggle-btn inline-flex items-center gap-2 text-[#0369A1] focus:outline focus:ring-2 focus:ring-[#A7C7E7] rounded-full"
                                    data-article-id="{{ article.id }}"
                                    title="Voir les commentaires">
                                <span class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-[#E8F4FC] text-[#1e3a5f] hover:bg-[#D4E8F8] transition-colors">
                                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM21 12c0 4.97-4.03 9-9 9a9.863 9.863 0 01-4.255-.949L3 21l1.395-3.72A8.971 8.971 0 013 12c0-4.97 4.03-9 9-9s9 4.03 9 9z" />
                                    </svg>
                                </span>
                            </button>

                            {# Repost article #}
                            <button type="button" class="article-repost-btn inline-flex items-center justify-center w-12 h-12 rounded-full bg-[#E0F2FE] text-[#0369A1] hover:bg-[#BAE6FD] transition-colors" data-url="{{ url('user_blog_show_article', {id: article.id}) }}">
                                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 1l4 4-4 4M3 11V9a4 4 0 014-4h14M7 23l-4-4 4-4M21 13v2a4 4 0 01-4 4H3" />
                                </svg>
                            </button>

                            {# Partage article #}
                            <button type="button" class="article-share-btn inline-flex items-center justify-center w-12 h-12 rounded-full bg-[#DCFCE7] text-[#15803D] hover:bg-[#BBF7D0] transition-colors" data-url="{{ url('user_blog_show_article', {id: article.id}) }}" data-title="{{ article.titre|blog_translate }}">
                                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 8.25L19.5 12m0 0L15 15.75M19.5 12H9.75c-2.9 0-5.25 2.35-5.25 5.25" />
                                </svg>
                            </button>
                        </div>

                        {# Panneau commentaires inline (style Substack) - affiché au clic sur l'icône #}
                        <div id="comments-panel-{{ article.id }}" class="comment-panel hidden" data-article-id="{{ article.id }}">
                            {{ include('front/blog/_commentaire_inline.html.twig', {
                                article: article,
                                commentaireForm: commentaireForms[article.id]|default(null),
                                redirectUrl: path('user_blog_module', {id: module.id}) ~ '?showComments=' ~ article.id
                            }) }}
                        </div>
                    </div>
                {% endfor %}
            </div>
            {% endif %}

            {# Section des brouillons de l'utilisateur connecté #}
            {% if app.user and drafts|length > 0 %}
                <div class="mt-8 pt-6 border-t border-[#E8DED5]">
                    <h3 class="text-lg font-semibold text-[#4B5563] mb-4">{{ 'Vos brouillons'|blog_translate }}</h3>
                    <div class="space-y-4">
                        {% for article in drafts|sort((a, b) => b.dateCreation <=> a.dateCreation) %}
                            <div class="bg-[#FAE8E3] rounded-xl border border-dashed border-[#E8DED5] p-6 hover:shadow-sm transition-shadow relative">
                                <div class="absolute top-4 right-4 flex gap-1.5 shrink-0">
                                    <span class="inline-flex items-center justify-center px-2 py-1 rounded-full bg-yellow-50 text-yellow-700 text-xs font-medium">
                                        {{ 'Brouillon'|blog_translate }}
                                    </span>
                                    <a href="{{ path('user_blog_edit_article', {'id': article.id, 'moduleId': module.id}) }}" class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-[#E8F4FC] text-[#1e3a5f] hover:bg-[#D4E8F8] transition-colors focus:outline focus:ring-2 focus:ring-[#93C5FD]" title="{{ 'Modifier le brouillon'|blog_translate }}">
                                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                        </svg>
                                    </a>
                                    <form method="post" action="{{ path('user_blog_delete_article', {'id': article.id, 'moduleId': module.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce brouillon ?');" class="inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ article.id) }}">
                                        <button type="submit" class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-[#FEE2E2] text-[#DC2626] hover:bg-[#FECACA] transition-colors focus:outline focus:ring-2 focus:ring-[#FCA5A5]" title="{{ 'Supprimer le brouillon'|blog_translate }}">
                                            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                            </svg>
                                        </button>
                                    </form>
                                </div>

                                <div class="pr-28 min-w-0">
                                    <div class="flex items-start gap-3 mb-3">
                                        {% if article.image %}
                                            <div class="flex-shrink-0">
                                                <img src="{{ asset(article.image) }}" alt="{{ article.titre|blog_translate }}" class="w-20 h-20 object-cover rounded-lg">
                                            </div>
                                        {% endif %}
                                        <div class="flex-1 min-w-0">
                                            <h4 class="text-lg font-semibold text-[#4B5563] mb-1 break-words">{{ article.titre|blog_translate }}</h4>
                                            <p class="text-sm text-[#687280] mb-2">{{ 'Créé le'|blog_translate }} {{ article.dateCreation|date('d/m/Y à H:i') }}</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="prose prose-[#4B5563] max-w-none">
                                    <div class="dict-content text-[#4B5563] break-words whitespace-pre-wrap" data-dict-lang="{{ app.session.get('blog_locale', 'fr') }}">{{ article.contenu|blog_translate|raw }}</div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        </div>
    {% else %}
        <div class="bg-white rounded-xl border border-[#E8DED5] p-8 text-center">
            {% if searchTerm is defined and searchTerm is not empty %}
                <p class="text-[#687280] mb-2">{{ 'Aucun article (publié ou brouillon) ne correspond au titre'|blog_translate }} « {{ searchTerm }} ».</p>
                <a href="{{ path('user_blog_module', { id: module.id }) }}" class="inline-flex items-center gap-2 text-sm text-[#A7C7E7] hover:text-[#B8D4ED] font-medium">
                    {{ 'Réinitialiser la recherche'|blog_translate }}
                </a>
            {% else %}
                <p class="text-[#687280] mb-4">{{ 'Aucun article publié pour ce module.'|blog_translate }}</p>
                <p class="text-sm text-[#687280]">{{ 'Soyez le premier à écrire un article !'|blog_translate }}</p>
            {% endif %}
        </div>
    {% endif %}

    {% if app.user %}
    {# Formulaire nouvel article - affiché à droite sous les articles au clic sur l'icône + #}
    <div id="article-form-panel" class="mt-6 {{ showArticleForm is defined and showArticleForm ? '' : 'hidden' }}">
        <div class="rounded-xl border border-[#E8DED5] bg-[#FAEDE8] p-4 md:p-5">
            <h3 class="text-lg font-semibold text-[#4B5563] mb-4">{{ 'Nouvel article'|blog_translate }}</h3>
            {% if articleForm is defined and articleForm %}
            {% form_theme articleForm 'form/form_div_layout.html.twig' %}
                {{ form_start(articleForm, {'attr': {'class': 'space-y-4', 'novalidate': 'novalidate', 'id': 'article-form', 'enctype': 'multipart/form-data'}, 'label_attr': {'class': 'block text-[#4B5563] font-medium mb-1'}}) }}
                    {{ form_errors(articleForm) }}
                    <div class="p-4 rounded-xl border border-[#CDB4DB] bg-[#E8DCF0]/50 space-y-4">
                        <h4 class="text-base font-semibold text-[#4B3D6B]">{{ 'Générer avec l\'IA'|blog_translate }}</h4>
                        <p class="text-sm text-[#687280]">{{ 'Saisissez un prompt et sélectionnez un type pour que l\'IA génère le titre et le contenu.'|blog_translate }}</p>
                        <div>
                            <label for="article-ai-prompt" class="block text-[#4B5563] font-medium mb-1 text-sm">{{ 'Prompt / Sujet'|blog_translate }}</label>
                            <div class="relative mt-1">
                                <textarea id="article-ai-prompt" rows="2" placeholder="{{ 'Ex. Témoignage sur les progrès avec les pictogrammes...'|blog_translate }}"
                                          class="block w-full rounded-lg border border-[#E8DED5] bg-[#FDF8F5] px-3 py-2 pr-12 text-sm text-[#4B5563] focus:outline focus:ring-2 focus:ring-[#CDB4DB]"></textarea>
                                <button type="button"
                                        class="dictation-btn absolute right-3 top-3 w-10 h-10 flex items-center justify-center rounded-lg
                                               bg-[#F5F1EB] text-[#687280] hover:bg-[#E8DED5] focus:outline focus:ring-2 focus:ring-[#CDB4DB]
                                               transition-colors"
                                        data-target="article-ai-prompt"
                                        title="{{ 'Dictée vocale'|blog_translate }}"
                                        aria-label="{{ 'Dictée vocale pour le prompt'|blog_translate }}">
                                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" />
                                    </svg>
                                </button>
                            </div>
                            <p class="dictation-status mt-1 text-sm text-[#687280] hidden" data-for="article-ai-prompt"></p>
                        </div>
                        <div>
                            <label for="article-ai-type" class="block text-[#4B5563] font-medium mb-1 text-sm">{{ 'Type d\'article'|blog_translate }}</label>
                            <select id="article-ai-type" class="mt-1 block w-full rounded-lg border border-[#E8DED5] bg-[#FDF8F5] px-3 py-2 text-sm text-[#4B5563] focus:outline focus:ring-2 focus:ring-[#CDB4DB]">
                                <option value="">-- {{ 'Choisir'|blog_translate }} --</option>
                                <option value="recommandation">Recommandation</option>
                                <option value="plainte">Plainte</option>
                                <option value="question">Question</option>
                                <option value="experience">Expérience</option>
                            </select>
                        </div>
                        <button type="button" id="article-ai-generate-btn"
                                class="px-3 py-2 rounded-lg bg-[#CDB4DB] text-white text-sm font-medium hover:bg-[#C4A8D5] focus:outline focus:ring-2 focus:ring-[#CDB4DB]">
                            {{ 'Générer titre et contenu'|blog_translate }}
                        </button>
                        <p id="article-ai-error-msg" class="text-sm text-red-600 hidden"></p>
                    </div>
                    <div>
                        {{ form_label(articleForm.titre) }}
                        <div class="relative mt-1">
                            {{ form_widget(articleForm.titre) }}
                            <button type="button"
                                    class="spell-check-btn absolute right-14 top-1/2 -translate-y-1/2 w-10 h-10 flex items-center justify-center rounded-lg
                                           bg-[#D4E5D0] text-[#4B5563] hover:bg-[#C4DFBF] focus:outline focus:ring-2 focus:ring-[#A8BBA3]
                                           transition-colors"
                                    data-target="blog_titre"
                                    title="{{ 'Vérifier l\'orthographe'|blog_translate }}"
                                    aria-label="{{ 'Vérifier l\'orthographe pour le titre'|blog_translate }}">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                </svg>
                            </button>
                            <button type="button"
                                    class="dictation-btn absolute right-3 top-1/2 -translate-y-1/2 w-10 h-10 flex items-center justify-center rounded-lg
                                           bg-[#F5F1EB] text-[#687280] hover:bg-[#E8DED5] focus:outline focus:ring-2 focus:ring-[#A7C7E7]
                                           transition-colors"
                                    data-target="blog_titre"
                                    title="Dictée vocale"
                                    aria-label="Dictée vocale pour le titre">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" />
                                </svg>
                            </button>
                        </div>
                        <div class="spell-check-result mt-1 hidden" data-for="blog_titre"></div>
                        <p class="dictation-status mt-1 text-sm text-[#687280] hidden" data-for="blog_titre"></p>
                        {% if articleForm.titre.vars.errors|length > 0 %}
                            <div class="mt-1 text-sm font-medium text-red-600" role="alert">{{ articleForm.titre.vars.errors|first.message }}</div>
                        {% endif %}
                    </div>
                    <div>
                        {{ form_label(articleForm.type) }}
                        {{ form_widget(articleForm.type) }}
                        {% if articleForm.type.vars.errors|length > 0 %}
                            <div class="mt-1 text-sm font-medium text-red-600" role="alert">{{ articleForm.type.vars.errors|first.message }}</div>
                        {% endif %}
                    </div>
                    <div>
                        {{ form_label(articleForm.contenu) }}
                        <div class="relative mt-1">
                            {{ form_widget(articleForm.contenu) }}
                            <button type="button"
                                    class="spell-check-btn absolute right-14 top-3 w-10 h-10 flex items-center justify-center rounded-lg
                                           bg-[#D4E5D0] text-[#4B5563] hover:bg-[#C4DFBF] focus:outline focus:ring-2 focus:ring-[#A8BBA3]
                                           transition-colors"
                                    data-target="blog_contenu"
                                    title="{{ 'Vérifier l\'orthographe'|blog_translate }}"
                                    aria-label="{{ 'Vérifier l\'orthographe pour le contenu'|blog_translate }}">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                </svg>
                            </button>
                            <button type="button"
                                    class="dictation-btn absolute right-3 top-3 w-10 h-10 flex items-center justify-center rounded-lg
                                           bg-[#F5F1EB] text-[#687280] hover:bg-[#E8DED5] focus:outline focus:ring-2 focus:ring-[#A7C7E7]
                                           transition-colors"
                                    data-target="blog_contenu"
                                    title="Dictée vocale"
                                    aria-label="Dictée vocale pour le contenu">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" />
                                </svg>
                            </button>
                        </div>
                        <div class="spell-check-result mt-1 hidden" data-for="blog_contenu"></div>
                        <p class="dictation-status mt-1 text-sm text-[#687280] hidden" data-for="blog_contenu"></p>
                        {% if articleForm.contenu.vars.errors|length > 0 %}
                            <div class="mt-1 text-sm font-medium text-red-600" role="alert">{{ articleForm.contenu.vars.errors|first.message }}</div>
                        {% endif %}
                    </div>
                    <div class="space-y-4">
                        <label class="block text-[#4B5563] font-medium mb-2">{{ 'Image de l\'article'|blog_translate }}</label>
                        <div class="flex gap-4 mb-2">
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="article_image_source" value="upload" checked
                                       class="rounded border-[#E8DED5] text-[#A7C7E7] focus:ring-[#A7C7E7]">
                                <span class="text-[#4B5563]">{{ 'Uploader un fichier'|blog_translate }}</span>
                            </label>
                            <label class="flex items-center gap-2 cursor-pointer">
                                <input type="radio" name="article_image_source" value="pexels"
                                       class="rounded border-[#E8DED5] text-[#A7C7E7] focus:ring-[#A7C7E7]">
                                <span class="text-[#4B5563]">{{ 'Rechercher sur Pexels'|blog_translate }}</span>
                            </label>
                        </div>
                        <div id="article-image-upload-zone" class="p-3 rounded-lg border border-[#E8DED5] bg-[#FDF8F5]">
                            {{ form_widget(articleForm.image) }}
                            {% if articleForm.image.vars.errors|length > 0 %}
                                <div class="mt-1 text-sm font-medium text-red-600" role="alert">{{ articleForm.image.vars.errors|first.message }}</div>
                            {% endif %}
                        </div>
                        <div id="article-pexels-zone" class="hidden space-y-3 p-3 rounded-lg border border-[#E8DED5] bg-[#FAEDE8]">
                            <div class="flex gap-2">
                                <input type="text" id="article-pexels-query" placeholder="{{ 'Ex. autisme, famille...'|blog_translate }}"
                                       class="flex-1 rounded-lg border border-[#E8DED5] px-3 py-2 text-sm text-[#4B5563] focus:outline focus:ring-2 focus:ring-[#A7C7E7]">
                                <button type="button" id="article-pexels-search-btn"
                                        class="px-3 py-2 rounded-lg bg-[#A7C7E7] text-white text-sm font-medium hover:bg-[#B8D4ED]">
                                    {{ 'Rechercher'|blog_translate }}
                                </button>
                            </div>
                            <div id="article-pexels-results" class="grid grid-cols-2 sm:grid-cols-4 gap-2"></div>
                            <p id="article-pexels-selected-msg" class="text-sm text-[#A8BBA3] hidden"></p>
                        </div>
                        {{ form_widget(articleForm.pexels_image_url) }}
                    </div>
                    {# Section Génération hashtags #}
                    <div class="p-3 rounded-xl border border-violet-200 bg-violet-50/50 space-y-2">
                        <h4 class="text-sm font-semibold text-violet-800">{{ 'Générer des hashtags'|blog_translate }}</h4>
                        <p class="text-xs text-[#6B7280]">{{ 'Génère des hashtags à partir du titre. Ils seront ajoutés à la fin du contenu.'|blog_translate }}</p>
                        <div class="flex flex-wrap items-center gap-2">
                            <button type="button" id="article-form-generate-hashtags-btn"
                                    class="px-3 py-2 rounded-lg bg-violet-600 text-white text-sm font-medium hover:bg-violet-700 focus:outline focus:ring-2 focus:ring-violet-500">
                                {{ 'Générer des hashtags'|blog_translate }}
                            </button>
                        </div>
                        <div id="article-form-hashtags-zone" class="hidden mt-2 p-2 rounded-lg bg-white border border-violet-200">
                            <p class="text-xs text-[#4B5563] mb-1">{{ 'Hashtags générés :'|blog_translate }}</p>
                            <p id="article-form-hashtags-result" class="text-sm text-[#4B5563] font-medium break-words mb-1"></p>
                            <button type="button" id="article-form-hashtags-insert-btn"
                                    class="px-2 py-1 rounded-lg bg-violet-600 text-white text-xs font-medium hover:bg-violet-700">
                                {{ 'Insérer à la fin du contenu'|blog_translate }}
                            </button>
                        </div>
                        <p id="article-form-hashtags-error" class="text-xs text-red-600 hidden"></p>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                        <div class="flex items-center gap-2">{{ form_widget(articleForm.isPublished) }}{{ form_label(articleForm.isPublished) }}</div>
                        <div class="flex items-center gap-2">{{ form_widget(articleForm.isUrgent) }}{{ form_label(articleForm.isUrgent) }}</div>
                        <div class="flex items-center gap-2">{{ form_widget(articleForm.isVisible) }}{{ form_label(articleForm.isVisible) }}</div>
                    </div>
                    <div class="flex items-center gap-2 pt-2">
                        <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-[#A7C7E7] text-white font-medium hover:bg-[#B8D4ED]">
                            {{ 'Publier'|blog_translate }}
                        </button>
                        <button type="button" id="cancel-article-form" class="px-4 py-2 rounded-lg border border-[#E8DED5] text-[#687280] hover:bg-[#F5F1EB]">
                            {{ 'Annuler'|blog_translate }}
                        </button>
                    </div>
                {{ form_end(articleForm) }}
            {% endif %}
        </div>
    </div>
    {% endif %}
    </div>
    </div>

    {# Modal Vérification orthographique (articles publiés) #}
    <div id="article-spell-check-modal" class="fixed inset-0 z-[9999] hidden">
        <div id="article-spell-check-backdrop" class="absolute inset-0 bg-black/45"></div>
        <div class="relative z-10 h-full w-full flex items-center justify-center p-4">
            <div class="w-full max-w-lg rounded-2xl bg-white border border-[#E8DED5] shadow-xl overflow-hidden">
                <div class="flex items-center justify-between px-4 py-3 border-b border-[#E8DED5]">
                    <h3 class="text-lg font-semibold text-amber-800">{{ 'Vérification orthographique'|blog_translate }}</h3>
                    <button type="button" id="close-article-spell-check" class="px-2 py-1 rounded-lg text-[#687280] hover:bg-[#F3F4F6]">{{ 'Fermer'|blog_translate }}</button>
                </div>
                <div class="p-4">
                    <div id="article-spell-check-loading" class="hidden flex items-center justify-center gap-2 py-8 text-amber-600">
                        <svg class="animate-spin w-6 h-6" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                        <span>{{ 'Vérification en cours...'|blog_translate }}</span>
                    </div>
                    <div id="article-spell-check-result" class="hidden"></div>
                </div>
            </div>
        </div>
    </div>

    {# Modal Résumé IA - style harmonisé avec le reste de la page #}
    <div id="module-summary-modal" class="fixed inset-0 z-[9999] hidden">
        <div id="module-summary-backdrop" class="absolute inset-0 bg-black/45"></div>
        <div class="relative z-10 h-full w-full flex items-center justify-center p-4">
            <div class="w-full max-w-xl rounded-2xl bg-[#FDF8F5] border border-[#E8DED5] shadow-xl overflow-hidden">
                <div class="flex items-center justify-between px-4 py-3 border-b border-[#E8DED5] bg-[#E8DCF0]/50">
                    <h3 class="text-lg font-semibold text-[#4B3D6B]">{{ 'Résumé IA'|blog_translate }}</h3>
                    <button type="button" id="close-module-summary" class="px-3 py-1.5 rounded-lg text-[#4B3D6B] font-medium hover:bg-[#DDD0E8] focus:outline focus:ring-2 focus:ring-[#CDB4DB]">{{ 'Fermer'|blog_translate }}</button>
                </div>

                <div class="p-4 min-w-0">
                    <div id="module-summary-loading" class="hidden flex items-center justify-center gap-2 py-8 text-[#4B3D6B]">
                        <svg class="animate-spin w-6 h-6 shrink-0" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                        <span>{{ 'Génération du résumé...'|blog_translate }}</span>
                    </div>
                    <div id="module-summary-content" class="hidden">
                        <div class="flex items-center gap-2 mb-3">
                            <button type="button" id="module-summary-tts-btn"
                                class="summary-tts-btn inline-flex items-center justify-center w-9 h-9 rounded-lg bg-[#E8DCF0] text-[#4B3D6B] hover:bg-[#DDD0E8] focus:outline focus:ring-2 focus:ring-[#CDB4DB] shrink-0"
                                title="{{ 'Écouter le résumé'|blog_translate }}"
                                aria-label="{{ 'Écouter le résumé'|blog_translate }}">
                                <svg class="summary-tts-icon-play w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M8 5v14l11-7z"/>
                                </svg>
                                <svg class="summary-tts-icon-pause w-5 h-5" fill="currentColor" viewBox="0 0 24 24" style="display:none">
                                    <path d="M6 4h4v16H6zm8 0h4v16h-4z"/>
                                </svg>
                            </button>
                            <span class="text-sm text-[#687280]">{{ 'Écouter le résumé'|blog_translate }}</span>
                        </div>
                        <p id="module-summary-text" class="text-[#4B5563] text-sm font-semibold leading-relaxed break-words min-w-0"></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</article>
<script>
function initModulePage() {

    /* ====== Ouvrir le panneau commentaires si on revient après ajout ====== */
    var urlParams = new URLSearchParams(window.location.search);
    var showComments = urlParams.get('showComments');
    if (showComments) {
        var panel = document.getElementById('comments-panel-' + showComments);
        if (panel) panel.classList.remove('hidden');
    }

    /* ====== Toast helper ====== */
    function showToast(message, duration) {
        duration = duration || 2500;
        var toastEl = document.getElementById('toast-notification');
        var msgEl = document.getElementById('toast-message');
        if (!toastEl || !msgEl) return;
        msgEl.textContent = message;
        toastEl.classList.remove('hidden');
        clearTimeout(toastEl._timer);
        toastEl._timer = setTimeout(function () {
            toastEl.classList.add('hidden');
        }, duration);
    }

    /* ====== Article form toggle ====== */
    var toggleBtn = document.getElementById('toggle-article-form');
    var cancelBtn = document.getElementById('cancel-article-form');
    var panel = document.getElementById('article-form-panel');

    if (toggleBtn && panel) {
        toggleBtn.addEventListener('click', function () {
            var isHidden = panel.classList.contains('hidden');
            panel.classList.toggle('hidden');
            toggleBtn.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
            if (isHidden) {
                panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        });
        if (cancelBtn) {
            cancelBtn.addEventListener('click', function () {
                panel.classList.add('hidden');
                toggleBtn.setAttribute('aria-expanded', 'false');
            });
        }
    }

    /* ====== Scroll to article form when validation errors ====== */
    var articleFormEl = document.getElementById('article-form');
    if (articleFormEl && (articleFormEl.querySelector('.text-red-600, .border-red-500, .text-red-700') || articleFormEl.querySelector('[role="alert"]'))) {
        document.getElementById('article-form-panel').classList.remove('hidden');
        if (toggleBtn) toggleBtn.setAttribute('aria-expanded', 'true');
        articleFormEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    /* ====== Article form : Upload / Pexels image ====== */
    (function() {
        var uploadRadio = document.querySelector('input[name="article_image_source"][value="upload"]');
        var pexelsRadio = document.querySelector('input[name="article_image_source"][value="pexels"]');
        var uploadZone = document.getElementById('article-image-upload-zone');
        var pexelsZone = document.getElementById('article-pexels-zone');
        var imageInput = document.querySelector('#article-image-upload-zone input[type="file"]');
        var pexelsUrlInput = document.querySelector('#article-form input[name*="pexels_image_url"]');
        var pexelsQuery = document.getElementById('article-pexels-query');
        var pexelsSearchBtn = document.getElementById('article-pexels-search-btn');
        var pexelsResults = document.getElementById('article-pexels-results');
        var pexelsSelectedMsg = document.getElementById('article-pexels-selected-msg');
        var pexelsSearchUrl = '{{ path("pexels_search") }}';

        var articleAiPrompt = document.getElementById('article-ai-prompt');
        var articleAiType = document.getElementById('article-ai-type');
        var articleAiGenerateBtn = document.getElementById('article-ai-generate-btn');
        var articleAiErrorMsg = document.getElementById('article-ai-error-msg');
        var articleTitreInput = document.querySelector('#article-form input[name*="[titre]"]');
        var articleTypeSelect = document.querySelector('#article-form select[name*="[type]"]');
        var articleContenuInput = document.querySelector('#article-form textarea[name*="[contenu]"]');
        var articleGenerateUrl = '{{ path("user_blog_generate") }}';

        if (articleAiGenerateBtn && articleTitreInput && articleContenuInput) {
            articleAiGenerateBtn.addEventListener('click', function() {
                var prompt = articleAiPrompt ? articleAiPrompt.value.trim() : '';
                var type = articleAiType ? articleAiType.value : '';
                if (!prompt) {
                    if (articleAiErrorMsg) {
                        articleAiErrorMsg.textContent = 'Veuillez saisir un prompt.';
                        articleAiErrorMsg.classList.remove('hidden');
                    }
                    return;
                }
                if (articleAiErrorMsg) articleAiErrorMsg.classList.add('hidden');
                articleAiGenerateBtn.disabled = true;
                articleAiGenerateBtn.textContent = 'Génération...';
                var formData = new FormData();
                formData.append('prompt', prompt);
                formData.append('type', type || '');
                fetch(articleGenerateUrl, {
                    method: 'POST',
                    body: formData,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data.error) {
                        if (articleAiErrorMsg) {
                            articleAiErrorMsg.textContent = data.error;
                            articleAiErrorMsg.classList.remove('hidden');
                        }
                    } else {
                        if (data.titre) articleTitreInput.value = data.titre;
                        if (data.contenu) articleContenuInput.value = data.contenu;
                        if (type && articleTypeSelect) articleTypeSelect.value = type;
                    }
                })
                .catch(function() {
                    if (articleAiErrorMsg) {
                        articleAiErrorMsg.textContent = 'Erreur lors de la génération.';
                        articleAiErrorMsg.classList.remove('hidden');
                    }
                })
                .finally(function() {
                    articleAiGenerateBtn.disabled = false;
                    articleAiGenerateBtn.textContent = '{{ "Générer titre et contenu"|blog_translate|e("js") }}';
                });
            });
        }

        var articleHashtagsBtn = document.getElementById('article-form-generate-hashtags-btn');
        var articleHashtagsZone = document.getElementById('article-form-hashtags-zone');
        var articleHashtagsResult = document.getElementById('article-form-hashtags-result');
        var articleHashtagsInsertBtn = document.getElementById('article-form-hashtags-insert-btn');
        var articleHashtagsError = document.getElementById('article-form-hashtags-error');
        var articleHashtagsUrl = '{{ path("user_blog_generate_hashtags") }}';

        if (articleHashtagsBtn && articleTitreInput) {
            articleHashtagsBtn.addEventListener('click', function() {
                var titre = articleTitreInput.value.trim();
                if (!titre) {
                    if (articleHashtagsError) {
                        articleHashtagsError.textContent = "Veuillez d'abord saisir un titre.";
                        articleHashtagsError.classList.remove('hidden');
                    }
                    return;
                }
                if (articleHashtagsError) articleHashtagsError.classList.add('hidden');
                articleHashtagsBtn.disabled = true;
                articleHashtagsBtn.textContent = 'Génération...';

                var formData = new FormData();
                formData.append('titre', titre);
                fetch(articleHashtagsUrl, {
                    method: 'POST',
                    body: formData,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    articleHashtagsBtn.disabled = false;
                    articleHashtagsBtn.textContent = 'Générer des hashtags';
                    if (data.error) {
                        articleHashtagsError.textContent = data.error;
                        articleHashtagsError.classList.remove('hidden');
                        if (articleHashtagsZone) articleHashtagsZone.classList.add('hidden');
                    } else if (data.hashtags) {
                        articleHashtagsResult.textContent = data.hashtags;
                        articleHashtagsZone.classList.remove('hidden');
                        articleHashtagsZone.dataset.hashtags = data.hashtags;
                    }
                })
                .catch(function() {
                    articleHashtagsBtn.disabled = false;
                    articleHashtagsBtn.textContent = 'Générer des hashtags';
                    articleHashtagsError.textContent = 'Erreur lors de la génération.';
                    articleHashtagsError.classList.remove('hidden');
                });
            });
        }

        if (articleHashtagsInsertBtn && articleContenuInput && articleHashtagsZone) {
            articleHashtagsInsertBtn.addEventListener('click', function() {
                var hashtags = articleHashtagsZone.dataset.hashtags || articleHashtagsResult.textContent;
                if (hashtags) {
                    var contenu = articleContenuInput.value;
                    articleContenuInput.value = contenu + (contenu ? '\n\n' : '') + hashtags;
                }
            });
        }

        var articleFormEl = document.getElementById('article-form');
        if (articleFormEl && articleContenuInput && articleHashtagsZone) {
            articleFormEl.addEventListener('submit', function() {
                var hashtags = articleHashtagsZone.dataset.hashtags;
                if (hashtags && !articleHashtagsZone.classList.contains('hidden')) {
                    var contenu = articleContenuInput.value;
                    if (!contenu.endsWith(hashtags.trim())) {
                        articleContenuInput.value = contenu + (contenu ? '\n\n' : '') + hashtags;
                    }
                }
            });
        }

        if (!uploadRadio || !pexelsZone) return;
        function switchSource() {
            if (uploadRadio.checked) {
                uploadZone.classList.remove('hidden');
                pexelsZone.classList.add('hidden');
                if (pexelsUrlInput) pexelsUrlInput.value = '';
                if (pexelsSelectedMsg) pexelsSelectedMsg.classList.add('hidden');
            } else {
                uploadZone.classList.add('hidden');
                pexelsZone.classList.remove('hidden');
                if (imageInput) imageInput.value = '';
            }
        }
        uploadRadio.addEventListener('change', switchSource);
        pexelsRadio.addEventListener('change', switchSource);
        if (pexelsSearchBtn) pexelsSearchBtn.addEventListener('click', function() {
            var query = (pexelsQuery ? pexelsQuery.value : '').trim();
            if (query.length < 2) {
                pexelsResults.innerHTML = '<p class="text-red-600 col-span-full">Champs obligatoire</p>';
                return;
            }
            pexelsSearchBtn.disabled = true;
            pexelsResults.innerHTML = '<p class="text-[#687280] col-span-full">Recherche en cours...</p>';
            fetch(pexelsSearchUrl + '?q=' + encodeURIComponent(query))
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    pexelsSearchBtn.disabled = false;
                    if (data.error) {
                        pexelsResults.innerHTML = '<p class="text-red-600 col-span-full">Erreur : ' + (data.error || 'Inconnue') + '</p>';
                        return;
                    }
                    if (!data.photos || data.photos.length === 0) {
                        pexelsResults.innerHTML = '<p class="text-[#687280] col-span-full">Aucune image trouvée.</p>';
                        return;
                    }
                    pexelsResults.innerHTML = data.photos.map(function(p) {
                        var src = (p.src_large || p.src_medium || '').replace(/"/g, '&quot;');
                        var photographer = (p.photographer || '').replace(/"/g, '&quot;');
                        return '<div class="aspect-square rounded-lg overflow-hidden cursor-pointer border-2 border-transparent hover:border-[#A7C7E7] article-pexels-photo" data-src="' + src + '" data-photographer="' + photographer + '"><img src="' + (p.src_medium || '').replace(/"/g, '&quot;') + '" alt="" class="w-full h-full object-cover"></div>';
                    }).join('');
                    pexelsResults.querySelectorAll('.article-pexels-photo').forEach(function(el) {
                        el.addEventListener('click', function() {
                            pexelsResults.querySelectorAll('.article-pexels-photo').forEach(function(e) { e.classList.remove('border-[#A7C7E7]'); });
                            this.classList.add('border-[#A7C7E7]');
                            if (pexelsUrlInput) pexelsUrlInput.value = this.getAttribute('data-src') || '';
                            if (pexelsSelectedMsg) {
                                pexelsSelectedMsg.textContent = 'Image sélectionnée : Photo by ' + (this.getAttribute('data-photographer') || '');
                                pexelsSelectedMsg.classList.remove('hidden');
                            }
                        });
                    });
                })
                .catch(function() {
                    pexelsSearchBtn.disabled = false;
                    pexelsResults.innerHTML = '<p class="text-red-600 col-span-full">Erreur réseau.</p>';
                });
        });
    })();

    /* ====== Module Heart = toggle favori ====== */
    var heartBtn = document.getElementById('module-heart-btn');
    if (heartBtn) {
        heartBtn.addEventListener('click', function () {
            var url = heartBtn.getAttribute('data-toggle-url');
            var csrf = heartBtn.getAttribute('data-csrf');
            var saved = heartBtn.getAttribute('data-saved') === '1';

            var formData = new FormData();
            formData.append('_token', csrf);

            fetch(url, {
                method: 'POST',
                body: formData,
                credentials: 'same-origin',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            }).then(function () {
                saved = !saved;
                heartBtn.setAttribute('data-saved', saved ? '1' : '0');
                var svg = heartBtn.querySelector('svg');
                if (saved) {
                    heartBtn.classList.remove('bg-[#FCE7F3]', 'text-[#BE185D]');
                    heartBtn.classList.add('bg-[#BE185D]', 'text-white');
                    svg.setAttribute('fill', 'currentColor');
                    heartBtn.title = 'Retirer des favoris';
                    showToast('Module enregistré !');
                } else {
                    heartBtn.classList.remove('bg-[#BE185D]', 'text-white');
                    heartBtn.classList.add('bg-[#FCE7F3]', 'text-[#BE185D]');
                    svg.setAttribute('fill', 'none');
                    heartBtn.title = 'Enregistrer le module';
                    showToast('Module retiré des favoris');
                }
            }).catch(function () {
                showToast('Erreur, veuillez réessayer');
            });
        });
    }

    /* ====== Article Heart = toggle favori ====== */
    document.querySelectorAll('.article-favorite-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var url = btn.getAttribute('data-toggle-url');
            var csrf = btn.getAttribute('data-csrf');
            var saved = btn.getAttribute('data-saved') === '1';
            var loginUrl = btn.getAttribute('data-login-url');

            if (!url || !csrf) return;

            var formData = new FormData();
            formData.append('_token', csrf);

            fetch(url, {
                method: 'POST',
                body: formData,
                credentials: 'same-origin',
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
                .then(function (response) {
                    if (response.status === 401 && loginUrl) {
                        window.location.href = loginUrl;
                        return null;
                    }
                    return response.json().then(function (data) {
                        if (!response.ok) {
                            throw new Error(data && data.error ? data.error : 'Erreur');
                        }
                        return data;
                    });
                })
                .then(function (data) {
                    if (!data) return;
                    saved = !!data.saved;
                    btn.setAttribute('data-saved', saved ? '1' : '0');
                    var svg = btn.querySelector('svg');
                    if (saved) {
                        btn.classList.remove('bg-[#FCE7F3]', 'text-[#BE185D]');
                        btn.classList.add('bg-[#BE185D]', 'text-white');
                        if (svg) svg.setAttribute('fill', 'currentColor');
                        btn.title = 'Retirer des favoris';
                        showToast('Article ajouté aux favoris');
                    } else {
                        btn.classList.remove('bg-[#BE185D]', 'text-white');
                        btn.classList.add('bg-[#FCE7F3]', 'text-[#BE185D]');
                        if (svg) svg.setAttribute('fill', 'none');
                        btn.title = 'Ajouter aux favoris';
                        showToast('Article retiré des favoris');
                    }
                })
                .catch(function (error) {
                    showToast(error && error.message ? error.message : 'Erreur, veuillez réessayer');
                });
        });
    });

    /* ====== Module Share Panel ====== */
    var shareBtn = document.getElementById('share-module');
    var shareModal = document.getElementById('module-share-modal');
    var shareBackdrop = document.getElementById('module-share-backdrop');
    var closeShareBtn = document.getElementById('close-module-share');
    var copyLinkBtn = document.getElementById('share-copy-link');

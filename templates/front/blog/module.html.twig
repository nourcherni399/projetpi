    function initSummaryTTS() {
        if (!summaryTtsBtn || !summaryTextEl) return;
        if (summaryTtsBtn._summaryTtsInit) return;
        summaryTtsBtn._summaryTtsInit = true;
        var langMap = { fr: 'fr-FR', en: 'en-US', es: 'es-ES', ar: 'ar-SA', de: 'de-DE', it: 'it-IT', pt: 'pt-PT', ru: 'ru-RU', zh: 'zh-CN', nl: 'nl-NL', ja: 'ja-JP', ko: 'ko-KR', tr: 'tr-TR', pl: 'pl-PL', sv: 'sv-SE', vi: 'vi-VN', id: 'id-ID', th: 'th-TH', uk: 'uk-UA' };
        summaryTtsBtn.addEventListener('click', function () {
            var text = (summaryTextEl && summaryTextEl.textContent) ? summaryTextEl.textContent.trim() : '';
            if (!text || text.indexOf('Erreur') === 0) return;
            if (window.speechSynthesis.speaking && !window.speechSynthesis.paused) {
                window.speechSynthesis.cancel();
                this.classList.remove('summary-tts-active');
                return;
            }
            if (window.speechSynthesis.paused) {
                window.speechSynthesis.resume();
                this.classList.add('summary-tts-active');
                return;
            }
            var utterance = new SpeechSynthesisUtterance(text);
            utterance.lang = langMap[summaryTtsLang] || (summaryTtsLang + '-' + summaryTtsLang.toUpperCase()) || 'fr-FR';
            utterance.rate = 0.95;
            utterance.onstart = function () { summaryTtsBtn.classList.add('summary-tts-active'); };
            utterance.onend = function () { summaryTtsBtn.classList.remove('summary-tts-active'); };
            utterance.onerror = function () { summaryTtsBtn.classList.remove('summary-tts-active'); };
            window.speechSynthesis.speak(utterance);

{% extends 'layouts/user.html.twig' %}

{% block title %}{{ categorie.name|blog_translate }} - Blog AutiCare{% endblock %}

{% block user_content %}
<div class="max-w-7xl mx-auto space-y-6">
    <div class="flex flex-col gap-2">
        <a href="{{ path('user_blog') }}" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl border border-[#E8DED5] text-[#4B5563] font-medium hover:bg-[#F5F1EB] transition-colors w-fit">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            {{ 'Retour aux catégories'|blog_translate }}
        </a>

        <!-- Hero catégorie -->
        <section class="relative flex flex-row items-center gap-4 md:gap-5 p-4 md:p-5 rounded-2xl bg-gradient-to-r from-[#FAEDE8] via-[#FAEDE8] to-[#F5E8E2] border-l-4 border-[#A8BBA3] border border-[#E8DED5] border-l-[#A8BBA3] shadow-[0_2px_12px_rgba(168,187,163,0.08)] overflow-hidden w-full max-w-2xl mx-auto">
            {% if categorie.image %}
                <div class="flex-shrink-0 w-20 h-20 md:w-24 md:h-24 lg:w-28 lg:h-28 rounded-xl overflow-hidden border-2 border-[#A8BBA3] shadow-sm">
                    <img src="{{ asset(categorie.image) }}" alt="{{ categorie.name|blog_translate }}" class="w-full h-full object-cover">
                </div>
            {% else %}
                <div class="flex-shrink-0 w-20 h-20 md:w-24 md:h-24 lg:w-28 lg:h-28 rounded-xl bg-[#D4E5D0] border-2 border-[#A8BBA3] flex items-center justify-center">
                    <svg class="w-8 h-8 text-[#A8BBA3]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                    </svg>
                </div>
            {% endif %}
            <div class="flex-1 min-w-0 text-left">
                <h1 class="text-2xl font-extrabold text-[#4B5563] mb-1 tracking-tight">{{ categorie.name|blog_translate }}</h1>
                <p class="text-[#687280] text-sm leading-relaxed">
                    {{ 'Découvrez tous les modules d\'apprentissage de la catégorie'|blog_translate }} <span class="font-semibold text-[#4B5563]">{{ categorie.name|blog_translate }}</span>.
                </p>
            </div>
        </section>
    </div>

    <div class="flex flex-col lg:flex-row gap-10">
        <div class="flex-1 min-w-0 space-y-8">
            {% if modules|length > 0 %}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {% for module in modules %}
                <a href="{{ path('user_blog_module', { id: module.id }) }}" class="block group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#A7C7E7] focus-visible:ring-offset-2 rounded-3xl">
                    <article class="relative rounded-3xl overflow-hidden bg-[#1F1F1F] aspect-square w-full flex flex-col shadow-lg ring-1 ring-white/20 opacity-0 animate-fade-in-up transition-all duration-300 ease-out group-hover:scale-[1.02] group-hover:shadow-xl group-hover:ring-[#A7C7E7]/30" style="animation-delay: {{ loop.index * 0.1 }}s">
                        {% if module.image %}
                            <img src="{{ asset(module.image) }}" alt="{{ module.titre|blog_translate }}" class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-105">
                        {% else %}
                            <div class="absolute inset-0 bg-gradient-to-br from-[#3F3C35] to-[#1F1F1F]"></div>
                        {% endif %}

                        <div class="absolute inset-0 bg-black/30"></div>
                        <div class="absolute inset-0 bg-gradient-to-t from-black/78 via-black/35 to-black/10"></div>

                        <div class="relative z-10 p-5 md:p-6 h-full text-white">
                            <div class="absolute top-5 left-5 md:top-6 md:left-6">
                                <span class="inline-flex px-3 py-1 rounded-full text-[10px] font-semibold bg-[#A8BBA3] text-white">
                                    {{ module.niveau|capitalize }}
                                </span>
                            </div>

                            <div class="h-full flex flex-col justify-end">
                                <div class="mb-2 text-[10px] text-white/85 uppercase tracking-wide">
                                    {{ (module.categorie ? module.categorie.label : 'Non défini')|blog_translate }}
                                </div>

                                <h3 class="text-xl md:text-2xl leading-tight font-bold mb-3 line-clamp-2">
                                    {{ module.titre|blog_translate }}
                                </h3>

                                <p class="text-white/75 text-xs md:text-sm leading-relaxed mb-2 line-clamp-3">
                                    {{ (module.description ?: 'Module sans description.')|blog_translate }}
                                </p>

                                <div class="mt-2 flex items-center gap-2">
                                    <span class="flex-1 inline-flex items-center justify-center gap-2 px-5 py-3 rounded-2xl bg-[#E8DCF0]/90 group-hover:bg-[#E8DCF0] group-hover:ring-2 group-hover:ring-[#CDB4DB]/50 text-[#4B3D6B] text-base font-semibold transition-all duration-300">
                                        {{ 'Lire'|blog_translate }}
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                                        </svg>
                                    </span>
                                    {% if app.user %}
                                        {% set isSaved = module.id in (savedModuleIds|default([])) %}
                                        <form method="POST" action="{{ path('favoris_module_toggle', { id: module.id }) }}" class="contents" onclick="event.stopPropagation()">
                                            <input type="hidden" name="_token" value="{{ csrf_token('toggle_module_favori_' ~ module.id) }}">
                                            <button type="submit"
                                                    aria-label="{{ isSaved ? 'Retirer des enregistrements' : 'Enregistrer le module' }}"
                                                    class="inline-flex items-center justify-center w-12 h-12 rounded-2xl transition-colors {{ isSaved ? 'bg-[#FF6B00] text-white hover:bg-[#ff7f26]' : 'bg-white/20 text-white hover:bg-white/30' }}">
                                                <svg class="w-5 h-5" fill="{{ isSaved ? 'currentColor' : 'none' }}" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                                                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3-7 3V5z" />
                                                </svg>
                                            </button>
                                        </form>
                                    {% else %}
                                        <a href="{{ path('app_login') }}"
                                           aria-label="Se connecter pour enregistrer"
                                           class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-white/20 hover:bg-white/30 text-white transition-colors">
                                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3-7 3V5z" />
                                            </svg>
                                        </a>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </article>
                </a>
                {% endfor %}
            </div>
            {% else %}
            <div class="text-center py-16 rounded-2xl bg-[#FAEDE8] border border-[#E8DED5]">
                <svg class="w-16 h-16 mx-auto text-[#A8BBA3] mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                <h3 class="text-lg font-semibold text-[#4B5563] mb-2">{{ 'Aucun module disponible'|blog_translate }}</h3>
                <p class="text-[#687280] mb-6">{{ 'Il n\'y a pas encore de modules dans cette catégorie.'|blog_translate }}</p>
                <a href="{{ path('user_blog') }}" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-[#A7C7E7] text-white font-medium hover:bg-[#95b8dc] transition-colors">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    {{ 'Retour aux catégories'|blog_translate }}
                </a>
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
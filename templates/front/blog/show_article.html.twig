{% extends 'layouts/user.html.twig' %}

{% block title %}{{ article.titre }} - {{ module.titre }} - AutiCare{% endblock %}

{% block user_content %}
<article class="max-w-4xl mx-auto">
    <!-- Navigation -->
    <div class="mb-6">
        <nav class="flex items-center gap-2 text-sm text-[#6B7280]">
            <a href="{{ path('user_blog') }}" class="hover:text-[#A7C7E7]">{{ 'Modules & Témoignages'|blog_translate }}</a>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
            <a href="{{ path('user_blog_module', {'id': module.id}) }}" class="hover:text-[#A7C7E7]">{{ module.titre|blog_translate }}</a>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
            <span class="text-[#4B5563] font-medium">{{ article.titre|blog_translate }}</span>
        </nav>
    </div>

    <div class="bg-white rounded-xl border border-[#E5E0D8] p-6 md:p-8 mb-8 relative">
        {# Icônes actions en haut à droite #}
        {% if is_granted('IS_AUTHENTICATED_FULLY') and (article.user and app.user and article.user.id == app.user.id or is_granted('ROLE_ADMIN')) %}
            <div class="absolute top-4 right-4 flex items-center gap-2">
                <a href="{{ path('user_blog_edit_article', {'id': article.id, 'moduleId': module.id}) }}"
                   class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-blue-50 text-blue-600 hover:bg-blue-100 focus:outline focus:ring-2 focus:ring-blue-500"
                   title="{{ 'Modifier l\'article'|blog_translate }}">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                </a>
                <form method="post"
                      action="{{ path('user_blog_delete_article', {'id': article.id, 'moduleId': module.id}) }}"
                      onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet article ?');"
                      class="inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ article.id) }}">
                    <button type="submit"
                            class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-red-50 text-red-600 hover:bg-red-100 focus:outline focus:ring-2 focus:ring-red-500"
                            title="{{ 'Supprimer l\'article'|blog_translate }}">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                    </button>
                </form>
            </div>
        {% endif %}

        <!-- En-tête de l'article -->
        <header>
        <div class="flex items-start gap-4 mb-6">
            <!-- Image de l'article -->
            {% if article.image %}
                <div class="flex-shrink-0">
                    <img src="{{ asset(article.image) }}" alt="{{ article.titre|blog_translate }}" class="w-20 h-20 object-cover rounded-lg">
                </div>
            {% endif %}
            
            <div class="flex-1">
                <!-- Titre et badges -->
                <div class="flex items-center gap-3 mb-3">
                    <h1 class="text-3xl font-bold text-[#4B5563]">{{ article.titre|blog_translate }}</h1>
                </div>
                
                <!-- Métadonnées -->
                <div class="flex flex-wrap items-center gap-4 text-sm text-[#6B7280]">
                    <span class="inline-flex px-3 py-1 text-xs font-medium rounded-full
                        {% if article.type == 'recommandation' %}bg-blue-100 text-blue-800
                        {% elseif article.type == 'plainte' %}bg-red-100 text-red-800
                        {% elseif article.type == 'question' %}bg-yellow-100 text-yellow-800
                        {% else %}bg-gray-100 text-gray-800{% endif %}">
                        {{ article.type|blog_translate_type }}
                    </span>
                    
                    {% if article.isUrgent %}
                        <span class="inline-flex px-2 py-1 text-xs font-medium rounded-full bg-red-100 text-red-800">{{ 'Urgent'|blog_translate }}</span>
                    {% endif %}
                    
                    <span>{{ 'Par'|blog_translate }} {{ article.user ? article.user.email : ('Anonyme'|blog_translate) }}</span>
                    <span>{{ 'Le'|blog_translate }} {{ article.dateCreation|date('d/m/Y à H:i') }}</span>
                    
                    {% if article.dateModif and article.dateModif != article.dateCreation %}
                        <span>{{ 'Modifié le'|blog_translate }} {{ article.dateModif|date('d/m/Y à H:i') }}</span>
                    {% endif %}
                </div>
            </div>
        </div>
        
        <!-- Module associé -->
        <div class="flex items-center gap-3 p-3 bg-[#F5F1EB] rounded-lg border border-[#E5E0D8]">
            <svg class="w-5 h-5 text-[#A7C7E7]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.256A8.967 8.967 0 016 18c2.295 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.256A8.967 8.967 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            </svg>
            <div>
                <p class="text-sm font-medium text-[#4B5563]">{{ 'Module'|blog_translate }} : {{ module.titre|blog_translate }}</p>
                <p class="text-xs text-[#6B7280]">{{ module.niveau|capitalize }} • {{ (module.categorie ? module.categorie.label : 'Non défini')|blog_translate }}</p>
            </div>
            <a href="{{ path('user_blog_module', {'id': module.id}) }}" class="ml-auto inline-flex items-center gap-2 px-3 py-1.5 text-sm bg-[#A7C7E7] text-white rounded-lg hover:bg-[#B8D4ED] transition-colors">
                {{ 'Voir le module'|blog_translate }}
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
            </a>
        </div>
        </header>

        <!-- Contenu de l'article (intégré au même cadre) -->
        <div class="mt-8">
            <div class="prose prose-[#4B5563] max-w-none">
                {% if article.contenu %}
                    <div class="dict-content text-[#4B5563] whitespace-pre-wrap break-words text-lg leading-relaxed" data-dict-lang="{{ app.session.get('blog_locale', 'fr') }}">
                        {{ article.contenu|blog_translate|raw }}
                    </div>
                {% else %}
                    <p class="text-[#6B7280]">{{ 'Aucun contenu disponible.'|blog_translate }}</p>
                {% endif %}
            </div>
        </div>
    </div>

    {# Actions article (édition/suppression) supprimées comme demandé #}

    <!-- Section des commentaires -->
    <div class="mt-8">
        <!-- Messages flash -->
        {% for message in app.flashes('success') %}
            <div class="mb-6 px-4 py-3 rounded-lg bg-emerald-50 border border-emerald-200 text-emerald-800">{{ message }}</div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="mb-6 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-red-800">{{ message }}</div>
        {% endfor %}

        <!-- Formulaire de commentaire -->
        {{ include('front/blog/_commentaire_form.html.twig', { 'article': article, 'commentaireForm': commentaireForm }) }}

        <!-- Liste des commentaires -->
        {% set commentaires = article.commentaires|filter(commentaire => commentaire.isPublished) %}
        {{ include('front/blog/_commentaires.html.twig', { 'commentaires': commentaires, 'reactedCommentTypes': reactedCommentTypes|default({}) }) }}
    </div>

    <!-- Articles similaires -->
    {% set similarArticles = module.blogs|filter(blog => blog.isPublished and blog.id != article.id)|slice(0, 3) %}
    {% if similarArticles|length > 0 %}
        <div class="mt-8">
            <h2 class="text-xl font-semibold text-[#4B5563] mb-4">{{ 'Autres articles dans ce module'|blog_translate }}</h2>
            <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
                {% for similarArticle in similarArticles %}
                    <div class="bg-white rounded-xl border border-[#E5E0D8] p-4 hover:shadow-md transition-shadow">
                        <div class="flex items-start gap-3">
                            {% if similarArticle.image %}
                                <img src="{{ asset(similarArticle.image) }}" alt="{{ similarArticle.titre|blog_translate }}" class="w-12 h-12 object-cover rounded-lg flex-shrink-0">
                            {% endif %}
                            <div class="flex-1 min-w-0">
                                <h3 class="font-medium text-[#4B5563] truncate">{{ similarArticle.titre|blog_translate }}</h3>
                                <p class="text-sm text-[#6B7280] mt-1">{{ similarArticle.dateCreation|date('d/m/Y') }}</p>
                                <a href="{{ path('user_blog_show_article', {'id': similarArticle.id}) }}" class="inline-flex items-center gap-1 text-[#A7C7E7] hover:text-[#B8D4ED] text-sm font-medium mt-2">
                                    {{ 'Lire'|blog_translate }}
                                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    {% endif %}
</article>

{% endblock %}
{% block javascripts %}
{{ parent() }}
<script>
function initShowArticle() {

    /* Vérification profanité en temps réel - délégation pour formulaires dynamiques */
    (function initProfanityCheck() {
        if (window._profanityCheckListenersAdded) return;
        window._profanityCheckListenersAdded = true;
        var debounceTimers = {};
        function runCheck(ta) {
            var form = ta.closest('.comment-form-profanity-check');
            if (!form) return;
            var articleId = form.getAttribute('data-article-id');
            var checkUrl = form.getAttribute('data-check-profanity-url');
            var warningEl = document.getElementById('profanity-warning-' + articleId);
            if (!articleId || !checkUrl || !warningEl) return;

            var text = (ta.value || '').trim();
            if (text === '') {
                warningEl.classList.add('hidden');
                return;
            }
            fetch(checkUrl, {
                method: 'POST',
                credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                body: JSON.stringify({ text: text })
            })
            .then(function (r) { return r.ok ? r.json() : { hasBadWords: false }; })
            .then(function (data) {
                if (data.hasBadWords) {
                    warningEl.classList.remove('hidden');
                    warningEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                } else {
                    warningEl.classList.add('hidden');
                }
            })
            .catch(function () { warningEl.classList.add('hidden'); });
        }
        function debouncedCheck(ta) {
            var form = ta.closest('.comment-form-profanity-check');
            if (!form) return;
            var articleId = form.getAttribute('data-article-id');
            if (!articleId) return;
            clearTimeout(debounceTimers[articleId]);
            debounceTimers[articleId] = setTimeout(function() { runCheck(ta); }, 250);
        }
        document.addEventListener('input', function(e) {
            var ta = e.target.tagName === 'TEXTAREA' ? e.target : null;
            if (!ta || !ta.closest('.comment-form-profanity-check')) return;
            debouncedCheck(ta);
        });
        document.addEventListener('paste', function(e) {
            var ta = e.target.tagName === 'TEXTAREA' ? e.target : null;
            if (!ta || !ta.closest('.comment-form-profanity-check')) return;
            debouncedCheck(ta);
        });
    })();

    var REACTION_EMOJIS = {like:'⭐', love:'❤️', haha:'😂', wow:'😮', sad:'😢', angry:'😡'};
    var REACTION_LABELS = {like:"J'aime", love:"J'adore", haha:'Haha', wow:'Wow', sad:'Quoi ?', angry:'Solidaire'};
    var REACTION_COLORS = {like:'#1877F2', love:'#F33E58', haha:'#F7B928', wow:'#F7B928', sad:'#F7B928', angry:'#E9710F'};

    function initReactionWrappers() {
        document.querySelectorAll('.reaction-wrapper').forEach(function (wrapper) {
            if (wrapper._reactionInit) return;
            wrapper._reactionInit = true;

            var mainBtn = wrapper.querySelector('.reaction-main-btn');
            var popup = wrapper.querySelector('.reaction-popup');
            var optionBtns = wrapper.querySelectorAll('.reaction-option-btn');
            var countsEl = wrapper.querySelector('.reaction-counts');
            var totalCountEl = wrapper.querySelector('.reaction-total-count');
            var hoverTimer, leaveTimer;

            function showPopup() {
                clearTimeout(leaveTimer);
                popup.classList.remove('opacity-0', 'pointer-events-none', 'scale-75');
                popup.classList.add('opacity-100', 'scale-100');
            }
            function hidePopup() {
                clearTimeout(hoverTimer);
                popup.classList.add('opacity-0', 'pointer-events-none', 'scale-75');
                popup.classList.remove('opacity-100', 'scale-100');
            }

            mainBtn.addEventListener('mouseenter', function () {
                hoverTimer = setTimeout(showPopup, 400);
            });
            mainBtn.addEventListener('mouseleave', function () {
                clearTimeout(hoverTimer);
                leaveTimer = setTimeout(hidePopup, 300);
            });
            popup.addEventListener('mouseenter', function () { clearTimeout(leaveTimer); });
            popup.addEventListener('mouseleave', function () { leaveTimer = setTimeout(hidePopup, 200); });

            function sendReaction(type) {
                hidePopup();
                var url = mainBtn.getAttribute('data-toggle-url');
                var csrf = mainBtn.getAttribute('data-csrf');
                var formData = new FormData();
                formData.append('_token', csrf);
                formData.append('type', type);

                fetch(url, {
                    method: 'POST',
                    body: formData,
                    credentials: 'same-origin',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    var userReaction = data.userReaction || null;
                    var total = data.total || 0;

                    mainBtn.setAttribute('data-current-reaction', userReaction || '');

                    var starIconUrl = wrapper.getAttribute('data-star-icon') || '';
                    var heartIconUrl = wrapper.getAttribute('data-heart-icon') || '';
                    var hahaIconUrl = wrapper.getAttribute('data-haha-icon') || '';
                    var wowIconUrl = wrapper.getAttribute('data-wow-icon') || '';
                    var sadIconUrl = wrapper.getAttribute('data-sad-icon') || '';
                    var angryIconUrl = wrapper.getAttribute('data-angry-icon') || '';
                    var emojiEl = mainBtn.querySelector('.reaction-main-emoji');
                    var displayType = userReaction || 'like';

                    if (userReaction) {
                        var color = REACTION_COLORS[userReaction] || '#1877F2';
                        mainBtn.style.background = color + '15';
                        mainBtn.style.borderColor = color;
                        mainBtn.style.color = color;
                        if (displayType === 'like' && starIconUrl) {
                            emojiEl.innerHTML = '<img src="' + starIconUrl + '" alt="J\'aime" class="w-7 h-7">';
                        } else if (displayType === 'love' && heartIconUrl) {
                            emojiEl.innerHTML = '<img src="' + heartIconUrl + '" alt="J\'adore" class="w-7 h-7">';
                        } else if (displayType === 'haha' && hahaIconUrl) {
                            emojiEl.innerHTML = '<img src="' + hahaIconUrl + '" alt="Haha" class="w-7 h-7">';
                        } else if (displayType === 'wow' && wowIconUrl) {
                            emojiEl.innerHTML = '<img src="' + wowIconUrl + '" alt="Wow" class="w-7 h-7">';
                        } else if (displayType === 'sad' && sadIconUrl) {
                            emojiEl.innerHTML = '<img src="' + sadIconUrl + '" alt="Quoi ?" class="w-7 h-7">';
                        } else if (displayType === 'angry' && angryIconUrl) {
                            emojiEl.innerHTML = '<img src="' + angryIconUrl + '" alt="Solidaire" class="w-7 h-7">';
                        } else {
                            emojiEl.textContent = REACTION_EMOJIS[userReaction] || '⭐';
                        }
                        mainBtn.querySelector('.reaction-main-label').textContent = REACTION_LABELS[userReaction] || "J'aime";
                    } else {
                        mainBtn.style.background = '';
                        mainBtn.style.borderColor = '';
                        mainBtn.style.color = '';
                        if (starIconUrl) {
                            emojiEl.innerHTML = '<img src="' + starIconUrl + '" alt="J\'aime" class="w-7 h-7">';
                        } else {
                            emojiEl.textContent = '⭐';
                        }
                        mainBtn.querySelector('.reaction-main-label').textContent = "J'aime";
                    }

                    if (totalCountEl) {
                        totalCountEl.textContent = total;
                        if (countsEl) countsEl.style.display = total > 0 ? '' : 'none';
                    }
                })
                .catch(function () {});
            }

            // Click on main button = toggle current reaction (or default like)
            mainBtn.addEventListener('click', function () {
                var current = mainBtn.getAttribute('data-current-reaction') || '';
                sendReaction(current || 'like');
            });

            // Click on a reaction option
            optionBtns.forEach(function (btn) {
                btn.addEventListener('click', function () {
                    sendReaction(btn.getAttribute('data-type'));
                });
            });
        });
    }

    initReactionWrappers();
}
document.addEventListener('turbo:load', initShowArticle);
</script>
{% endblock %}
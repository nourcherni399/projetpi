{% extends 'layouts/user.html.twig' %}

{% block title %}Modules & Témoignages - AutiCare{% endblock %}

{% block user_content %}
<div class="max-w-7xl mx-auto space-y-12">
<section class="relative text-center p-6 md:p-8 rounded-2xl bg-[#FAEDE8] border border-[#E8DED5] shadow-sm overflow-hidden">
    <div class="inline-flex items-center justify-center w-20 h-20 rounded-full border-2 border-[#A8BBA3] bg-[#D4E5D0] mb-4 shadow-[0_0_20px_rgba(168,187,163,0.3)] p-2">
        <img src="{{ asset('images/hero-icon.png') }}" alt="" class="w-full h-full object-contain" aria-hidden="true">
    </div>
    <h1 class="text-3xl font-extrabold text-[#4B5563] mb-3 tracking-tight">{{ 'Modules & Témoignages'|blog_translate }}</h1>
    <p class="text-[#687280] max-w-2xl mx-auto leading-relaxed text-base">
        {{ 'Explorez nos modules d\'apprentissage par catégorie. Partagez vos expériences, découvrez des conseils pratiques et rejoignez notre communauté.'|blog_translate }}
    </p>
    <div class="absolute right-0 bottom-0 w-48 h-48 md:w-64 md:h-64 lg:w-72 lg:h-72 flex flex-col justify-end items-end">
        <img src="{{ asset('images/hero-enfants.png') }}" alt="" class="max-w-full max-h-full object-contain object-bottom object-right" aria-hidden="true">
    </div>
</section>
<div class="border-t border-[#E8DED5]"></div>

<div class="flex flex-col lg:flex-row gap-10">
    <div class="flex-1 min-w-0 space-y-8">
        <!-- Liste des modules par catégorie (sans cadre de fond) -->
        <div class="space-y-6">

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {% for category in categories %}
                <a href="{{ path('user_blog_categorie', {'slug': category.slug}) }}" class="block group focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#A7C7E7] focus-visible:ring-offset-2 rounded-3xl">
                <article class="relative rounded-3xl overflow-hidden bg-[#1F1F1F] aspect-square w-full flex flex-col shadow-lg ring-1 ring-white/20 opacity-0 animate-fade-in-up transition-all duration-300 ease-out group-hover:scale-[1.02] group-hover:shadow-xl group-hover:ring-[#A7C7E7]/30" style="animation-delay: {{ loop.index * 0.1 }}s">
                    {% if category.image %}
                        <img src="{{ asset(category.image) }}" alt="{{ category.name|blog_translate }}" class="absolute inset-0 w-full h-full object-cover transition-transform duration-300 ease-out group-hover:scale-[1.03]">
                    {% else %}
                        <div class="absolute inset-0 bg-gradient-to-br from-[#E8F4FC] to-[#E8DCF0]"></div>
                    {% endif %}

                    <div class="absolute inset-0 bg-black/30"></div>
                    <div class="absolute inset-0 bg-gradient-to-t from-black/78 via-black/35 to-black/10"></div>

                    <div class="relative z-10 p-5 md:p-6 h-full text-white">
                        <div class="h-full flex flex-col justify-end">
                            <h3 class="text-xl md:text-2xl leading-tight font-bold mb-3 line-clamp-2">
                                {{ category.name|blog_translate }}
                            </h3>

                            <div class="mt-2 flex items-center gap-2">
                                <span class="flex-1 inline-flex items-center justify-center gap-2 px-5 py-3 rounded-2xl bg-[#E8DCF0]/90 group-hover:bg-[#E8DCF0] group-hover:ring-2 group-hover:ring-[#CDB4DB]/50 text-[#4B3D6B] text-base font-semibold transition-all duration-300">
                                    {{ 'Voir les modules'|blog_translate }}
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                                    </svg>
                                </span>
                            </div>
                        </div>
                    </div>
                </article>
                </a>
                {% else %}
                <div class="col-span-3 text-center py-12">
                    {% if searchTerm is defined and searchTerm is not empty %}
                        <p class="text-[#687280] mb-2">{{ 'Aucun module ne correspond au titre'|blog_translate }} « {{ searchTerm }} ».</p>
                        <a href="{{ path('user_blog') }}" class="inline-flex items-center gap-2 text-sm text-[#A7C7E7] hover:text-[#95b8dc] font-medium underline-offset-4 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#A7C7E7] focus-visible:ring-offset-1 rounded transition-colors duration-300">
                            {{ 'Réinitialiser la recherche'|blog_translate }}
                        </a>
                    {% else %}
                        <svg class="w-16 h-16 mx-auto text-gray-400 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                        </svg>
                        <p class="text-[#687280]">{{ 'Aucune catégorie disponible pour le moment.'|blog_translate }}</p>
                    {% endif %}
                </div>
                {% endfor %}
            </div>
        </div>
    </div>

    <aside class="lg:w-80 lg:max-w-xs shrink-0 space-y-2">
        <!-- Recherche de module -->
        <div class="rounded-xl p-4 pt-0">
            <form method="get" action="{{ path('user_blog') }}">
                <div class="relative">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-[#687280]">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
                        </svg>
                    </span>
                    <input
                        type="search"
                        name="q"
                        value="{{ searchTerm ?? '' }}"
                        placeholder="{{ 'Rechercher un module...'|blog_translate }}"
                        class="w-full pl-10 pr-4 py-2.5 rounded-lg border border-[#E8DED5] bg-[#FDF8F5] text-[#687280] placeholder-[#9CA3AF] focus:outline focus:ring-2 focus:ring-[#A7C7E7] focus:ring-offset-1 focus:border-[#A7C7E7] transition-all duration-300"
                    >
                </div>
            </form>
        </div>
        <div class="h-px bg-[#E8DED5]"></div>
        <!-- Écrire un article -->
        <div id="ecrire-article" class="relative bg-[#FAEDE8] rounded-xl shadow-sm p-5 border border-[#E8DED5] overflow-hidden">
            <div class="inline-flex items-center justify-center w-12 h-12 rounded-full border-2 border-[#A8BBA3] bg-[#A8BBA3]/10 text-[#A8BBA3] mb-3">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                </svg>
            </div>
            <h2 class="font-semibold text-[#1e3a5f] mb-2">{{ 'Partagez votre histoire'|blog_translate }}</h2>
            <p class="text-[#687280] text-sm mb-4">{{ 'Votre expérience peut aider d\'autres familles. Écrivez votre témoignage dans nos modules.'|blog_translate }}</p>
            {% if app.user %}
                <a href="#" onclick="toggleForm()" class="inline-block px-4 py-2.5 rounded-lg bg-[#A8BBA3] text-white font-medium hover:bg-[#95B89E] focus:outline focus-visible:ring-2 focus-visible:ring-[#A8BBA3] focus-visible:ring-offset-2 transition-colors duration-300">{{ 'Écrire un article'|blog_translate }}</a>
            {% else %}
                <div class="bg-[#E8F5E9] border border-[#E8DED5] rounded-lg p-4">
                    <p class="text-[#1e3a5f] mb-2">{{ 'Pour écrire un article, veuillez vous'|blog_translate }} <a href="{{ path('app_login') }}" class="text-[#A8BBA3] hover:text-[#95B89E] underline underline-offset-4 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#A8BBA3] focus-visible:ring-offset-1 rounded transition-colors duration-300">{{ 'connecter'|blog_translate }}</a>.</p>
                </div>
            {% endif %}
        </div>
        
    </aside>
</div>
</div>
{% endblock %}
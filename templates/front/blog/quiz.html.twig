{% extends 'layouts/user.html.twig' %}

{% block title %}Quiz - {{ module.titre }} - AutiCare{% endblock %}

{% block user_content %}
<div class="max-w-2xl mx-auto">
    <div class="mb-6">
        <a href="{{ path('user_blog_module', { id: module.id }) }}" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl border border-[#E8DED5] text-[#4B5563] font-medium hover:bg-[#F5F1EB] transition-colors w-fit">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
            {{ 'Retour au module'|blog_translate }}
        </a>
    </div>

    <div class="bg-[#FDF8F5] rounded-2xl border border-[#E8DED5] p-6 md:p-8 shadow-sm">
        <h1 class="text-2xl font-bold text-[#4B5563] mb-2">{{ 'Quiz de validation'|blog_translate }}</h1>
        <p class="text-[#687280] mb-6">{{ 'Module'|blog_translate }} : {{ module.titre|blog_translate }}</p>
        <p class="text-sm text-[#6B7280] mb-8">{{ 'Répondez à toutes les questions. Vous devez obtenir plus de 80% pour valider ce module.'|blog_translate }}</p>

        <form id="quiz-form" method="post" action="{{ path('user_blog_quiz', { id: module.id, quizId: moduleQuiz.id }) }}" class="space-y-8" novalidate data-turbo="false">
            <input type="hidden" name="_token" value="{{ csrf_token('quiz_' ~ moduleQuiz.id) }}">
            <div id="quiz-validation-msg" class="hidden mb-6 p-4 rounded-xl bg-amber-50 border border-amber-200 text-amber-800 text-sm font-medium"></div>

            {% for index, question in moduleQuiz.questionsJson %}
                <div class="rounded-xl border border-[#E8DED5] p-5 bg-white">
                    <p class="font-semibold text-[#4B5563] mb-4">
                        {{ loop.index }}. {{ question.question|blog_translate }}
                    </p>
                    <div class="space-y-3">
                        {% for repIndex, reponse in question.reponses %}
                            <label class="flex items-start gap-3 p-3 rounded-lg border border-[#E8DED5] hover:bg-[#FAEDE8] cursor-pointer transition-colors">
                                <input type="radio" name="reponses[{{ index }}]" value="{{ repIndex }}" required
                                       class="mt-1 w-4 h-4 rounded-full border-[#E8DED5] text-[#A8BBA3] focus:ring-[#A8BBA3]">
                                <span class="text-[#4B5563]">{{ reponse|blog_translate }}</span>
                            </label>
                        {% endfor %}
                    </div>
                </div>
            {% endfor %}

            <div class="flex flex-wrap gap-3 pt-4">
                <button type="submit" class="px-6 py-3 rounded-xl bg-[#A8BBA3] text-white font-semibold hover:bg-[#95B89E] focus:outline focus:ring-2 focus:ring-[#A8BBA3] transition-colors">
                    {{ 'Valider le quiz'|blog_translate }}
                </button>
                <a href="{{ path('user_blog_module', { id: module.id }) }}" class="px-6 py-3 rounded-xl border border-[#E8DED5] text-[#6B7280] font-medium hover:bg-[#F5F1EB] transition-colors">
                    {{ 'Annuler'|blog_translate }}
                </a>
            </div>
        </form>
    </div>
</div>
<script>
document.addEventListener('DOMContentLoaded', function() {
    var form = document.getElementById('quiz-form');
    var msgEl = document.getElementById('quiz-validation-msg');
    if (!form || !msgEl) return;

    form.addEventListener('submit', function(e) {
        var groups = form.querySelectorAll('input[type="radio"][name^="reponses"]');
        var names = [];
        groups.forEach(function(r) {
            if (names.indexOf(r.name) === -1) names.push(r.name);
        });
        var unanswered = [];
        names.forEach(function(name) {
            var checked = form.querySelector('input[name="' + name + '"]:checked');
            if (!checked) {
                var idx = name.match(/\[(\d+)\]/);
                unanswered.push(idx ? parseInt(idx[1], 10) + 1 : names.indexOf(name) + 1);
            }
        });
        if (unanswered.length > 0) {
            e.preventDefault();
            msgEl.textContent = 'Veuillez répondre à toutes les questions. Question(s) non répondue(s) : ' + unanswered.join(', ');
            msgEl.classList.remove('hidden');
            msgEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
            return false;
        }
        msgEl.classList.add('hidden');
    });
});
</script>
{% endblock %}

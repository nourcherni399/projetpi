{% extends 'layouts/user.html.twig' %}

{% block title %}Accueil - AutiCare{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        @keyframes hero-cta-pulse {
            0%, 100% { transform: scale(1); box-shadow: 0 10px 25px -5px rgb(0 0 0 / 0.15), 0 8px 10px -6px rgb(0 0 0 / 0.1); }
            50% { transform: scale(1.02); box-shadow: 0 20px 35px -5px rgb(0 0 0 / 0.18), 0 10px 15px -6px rgb(0 0 0 / 0.12); }
        }
        .hero-cta-btn { animation: hero-cta-pulse 2.5s ease-in-out infinite; }
        .hero-cta-btn-2 { animation-delay: 0.4s; }
        .hero-cta-btn:hover, .hero-cta-btn-2:hover { animation-play-state: paused; }
    </style>
{% endblock %}

{% block user_content %}
{# Hero : fond = bande d'images défilant horizontalement (layout, visible) #}
<section class="relative min-h-[85vh] flex flex-col items-center justify-center text-center px-4 overflow-hidden">
    {# Légère ombre sous le texte pour lisibilité sur le fond défilant #}
    <div class="absolute inset-0 z-0 bg-gradient-to-t from-black/20 via-transparent to-transparent pointer-events-none"></div>

    <div class="relative z-10 max-w-4xl mx-auto">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/90 text-[#5C5C5C] text-sm font-medium mb-6 shadow-lg">
            <svg class="w-5 h-5 text-[#CDB4DB]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg>
            Bienvenue sur AutiCare
        </div>
        <h1 class="text-4xl md:text-6xl font-bold text-white drop-shadow-lg mb-5 tracking-tight">
            Accompagnement bienveillant pour les <span class="text-[#FFF8F0]">personnes autistes</span>
        </h1>
        <p class="text-lg md:text-xl text-white/95 max-w-2xl mx-auto mb-10 leading-relaxed drop-shadow">
            Une plateforme dédiée aux personnes autistes et à leurs familles. Produits adaptés, événements et une communauté à vos côtés.
        </p>
        <div class="flex flex-wrap gap-4 justify-center">
            <a href="{{ path('user_products_index') }}" class="hero-cta-btn inline-flex items-center gap-2 px-7 py-4 rounded-2xl bg-white text-[#3D3D3D] font-semibold hover:bg-[#FFF8F0] shadow-xl transition-all hover:scale-105">
                Découvrir nos produits
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </a>
            <a href="{{ path('user_events') }}" class="hero-cta-btn hero-cta-btn-2 inline-flex items-center gap-2 px-7 py-4 rounded-2xl bg-white/90 text-[#3D3D3D] font-semibold hover:bg-white border-2 border-white/50 shadow-xl transition-all hover:scale-105">
                Voir les événements
            </a>
        </div>
    </div>
</section>

{# Section image + texte — Notre mission #}
<section class="py-20 bg-[#E8E0F0]/40 dark:bg-gray-600/40">
    <div class="max-w-6xl mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <div class="order-2 lg:order-1">
                <img src="https://images.unsplash.com/photo-1607619056574-7b8d3ee536b2?w=1200&q=90" alt="Enfant et parent, moment d'accompagnement bienveillant" class="rounded-3xl shadow-pastel-md w-full object-cover max-h-[400px]" />
            </div>
            <div class="order-1 lg:order-2">
                <span class="text-[#CDB4DB] font-semibold text-sm uppercase tracking-wider">Notre mission</span>
                <h2 class="text-3xl md:text-4xl font-bold text-[#3D3D3D] dark:text-gray-100 mt-2 mb-4">Écouter, aider, accompagner</h2>
                <p class="text-[#5C5C5C] dark:text-gray-300 text-lg leading-relaxed mb-6">
                    AutiCare propose un accompagnement adapté aux personnes autistes et à leurs proches : produits spécialisés, ateliers, événements et un espace d'échange bienveillant.
                </p>
                <a href="{{ path('about') }}" class="inline-flex items-center gap-2 px-5 py-3 rounded-2xl bg-[#CDB4DB] text-white font-medium hover:bg-[#B8A4CC] transition-colors">
                    En savoir plus
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                </a>
            </div>
        </div>
    </div>
</section>

{# Statistiques avec pastels différents #}
<section class="py-20 bg-[#FDF8F5] dark:bg-gray-600/30">
    <div class="max-w-5xl mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10 text-center">
            <div class="flex flex-col items-center p-8 rounded-3xl bg-[#D4E5D0] border-2 border-[#A8BBA3]/50">
                <div class="w-20 h-20 rounded-2xl bg-[#A8BBA3] text-white flex items-center justify-center mb-4 shadow-pastel">
                    <svg class="w-10 h-10" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd" /></svg>
                </div>
                <p class="text-4xl font-bold text-[#3D3D3D]">500+</p>
                <p class="text-[#5C5C5C] mt-2 font-medium">Familles accompagnées</p>
            </div>
            <div class="flex flex-col items-center p-8 rounded-3xl bg-[#DFEEF5] border-2 border-[#B5D4E8]/50">
                <div class="w-20 h-20 rounded-2xl bg-[#B5D4E8] text-white flex items-center justify-center mb-4 shadow-pastel">
                    <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
                </div>
                <p class="text-4xl font-bold text-[#3D3D3D]">50+</p>
                <p class="text-[#5C5C5C] mt-2 font-medium">Événements par an</p>
            </div>
            <div class="flex flex-col items-center p-8 rounded-3xl bg-[#FAEDE8] border-2 border-[#F0D5C8]/50">
                <div class="w-20 h-20 rounded-2xl bg-[#F0D5C8] text-[#5C5C5C] flex items-center justify-center mb-4 shadow-pastel">
                    <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg>
                </div>
                <p class="text-4xl font-bold text-[#3D3D3D]">100+</p>
                <p class="text-[#5C5C5C] mt-2 font-medium">Produits adaptés</p>
            </div>
        </div>
    </div>
</section>

{# Produits suggérés par l'IA (validés par l'admin) - INTÉGRATION FONCTIONNELLE #}
{% if produits_ia_valides|default([])|length > 0 %}
<section class="py-20 bg-[#FDF8F5] dark:bg-gray-600/25">
    <div class="max-w-6xl mx-auto px-4">
        <div class="text-center mb-12">
            <span class="inline-block px-4 py-1.5 rounded-full bg-[#CDB4DB]/20 text-[#CDB4DB] text-sm font-medium mb-4">Nouveauté</span>
            <h2 class="text-3xl md:text-4xl font-bold text-[#3D3D3D] dark:text-gray-100 mb-3">Produits suggérés par l'IA</h2>
            <p class="text-[#5C5C5C] dark:text-gray-300 text-lg max-w-2xl mx-auto">Des produits créés grâce à notre assistant et validés pour vous.</p>
        </div>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            {% for produit in produits_ia_valides %}
            <article class="group bg-white dark:bg-gray-600/70 rounded-3xl border-2 border-[#E8DCF0] dark:border-gray-600 p-6 shadow-pastel hover:shadow-pastel-md transition-all overflow-hidden">
                <a href="{{ path('user_product_show', { id: produit.id }) }}" class="block">
                    <div class="w-full h-36 -mx-6 -mt-6 mb-4 overflow-hidden rounded-t-3xl bg-[#CDB4DB]">
                        {% if produit.image %}
                            {% if produit.image starts with 'http' %}
                                <img src="{{ produit.image }}" alt="{{ produit.nom }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
                            {% else %}
                                <img src="{{ asset(produit.image) }}" alt="{{ produit.nom }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300">
                            {% endif %}
                        {% else %}
                            <div class="w-full h-full bg-[#CDB4DB] flex items-center justify-center">
                                <span class="text-white text-sm">Image</span>
                            </div>
                        {% endif %}
                    </div>
                    
                    <div class="flex-1 flex flex-col">
                        {% if produit.categorie %}
                        <span class="inline-flex self-start px-3 py-1 rounded-full text-xs font-medium text-white bg-[#CDB4DB] mb-2">{{ produit.categorie.label() }}</span>
                        {% endif %}
                        
                        <h3 class="font-bold text-[#3D3D3D] dark:text-gray-100 mb-2 line-clamp-1">{{ produit.nom }}</h3>
                        
                        {% if produit.description %}
                        <p class="text-[#5C5C5C] dark:text-gray-300 text-sm leading-relaxed line-clamp-2">{{ produit.description }}</p>
                        {% endif %}
                        
                        <div class="mt-3 flex items-center justify-between">
                            <p class="font-semibold text-lg text-[#CDB4DB]">{{ produit.prix|number_format(2, ',', ' ') }} dt</p>
                            <span class="inline-flex items-center gap-1 text-[#CDB4DB] text-sm font-medium group-hover:translate-x-1 transition-transform">
                                Voir
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                            </span>
                        </div>
                    </div>
                </a>
            </article>
            {% endfor %}
        </div>
        
        <div class="text-center mt-12">
            <a href="{{ path('user_products_index') }}" class="inline-flex items-center gap-2 px-7 py-4 rounded-2xl bg-[#CDB4DB] text-white font-semibold hover:bg-[#B8A4CC] shadow-pastel transition-all hover:scale-105">
                Voir tous les produits
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
            </a>
        </div>
    </div>
</section>
{% endif %}

{# Tout ce dont vous avez besoin — avec image #}
<section class="py-20 bg-[#FAEDE8]/60 dark:bg-gray-600/25">
    <div class="max-w-6xl mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold text-[#3D3D3D] dark:text-gray-100 mb-3">Tout ce dont vous avez besoin</h2>
        <p class="text-[#5C5C5C] dark:text-gray-300 max-w-2xl mx-auto text-lg">AutiCare propose un ensemble complet de services pour accompagner les personnes autistes et leurs proches au quotidien.</p>
    </div>
</section>

{# 4 cartes avec couleurs pastel et images décoratives #}
<section class="py-16 pb-24 bg-[#FDF8F5] dark:bg-gray-600/25">
    <div class="max-w-6xl mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <article class="group bg-white dark:bg-gray-600/70 rounded-3xl border-2 border-[#D4E5D0] dark:border-gray-600 p-6 shadow-pastel hover:shadow-pastel-md transition-all overflow-hidden">
                <div class="w-full h-36 -mx-6 -mt-6 mb-4 overflow-hidden rounded-t-3xl bg-[#A8BBA3]">
                    <img src="https://images.unsplash.com/photo-1616486338811-3dada111a655?w=800&q=90" alt="Jeux sensoriels et jouets apaisants" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                </div>
                <h3 class="font-bold text-[#3D3D3D] dark:text-gray-100 mb-2">Produits spécialisés</h3>
                <p class="text-[#5C5C5C] dark:text-gray-300 text-sm leading-relaxed">Stimulation sensorielle, concentration et apaisement au quotidien.</p>
                <a href="{{ path('user_products_index') }}" class="inline-block mt-3 text-[#A8BBA3] font-medium text-sm hover:underline">Découvrir →</a>
            </article>
            <article class="group bg-white dark:bg-gray-600/70 rounded-3xl border-2 border-[#E8DCF0] dark:border-gray-600 p-6 shadow-pastel hover:shadow-pastel-md transition-all overflow-hidden">
                <div class="w-full h-36 -mx-6 -mt-6 mb-4 overflow-hidden rounded-t-3xl bg-[#CDB4DB]">
                    <img src="https://images.unsplash.com/photo-1529156069898-49953e39b3ac?w=800&q=90" alt="Ateliers et groupe de soutien" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                </div>
                <h3 class="font-bold text-[#3D3D3D] dark:text-gray-100 mb-2">Événements & ateliers</h3>
                <p class="text-[#5C5C5C] dark:text-gray-300 text-sm leading-relaxed">Ateliers, rencontres et sensibilisation adaptés à vos besoins.</p>
                <a href="{{ path('user_events') }}" class="inline-block mt-3 text-[#CDB4DB] font-medium text-sm hover:underline">Voir le programme →</a>
            </article>
            <article class="group bg-white dark:bg-gray-600/70 rounded-3xl border-2 border-[#DFEEF5] dark:border-gray-600 p-6 shadow-pastel hover:shadow-pastel-md transition-all overflow-hidden">
                <div class="w-full h-36 -mx-6 -mt-6 mb-4 overflow-hidden rounded-t-3xl bg-[#B5D4E8]">
                    <img src="https://images.unsplash.com/photo-1503676260728-1c00da094a0b?w=800&q=90" alt="Ressources et lecture adaptée" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                </div>
                <h3 class="font-bold text-[#3D3D3D] dark:text-gray-100 mb-2">Blog & ressources</h3>
                <p class="text-[#5C5C5C] dark:text-gray-300 text-sm leading-relaxed">Expériences, conseils et articles pour les familles.</p>
                <a href="{{ path('user_blog') }}" class="inline-block mt-3 text-[#B5D4E8] font-medium text-sm hover:underline">Lire le blog →</a>
            </article>
            <article class="group bg-white dark:bg-gray-600/70 rounded-3xl border-2 border-[#FAEDE8] dark:border-gray-600 p-6 shadow-pastel hover:shadow-pastel-md transition-all overflow-hidden">
                <div class="w-full h-36 -mx-6 -mt-6 mb-4 overflow-hidden rounded-t-3xl bg-[#F0D5C8]">
                    <img src="https://images.unsplash.com/photo-1523240795612-9a054b0db644?w=800&q=90" alt="Communauté inclusive et bienveillante" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
                </div>
                <h3 class="font-bold text-[#3D3D3D] dark:text-gray-100 mb-2">Communauté bienveillante</h3>
                <p class="text-[#5C5C5C] dark:text-gray-300 text-sm leading-relaxed">Un espace d'échange où chacun est accueilli avec respect.</p>
                <a href="{{ path('user_events') }}" class="inline-block mt-3 text-[#E8A598] font-medium text-sm hover:underline">Rejoindre →</a>
            </article>
        </div>
    </div>
</section>

{# Témoignages avec fond pastel et images #}
<section class="py-20 bg-[#E8DCF0]/30 dark:bg-gray-600/30">
    <div class="max-w-6xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-[#3D3D3D] dark:text-gray-100 text-center mb-2">Ce que dit notre communauté</h2>
        <p class="text-[#5C5C5C] dark:text-gray-300 text-center max-w-2xl mx-auto mb-12 text-lg">Des familles et des personnes qui nous font confiance.</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <article class="bg-white dark:bg-gray-600/70 rounded-3xl border-2 border-[#E8DCF0] dark:border-gray-600 p-8 shadow-pastel">
                <p class="text-5xl text-[#CDB4DB] font-serif leading-none mb-4">"</p>
                <p class="text-[#5C5C5C] dark:text-gray-300 mb-6 leading-relaxed">AutiCare nous a accompagnés avec une bienveillance rare. Les produits recommandés ont vraiment aidé notre fils au quotidien.</p>
                <div class="flex items-center gap-4">
                    <img src="https://images.unsplash.com/photo-1544005313-94ddf0286df2?w=160&h=160&fit=crop&q=90" alt="" class="w-12 h-12 rounded-full object-cover border-2 border-[#CDB4DB]" />
                    <div>
                        <p class="font-semibold text-[#3D3D3D]">Marie L.</p>
                        <p class="text-sm text-[#5C5C5C]">Maman d'un enfant autiste</p>
                    </div>
                </div>
            </article>
            <article class="bg-white dark:bg-gray-600/70 rounded-3xl border-2 border-[#D4E5D0] dark:border-gray-600 p-8 shadow-pastel">
                <p class="text-5xl text-[#A8BBA3] font-serif leading-none mb-4">"</p>
                <p class="text-[#5C5C5C] dark:text-gray-300 mb-6 leading-relaxed">Enfin une plateforme qui me comprend. Les événements en ligne m'ont permis de rencontrer d'autres personnes comme moi.</p>
                <div class="flex items-center gap-4">
                    <img src="https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=160&h=160&fit=crop&q=90" alt="" class="w-12 h-12 rounded-full object-cover border-2 border-[#A8BBA3]" />
                    <div>
                        <p class="font-semibold text-[#3D3D3D]">Thomas D.</p>
                        <p class="text-sm text-[#5C5C5C]">Personne autiste</p>
                    </div>
                </div>
            </article>
            <article class="bg-white dark:bg-gray-600/70 rounded-3xl border-2 border-[#DFEEF5] dark:border-gray-600 p-8 shadow-pastel">
                <p class="text-5xl text-[#B5D4E8] font-serif leading-none mb-4">"</p>
                <p class="text-[#5C5C5C] dark:text-gray-300 mb-6 leading-relaxed">En tant qu'éducatrice, j'oriente les familles vers AutiCare. Les ressources et le blog sont d'une grande qualité.</p>
                <div class="flex items-center gap-4">
                    <img src="https://images.unsplash.com/photo-1580489944761-15a19d654956?w=160&h=160&fit=crop&q=90" alt="" class="w-12 h-12 rounded-full object-cover border-2 border-[#B5D4E8]" />
                    <div>
                        <p class="font-semibold text-[#3D3D3D]">Sophie R.</p>
                        <p class="text-sm text-[#5C5C5C]">Éducatrice spécialisée</p>
                    </div>
                </div>
            </article>
        </div>
    </div>
</section>

{# CTA final avec image et fond pastel #}
<section class="py-24 bg-gradient-to-br from-[#D4E5D0] via-[#E8DCF0] to-[#FAEDE8] dark:from-gray-600 dark:via-gray-600 dark:to-gray-700">
    <div class="max-w-4xl mx-auto px-4 text-center">
        <div class="flex justify-center mb-8">
            <img src="{{ asset('images/logo.png') }}" alt="AutiCare" class="h-24 w-auto object-contain drop-shadow-lg" />
        </div>
        {% if app.user %}
            <h2 class="text-3xl font-bold text-[#3D3D3D] dark:text-gray-100 mb-3">Vous faites partie de la communauté</h2>
            <p class="text-[#5C5C5C] dark:text-gray-300 mb-8 text-lg">Accédez à vos services : produits, événements et votre espace personnel.</p>
            <div class="flex flex-wrap gap-4 justify-center">
                <a href="{{ path('user_profile') }}" class="inline-flex items-center gap-2 px-6 py-3.5 rounded-2xl bg-[#CDB4DB] text-white font-semibold hover:bg-[#B8A4CC] shadow-pastel transition-colors">
                    Mon profil
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                </a>
                <a href="{{ path('user_products_index') }}" class="inline-flex items-center gap-2 px-6 py-3.5 rounded-2xl border-2 border-[#E8DED5] bg-white text-[#5C5C5C] font-semibold hover:bg-[#FFF8F0] transition-colors">Découvrir les produits</a>
                <a href="{{ path('user_events') }}" class="inline-flex items-center gap-2 px-6 py-3.5 rounded-2xl border-2 border-[#E8DED5] bg-white text-[#5C5C5C] font-semibold hover:bg-[#FFF8F0] transition-colors">Voir les événements</a>
            </div>
        {% else %}
            <h2 class="text-3xl font-bold text-[#3D3D3D] dark:text-gray-100 mb-3">Rejoignez notre communauté</h2>
            <p class="text-[#5C5C5C] dark:text-gray-300 mb-8 text-lg">Créez votre compte et accédez aux produits adaptés, événements et à un espace d'échange bienveillant.</p>
            <div class="flex flex-wrap gap-4 justify-center">
                <a href="{{ path('register') }}" class="inline-flex items-center gap-2 px-7 py-4 rounded-2xl bg-[#A8BBA3] text-white font-semibold hover:bg-[#94B08E] shadow-pastel-md transition-colors">
                    Créer mon compte
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>

{% extends 'layouts/user.html.twig' %}

{% block title %}Mon panier et mes commandes - AutiCare{% endblock %}

{% block user_content %}
<span class="cart-items-count hidden">{{ cart.totalItems }}</span>
{% for message in app.flashes('error') %}
    <div class="mb-4 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-red-800">{{ message }}</div>
{% endfor %}
{% for message in app.flashes('success') %}
    <div class="mb-4 px-4 py-3 rounded-lg bg-emerald-50 border border-emerald-200 text-emerald-800">{{ message }}</div>
{% endfor %}
<section class="text-center mb-10">
    <h1 class="text-3xl font-bold text-[#4B5563] mb-3">Mon panier et mes commandes</h1>
    <p class="text-[#6B7280]">Gérez votre panier et consultez le suivi de vos commandes.</p>
</section>

{% if cart and not cart.empty %}
<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2">
        <div class="bg-white rounded-xl shadow-sm border border-[#E5E0D8] overflow-hidden">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-[#E5E0D8] bg-[#F5F1EB]">
                        <th class="px-6 py-3 text-left text-sm font-semibold text-[#4B5563]">Produit</th>
                        <th class="px-6 py-3 text-center text-sm font-semibold text-[#4B5563]">Prix</th>
                        <th class="px-6 py-3 text-center text-sm font-semibold text-[#4B5563]">Quantité</th>
                        <th class="px-6 py-3 text-right text-sm font-semibold text-[#4B5563]">Total</th>
                        <th class="px-6 py-3 text-center text-sm font-semibold text-[#4B5563]">Action</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in cart.items %}
                    <tr class="border-b border-[#E5E0D8] hover:bg-[#F5F1EB] cart-row{% if error_product_id|default(null) == item.produit.id %} bg-red-50 border-l-4 border-l-red-500{% endif %}" data-product-id="{{ item.produit.id }}">
                        <td class="px-6 py-4">
                            <div class="flex gap-4">
                                {% if item.produit.image %}
                                    <img src="{{ asset(item.produit.image) }}" alt="{{ item.produit.nom }}" class="w-16 h-16 object-cover rounded-lg">
                                {% else %}
                                    <div class="w-16 h-16 bg-[#E5E0D8] rounded-lg"></div>
                                {% endif %}
                                <div>
                                    <p class="font-semibold text-[#4B5563]">{{ item.produit.nom }}</p>
                                    {% if item.produit.description %}
                                        <p class="text-sm text-[#6B280] mt-1">{{ item.produit.description|slice(0, 100) }}...</p>
                                    {% endif %}
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-4 text-center text-[#4B5563] font-semibold">{{ item.prix|number_format(2, ',', ' ') }} dt</td>
                        <td class="px-6 py-4 text-center">
                            <form method="POST" action="{{ path('cart_update', {id: item.produit.id}) }}" class="cart-update-form flex flex-col items-center gap-2" novalidate>
                                <div class="flex flex-col items-center gap-1">
                                    <div class="flex justify-center gap-2">
                                        <input type="number" name="quantite" value="{{ item.quantite }}" min="1" class="cart-qty-input w-16 px-2 py-1 border border-[#E5E0D8] rounded-lg text-center focus:outline-none focus:ring-2 focus:ring-[#A7C7E7]" aria-label="Quantité" data-product-id="{{ item.produit.id }}" aria-invalid="false" aria-describedby="cart-qty-error-{{ item.produit.id }}">
                                        <button type="submit" class="px-3 py-1 bg-[#A7C7E7] text-white rounded-lg text-sm hover:bg-[#B8D4ED]">OK</button>
                                    </div>
                                    <p id="cart-qty-error-{{ item.produit.id }}" class="cart-qty-error hidden text-sm text-red-600 mt-1" role="alert">La quantité doit être au moins 1.</p>
                                </div>
                            </form>
                        </td>
                        <td class="px-6 py-4 text-right text-[#A7C7E7] font-semibold">{{ item.totalPrice|number_format(2, ',', ' ') }} dt</td>
                        <td class="px-6 py-4 text-center">
                            <form method="POST" action="{{ path('cart_remove', {id: item.produit.id}) }}" onsubmit="return confirm('Êtes-vous sûr?')">
                                <button type="submit" class="px-4 py-2 bg-red-500 text-white rounded-lg text-sm hover:bg-red-600">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="lg:col-span-1">
        <div class="bg-white rounded-xl shadow-sm border border-[#E5E0D8] p-6 sticky top-20">
            <h3 class="text-lg font-semibold text-[#4B5563] mb-4">Résumé de la Commande</h3>
            
            <div class="space-y-3 mb-6 pb-6 border-b border-[#E5E0D8]">
                <div class="flex justify-between text-[#6B280]">
                    <span>Nombre d'articles:</span>
                    <span>{{ cart.totalItems }}</span>
                </div>
                <div class="flex justify-between text-[#6B280]">
                    <span>Sous-total:</span>
                    <span>{{ cart.totalPrice|number_format(2, ',', ' ') }} dt</span>
                </div>
            </div>

            <div class="flex justify-between text-lg font-bold text-[#4B5563] mb-6">
                <span>Total:</span>
                <span class="text-[#A7C7E7]">{{ cart.totalPrice|number_format(2, ',', ' ') }} dt</span>
            </div>

            <div class="space-y-3">
                <a href="{{ path('order_checkout') }}" class="block w-full px-4 py-3 bg-[#A7C7E7] text-white rounded-lg font-semibold text-center hover:bg-[#B8D4ED] transition">
                    Passer la commande
                </a>
                <a href="{{ path('user_products_index') }}" class="block w-full px-4 py-3 border border-[#A7C7E7] text-[#A7C7E7] rounded-lg font-semibold text-center hover:bg-[#F5F1EB] transition">
                    Continuer les achats
                </a>
                <form method="POST" action="{{ path('cart_clear') }}" onsubmit="return confirm('Vider le panier?')">
                    <button type="submit" class="w-full px-4 py-3 bg-gray-300 text-gray-700 rounded-lg font-semibold hover:bg-gray-400 transition">
                        Vider le panier
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
<script>
document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.cart-update-form').forEach(function(form) {
        form.addEventListener('submit', function(e) {
            var input = form.querySelector('.cart-qty-input');
            var row = form.closest('.cart-row');
            var errorP = form.querySelector('.cart-qty-error');
            var qty = parseInt(input.value, 10) || 0;
            row.classList.remove('bg-red-50', 'border-l-4', 'border-l-red-500');
            input.classList.remove('border-red-500');
            input.setAttribute('aria-invalid', 'false');
            if (errorP) {
                errorP.classList.add('hidden');
            }
            if (qty < 1) {
                e.preventDefault();
                row.classList.add('bg-red-50', 'border-l-4', 'border-l-red-500');
                input.classList.add('border-red-500');
                input.setAttribute('aria-invalid', 'true');
                input.focus();
                if (errorP) {
                    errorP.classList.remove('hidden');
                }
            }
        });
        var input = form.querySelector('.cart-qty-input');
        var errorP = form.querySelector('.cart-qty-error');
        if (input && errorP) {
            input.addEventListener('input', function() {
                var qty = parseInt(this.value, 10) || 0;
                if (qty >= 1) {
                    this.classList.remove('border-red-500');
                    this.setAttribute('aria-invalid', 'false');
                    errorP.classList.add('hidden');
                    form.closest('.cart-row').classList.remove('bg-red-50', 'border-l-4', 'border-l-red-500');
                }
            });
        }
    });
});
</script>

{% else %}
<div class="bg-white rounded-xl shadow-sm border border-[#E5E0D8] p-12 text-center">
    <svg class="w-16 h-16 mx-auto text-[#E5E0D8] mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16.35 5.4c-1.32-1.6-3.36-2.556-5.54-2.556-3.728 0-6.75 3.022-6.75 6.75s3.022 6.75 6.75 6.75c2.54 0 4.722-1.482 5.756-3.612m3.72-3.612a5.06 5.06 0 01-2.748 4.971m0-9.942a5.06 5.06 0 012.748 4.971M15.75 6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008v-.008z" />
    </svg>
    <h3 class="text-2xl font-bold text-[#4B5563] mb-2">Panier vide</h3>
    <p class="text-[#6B7280] mb-6">Votre panier ne contient aucun produit pour le moment.</p>
    <a href="{{ path('user_products_index') }}" class="inline-block px-6 py-3 bg-[#A7C7E7] text-white rounded-lg font-semibold hover:bg-[#B8D4ED]">
        Retourner aux produits
    </a>
</div>
{% endif %}

{# Mes commandes (même page que le panier pour les utilisateurs connectés) #}
{% if app.user %}
<section class="mt-12">
    <h2 class="text-xl font-bold text-[#4B5563] mb-4">Historique de mes commandes</h2>
    {% if commandes|default([]) is empty %}
    <div class="bg-white rounded-xl shadow-sm border border-[#E5E0D8] p-8 text-center">
        <p class="text-[#6B7280]">Vous n'avez pas encore passé de commande.</p>
        <a href="{{ path('user_products_index') }}" class="inline-block mt-4 px-6 py-3 bg-[#A7C7E7] text-white rounded-lg font-semibold hover:bg-[#B8D4ED]">Voir les produits</a>
    </div>
    {% else %}
    <div class="bg-white rounded-xl shadow-sm border border-[#E5E0D8] overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-[#E5E0D8] bg-[#F5F1EB]">
                        <th class="px-6 py-3 text-left text-sm font-semibold text-[#4B5563]">N° commande</th>
                        <th class="px-6 py-3 text-left text-sm font-semibold text-[#4B5563]">Date</th>
                        <th class="px-6 py-3 text-right text-sm font-semibold text-[#4B5563]">Total</th>
                        <th class="px-6 py-3 text-center text-sm font-semibold text-[#4B5563]">Statut</th>
                        <th class="px-6 py-3 text-center text-sm font-semibold text-[#4B5563]">Suivi</th>
                    </tr>
                </thead>
                <tbody>
                    {% for commande in commandes %}
                    <tr class="border-b border-[#E5E0D8] hover:bg-[#F5F1EB]">
                        <td class="px-6 py-4 font-medium text-[#4B5563]">#{{ commande.id }}</td>
                        <td class="px-6 py-4 text-[#6B7280]">{{ commande.dateCreation|date('d/m/Y H:i') }}</td>
                        <td class="px-6 py-4 text-right font-semibold text-[#4B5563]">{{ commande.total|number_format(2, ',', ' ') }} dt</td>
                        <td class="px-6 py-4 text-center">
                            {% set s = commande.statut %}
                            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium
                                {% if s == 'en_attente' %}bg-amber-100 text-amber-800
                                {% elseif s == 'confirmer' %}bg-blue-100 text-blue-800
                                {% elseif s == 'livraison' %}bg-sky-100 text-sky-800
                                {% elseif s == 'recu' or s == 'livrée' %}bg-emerald-100 text-emerald-800
                                {% elseif s == 'annulée' %}bg-red-100 text-red-800
                                {% else %}bg-gray-100 text-gray-800{% endif %}">
                                {% if s == 'en_attente' %}En attente
                                {% elseif s == 'confirmer' %}Préparation
                                {% elseif s == 'livraison' %}En livraison
                                {% elseif s == 'recu' or s == 'livrée' %}Reçu
                                {% elseif s == 'annulée' %}Annulée
                                {% else %}{{ s }}{% endif %}
                            </span>
                        </td>
                        <td class="px-6 py-4 text-center">
                            <a href="{{ path('order_confirmation', { id: commande.id }) }}" class="inline-flex items-center gap-1.5 px-4 py-2 bg-[#A7C7E7] text-white rounded-lg font-medium text-sm hover:bg-[#B8D4ED] transition">Voir le détail</a>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}
</section>
{% endif %}

{% endblock %}
{% extends 'base.html.twig' %}

{% block title %}Lien invalide - AutiCare{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center p-4 bg-pastel-bg">
    <div class="w-full max-w-md rounded-2xl bg-white shadow-lg border border-pastel-border p-8 text-center">
        <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-red-100 flex items-center justify-center">
            <svg class="w-8 h-8 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
        </div>
        <h1 class="text-xl font-bold text-pastel-text-strong mb-2">Lien invalide</h1>
        <p class="text-pastel-text mb-6">{{ message|default('Ce lien est invalide ou a déjà été utilisé.') }}</p>
        <a href="{{ path('home') }}" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-pastel-lavender text-white font-medium hover:opacity-90 focus:outline focus:ring-2 focus:ring-pastel-lavender">
            Retour à l'accueil
        </a>
    </div>
</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Confirmation - AutiCare{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center p-4 bg-pastel-bg">
    <div class="w-full max-w-md rounded-2xl bg-white shadow-lg border border-pastel-border p-8 text-center">
        <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-pastel-mint-soft flex items-center justify-center">
            <svg class="w-8 h-8 text-pastel-mint" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
        </div>
        <h1 class="text-xl font-bold text-pastel-text-strong mb-2">C'est fait</h1>
        <p class="text-pastel-text mb-6">{{ message|default('Votre demande a bien été enregistrée.') }}</p>
        <a href="{{ path('home') }}" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-pastel-lavender text-white font-medium hover:opacity-90 focus:outline focus:ring-2 focus:ring-pastel-lavender">
            Retour à l'accueil
        </a>
    </div>
</div>
{% endblock %}

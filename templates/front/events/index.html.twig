{% extends 'layouts/user.html.twig' %}

{% block title %}Événements & Ateliers - AutiCare{% endblock %}

{% block user_content %}
<div class="bg-white/95 dark:bg-gray-700/95 backdrop-blur-sm rounded-3xl shadow-pastel-md border-2 border-[#E8DED5] dark:border-gray-600 p-6 md:p-8">
<section class="mb-10">
    <h1 class="text-3xl md:text-4xl font-bold text-[#2D2D2D] dark:text-white mb-2">Événements & Ateliers</h1>
    <p class="text-[#4A4A4A] dark:text-gray-200 text-lg">Découvrez nos ateliers et rencontres par thématique.</p>
</section>

<form method="get" action="{{ path('user_events') }}" class="mb-8 p-5 bg-white dark:bg-gray-600/80 rounded-2xl border-2 border-[#E8DED5] dark:border-gray-500 shadow-pastel overflow-visible">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-[1fr_1fr_1fr_1fr_minmax(12rem,1fr)] gap-4 items-end">
        <div>
            <label for="filter_date_from" class="block font-semibold text-[#3D3D3D] dark:text-gray-100 mb-2">Date début</label>
            <input type="date" id="filter_date_from" name="date_from" value="{{ filter_date_from|default('') }}"
                class="w-full rounded-xl border-2 border-[#E8DED5] dark:border-gray-500 px-4 py-3 text-[#3D3D3D] dark:text-gray-100 bg-white dark:bg-gray-500/50 focus:ring-2 focus:ring-[#CDB4DB] focus:border-[#CDB4DB]">
        </div>
        <div>
            <label for="filter_date_to" class="block font-semibold text-[#3D3D3D] dark:text-gray-100 mb-2">Date fin</label>
            <input type="date" id="filter_date_to" name="date_to" value="{{ filter_date_to|default('') }}"
                class="w-full rounded-xl border-2 border-[#E8DED5] dark:border-gray-500 px-4 py-3 text-[#3D3D3D] dark:text-gray-100 bg-white dark:bg-gray-500/50 focus:ring-2 focus:ring-[#CDB4DB] focus:border-[#CDB4DB]">
        </div>
        <div>
            <label for="filter_lieu" class="block font-semibold text-[#3D3D3D] dark:text-gray-100 mb-2">Lieu</label>
            <input type="text" id="filter_lieu" name="lieu" value="{{ filter_lieu|default('') }}" placeholder="Ex. Salle d'art"
                class="w-full rounded-xl border-2 border-[#E8DED5] dark:border-gray-500 px-4 py-3 text-[#3D3D3D] dark:text-gray-100 bg-white dark:bg-gray-500/50 placeholder-[#9CA3AF] focus:ring-2 focus:ring-[#CDB4DB] focus:border-[#CDB4DB]">
        </div>
        <div>
            <label for="filter_thematique" class="block font-semibold text-[#3D3D3D] dark:text-gray-100 mb-2">Thématique</label>
            <select id="filter_thematique" name="thematique" class="w-full rounded-xl border-2 border-[#E8DED5] dark:border-gray-500 px-4 py-3 text-[#3D3D3D] dark:text-gray-100 bg-white dark:bg-gray-500/50 focus:ring-2 focus:ring-[#CDB4DB] focus:border-[#CDB4DB]">
                <option value="0" {{ (filter_thematique|default(0)) == 0 ? 'selected' : '' }}>Toutes</option>
                {% for t in thematiques|default([]) %}
                <option value="{{ t.id }}" {{ (filter_thematique|default(0)) == t.id ? 'selected' : '' }}>{{ t.nomThematique }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="flex flex-wrap gap-3 items-end min-w-0">
            <button type="submit" class="inline-flex items-center gap-2 px-5 py-3 rounded-xl bg-[#A8BBA3] text-white font-semibold hover:bg-[#94B08E] focus:outline focus:ring-2 focus:ring-[#A8BBA3] focus:ring-offset-2 shadow-pastel transition-all shrink-0">
                <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
                Rechercher
            </button>
            <a href="{{ path('user_events') }}" class="inline-flex items-center justify-center px-5 py-3 rounded-xl border-2 border-[#E8DED5] dark:border-gray-500 text-[#3D3D3D] dark:text-gray-100 font-semibold hover:bg-[#F5F1EB] dark:hover:bg-gray-500/30 focus:outline focus:ring-2 focus:ring-[#CDB4DB] transition-all shrink-0">Réinitialiser</a>
        </div>
    </div>
</form>

{% if filter_lieu|default('') != '' or filter_date_from|default('') != '' or filter_date_to|default('') != '' or (filter_thematique|default(0)) > 0 %}
<p class="text-sm text-[#5C5C5C] dark:text-gray-300 mb-4">Filtres actifs : {% if filter_lieu|default('') != '' %}Lieu « {{ filter_lieu }} »{% endif %}{% if filter_date_from|default('') != '' %} · À partir du {{ filter_date_from }}{% endif %}{% if filter_date_to|default('') != '' %} · Jusqu'au {{ filter_date_to }}{% endif %}{% if (filter_thematique|default(0)) > 0 %} · Thématique sélectionnée{% endif %}</p>
{% endif %}
{% if total_filtered|default(0) > 0 and (sansThematique|default([])|length) == (total_filtered|default(0)) %}
<p class="text-sm text-[#5C5C5C] dark:text-gray-300 mb-4 rounded-xl bg-[#E8DCF0]/50 dark:bg-gray-500/30 border-2 border-[#E8DED5] dark:border-gray-500 px-4 py-3">Tous vos événements sont listés dans « Autres événements » ci-dessous. Assignez une thématique à chaque événement (admin) pour les afficher dans les cartes par thème.</p>
{% endif %}

<div class="flex flex-wrap items-center justify-between gap-4 mb-6">
    <span class="text-sm font-semibold text-[#3D3D3D] dark:text-gray-100">Affichage :</span>
    <div class="flex rounded-xl border-2 border-[#E8DED5] dark:border-gray-500 p-1 bg-[#FDF8F5] dark:bg-gray-500/30" role="group" aria-label="Mode d'affichage">
        <button type="button" id="view-grid-btn" class="events-view-btn rounded-lg px-4 py-2.5 text-sm font-semibold transition-colors bg-[#A8BBA3] text-white" aria-pressed="true" title="Grille">
            <span class="inline-flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" /></svg>
                Grille
            </span>
        </button>
        <button type="button" id="view-list-btn" class="events-view-btn rounded-lg px-4 py-2.5 text-sm font-semibold transition-colors text-[#5C5C5C] dark:text-gray-300 hover:bg-[#E8DED5] dark:hover:bg-gray-500/50 hover:text-[#3D3D3D] dark:hover:text-gray-100" aria-pressed="false" title="Liste">
            <span class="inline-flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" /></svg>
                Liste
            </span>
        </button>
    </div>
</div>

<div id="thematiques-container" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" data-view="grid">
    {% for item in grouped %}
    {% set thematique = item.thematique %}
    {% set evenements = item.evenements %}
    <div class="events-card bg-white dark:bg-gray-600/80 rounded-2xl border-2 border-[#E8DED5] dark:border-gray-500 overflow-hidden flex flex-col shadow-pastel hover:shadow-pastel-md hover:border-[#CDB4DB]/50 dark:hover:border-gray-400 transition-all duration-200 {{ thematique.couleur ? 'border-l-4' : '' }}" {% if thematique.couleur %}style="border-left-color: {{ thematique.couleur }};"{% endif %}>
        <div class="events-card-media flex-shrink-0">
        {% if thematique.image %}
        {% set imgUrl = thematique.image starts with 'http' ? thematique.image : asset(thematique.image) %}
        <div class="aspect-[21/9] max-h-40 bg-[#E5E0D8] dark:bg-gray-500 overflow-hidden">
            <img src="{{ imgUrl }}" alt="{{ thematique.nomThematique }}" class="w-full h-full object-cover" loading="lazy">
        </div>
        {% endif %}
        </div>
        <div class="events-card-body flex flex-col flex-1 min-w-0">
        <div class="p-5 border-b border-[#E8DED5] dark:border-gray-500">
            {% if thematique.couleur and not thematique.image %}
            <span class="inline-block w-10 h-10 rounded-xl border-2 border-[#E8DED5] dark:border-gray-500 mb-3 shrink-0" style="background-color: {{ thematique.couleur }};" title="Couleur"></span>
            {% endif %}
            <h2 class="text-lg font-bold text-[#3D3D3D] dark:text-gray-100 mb-1">{{ thematique.nomThematique }}</h2>
            {% if thematique.sousTitre %}
            <p class="text-[#5C5C5C] dark:text-gray-300 text-sm mb-2">{{ thematique.sousTitre }}</p>
            {% elseif thematique.publicCible %}
            <p class="text-[#5C5C5C] dark:text-gray-300 text-sm mb-2">{{ thematique.publicCible.value }}</p>
            {% endif %}
            <p class="text-[#A8BBA3] dark:text-[#93C5FD] font-semibold text-sm">{{ evenements|length }} événement{{ evenements|length != 1 ? 's' : '' }}</p>
        </div>
        <div class="p-4 flex-1 space-y-3">
            {% for event in evenements %}
            <a href="{{ path('user_event_show', { id: event.id }) }}" class="event-item-card flex flex-col sm:flex-row sm:items-center gap-4 rounded-2xl border-2 border-[#E8DED5] dark:border-gray-500 p-4 bg-[#FDF8F5] dark:bg-gray-500/30 hover:bg-[#F5F1EB] dark:hover:bg-gray-500/50 hover:border-[#CDB4DB]/50 transition-all duration-200 focus:outline focus:ring-2 focus:ring-[#CDB4DB]">
                <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-[#A8BBA3]/30 dark:bg-[#93C5FD]/30 text-[#3D3D3D] dark:text-gray-100 shrink-0">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
                </div>
                <div class="flex-1 min-w-0">
                    <h3 class="font-bold text-[#3D3D3D] dark:text-gray-100 text-sm mb-1">{{ event.title }}</h3>
                    <p class="text-[#5C5C5C] dark:text-gray-300 text-xs flex flex-wrap items-center gap-x-2">
                        <span>{{ event.dateEvent ? event.dateEvent|date('d/m/Y') : '—' }} {{ event.heureDebut ? event.heureDebut|date('H:i') : '' }}</span>
                        <span>·</span>
                        <span>{{ event.lieu }}</span>
                    </p>
                </div>
                <span class="inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl bg-[#A8BBA3] dark:bg-[#93C5FD]/50 text-white text-sm font-semibold hover:bg-[#94B08E] shrink-0 transition-colors">
                    Voir
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                </span>
            </a>
            {% else %}
            <p class="text-[#5C5C5C] dark:text-gray-300 text-sm py-4 text-center rounded-xl bg-[#F5F1EB] dark:bg-gray-500/30">Aucun événement pour le moment.</p>
            {% endfor %}
        </div>
        </div>
    </div>
    {% endfor %}

    {% if sansThematique|length > 0 %}
    <div class="events-card bg-white dark:bg-gray-600/80 rounded-2xl border-2 border-[#E8DED5] dark:border-gray-500 overflow-hidden flex flex-col md:col-span-2 lg:col-span-3 shadow-pastel hover:shadow-pastel-md transition-all duration-200">
        <div class="p-5 border-b border-[#E8DED5] dark:border-gray-500">
            <h2 class="text-lg font-bold text-[#3D3D3D] dark:text-gray-100">Autres événements</h2>
            <p class="text-[#A8BBA3] dark:text-[#93C5FD] font-semibold text-sm">{{ sansThematique|length }} événement{{ sansThematique|length != 1 ? 's' : '' }}</p>
        </div>
        <div class="p-4 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
            {% for event in sansThematique %}
            <a href="{{ path('user_event_show', { id: event.id }) }}" class="event-item-card flex flex-col sm:flex-row sm:items-center gap-4 rounded-2xl border-2 border-[#E8DED5] dark:border-gray-500 p-4 bg-[#FDF8F5] dark:bg-gray-500/30 hover:bg-[#F5F1EB] dark:hover:bg-gray-500/50 hover:border-[#CDB4DB]/50 transition-all duration-200 focus:outline focus:ring-2 focus:ring-[#CDB4DB]">
                <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-[#A8BBA3]/30 dark:bg-[#93C5FD]/30 text-[#3D3D3D] dark:text-gray-100 shrink-0">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
                </div>
                <div class="flex-1 min-w-0">
                    <h3 class="font-bold text-[#3D3D3D] dark:text-gray-100 text-sm mb-1">{{ event.title }}</h3>
                    <p class="text-[#5C5C5C] dark:text-gray-300 text-xs">
                        {{ event.dateEvent ? event.dateEvent|date('d/m/Y') : '—' }} {{ event.heureDebut ? event.heureDebut|date('H:i') : '' }}
                        · {{ event.lieu }}
                    </p>
                </div>
                <span class="inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-xl bg-[#A8BBA3] dark:bg-[#93C5FD]/50 text-white text-sm font-semibold hover:bg-[#94B08E] shrink-0 transition-colors">
                    Voir
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
                </span>
            </a>
            {% endfor %}
        </div>
    </div>
    {% endif %}
</div>

{% if has_active_filters|default(false) and total_filtered|default(0) == 0 %}
<p class="text-center text-[#6B7280] dark:text-gray-300 py-6 rounded-2xl bg-amber-50 dark:bg-amber-900/20 border-2 border-amber-200 dark:border-amber-800 text-amber-800 dark:text-amber-200">Aucun résultat pour ces critères. Vérifiez le lieu, les dates ou la thématique, ou réinitialisez les filtres.</p>
{% endif %}
{% if grouped is empty and (sansThematique|default([])) is empty and not (has_active_filters|default(false)) %}
<p class="text-center text-[#6B7280] dark:text-gray-300 py-12">Aucun événement à venir pour le moment.</p>
{% endif %}
</div>

<style>
#thematiques-container[data-view="list"] {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}
#thematiques-container[data-view="list"] .events-card {
    display: flex;
    flex-direction: row;
    max-width: 100%;
}
#thematiques-container[data-view="list"] .events-card-media {
    width: 14rem;
    min-width: 14rem;
    flex-shrink: 0;
}
#thematiques-container[data-view="list"] .events-card-media .aspect-[21\/9] {
    max-height: none;
    aspect-ratio: 21/9;
    height: 100%;
    min-height: 10rem;
}
#thematiques-container[data-view="list"] .events-card-body {
    display: flex;
    flex-direction: column;
    min-width: 0;
}
</style>

<script>
(function() {
    var container = document.getElementById('thematiques-container');
    var gridBtn = document.getElementById('view-grid-btn');
    var listBtn = document.getElementById('view-list-btn');
    if (!container || !gridBtn || !listBtn) return;
    var key = 'eventsView';
    function setView(view) {
        container.setAttribute('data-view', view);
        if (view === 'grid') {
            gridBtn.classList.add('bg-[#A8BBA3]', 'text-white');
            gridBtn.classList.remove('text-[#5C5C5C]');
            gridBtn.setAttribute('aria-pressed', 'true');
            listBtn.classList.remove('bg-[#A8BBA3]', 'text-white');
            listBtn.classList.add('text-[#5C5C5C]', 'dark:text-gray-300');
            listBtn.setAttribute('aria-pressed', 'false');
        } else {
            listBtn.classList.add('bg-[#A8BBA3]', 'text-white');
            listBtn.classList.remove('text-[#5C5C5C]', 'dark:text-gray-300');
            listBtn.setAttribute('aria-pressed', 'true');
            gridBtn.classList.remove('bg-[#A8BBA3]', 'text-white');
            gridBtn.classList.add('text-[#5C5C5C]', 'dark:text-gray-300');
            gridBtn.setAttribute('aria-pressed', 'false');
        }
        try { localStorage.setItem(key, view); } catch (e) {}
    }
    gridBtn.addEventListener('click', function() { setView('grid'); });
    listBtn.addEventListener('click', function() { setView('list'); });
    try {
        var saved = localStorage.getItem(key);
        if (saved === 'list') setView('list');
    } catch (e) {}
})();
</script>
{% endblock %}
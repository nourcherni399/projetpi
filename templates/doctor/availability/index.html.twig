{% extends 'layouts/doctor.html.twig' %}

{% block title %}Disponibilités - AutiCare Médecin{% endblock %}

{% block doctor_content %}
<h1 class="text-2xl font-bold text-[#374151] tracking-tight mb-6">Gestion des disponibilités</h1>
<div id="form-nouvelle-dispo" class="mb-6 bg-white rounded-2xl border border-[#E5E7EB] shadow-soft overflow-hidden {% if not form.vars.submitted or form.vars.valid %}hidden{% endif %}" aria-hidden="{{ (form.vars.submitted and not form.vars.valid) ? 'false' : 'true' }}">
    <div class="p-5 border-b border-[#E5E7EB] bg-slate-50/50">
        <h2 class="text-lg font-semibold text-[#374151]">Nouvelle disponibilité</h2>
        <p class="text-sm text-[#6B7280] mt-1">Date, heure de début et fin, durée (minutes), disponible.</p>
    </div>
    <div class="p-6">
        {{ form_start(form, { attr: { class: 'space-y-4' }, label_attr: { class: 'block text-[#4B5563] font-medium mb-1' } }) }}
        {{ form_errors(form) }}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                {{ form_label(form.date) }}
                {{ form_widget(form.date) }}
                {{ form_errors(form.date) }}
            </div>
            <div>
                {{ form_label(form.heureDebut) }}
                <div class="mt-1 relative flex items-center rounded-lg border border-[#E5E0D8] bg-white px-4 py-2.5 text-[#4B5563] focus-within:ring-2 focus-within:ring-[#A7C7E7] focus-within:border-transparent">
                    {{ form_widget(form.heureDebut, { attr: { class: 'border-0 bg-transparent p-0 flex-1 min-w-0 pr-10 focus:ring-0 focus:outline-none w-full text-[#4B5563]' } }) }}
                    <span class="absolute right-3 top-1/2 -translate-y-1/2 text-sm font-semibold text-[#4B5563] pointer-events-none" id="heure-debut-ampm" aria-hidden="true">--</span>
                </div>
                {{ form_errors(form.heureDebut) }}
            </div>
            <div>
                {{ form_label(form.heureFin) }}
                <div class="mt-1 relative flex items-center rounded-lg border border-[#E5E0D8] bg-white px-4 py-2.5 text-[#4B5563] focus-within:ring-2 focus-within:ring-[#A7C7E7] focus-within:border-transparent">
                    {{ form_widget(form.heureFin, { attr: { class: 'border-0 bg-transparent p-0 flex-1 min-w-0 pr-10 focus:ring-0 focus:outline-none w-full text-[#4B5563]' } }) }}
                    <span class="absolute right-3 top-1/2 -translate-y-1/2 text-sm font-semibold text-[#4B5563] pointer-events-none" id="heure-fin-ampm" aria-hidden="true">--</span>
                </div>
                {{ form_errors(form.heureFin) }}
            </div>
            <div>
                {{ form_label(form.duree) }}
                {{ form_widget(form.duree) }}
                {{ form_errors(form.duree) }}
            </div>
            <div class="flex items-center gap-2 md:col-span-2">
                {{ form_widget(form.estDispo) }}
                {{ form_label(form.estDispo) }}
                {{ form_errors(form.estDispo) }}
            </div>
        </div>
        <div class="mt-5 flex gap-3">
            <button type="submit" class="px-5 py-2.5 rounded-xl bg-[#5B9BD5] text-white font-medium hover:bg-[#4A8BC4] focus:outline focus:ring-2 focus:ring-[#5B9BD5]/50 shadow-soft transition-colors">Enregistrer la disponibilité</button>
            <button type="button" id="btn-annuler-dispo" class="px-5 py-2.5 rounded-xl border border-[#E5E7EB] text-[#374151] font-medium hover:bg-slate-100 focus:outline focus:ring-2 focus:ring-[#5B9BD5]/40 transition-colors">Annuler</button>
        </div>
        {{ form_end(form) }}
    </div>
</div>

<div class="bg-white rounded-2xl border border-[#E5E7EB] shadow-soft overflow-hidden">
    <div class="p-4 border-b border-[#E5E7EB] flex flex-wrap gap-4 justify-between items-center bg-white">
        <form method="get" action="{{ path('doctor_availability') }}" class="flex items-center gap-2 max-w-xs w-full">
            {% if calendar_first is defined %}
            <input type="hidden" name="month" value="{{ calendar_first|date('Y-m') }}">
            {% endif %}
            <input
                type="search"
                name="q"
                value="{{ search ?? app.request.query.get('q') }}"
                placeholder="Rechercher un créneau…"
                class="px-4 py-2.5 rounded-xl border border-[#E5E7EB] bg-slate-50 text-[#374151] placeholder-[#9CA3AF] focus:outline focus:ring-2 focus:ring-[#5B9BD5]/40 focus:border-[#5B9BD5] w-full transition-shadow"
            >
        </form>
        <button type="button" id="btn-nouvelle-dispo" class="px-5 py-2.5 rounded-xl bg-[#5B9BD5] text-white font-medium hover:bg-[#4A8BC4] focus:outline focus:ring-2 focus:ring-[#5B9BD5]/50 shadow-soft transition-colors">Nouvelle disponibilité</button>
    </div>

    {# Navigation du calendrier #}
    <div class="p-4 border-b border-[#E5E7EB] flex items-center justify-between bg-slate-50/30">
        <a href="{{ path('doctor_availability', { month: prev_month, q: search|default('') }) }}" class="p-2.5 rounded-xl border border-[#E5E7EB] text-[#374151] hover:bg-slate-100 focus:outline focus:ring-2 focus:ring-[#5B9BD5]/40 transition-colors" aria-label="Mois précédent">←</a>
        <h2 class="text-lg font-semibold text-[#374151] capitalize">{{ calendar_label|default('') }}</h2>
        <a href="{{ path('doctor_availability', { month: next_month, q: search|default('') }) }}" class="p-2.5 rounded-xl border border-[#E5E7EB] text-[#374151] hover:bg-slate-100 focus:outline focus:ring-2 focus:ring-[#5B9BD5]/40 transition-colors" aria-label="Mois suivant">→</a>
    </div>

    {# Grille calendrier (lundi = premier jour) #}
    <div class="p-4 overflow-x-auto">
        <table class="w-full border-collapse calendar-grid">
            <thead>
                <tr>
                    <th class="p-2 text-center text-xs font-semibold uppercase tracking-wider text-[#6B7280] border-b border-[#E5E7EB] bg-[#F9FAFB]">Lun</th>
                    <th class="p-2 text-center text-xs font-semibold uppercase tracking-wider text-[#6B7280] border-b border-[#E5E7EB] bg-[#F9FAFB]">Mar</th>
                    <th class="p-2 text-center text-xs font-semibold uppercase tracking-wider text-[#6B7280] border-b border-[#E5E7EB] bg-[#F9FAFB]">Mer</th>
                    <th class="p-2 text-center text-xs font-semibold uppercase tracking-wider text-[#6B7280] border-b border-[#E5E7EB] bg-[#F9FAFB]">Jeu</th>
                    <th class="p-2 text-center text-xs font-semibold uppercase tracking-wider text-[#6B7280] border-b border-[#E5E7EB] bg-[#F9FAFB]">Ven</th>
                    <th class="p-2 text-center text-xs font-semibold uppercase tracking-wider text-[#6B7280] border-b border-[#E5E7EB] bg-[#F9FAFB]">Sam</th>
                    <th class="p-2 text-center text-xs font-semibold uppercase tracking-wider text-[#6B7280] border-b border-[#E5E7EB] bg-[#F9FAFB]">Dim</th>
                </tr>
            </thead>
            <tbody>
                {% set today = "now"|date("Y-m-d") %}
                {% for week in calendar_weeks|default([]) %}
                <tr>
                    {% for day in week %}
                    <td class="align-top border-b border-r border-[#E5E7EB] p-2 min-h-[120px] w-[14.28%]                     {% if day.date|date('Y-m-d') == today %}bg-[#EFF6FF]{% elseif day.is_current_month %}bg-white{% else %}bg-slate-50/50{% endif %}">
                        <div class="flex items-center justify-center w-7 h-7 rounded-full text-sm font-semibold mb-2 {% if day.date|date('Y-m-d') == today %}bg-[#5B9BD5] text-white{% elseif day.is_current_month %}text-[#374151]{% else %}text-[#9CA3AF]{% endif %}">{{ day.date|date('j') }}</div>
                        <div class="space-y-2">
                            {% for dispo in day.dispos %}
                            <div class="creneau-card group rounded-xl bg-white border border-[#E5E7EB] shadow-soft hover:shadow-soft-md hover:border-[#5B9BD5]/50 transition-all duration-200 overflow-hidden">
                                <div class="flex items-center gap-2 px-2.5 py-2 border-l-4 border-l-[#5B9BD5] bg-gradient-to-r from-[#F0F9FF] to-white">
                                    <span class="text-sm font-semibold tabular-nums text-[#374151]">{{ dispo.heureDebut ? dispo.heureDebut|date('H:i') : '—' }} – {{ dispo.heureFin ? dispo.heureFin|date('H:i') : '—' }}</span>
                                    <span class="text-[10px] font-medium px-1.5 py-0.5 rounded-full bg-[#DBEAFE] text-[#1D4ED8]">{{ dispo.duree }} min</span>
                                </div>
                                <div class="flex items-center justify-center gap-1.5 px-2 pb-2 pt-0.5">
                                    <a href="{{ path('doctor_availability_edit', { id: dispo.id }) }}" title="Modifier" class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-[#DBEAFE] text-[#5B9BD5] hover:bg-[#BFDBFE] transition-colors" aria-label="Modifier">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
                                    </a>
                                    <form action="{{ path('doctor_availability_delete', { id: dispo.id }) }}" method="post" class="inline" onsubmit="return confirm('Supprimer ce créneau ?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('doctor_availability_delete_' ~ dispo.id) }}">
                                        <button type="submit" title="Supprimer" class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-[#FEF2F2] text-[#DC2626] hover:bg-[#FEE2E2] transition-colors" aria-label="Supprimer">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
                                        </button>
                                    </form>
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                    </td>
                    {% endfor %}
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<script>
var formDispoEl = document.getElementById('form-nouvelle-dispo');
document.getElementById('btn-nouvelle-dispo').addEventListener('click', function() {
    formDispoEl.classList.toggle('hidden');
    formDispoEl.setAttribute('aria-hidden', formDispoEl.classList.contains('hidden'));
});
document.getElementById('btn-annuler-dispo').addEventListener('click', function() {
    formDispoEl.classList.add('hidden');
    formDispoEl.setAttribute('aria-hidden', 'true');
});

function updateAmPm(input, spanId) {
    var span = document.getElementById(spanId);
    if (!span) return;
    var val = input ? input.value : '';
    if (!val) { span.textContent = '--'; return; }
    var h = parseInt(val.split(':')[0], 10);
    span.textContent = h >= 12 ? 'PM' : 'AM';
}
var timeInputs = formDispoEl.querySelectorAll('input[type="time"]');
if (timeInputs.length >= 2) {
    timeInputs[0].addEventListener('input', function() { updateAmPm(timeInputs[0], 'heure-debut-ampm'); });
    timeInputs[0].addEventListener('change', function() { updateAmPm(timeInputs[0], 'heure-debut-ampm'); });
    timeInputs[1].addEventListener('input', function() { updateAmPm(timeInputs[1], 'heure-fin-ampm'); });
    timeInputs[1].addEventListener('change', function() { updateAmPm(timeInputs[1], 'heure-fin-ampm'); });
    updateAmPm(timeInputs[0], 'heure-debut-ampm');
    updateAmPm(timeInputs[1], 'heure-fin-ampm');
}
</script>
{% endblock %}

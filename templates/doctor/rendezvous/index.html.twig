{% extends 'layouts/doctor.html.twig' %}

{% block title %}Rendez-vous - AutiCare Médecin{% endblock %}

{% block doctor_content %}
<div class="space-y-6">
    <div class="bg-gradient-to-r from-[#A7C7E7] via-[#B8D4ED] to-[#C5D9F2] rounded-2xl p-8 text-white shadow-xl hover:shadow-2xl transition-all duration-300">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-4xl font-bold mb-3 flex items-center gap-3">
                    <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12A2 2 0 002 2z" />
                    </svg>
                    Mes rendez-vous
                </h1>
                <p class="text-blue-100 text-lg">Gérez vos consultations et suivez vos patients</p>
            </div>
            {% if stats is defined %}
            <div class="text-center bg-white/20 backdrop-blur-sm rounded-xl p-6">
                <div class="text-5xl font-bold">{{ stats.total }}</div>
                <div class="text-sm text-blue-100 mt-2">Total rendez-vous</div>
            </div>
            {% else %}
            <div class="text-center bg-white/20 backdrop-blur-sm rounded-xl p-6">
                <div class="text-5xl font-bold">{{ rendez_vous|length }}</div>
                <div class="text-sm text-blue-100 mt-2">Total rendez-vous</div>
            </div>
            {% endif %}
        </div>
    </div>

    {% if stats is defined %}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-gradient-to-br from-green-50 to-emerald-100 rounded-2xl border border-green-200 p-6 hover:shadow-xl transition-all duration-300">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-green-600 text-sm font-semibold">Confirmés</p>
                    <p class="text-4xl font-bold text-green-900 mt-3">{{ stats.confirmes ?? 0 }}</p>
                </div>
            </div>
        </div>
        <div class="bg-gradient-to-br from-amber-50 to-orange-100 rounded-2xl border border-amber-200 p-6 hover:shadow-xl transition-all duration-300">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-amber-600 text-sm font-semibold">En attente</p>
                    <p class="text-4xl font-bold text-amber-900 mt-3">{{ stats.en_attente ?? 0 }}</p>
                </div>
            </div>
        </div>
        <div class="bg-gradient-to-br from-red-50 to-pink-100 rounded-2xl border border-red-200 p-6 hover:shadow-xl transition-all duration-300">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-red-600 text-sm font-semibold">Annulés</p>
                    <p class="text-4xl font-bold text-red-900 mt-3">{{ stats.annules ?? 0 }}</p>
                </div>
            </div>
        </div>
        <div class="bg-gradient-to-br from-blue-50 to-indigo-100 rounded-2xl border border-blue-200 p-6 hover:shadow-xl transition-all duration-300">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-blue-600 text-sm font-semibold">Aujourd'hui</p>
                    <p class="text-4xl font-bold text-blue-900 mt-3">{{ today_count is defined ? today_count : 0 }}</p>
                </div>
            </div>
        </div>
    </div>
    {% endif %}

    {% set currentOrder = order|default('asc') %}
    {% set sortParams = { order: currentOrder == 'asc' ? 'desc' : 'asc' } %}
    {% if search is defined and search is not empty %}{% set sortParams = sortParams|merge({ q: search }) %}{% endif %}

    <div class="flex flex-wrap items-center justify-end gap-2 mb-4">
        <a href="{{ path('doctor_rendezvous_calendrier') }}"
           class="inline-flex items-center gap-2 px-3 py-2 rounded-lg bg-[#A7C7E7] text-white text-sm font-medium hover:bg-[#95b8dc] focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#A7C7E7]">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
            </svg>
            Vue calendrier
        </a>
        <a href="{{ path('doctor_rendezvous', sortParams) }}"
           class="inline-flex items-center gap-2 px-3 py-2 rounded-lg border border-gray-300 text-sm font-medium text-gray-700 bg-white hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#A7C7E7]">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h8m-6 5h6m-4 5h4" />
            </svg>
            Trier par date {{ currentOrder == 'asc' ? '(ancien → récent)' : '(récent → ancien)' }}
        </a>
    </div>

    {% if rendez_vous_confirmes is empty and rendez_vous_en_attente is empty and rendez_vous_annules is empty %}
    <div class="bg-white rounded-2xl shadow-lg border border-gray-200 p-12 text-center">
        <svg class="w-16 h-16 mx-auto text-gray-400 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12A2 2 0 002 2z" />
        </svg>
        <h3 class="text-xl font-semibold text-gray-600 mb-2">Aucun rendez-vous</h3>
        <p class="text-gray-500">Vous n'avez pas encore de rendez-vous programmés.</p>
    </div>
    {% else %}
    {% set table_header %}
    <thead class="bg-gradient-to-r from-gray-50 to-gray-100 border-b border-gray-200">
        <tr>
            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Patient</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Date & Heure</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Statut</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Contact</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Note patient</th>
            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-700 uppercase tracking-wider">Action</th>
        </tr>
    </thead>
    {% endset %}

    {# ——— Confirmés ——— #}
    <div class="bg-white rounded-2xl shadow-lg border border-gray-200 overflow-hidden mb-6">
        <div class="bg-gradient-to-r from-emerald-50 to-green-50 px-6 py-4 border-b border-emerald-200">
            <h2 class="text-lg font-bold text-emerald-800 flex items-center gap-2">
                <span class="w-2 h-6 rounded-full bg-emerald-500"></span>
                Rendez-vous confirmés
                <span class="ml-2 text-sm font-normal text-emerald-600">({{ rendez_vous_confirmes|length }})</span>
            </h2>
        </div>
        <div class="overflow-x-auto">
            {% if rendez_vous_confirmes is empty %}
            <p class="p-6 text-gray-500 text-sm">Aucun rendez-vous confirmé.</p>
            {% else %}
            <table class="w-full">
                {{ table_header }}
                <tbody class="divide-y divide-gray-200">
                    {% for rv in rendez_vous_confirmes %}
                        {% include 'doctor/rendezvous/_row.html.twig' with { rv: rv, statut_val: 'confirmer' } %}
                    {% endfor %}
                </tbody>
            </table>
            {% endif %}
        </div>
    </div>

    {# ——— En attente ——— #}
    <div class="bg-white rounded-2xl shadow-lg border border-gray-200 overflow-hidden mb-6">
        <div class="bg-gradient-to-r from-amber-50 to-orange-50 px-6 py-4 border-b border-amber-200">
            <h2 class="text-lg font-bold text-amber-800 flex items-center gap-2">
                <span class="w-2 h-6 rounded-full bg-amber-500"></span>
                Rendez-vous en attente
                <span class="ml-2 text-sm font-normal text-amber-600">({{ rendez_vous_en_attente|length }})</span>
            </h2>
        </div>
        <div class="overflow-x-auto">
            {% if rendez_vous_en_attente is empty %}
            <p class="p-6 text-gray-500 text-sm">Aucun rendez-vous en attente.</p>
            {% else %}
            <table class="w-full">
                {{ table_header }}
                <tbody class="divide-y divide-gray-200">
                    {% for rv in rendez_vous_en_attente %}
                        {% include 'doctor/rendezvous/_row.html.twig' with { rv: rv, statut_val: 'en_attente' } %}
                    {% endfor %}
                </tbody>
            </table>
            {% endif %}
        </div>
    </div>

    {# ——— Annulés ——— #}
    <div class="bg-white rounded-2xl shadow-lg border border-gray-200 overflow-hidden">
        <div class="bg-gradient-to-r from-red-50 to-pink-50 px-6 py-4 border-b border-red-200">
            <h2 class="text-lg font-bold text-red-800 flex items-center gap-2">
                <span class="w-2 h-6 rounded-full bg-red-500"></span>
                Rendez-vous annulés
                <span class="ml-2 text-sm font-normal text-red-600">({{ rendez_vous_annules|length }})</span>
            </h2>
        </div>
        <div class="overflow-x-auto">
            {% if rendez_vous_annules is empty %}
            <p class="p-6 text-gray-500 text-sm">Aucun rendez-vous annulé.</p>
            {% else %}
            <table class="w-full">
                {{ table_header }}
                <tbody class="divide-y divide-gray-200">
                    {% for rv in rendez_vous_annules %}
                        {% include 'doctor/rendezvous/_row.html.twig' with { rv: rv, statut_val: 'annuler' } %}
                    {% endfor %}
                </tbody>
            </table>
            {% endif %}
        </div>
    </div>
    {% endif %}
</div>

<script>
function toggleNote(rdvId) {
    const noteEl = document.getElementById('note-' + rdvId);
    const btn = document.querySelector('[onclick="toggleNote(' + rdvId + ')"]');
    const btnText = document.querySelector('.note-btn-text-' + rdvId);
    if (!noteEl || !btn) return;
    const isHidden = noteEl.classList.contains('hidden');
    noteEl.classList.toggle('hidden', !isHidden);
    btn.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
    if (btnText) btnText.textContent = isHidden ? 'Masquer la note' : 'Voir la note patient';
}
</script>
{% endblock %}
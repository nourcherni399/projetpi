<tr class="hover:bg-gray-50 transition-colors">
    <td class="px-6 py-4">
        <div class="flex items-center gap-3">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-[#A7C7E7] to-[#B8D4ED] flex items-center justify-center text-white font-bold">
                {% if rv.patient %}
                    {{ rv.patient.nom|first|upper }}{{ rv.patient.prenom|first|upper }}
                {% else %}
                    {{ rv.nom|first|upper }}{{ rv.prenom|first|upper }}
                {% endif %}
            </div>
            <div>
                <div class="font-semibold text-gray-900">
                    {% if rv.patient %}
                        {{ rv.patient.prenom }} {{ rv.patient.nom }}
                    {% else %}
                        {{ rv.prenom }} {{ rv.nom }}
                    {% endif %}
                </div>
            </div>
        </div>
    </td>
    <td class="px-6 py-4 text-gray-700">
        {% if rv.dateRdv is defined and rv.dateRdv is not null %}
            {{ rv.dateRdv|date('d/m/Y') }}
            {% if rv.disponibilite is defined and rv.disponibilite is not null and rv.disponibilite.heureDebut is defined and rv.disponibilite.heureFin is defined %}
                {{ rv.disponibilite.heureDebut|date('H:i') }} - {{ rv.disponibilite.heureFin|date('H:i') }}
            {% else %}
                —
            {% endif %}
        {% else %}
            —
        {% endif %}
    </td>
    <td class="px-6 py-4">
        {% if statut_val == 'confirmer' %}
            <span class="px-2 py-1 text-xs rounded-full bg-emerald-100 text-emerald-800">Confirmé</span>
        {% elseif statut_val == 'annuler' %}
            <span class="px-2 py-1 text-xs rounded-full bg-red-100 text-red-800">Annulé</span>
        {% else %}
            <span class="px-2 py-1 text-xs rounded-full bg-amber-100 text-amber-800">En attente</span>
        {% endif %}
    </td>
    <td class="px-6 py-4 text-gray-700">
        {{ (rv.telephone is defined and rv.telephone is not null and rv.telephone != '') ? rv.telephone : (rv.patient is defined and rv.patient is not null and rv.patient.telephone is defined and rv.patient.telephone is not null ? rv.patient.telephone : '—') }}
    </td>
    <td class="px-6 py-4">
        {% set hasNote = rv.notePatient is defined and rv.notePatient and rv.notePatient != 'vide' %}
        {% if hasNote %}
            <button type="button"
                    class="inline-flex items-center gap-2 px-3 py-1.5 text-sm font-medium text-purple-700 bg-purple-100 hover:bg-purple-200 rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-purple-500 focus:ring-offset-1"
                    onclick="toggleNote({{ rv.id }})"
                    aria-expanded="false"
                    aria-controls="note-{{ rv.id }}">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
                <span class="note-btn-text-{{ rv.id }}">Voir la note patient</span>
            </button>
            <div id="note-{{ rv.id }}" class="hidden mt-3 p-4 bg-purple-50 rounded-lg border border-purple-200">
                <p class="text-sm text-gray-700 whitespace-pre-wrap">{{ rv.notePatient }}</p>
            </div>
        {% else %}
            <span class="text-gray-400 text-sm">—</span>
        {% endif %}
    </td>
    <td class="px-6 py-4">
        <div class="flex flex-wrap items-center gap-2">
            {% if sms_enabled|default(false) and statut_val == 'confirmer' and rv.dateRdv and rv.disponibilite and (rv.dateRdv|date('Y-m-d')) >= ('now'|date('Y-m-d')) %}
                <form method="post" action="{{ path('doctor_rendezvous_envoyer_rappel_sms', { id: rv.id }) }}" class="inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('doctor_rdv_rappel_sms_' ~ rv.id) }}">
                    <button type="submit"
                            class="inline-flex items-center gap-2 px-4 py-2 rounded-xl text-sm font-semibold text-white bg-gradient-to-r from-emerald-500 to-teal-600 hover:from-emerald-600 hover:to-teal-700 shadow-sm hover:shadow-md border border-emerald-400/30 transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-emerald-400 focus:ring-offset-2 active:scale-[0.98]"
                            title="Envoyer un SMS de rappel au patient (24h avant le RDV)">
                        <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                        </svg>
                        <span>Rappel SMS 24h</span>
                    </button>
                </form>
            {% endif %}
            <a href="{{ path('doctor_rendezvous_edit', { id: rv.id }) }}"
               class="inline-flex items-center justify-center w-9 h-9 rounded-lg text-blue-600 bg-blue-50 hover:bg-blue-100 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-1"
               title="Modifier">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125" />
                </svg>
            </a>
            <form method="post" action="{{ path('doctor_rendezvous_delete', { id: rv.id }) }}" class="inline"
                  onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce rendez-vous ?');">
                <input type="hidden" name="_token" value="{{ csrf_token('doctor_rendezvous_delete_' ~ rv.id) }}">
                <button type="submit"
                        class="inline-flex items-center justify-center w-9 h-9 rounded-lg text-red-600 bg-red-50 hover:bg-red-100 transition-colors focus:outline-none focus:ring-2 focus:ring-red-500 focus:ring-offset-1"
                        title="Supprimer">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                    </svg>
                </button>
            </form>
        </div>
    </td>
</tr>

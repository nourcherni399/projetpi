{% extends 'layouts/doctor.html.twig' %}

{% block title %}Modifier la note - AutiCare Médecin{% endblock %}

{% block doctor_content %}
<div class="space-y-6">
    <div class="flex items-center gap-4">
        <a href="{{ path('doctor_notes') }}" class="inline-flex items-center gap-2 text-[#6B7280] hover:text-[#A7C7E7] focus:outline focus:ring-2 focus:ring-[#A7C7E7] rounded-lg">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
            Retour aux notes
        </a>
    </div>

    <div class="bg-white rounded-2xl border border-[#E5E0D8] shadow-lg overflow-hidden">
        <div class="p-6 border-b border-[#E5E0D8] bg-gradient-to-r from-[#A7C7E7]/10 to-transparent">
            <h1 class="text-2xl font-bold text-[#4B5563]">Modifier la note</h1>
            <p class="text-[#6B7280] text-sm mt-1">Modifiez le contenu de la note avec l'éditeur de texte riche.</p>
        </div>
        <div class="p-6">
            {{ form_start(form, { attr: { class: 'space-y-4 note-form-rich', 'data-turbo': 'false', novalidate: 'novalidate', 'data-note-editor-id': 'note_editor_edit_content', 'data-note-field-id': 'note_contenu_field_edit' }, label_attr: { class: 'block text-[#4B5563] font-medium mb-1' } }) }}
            {{ form_errors(form) }}
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    {{ form_label(form.patient) }}
                    {{ form_widget(form.patient, { 'attr': { 'class': 'mt-1 block w-full rounded-lg border border-[#E5E0D8] bg-white px-4 py-2.5 text-[#4B5563] focus:outline focus:ring-2 focus:ring-[#A7C7E7]' } }) }}
                    {{ form_errors(form.patient) }}
                </div>
                <div class="md:col-span-2">
                    {{ form_label(form.contenu) }}
                    <div class="note-rich-editor-wrapper rounded-lg border border-[#E5E0D8] bg-white overflow-hidden focus-within:ring-2 focus-within:ring-[#A7C7E7] focus-within:border-transparent" data-note-editor-id="note_editor_edit_content">
                        <div class="note-toolbar flex flex-wrap items-center gap-0 p-2 border-b border-[#E5E0D8] bg-[#FAFAF9] text-[#4B5563]" onmousedown="var w=event.target.closest('.note-rich-editor-wrapper');if(w&&w.getAttribute('data-note-editor-id')&&typeof noteEditorSaveSel==='function')noteEditorSaveSel(w.getAttribute('data-note-editor-id'));var b=event.target.closest('.note-tb-btn');if(b)event.preventDefault();" onclick="var w=event.target.closest('.note-rich-editor-wrapper');var eid=w?w.getAttribute('data-note-editor-id'):'note_editor_content';var fid=(eid==='note_editor_edit_content')?'note_contenu_field_edit':'note_contenu_field';var b=event.target.closest('.note-tb-btn');if(b&&b.getAttribute('data-cmd')){if(typeof noteEditorCmd==='function')noteEditorCmd(b.getAttribute('data-cmd'),eid,fid);return false;}">
                            <div class="flex items-center gap-0.5">
                                <select class="note-toolbar-select ml-1 mr-0.5 h-8 min-w-0 rounded border border-[#E5E0D8] bg-white px-2 text-sm text-[#4B5563] focus:outline focus:ring-2 focus:ring-[#A7C7E7]" data-cmd="fontName" title="Police">
                                    <option value="">Police</option>
                                    <option value="Arial">Arial</option>
                                    <option value="Georgia">Georgia</option>
                                    <option value="Times New Roman">Times New Roman</option>
                                    <option value="Verdana">Verdana</option>
                                    <option value="Courier New">Courier New</option>
                                    <option value="Trebuchet MS">Trebuchet MS</option>
                                </select>
                                <select class="note-toolbar-select h-8 min-w-0 rounded border border-[#E5E0D8] bg-white px-2 text-sm text-[#4B5563] focus:outline focus:ring-2 focus:ring-[#A7C7E7]" data-cmd="fontSize" title="Taille">
                                    <option value="">Taille</option>
                                    <option value="1">Très petit</option>
                                    <option value="2">Petit</option>
                                    <option value="3">Normal</option>
                                    <option value="4">Moyen</option>
                                    <option value="5">Grand</option>
                                    <option value="6">Très grand</option>
                                    <option value="7">Maximum</option>
                                </select>
                            </div>
                            <span class="w-px h-6 bg-[#E5E0D8] mx-1.5"></span>
                            <div class="flex items-center gap-0.5">
                                <button type="button" class="note-tb-btn p-2 rounded hover:bg-[#E5E0D8] focus:outline focus:ring-2 focus:ring-[#A7C7E7]" title="Gras" data-cmd="bold"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M15.6 10.79c.97-.67 1.65-1.77 1.65-2.79 0-2.26-1.75-4-4-4H7v14h7.04c2.09 0 3.71-1.7 3.71-3.79 0-1.52-.86-2.82-2.15-3.42zM10 6.5h3c.83 0 1.5.67 1.5 1.5s-.67 1.5-1.5 1.5h-3v-3zm3.5 9H10v-3h3.5c.83 0 1.5.67 1.5 1.5s-.67 1.5-1.5 1.5z"/></svg></button>
                                <button type="button" class="note-tb-btn p-2 rounded hover:bg-[#E5E0D8] focus:outline focus:ring-2 focus:ring-[#A7C7E7]" title="Italique" data-cmd="italic"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M10 4v3h2.21l-3.42 8H6v3h8v-3h-2.21l3.42-8H18V4z"/></svg></button>
                                <button type="button" class="note-tb-btn p-2 rounded hover:bg-[#E5E0D8] focus:outline focus:ring-2 focus:ring-[#A7C7E7]" title="Souligner" data-cmd="underline"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 17c3.31 0 6-2.69 6-6V3h-2.5v8c0 1.93-1.57 3.5-3.5 3.5S8.5 12.93 8.5 11V3H6v8c0 3.31 2.69 6 6 6zm-5 2v2h14v-2H7z"/></svg></button>
                            </div>
                            <span class="w-px h-6 bg-[#E5E0D8] mx-1.5"></span>
                            <div class="flex items-center gap-0.5">
                                <button type="button" class="note-tb-btn p-2 rounded hover:bg-[#E5E0D8] focus:outline focus:ring-2 focus:ring-[#A7C7E7]" title="Aligner à gauche" data-cmd="justifyLeft"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M15 15H3v2h12v-2zm0-8H3v2h12V7zM3 13h18v-2H3v2zm0 8h18v-2H3v2zM3 3v2h18V3H3z"/></svg></button>
                                <button type="button" class="note-tb-btn p-2 rounded hover:bg-[#E5E0D8] focus:outline focus:ring-2 focus:ring-[#A7C7E7]" title="Centrer" data-cmd="justifyCenter"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M7 15v2h10v-2H7zm-4 6h18v-2H3v2zm0-8h18v-2H3v2zm4-6v2h10V7H7zM3 3v2h18V3H3z"/></svg></button>
                                <button type="button" class="note-tb-btn p-2 rounded hover:bg-[#E5E0D8] focus:outline focus:ring-2 focus:ring-[#A7C7E7]" title="Aligner à droite" data-cmd="justifyRight"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M3 21h18v-2H3v2zm6-4h12v-2H9v2zm-6-4h18v-2H3v2zm6-4h12V7H9v2zM3 3v2h18V3H3z"/></svg></button>
                                <button type="button" class="note-tb-btn p-2 rounded hover:bg-[#E5E0D8] focus:outline focus:ring-2 focus:ring-[#A7C7E7]" title="Justifier" data-cmd="justifyFull"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M3 21h18v-2H3v2zm0-4h18v-2H3v2zm0-4h18v-2H3v2zm0-4h18V7H3v2z"/></svg></button>
                            </div>
                            <span class="w-px h-6 bg-[#E5E0D8] mx-1.5"></span>
                            <div class="flex items-center gap-0.5">
                                <button type="button" class="note-tb-btn p-2 rounded hover:bg-[#E5E0D8] focus:outline focus:ring-2 focus:ring-[#A7C7E7]" title="Liste à puces" data-cmd="insertUnorderedList"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M4 10.5c-.83 0-1.5.67-1.5 1.5s.67 1.5 1.5 1.5 1.5-.67 1.5-1.5-.67-1.5-1.5-1.5zm0-6c-.83 0-1.5.67-1.5 1.5S3.17 7.5 4 7.5 5.5 6.83 5.5 6 4.83 4.5 4 4.5zm0 12c-.83 0-1.5.68-1.5 1.5s.68 1.5 1.5 1.5 1.5-.68 1.5-1.5-.67-1.5-1.5-1.5zM7 19h14v-2H7v2zm0-6h14v-2H7v2zm0-8v2h14V5H7z"/></svg></button>
                                <button type="button" class="note-tb-btn p-2 rounded hover:bg-[#E5E0D8] focus:outline focus:ring-2 focus:ring-[#A7C7E7]" title="Liste numérotée" data-cmd="insertOrderedList"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M2 17h2v.5H3v1h1v.5H2v1h3v-4H2v1zm1-9h1V4H2v1h1v3zm-1 3h1.8L2 13.1v.9h3v-1H3.2L5 10.9V10H2v1zm5-6v2h14V5H7zm0 14h14v-2H7v2zm0-6h14v-2H7v2z"/></svg></button>
                            </div>
                            <span class="w-px h-6 bg-[#E5E0D8] mx-1.5"></span>
                            <div class="flex items-center gap-0.5">
                                <button type="button" class="note-tb-btn p-2 rounded hover:bg-[#E5E0D8] focus:outline focus:ring-2 focus:ring-[#A7C7E7]" title="Annuler" data-cmd="undo"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12.5 8c-2.65 0-5.05.99-6.9 2.6L2 7v9h9l-3.62-3.62c1.39-1.16 3.16-1.88 5.12-1.88 3.54 0 6.55 2.31 7.6 5.5l2.37-.78C21.08 11.03 17.15 8 12.5 8z"/></svg></button>
                                <button type="button" class="note-tb-btn p-2 rounded hover:bg-[#E5E0D8] focus:outline focus:ring-2 focus:ring-[#A7C7E7]" title="Rétablir" data-cmd="redo"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.4 10.6C16.55 8.99 14.15 8 11.5 8c-4.65 0-8.58 3.03-9.96 7.22L3.9 16c1.05-3.19 4.05-5.5 7.6-5.5 2.95 0 5.73 1.73 7.06 4.27l3.62-3.62V7h-9l2.22 2.22z"/></svg></button>
                            </div>
                            <span class="w-px h-6 bg-[#E5E0D8] mx-1.5"></span>
                            <div class="flex items-center gap-0.5">
                                <button type="button" class="note-tb-btn p-2 rounded hover:bg-[#E5E0D8] focus:outline focus:ring-2 focus:ring-[#A7C7E7]" title="Insérer un lien" data-cmd="link"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M3.9 12c0-1.71 1.39-3.1 3.1-3.1h4V7H7c-2.76 0-5 2.24-5 5s2.24 5 5 5h4v-1.9H7c-1.71 0-3.1-1.39-3.1-3.1zM8 13h8v-2H8v2zm9-6h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1s-1.39 3.1-3.1 3.1h-4V17h4c2.76 0 5-2.24 5-5s-2.24-5-5-5z"/></svg></button>
                                <button type="button" class="note-tb-btn p-2 rounded hover:bg-[#E5E0D8] focus:outline focus:ring-2 focus:ring-[#A7C7E7]" title="Supprimer le lien" data-cmd="unlink"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17 7h-4v1.9h4c1.71 0 3.1 1.39 3.1 3.1 0 1.43-1.04 2.61-2.42 2.92l1.13 1.13c1.63-.49 2.81-1.88 2.81-3.55 0-2.21-1.79-4-4-4H7V5H3v2h2.17L2.06 9.91 3.5 11.33 17 7zm-4 10h4c1.71 0 3.1-1.39 3.1-3.1 0-1.43-1.04-2.61-2.42-2.92l-1.13-1.13c-1.63.49-2.81 1.88-2.81 3.55 0 2.21 1.79 4 4 4h4v2h4v-2h-2.17l3.11 3.11 1.44-1.42L17 17z"/></svg></button>
                                <button type="button" class="note-tb-btn p-2 rounded hover:bg-[#E5E0D8] focus:outline focus:ring-2 focus:ring-[#A7C7E7]" title="Supprimer le formatage" data-cmd="removeFormat"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M3.27 5L2 6.27l6.97 6.97L6 15l3 3 .95-2.94 6.26 6.26L19 18.27 3.55 2.9 3.27 5zM15 9l2 2h-3l-2-2h3zm-4 8l2 2H3v-2h3l2-2H5l-4-4 2.83-2.83L9.17 13H10l2 2h-1.17l2 2H11z"/></svg></button>
                                <span class="w-px h-6 bg-[#E5E0D8] mx-1.5"></span>
                                <button type="button" class="note-tb-btn p-2 rounded hover:bg-[#E5E0D8] focus:outline focus:ring-2 focus:ring-[#A7C7E7]" title="Pièce jointe" onclick="var w=this.closest('.note-rich-editor-wrapper');var i=w?w.querySelector('.note-attachment-input'):null;if(i)i.click();return false;"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M16.5 6v11.5c0 2.21-1.79 4-4 4s-4-1.79-4-4V5c0-1.38 1.12-2.5 2.5-2.5s2.5 1.12 2.5 2.5v10.5c0 .55-.45 1-1 1s-1-.45-1-1V6H10v9.5c0 1.38 1.12 2.5 2.5 2.5s2.5-1.12 2.5-2.5V5c0-2.21-1.79-4-4-4S7 2.79 7 5v12.5c0 3.04 2.46 5.5 5.5 5.5s5.5-2.46 5.5-5.5V6h-1.5z"/></svg></button>
                                <input type="file" class="note-attachment-input hidden" accept="image/*,.pdf,.doc,.docx" data-upload-url="{{ path('doctor_notes_upload') }}" data-csrf-token="{{ csrf_token('doctor_notes_upload') }}">
                            </div>
                        </div>
                        <div id="note_editor_edit_content" contenteditable="true" tabindex="0" class="min-h-[240px] p-4 text-[#4B5563] bg-white focus:outline-none text-base leading-relaxed" data-placeholder="Déposez les fichiers ici ou cliquez pour ajouter du texte."></div>
                        {{ form_widget(form.contenu, { attr: { 'id': 'note_contenu_field_edit', 'class': 'hidden', 'style': 'display:none !important; height:0; overflow:hidden; position:absolute; left:-9999px;' } }) }}
                    </div>
                    {{ form_errors(form.contenu) }}
                </div>
            </div>
            <div class="flex flex-wrap gap-2 pt-4">
                <button type="submit" class="px-4 py-2 rounded-lg bg-[#A7C7E7] text-white font-medium hover:bg-[#B8D4ED] focus:outline focus:ring-2 focus:ring-[#A7C7E7]" onmousedown="var f=this.form;var eid=f.getAttribute('data-note-editor-id');var fid=f.getAttribute('data-note-field-id');if(eid&&fid){var e=document.getElementById(eid);var fl=document.getElementById(fid);if(e&&fl)fl.value=e.innerHTML;}">Enregistrer les modifications</button>
                <a href="{{ path('doctor_note_show', { id: note.id }) }}" class="px-4 py-2 rounded-lg border border-[#E5E0D8] text-[#4B5563] font-medium hover:bg-[#F5F1EB] focus:outline focus:ring-2 focus:ring-[#A7C7E7]">Annuler</a>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>

<style>
#note_editor_edit_content:empty::before { content: attr(data-placeholder); color: #9CA3AF; }
#note_editor_edit_content { outline: none; color: #4B5563; font-size: 1rem; line-height: 1.625; }
#note_editor_edit_content ul, #note_editor_edit_content ol { margin: 0.5em 0; padding-left: 1.5em; }
#note_editor_edit_content ul { list-style-type: disc; }
#note_editor_edit_content ol { list-style-type: decimal; }
#note_editor_edit_content li { display: list-item; }
#note_editor_edit_content a { color: #2563eb; text-decoration: underline; }
#note_editor_edit_content img { max-width: 100%; height: auto; vertical-align: middle; }
.note-toolbar .note-tb-btn { min-width: 32px; min-height: 32px; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; -webkit-user-select: none; user-select: none; }
</style>
<script>
if (typeof noteEditorInit === 'function') noteEditorInit();
(function() {
  var form = document.querySelector('form.note-form-rich[data-note-editor-id="note_editor_edit_content"]');
  if (!form) return;
  form.addEventListener('submit', function(ev) {
    ev.preventDefault();
    var editor = document.getElementById('note_editor_edit_content');
    if (!editor) return;
    var formData = new FormData(form);
    formData.set('note[contenu]', editor.innerHTML || '');
    var btn = form.querySelector('button[type="submit"]');
    if (btn) btn.disabled = true;
    fetch(form.action, {
      method: 'POST',
      body: formData,
      redirect: 'follow',
      headers: { 'X-Requested-With': 'XMLHttpRequest' }
    }).then(function(r) {
      if (btn) btn.disabled = false;
      return r.text().then(function(html) {
        document.open();
        document.write(html);
        document.close();
      });
    }).catch(function() {
      if (btn) btn.disabled = false;
      alert('Erreur réseau. Réessayez.');
    });
  }, true);
})();
</script>
{% endblock %}

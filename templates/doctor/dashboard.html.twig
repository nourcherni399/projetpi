{% extends 'layouts/doctor.html.twig' %}

{% block title %}Tableau de bord - AutiCare Médecin{% endblock %}

{% block doctor_content %}
{# Message de bienvenue + illustration #}
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8 p-6 rounded-2xl bg-white dark:bg-gray-700/80 border border-[#e2e8f0] dark:border-gray-600 shadow-sm">
    <div>
        <h2 class="text-xl font-bold text-[#1e293b] dark:text-white mb-1">
            Bonjour, Dr {{ app.user ? app.user.prenom : '' }}
        </h2>
        <p class="text-[#64748b] dark:text-gray-400 text-sm mb-0.5">Consultez vos rendez-vous et votre activité.</p>
        <p class="text-[#94a3b8] dark:text-gray-500 text-sm">Bonne journée.</p>
    </div>
    <div class="flex items-center justify-center w-24 h-24 rounded-2xl bg-gradient-to-br from-[#E8DCF0] to-[#D4E5D0] dark:from-[#CDB4DB]/30 dark:to-[#A8BBA3]/30 shrink-0">
        <svg class="w-12 h-12 text-[#CDB4DB] dark:text-[#93C5FD]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
    </div>
</div>

{# KPIs - 4 cartes #}
{% if stats is defined %}
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
    <div class="rounded-2xl border border-[#e2e8f0] dark:border-gray-600 bg-white dark:bg-gray-700/80 p-5 shadow-sm hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-[#64748b] dark:text-gray-400 text-sm font-medium">Patients suivis</p>
                <p class="text-2xl font-bold text-[#1e293b] dark:text-white mt-1">{{ stats.total_patients|default(0) }}</p>
                <p class="text-[#94a3b8] dark:text-gray-500 text-xs mt-0.5">Total unique</p>
            </div>
            <div class="w-12 h-12 rounded-xl bg-[#E8DCF0] dark:bg-[#CDB4DB]/30 flex items-center justify-center">
                <svg class="w-6 h-6 text-[#CDB4DB] dark:text-[#93C5FD]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            </div>
        </div>
    </div>
    <div class="rounded-2xl border border-[#e2e8f0] dark:border-gray-600 bg-white dark:bg-gray-700/80 p-5 shadow-sm hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-[#64748b] dark:text-gray-400 text-sm font-medium">Rendez-vous</p>
                <p class="text-2xl font-bold text-[#1e293b] dark:text-white mt-1">{{ stats.total_rdv|default(0) }}</p>
                <p class="text-[#94a3b8] dark:text-gray-500 text-xs mt-0.5">{{ stats.rdv_today|default(0) }} aujourd'hui</p>
            </div>
            <div class="w-12 h-12 rounded-xl bg-[#D4E5D0] dark:bg-[#A8BBA3]/30 flex items-center justify-center">
                <svg class="w-6 h-6 text-[#A8BBA3] dark:text-[#93C5FD]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
            </div>
        </div>
    </div>
    <div class="rounded-2xl border border-[#e2e8f0] dark:border-gray-600 bg-white dark:bg-gray-700/80 p-5 shadow-sm hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-[#64748b] dark:text-gray-400 text-sm font-medium">Notes rédigées</p>
                <p class="text-2xl font-bold text-[#1e293b] dark:text-white mt-1">{{ stats.total_notes|default(0) }}</p>
                <p class="text-[#94a3b8] dark:text-gray-500 text-xs mt-0.5">Total notes</p>
            </div>
            <div class="w-12 h-12 rounded-xl bg-[#E8DCF0] dark:bg-[#CDB4DB]/30 flex items-center justify-center">
                <svg class="w-6 h-6 text-[#CDB4DB] dark:text-[#93C5FD]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
            </div>
        </div>
    </div>
    <div class="rounded-2xl border border-[#e2e8f0] dark:border-gray-600 bg-white dark:bg-gray-700/80 p-5 shadow-sm hover:shadow-md transition-shadow">
        <div class="flex items-center justify-between">
            <div>
                <p class="text-[#64748b] dark:text-gray-400 text-sm font-medium">Disponibilités</p>
                <p class="text-2xl font-bold text-[#1e293b] dark:text-white mt-1">Actif</p>
                <p class="text-[#94a3b8] dark:text-gray-500 text-xs mt-0.5">Gérer les créneaux</p>
            </div>
            <div class="w-12 h-12 rounded-xl bg-[#D4E5D0] dark:bg-[#A8BBA3]/30 flex items-center justify-center">
                <svg class="w-6 h-6 text-[#A8BBA3] dark:text-[#93C5FD]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
        </div>
    </div>
</div>
{% endif %}

{# Activité + grille RDV / Profil #}
<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
    {# Colonne gauche : Activité (graph) + Prochains RDV #}
    <div class="lg:col-span-2 space-y-6">
        <div class="rounded-2xl border border-[#e2e8f0] dark:border-gray-600 bg-white dark:bg-gray-700/80 overflow-hidden shadow-sm">
            <div class="px-6 py-4 border-b border-[#e2e8f0] dark:border-gray-600 flex items-center justify-between">
                <h3 class="font-semibold text-[#1e293b] dark:text-white">Activité</h3>
                <span class="text-xs text-[#94a3b8] dark:text-gray-500">Derniers 6 mois</span>
            </div>
            <div class="p-6">
                <div class="h-56">
                    <canvas id="activityChart" class="w-full h-full"></canvas>
                </div>
            </div>
        </div>

        <div class="rounded-2xl border border-[#e2e8f0] dark:border-gray-600 bg-white dark:bg-gray-700/80 overflow-hidden shadow-sm">
            <div class="px-6 py-4 border-b border-[#e2e8f0] dark:border-gray-600 flex items-center justify-between">
                <h3 class="font-semibold text-[#1e293b] dark:text-white">Prochains rendez-vous</h3>
                <a href="{{ path('doctor_rendezvous') }}" class="text-sm text-[#CDB4DB] dark:text-[#93C5FD] font-medium hover:underline">Voir tout →</a>
            </div>
            <div class="p-4">
                {% if stats is defined and stats.upcoming_rdv is defined and stats.upcoming_rdv is not empty %}
                    <ul class="space-y-2">
                        {% for rdv in stats.upcoming_rdv %}
                        <li>
                            <a href="{{ path('doctor_rendezvous_edit', { id: rdv.id }) }}" class="flex items-center gap-4 p-3 rounded-xl hover:bg-[#f8fafc] dark:hover:bg-gray-600/50 transition-colors group">
                                <span class="flex items-center justify-center w-10 h-10 rounded-full bg-[#E8DCF0] dark:bg-[#CDB4DB]/30 text-[#CDB4DB] dark:text-[#93C5FD] font-semibold text-sm shrink-0">
                                    {{ rdv.patient ? (rdv.patient.prenom|slice(0,1) ~ rdv.patient.nom|slice(0,1))|upper : '?' }}
                                </span>
                                <div class="flex-1 min-w-0">
                                    <p class="font-medium text-[#1e293b] dark:text-white text-sm truncate">
                                        {{ rdv.patient ? (rdv.patient.prenom ~ ' ' ~ rdv.patient.nom) : 'Patient non spécifié' }}
                                    </p>
                                    <p class="text-xs text-[#64748b] dark:text-gray-400">
                                        {{ rdv.dateRdv ? rdv.dateRdv|date('d/m/Y') : '' }}
                                        {% if rdv.disponibilite is defined and rdv.disponibilite %}
                                            · {{ rdv.disponibilite.heureDebut|date('H:i') }} - {{ rdv.disponibilite.heureFin|date('H:i') }}
                                        {% endif %}
                                    </p>
                                </div>
                                {% set statusVal = rdv.status is defined and rdv.status is not null ? (rdv.status.value ?? rdv.status) : '' %}
                                <span class="px-2.5 py-1 rounded-lg text-xs font-medium shrink-0
                                    {% if statusVal == 'confirmer' %}bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-300
                                    {% elseif statusVal == 'en_attente' %}bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-300
                                    {% else %}bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-300{% endif %}">
                                    {{ statusVal ? statusVal|replace({'_': ' '})|title : '—' }}
                                </span>
                                <svg class="w-5 h-5 text-[#94a3b8] dark:text-gray-500 group-hover:text-[#CDB4DB] dark:group-hover:text-[#93C5FD] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
                            </a>
                        </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <div class="text-center py-10">
                        <div class="w-14 h-14 rounded-2xl bg-[#f1f5f9] dark:bg-gray-600 mx-auto mb-3 flex items-center justify-center">
                            <svg class="w-7 h-7 text-[#cbd5e1] dark:text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
                        </div>
                        <p class="text-[#64748b] dark:text-gray-400 text-sm">Aucun rendez-vous à venir</p>
                        <a href="{{ path('doctor_availability_new') }}" class="inline-block mt-2 text-sm text-[#CDB4DB] dark:text-[#93C5FD] font-medium hover:underline">Ajouter des créneaux</a>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    {# Colonne droite : Mon profil + Mon agenda #}
    <div class="space-y-6">
        <div class="rounded-2xl border border-[#e2e8f0] dark:border-gray-600 bg-white dark:bg-gray-700/80 overflow-hidden shadow-sm">
            <div class="px-6 py-4 border-b border-[#e2e8f0] dark:border-gray-600">
                <h3 class="font-semibold text-[#1e293b] dark:text-white">Mon profil</h3>
            </div>
            <div class="p-6 text-center">
                <span class="inline-flex items-center justify-center w-16 h-16 rounded-2xl overflow-hidden bg-gradient-to-br from-[#CDB4DB] to-[#A8BBA3] text-white font-bold text-lg mb-3">
                    {% if app.user and app.user.image %}<img src="{{ asset(app.user.image) }}" alt="" class="w-full h-full object-cover">{% else %}{{ app.user ? (app.user.prenom|slice(0,1) ~ app.user.nom|slice(0,1))|upper : 'DR' }}{% endif %}
                </span>
                <p class="font-semibold text-[#1e293b] dark:text-white">Dr {{ app.user ? app.user.prenom ~ ' ' ~ app.user.nom : '' }}</p>
                <p class="text-xs text-[#64748b] dark:text-gray-400 mt-0.5">{{ app.user ? app.user.email : '' }}</p>
                <p class="text-sm text-[#64748b] dark:text-gray-400 mt-3">Vous avez {{ stats.rdv_today|default(0) }} rendez-vous aujourd'hui.</p>
                <a href="{{ path('doctor_profile') }}" class="inline-block mt-4 px-4 py-2 rounded-xl bg-[#E8DCF0] dark:bg-[#CDB4DB]/30 text-[#4B3D6B] dark:text-white text-sm font-medium hover:bg-[#CDB4DB]/50 dark:hover:bg-[#CDB4DB]/50 transition-colors">Voir le profil</a>
            </div>
        </div>

        <div class="rounded-2xl border border-[#e2e8f0] dark:border-gray-600 bg-white dark:bg-gray-700/80 overflow-hidden shadow-sm">
            <div class="px-6 py-4 border-b border-[#e2e8f0] dark:border-gray-600 flex items-center justify-between">
                <h3 class="font-semibold text-[#1e293b] dark:text-white">Aujourd'hui</h3>
                <span class="text-xs text-[#94a3b8] dark:text-gray-500">{{ "now"|date("d/m/Y") }}</span>
            </div>
            <div class="p-4">
                <div class="rounded-xl bg-[#f8fafc] dark:bg-gray-600/50 p-4 mb-4">
                    <p class="text-center text-2xl font-bold text-[#1e293b] dark:text-white">{{ "now"|date("d") }}</p>
                    <p class="text-center text-xs text-[#64748b] dark:text-gray-400">{{ "now"|date("F") }}</p>
                </div>
                <p class="text-sm text-[#64748b] dark:text-gray-400">{{ stats.rdv_today|default(0) }} rendez-vous prévus.</p>
                <a href="{{ path('doctor_rendezvous') }}" class="inline-flex items-center gap-1.5 mt-3 text-sm text-[#CDB4DB] dark:text-[#93C5FD] font-medium hover:underline">
                    Voir l'agenda
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
                </a>
            </div>
        </div>
    </div>
</div>

{# Actions rapides #}
<div class="rounded-2xl border border-[#e2e8f0] dark:border-gray-600 bg-white dark:bg-gray-700/80 p-6 shadow-sm">
    <h3 class="font-semibold text-[#1e293b] dark:text-white mb-4">Actions rapides</h3>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="{{ path('doctor_availability_new') }}" class="flex items-center gap-3 p-4 rounded-xl bg-[#E8DCF0]/50 dark:bg-[#CDB4DB]/20 hover:bg-[#E8DCF0] dark:hover:bg-[#CDB4DB]/30 transition-colors group">
            <span class="w-10 h-10 rounded-xl bg-[#CDB4DB] dark:bg-[#9B7BB8] flex items-center justify-center text-white group-hover:scale-105 transition-transform">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
            </span>
            <div>
                <p class="font-medium text-[#1e293b] dark:text-white text-sm">Nouveau créneau</p>
                <p class="text-xs text-[#64748b] dark:text-gray-400">Ajouter une disponibilité</p>
            </div>
        </a>
        <a href="{{ path('doctor_notes') }}" class="flex items-center gap-3 p-4 rounded-xl bg-[#D4E5D0]/50 dark:bg-[#A8BBA3]/20 hover:bg-[#D4E5D0] dark:hover:bg-[#A8BBA3]/30 transition-colors group">
            <span class="w-10 h-10 rounded-xl bg-[#A8BBA3] dark:bg-[#7B9B6E] flex items-center justify-center text-white group-hover:scale-105 transition-transform">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
            </span>
            <div>
                <p class="font-medium text-[#1e293b] dark:text-white text-sm">Notes patients</p>
                <p class="text-xs text-[#64748b] dark:text-gray-400">Consulter et rédiger</p>
            </div>
        </a>
        <a href="{{ path('doctor_rendezvous') }}" class="flex items-center gap-3 p-4 rounded-xl bg-[#E8DCF0]/50 dark:bg-[#CDB4DB]/20 hover:bg-[#E8DCF0] dark:hover:bg-[#CDB4DB]/30 transition-colors group">
            <span class="w-10 h-10 rounded-xl bg-[#CDB4DB] dark:bg-[#9B7BB8] flex items-center justify-center text-white group-hover:scale-105 transition-transform">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
            </span>
            <div>
                <p class="font-medium text-[#1e293b] dark:text-white text-sm">Agenda</p>
                <p class="text-xs text-[#64748b] dark:text-gray-400">Voir les rendez-vous</p>
            </div>
        </a>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    var canvas = document.getElementById('activityChart');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    var months = ['Janv.', 'Févr.', 'Mars', 'Avr.', 'Mai', 'Juin'];
    var data = [12, 19, 15, 25, 22, 30];
    var gradient = ctx.createLinearGradient(0, 0, 0, 220);
    gradient.addColorStop(0, 'rgba(205, 180, 219, 0.35)');
    gradient.addColorStop(1, 'rgba(205, 180, 219, 0.02)');
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: months,
            datasets: [{
                label: 'Rendez-vous',
                data: data,
                borderColor: '#CDB4DB',
                backgroundColor: gradient,
                borderWidth: 2,
                fill: true,
                tension: 0.4,
                pointBackgroundColor: '#CDB4DB',
                pointBorderColor: '#fff',
                pointBorderWidth: 2,
                pointRadius: 4,
                pointHoverRadius: 6
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { display: false }, ticks: { color: '#94a3b8', font: { size: 11 } } },
                y: { beginAtZero: true, grid: { color: 'rgba(148, 163, 184, 0.2)' }, ticks: { color: '#94a3b8', font: { size: 11 } } }
            }
        }
    });
});
</script>
{% endblock %}

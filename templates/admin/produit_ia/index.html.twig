{% extends 'layouts/admin.html.twig' %}

{% block title %}Demandes de produits - AutiCare Admin{% endblock %}

{% block admin_content %}
<div class="mb-6">
    <div class="flex items-center gap-3 flex-wrap">
        <h1 class="text-2xl md:text-3xl font-bold text-[#4B5563]">Demandes de produits</h1>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-violet-100 text-violet-700 border border-violet-200">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
            </svg>
            {{ produitsEnAttente|length }} en attente
        </span>
    </div>
    <p class="text-[#6B7280] mt-1">Validez ou refusez les produits créés par les clients via le chatbot IA</p>
</div>

<div class="mb-6">
    <a href="{{ path('admin_produit_index') }}" class="px-4 py-2.5 rounded-lg border border-[#E5E0D8] text-[#6B7280] font-medium hover:bg-[#F5F1EB] inline-flex items-center gap-2">
        ← Retour aux produits
    </a>
</div>

{% for message in app.flashes('success') %}
    <div class="mb-4 px-4 py-3 rounded-lg bg-emerald-50 border border-emerald-200 text-emerald-800">{{ message }}</div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="mb-4 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-red-800">{{ message }}</div>
{% endfor %}

{# Section: Produits en attente #}
<section class="mb-8">
    <h2 class="text-lg font-bold text-[#4B5563] mb-4 flex items-center gap-2">
        <span class="w-3 h-3 rounded-full bg-amber-400"></span>
        En attente de validation ({{ produitsEnAttente|length }})
    </h2>

    {% if produitsEnAttente|length == 0 %}
        <div class="bg-white rounded-xl border border-[#E5E0D8] shadow-sm p-8 text-center text-[#6B7280]">
            <svg class="w-12 h-12 mx-auto mb-3 text-[#E5E0D8]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Aucun produit en attente de validation.
        </div>
    {% else %}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {% for produit in produitsEnAttente %}
                <article class="bg-white rounded-xl border border-amber-200 shadow-sm overflow-hidden">
                    <div class="aspect-video bg-[#F5F1EB] flex items-center justify-center overflow-hidden">
                        {% if produit.image %}
                            <img src="{{ asset(produit.image) }}" alt="{{ produit.nom }}" class="w-full h-full object-cover">
                        {% else %}
                            <span class="text-[#9CA3AF]">Pas d'image</span>
                        {% endif %}
                    </div>
                    <div class="p-4">
                        <div class="flex items-start justify-between gap-2 mb-2">
                            <span class="inline-block px-2 py-0.5 rounded text-xs font-medium text-white bg-[#A7C7E7]">
                                {{ produit.categorie ? produit.categorie.label() : '—' }}
                            </span>
                            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-medium bg-violet-50 text-violet-700 border border-violet-200">
                                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
                                </svg>
                                IA
                            </span>
                        </div>
                        <h3 class="font-semibold text-[#4B5563] text-lg">{{ produit.nom }}</h3>
                        {% if produit.description %}
                            <p class="text-[#6B7280] text-sm mt-1 line-clamp-2">{{ produit.description }}</p>
                        {% endif %}
                        <p class="font-bold text-[#A7C7E7] text-xl mt-2">{{ produit.prix|number_format(2, ',', ' ') }} DT</p>
                        
                        {% if produit.user %}
                            <p class="text-xs text-[#9CA3AF] mt-2">
                                Créé par : {{ produit.user.prenom }} {{ produit.user.nom }}
                            </p>
                        {% endif %}

                        <div class="flex gap-2 mt-4">
                            <form method="POST" action="{{ path('admin_demandes_produit_valider', {id: produit.id}) }}" class="flex-1">
                                <input type="hidden" name="_token" value="{{ csrf_token('valider_' ~ produit.id) }}">
                                <button type="submit" class="w-full px-4 py-2 rounded-lg bg-emerald-500 text-white font-medium hover:bg-emerald-600 flex items-center justify-center gap-2">
                                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                                    </svg>
                                    Valider
                                </button>
                            </form>
                            <form method="POST" action="{{ path('admin_demandes_produit_refuser', {id: produit.id}) }}" class="flex-1" onsubmit="return confirm('Supprimer ce produit ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('refuser_' ~ produit.id) }}">
                                <button type="submit" class="w-full px-4 py-2 rounded-lg bg-red-500 text-white font-medium hover:bg-red-600 flex items-center justify-center gap-2">
                                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                                    </svg>
                                    Refuser
                                </button>
                            </form>
                        </div>
                    </div>
                </article>
            {% endfor %}
        </div>
    {% endif %}
</section>

{# Section: Produits validés #}
<section>
    <h2 class="text-lg font-bold text-[#4B5563] mb-4 flex items-center gap-2">
        <span class="w-3 h-3 rounded-full bg-emerald-400"></span>
        Produits IA validés ({{ produitsValides|length }})
    </h2>

    {% if produitsValides|length == 0 %}
        <div class="bg-white rounded-xl border border-[#E5E0D8] shadow-sm p-6 text-center text-[#6B7280]">
            Aucun produit IA validé pour le moment.
        </div>
    {% else %}
        <div class="bg-white rounded-xl border border-[#E5E0D8] shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm">
                    <thead class="bg-[#F5F1EB] border-b border-[#E5E0D8]">
                        <tr>
                            <th class="px-6 py-3 font-semibold text-[#4B5563]">Produit</th>
                            <th class="px-6 py-3 font-semibold text-[#4B5563]">Catégorie</th>
                            <th class="px-6 py-3 font-semibold text-[#4B5563]">Prix</th>
                            <th class="px-6 py-3 font-semibold text-[#4B5563]">Créé par</th>
                            <th class="px-6 py-3 font-semibold text-[#4B5563]">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-[#E5E0D8]">
                        {% for produit in produitsValides %}
                            <tr class="hover:bg-[#F9FAFB]">
                                <td class="px-6 py-3">
                                    <div class="flex items-center gap-3">
                                        {% if produit.image %}
                                            <img src="{{ asset(produit.image) }}" alt="" class="w-10 h-10 rounded-lg object-cover">
                                        {% else %}
                                            <div class="w-10 h-10 rounded-lg bg-[#E5E0D8] flex items-center justify-center text-[#9CA3AF] text-xs">—</div>
                                        {% endif %}
                                        <span class="font-medium text-[#4B5563]">{{ produit.nom }}</span>
                                    </div>
                                </td>
                                <td class="px-6 py-3 text-[#6B7280]">{{ produit.categorie ? produit.categorie.label() : '—' }}</td>
                                <td class="px-6 py-3 font-medium text-[#4B5563]">{{ produit.prix|number_format(2, ',', ' ') }} DT</td>
                                <td class="px-6 py-3 text-[#6B7280]">{{ produit.user ? produit.user.prenom ~ ' ' ~ produit.user.nom : '—' }}</td>
                                <td class="px-6 py-3">
                                    <a href="{{ path('admin_produit_show', {id: produit.id}) }}" class="text-[#A7C7E7] hover:underline">Voir</a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% endif %}
</section>
{% endblock %}

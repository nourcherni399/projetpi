{% extends 'layouts/admin.html.twig' %}

{% block title %}Demandes de produits - AutiCare Admin{% endblock %}

{% block admin_content %}
<div class="mb-6">
    <div class="flex items-center gap-3 flex-wrap">
        <h1 class="text-2xl md:text-3xl font-bold text-[#4B5563]">Demandes de produits</h1>
        {% set pendingCount = demandes|filter(d => d.statut == 'en_attente')|length %}
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-amber-100 text-amber-700 border border-amber-200">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {{ pendingCount }} en attente
        </span>
    </div>
    <p class="text-[#6B7280] mt-1">Validez ou refusez les demandes de produits des clients</p>
</div>

<div class="mb-6 flex flex-wrap gap-2">
    <a href="{{ path('admin_produit_index') }}" class="px-4 py-2.5 rounded-lg border border-[#E5E0D8] text-[#6B7280] font-medium hover:bg-[#F5F1EB] inline-flex items-center gap-2">
        ← Retour aux produits
    </a>
    <a href="{{ path('admin_demande_produit_export_pdf_list') }}" class="px-4 py-2.5 rounded-lg border border-[#E5E0D8] text-[#6B7280] font-medium hover:bg-[#F5F1EB] inline-flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
        PDF
    </a>
</div>

{% for message in app.flashes('success') %}
    <div class="mb-4 px-4 py-3 rounded-lg bg-emerald-50 border border-emerald-200 text-emerald-800">{{ message }}</div>
{% endfor %}
{% for message in app.flashes('error') %}
    <div class="mb-4 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-red-800">{{ message }}</div>
{% endfor %}
{% for message in app.flashes('warning') %}
    <div class="mb-4 px-4 py-3 rounded-lg bg-amber-50 border border-amber-200 text-amber-800">{{ message }}</div>
{% endfor %}

{# Section: Demandes en attente #}
<section class="mb-8">
    <h2 class="text-lg font-bold text-[#4B5563] mb-4 flex items-center gap-2">
        <span class="w-3 h-3 rounded-full bg-amber-400"></span>
        Demandes en attente ({{ pendingCount }})
    </h2>

    {% set demandesEnAttente = demandes|filter(d => d.statut == 'en_attente') %}
    
    {% if demandesEnAttente|length == 0 %}
        <div class="bg-white rounded-xl border border-[#E5E0D8] shadow-sm p-8 text-center text-[#6B7280]">
            <svg class="w-12 h-12 mx-auto mb-3 text-[#E5E0D8]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Aucune demande en attente.
        </div>
    {% else %}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {% for demande in demandesEnAttente %}
                <article class="bg-white rounded-xl border border-amber-200 shadow-sm overflow-hidden">
                    {% set donneesExternes = demande.donneesExternes %}
                    {% set imageOptions = donneesExternes.image_options ?? [] %}
                    
                    {# Fallback: si image_options n'existe pas, utiliser results #}
                    {% if imageOptions|length == 0 and donneesExternes.results is defined %}
                        {% set imageOptions = [] %}
                        {% for result in donneesExternes.results %}
                            {% if result.image_url %}
                                {% set imageOptions = imageOptions|merge([{
                                    'url': result.image_url,
                                    'source': result.source ?? 'Google',
                                    'price': result.price_tnd ?? null
                                }]) %}
                            {% endif %}
                        {% endfor %}
                    {% endif %}
                    
                    {% set imageUrl = imageOptions[0].url ?? donneesExternes.image_path ?? donneesExternes.image_url ?? null %}
                    
                    <div class="aspect-video bg-[#F5F1EB] flex items-center justify-center overflow-hidden">
                        {% if imageUrl %}
                            <img src="{{ imageUrl }}" alt="{{ demande.nom }}" class="w-full h-full object-cover" referrerpolicy="no-referrer">
                        {% else %}
                            <span class="text-[#9CA3AF]">Pas d'image</span>
                        {% endif %}
                    </div>
                    
                    <div class="p-4">
                        <div class="flex items-start justify-between gap-2 mb-2">
                            <span class="inline-block px-2 py-0.5 rounded text-xs font-medium text-white bg-[#A7C7E7]">
                                {{ demande.categorie ? demande.categorie.label : 'Non defini' }}
                            </span>
                            <div class="flex gap-1">
                                {% if imageOptions|length > 0 %}
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-medium bg-violet-50 text-violet-700 border border-violet-200" title="{{ imageOptions|length }} image(s) trouvée(s)">
                                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                                    </svg>
                                    {{ imageOptions|length }}
                                </span>
                                {% endif %}
                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-medium bg-amber-50 text-amber-700 border border-amber-200">
                                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                    En attente
                                </span>
                            </div>
                        </div>
                        
                        <h3 class="font-semibold text-[#4B5563] text-lg">{{ demande.nom }}</h3>
                        
                        {% if demande.description %}
                            <p class="text-[#6B7280] text-sm mt-1 line-clamp-2">{{ demande.description|slice(0, 100) }}{% if demande.description|length > 100 %}...{% endif %}</p>
                        {% endif %}
                        
                        <p class="font-bold text-[#A7C7E7] text-xl mt-2">{{ demande.prixEstime|number_format(2, ',', ' ') }} DT</p>
                        
                        <p class="text-xs text-[#9CA3AF] mt-2">
                            Demande : {{ demande.demandeClient|slice(0, 50) }}{% if demande.demandeClient|length > 50 %}...{% endif %}
                        </p>
                        
                        {% if demande.demandeur %}
                            <p class="text-xs text-[#9CA3AF] mt-1">
                                Par : {{ demande.demandeur.prenom }} {{ demande.demandeur.nom }}
                            </p>
                        {% endif %}
                        
                        <p class="text-xs text-[#9CA3AF] mt-1">
                            {{ demande.createdAt ? demande.createdAt|date('d/m/Y H:i') : '' }}
                        </p>

                        <div class="flex gap-2 mt-4">
                            <a href="{{ path('admin_demande_produit_creer_produit', {id: demande.id}) }}" class="flex-1 px-4 py-2 rounded-lg bg-emerald-500 text-white font-medium hover:bg-emerald-600 flex items-center justify-center gap-2 text-sm">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                                </svg>
                                Accepter
                            </a>
                            <form method="post" action="{{ path('admin_demande_produit_rejeter', {id: demande.id}) }}" class="flex-1" onsubmit="return confirm('Rejeter cette demande ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('rejeter_demande_' ~ demande.id) }}">
                                <button type="submit" class="w-full px-4 py-2 rounded-lg bg-red-500 text-white font-medium hover:bg-red-600 flex items-center justify-center gap-2 text-sm">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                                    </svg>
                                    Refuser
                                </button>
                            </form>
                        </div>
                    </div>
                </article>
            {% endfor %}
        </div>
    {% endif %}
</section>

{# Section: Produits valides #}
<section>
    <h2 class="text-lg font-bold text-[#4B5563] mb-4 flex items-center gap-2">
        <span class="w-3 h-3 rounded-full bg-emerald-400"></span>
        Produits valides
    </h2>

    {% set demandesApprouvees = demandes|filter(d => d.statut == 'approuve' and d.produit is not null) %}
    
    {% if demandesApprouvees|length == 0 %}
        <div class="bg-white rounded-xl border border-[#E5E0D8] shadow-sm p-6 text-center text-[#6B7280]">
            Aucun produit valide pour le moment.
        </div>
    {% else %}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
            {% for demande in demandesApprouvees %}
                {% set produit = demande.produit %}
                <article class="bg-white rounded-xl border border-emerald-200 shadow-sm overflow-hidden">
                    <div class="aspect-video bg-[#F5F1EB] flex items-center justify-center overflow-hidden">
                        {% if produit.image %}
                            <img src="{{ asset(produit.image) }}" alt="{{ produit.nom }}" class="w-full h-full object-cover">
                        {% else %}
                            <span class="text-[#9CA3AF]">Pas d'image</span>
                        {% endif %}
                    </div>
                    
                    <div class="p-4">
                        <div class="flex items-start justify-between gap-2 mb-2">
                            <span class="inline-block px-2 py-0.5 rounded text-xs font-medium text-white bg-[#A7C7E7]">
                                {{ produit.categorie ? produit.categorie.label : 'Non defini' }}
                            </span>
                            <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-medium bg-emerald-50 text-emerald-700 border border-emerald-200">
                                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                                </svg>
                                Valide
                            </span>
                        </div>
                        
                        <h3 class="font-semibold text-[#4B5563] text-lg">{{ produit.nom }}</h3>
                        
                        {% if produit.description %}
                            <p class="text-[#6B7280] text-sm mt-1 line-clamp-2">{{ produit.description|slice(0, 80) }}...</p>
                        {% endif %}
                        
                        <p class="font-bold text-[#A7C7E7] text-xl mt-2">{{ produit.prix|number_format(2, ',', ' ') }} DT</p>
                        
                        <a href="{{ path('admin_produit_show', {id: produit.id}) }}" class="mt-4 block text-center px-4 py-2 rounded-lg bg-[#A7C7E7] text-white font-medium hover:bg-[#B8D4ED] text-sm">
                            Voir le produit
                        </a>
                    </div>
                </article>
            {% endfor %}
        </div>
    {% endif %}
</section>

{# Section: Demandes rejetees #}
{% set demandesRejetees = demandes|filter(d => d.statut == 'rejete') %}
{% if demandesRejetees|length > 0 %}
<section class="mt-8">
    <h2 class="text-lg font-bold text-[#4B5563] mb-4 flex items-center gap-2">
        <span class="w-3 h-3 rounded-full bg-red-400"></span>
        Demandes rejetees ({{ demandesRejetees|length }})
    </h2>
    
    <div class="bg-white rounded-xl border border-[#E5E0D8] shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead class="bg-[#F5F1EB] border-b border-[#E5E0D8]">
                    <tr>
                        <th class="px-6 py-3 font-semibold text-[#4B5563]">Demande</th>
                        <th class="px-6 py-3 font-semibold text-[#4B5563]">Categorie</th>
                        <th class="px-6 py-3 font-semibold text-[#4B5563]">Prix</th>
                        <th class="px-6 py-3 font-semibold text-[#4B5563]">Date</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-[#E5E0D8]">
                    {% for demande in demandesRejetees %}
                        <tr class="hover:bg-[#F9FAFB]">
                            <td class="px-6 py-3">
                                <span class="font-medium text-[#4B5563]">{{ demande.nom }}</span>
                                <p class="text-xs text-[#9CA3AF]">{{ demande.demandeClient|slice(0, 50) }}...</p>
                            </td>
                            <td class="px-6 py-3 text-[#6B7280]">{{ demande.categorie ? demande.categorie.label : '' }}</td>
                            <td class="px-6 py-3 font-medium text-[#4B5563]">{{ demande.prixEstime|number_format(2, ',', ' ') }} DT</td>
                            <td class="px-6 py-3 text-[#6B7280]">{{ demande.createdAt ? demande.createdAt|date('d/m/Y') : '' }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</section>
{% endif %}
{% endblock %}

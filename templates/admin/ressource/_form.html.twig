{{ form_start(form, {
    attr: { class: 'space-y-6', novalidate: 'novalidate', id: 'ressource-form' },
    label_attr: { class: 'block text-[#4B5563] font-medium mb-1' }
}) }}
{{ form_errors(form) }}

<div class="grid grid-cols-1 gap-6">
    {{ form_row(form.titre) }}
    {{ form_row(form.typeRessource) }}

    {# Recherche YouTube (visible uniquement quand type = video) #}
    <div id="youtube-search-block" class="hidden space-y-3 p-4 rounded-lg bg-[#f8fafc] dark:bg-gray-700/50 border border-[#E5E0D8] dark:border-gray-600">
        <div class="flex items-center gap-2">
            <svg class="w-6 h-6 text-[#FF0000] shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            <p class="text-sm text-[#4B5563] dark:text-gray-300 font-medium">YouTube</p>
        </div>
        <input type="text" id="youtube-search-input" placeholder="Ex. communication autisme (tapez Entrée pour rechercher)"
            class="w-full rounded-lg border border-[#E5E0D8] dark:border-gray-600 bg-white dark:bg-gray-600 px-4 py-2.5 text-[#4B5563] dark:text-gray-100 focus:ring-2 focus:ring-[#A7C7E7] focus:outline-none">
        <div id="youtube-search-status" class="text-sm text-[#6B7280] dark:text-gray-400 hidden"></div>
        <div id="youtube-search-results" class="grid grid-cols-2 sm:grid-cols-3 gap-3 max-h-64 overflow-y-auto"></div>
    </div>

    {{ form_row(form.contenu) }}
    {{ form_row(form.mediaFile) }}
    {{ form_row(form.module) }}
    {{ form_row(form.ordre) }}
    <div class="flex items-center gap-2">
        {{ form_widget(form.isActive) }}
        {{ form_label(form.isActive) }}
        {{ form_errors(form.isActive) }}
    </div>
</div>

<div class="flex flex-wrap gap-3 pt-4">
    <button type="submit" class="px-5 py-2.5 rounded-lg bg-[#A7C7E7] text-white font-medium hover:bg-[#B8D4ED]">
        {{ button_label|default('Enregistrer') }}
    </button>
    <a href="{{ path('admin_ressource_index') }}" class="px-5 py-2.5 rounded-lg border border-[#E5E0D8] text-[#6B7280] font-medium hover:bg-[#F5F1EB]">
        Annuler
    </a>
</div>
{{ form_end(form) }}

<script>
(function() {
    var form = document.getElementById('ressource-form');
    var typeSelect = form ? form.querySelector('select[name$="[typeRessource]"]') : null;
    var searchBlock = document.getElementById('youtube-search-block');
    var searchInput = document.getElementById('youtube-search-input');
    var statusEl = document.getElementById('youtube-search-status');
    var resultsEl = document.getElementById('youtube-search-results');
    var contenuInput = form ? form.querySelector('input[name$="[contenu]"]') : null;
    var titreInput = form ? form.querySelector('input[name$="[titre]"]') : null;
    var searchUrl = '{{ path('admin_ressource_youtube_search') }}';

    function toggleSearchBlock() {
        var type = typeSelect ? (typeSelect.options[typeSelect.selectedIndex] || {}).value : '';
        if (searchBlock) searchBlock.classList.toggle('hidden', type !== 'video');
        if (type !== 'video') resultsEl.innerHTML = '';
    }

    if (typeSelect) {
        typeSelect.addEventListener('change', toggleSearchBlock);
        toggleSearchBlock();
    }

    function doSearch() {
        var q = searchInput ? searchInput.value.trim() : '';
        if (!q) return;
        statusEl.textContent = 'Recherche en cours...';
        statusEl.classList.remove('hidden');
        resultsEl.innerHTML = '';

        fetch(searchUrl + '?q=' + encodeURIComponent(q))
            .then(function(r) { return r.json(); })
            .then(function(data) {
                statusEl.classList.add('hidden');
                if (data.error) {
                    statusEl.textContent = data.error;
                    statusEl.classList.remove('hidden');
                    return;
                }
                var videos = data.videos || [];
                if (videos.length === 0) {
                    resultsEl.innerHTML = '<p class="col-span-full text-sm text-[#6B7280] dark:text-gray-400">Aucun résultat.</p>';
                    return;
                }
                videos.forEach(function(v) {
                    var div = document.createElement('div');
                    div.className = 'rounded-lg border border-[#E5E0D8] dark:border-gray-600 overflow-hidden cursor-pointer hover:border-[#A7C7E7] hover:shadow transition-all';
                    div.innerHTML = '<img src="' + (v.thumbnail || '') + '" alt="" class="w-full aspect-video object-cover"><div class="p-2 text-xs text-[#4B5563] dark:text-gray-300 line-clamp-2">' + (v.title || '').replace(/</g, '&lt;').replace(/>/g, '&gt;') + '</div>';
                    div.addEventListener('click', function() {
                        if (contenuInput) contenuInput.value = v.url;
                        if (titreInput) titreInput.value = v.title || '';
                        document.querySelectorAll('#youtube-search-results > div').forEach(function(el) { el.classList.remove('ring-2', 'ring-[#A7C7E7]'); });
                        div.classList.add('ring-2', 'ring-[#A7C7E7]');
                    });
                    resultsEl.appendChild(div);
                });
            })
            .catch(function() {
                statusEl.textContent = 'Erreur lors de la recherche.';
                statusEl.classList.remove('hidden');
            });
    }

    if (searchInput) searchInput.addEventListener('keydown', function(e) { if (e.key === 'Enter') { e.preventDefault(); doSearch(); } });
})();
</script>

{% extends 'layouts/admin.html.twig' %}

{% block title %}{{ produit.nom }} - AutiCare Admin{% endblock %}

{% block admin_content %}
<div class="max-w-4xl">
    <div class="mb-6 flex items-center gap-4">
        <a href="{{ path('admin_produit_index') }}" class="inline-flex items-center gap-2 text-[#6B7280] hover:text-[#A7C7E7] focus:outline focus:ring-2 focus:ring-[#A7C7E7] rounded-lg">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
            Retour aux produits
        </a>
    </div>

    <div class="bg-white rounded-xl border border-[#E5E0D8] p-6 md:p-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Image + Galerie -->
            <div class="space-y-4">
                <div class="flex items-center justify-center">
                    {% if produit.image %}
                        <img src="{{ asset(produit.image) }}" alt="{{ produit.nom }}" class="w-full h-auto object-cover rounded-lg shadow-md">
                    {% else %}
                        <div class="w-full aspect-square bg-[#E5E0D8] rounded-lg flex items-center justify-center text-[#9CA3AF]">Pas d'image</div>
                    {% endif %}
                </div>
                {% if produit.images|length > 0 %}
                <div>
                    <p class="text-sm font-medium text-[#4B5563] mb-2">Galerie ({{ produit.images|length }})</p>
                    <div class="flex flex-wrap gap-2">
                        {% for img in produit.images %}
                        <img src="{{ asset(img.chemin) }}" alt="Galerie" class="w-16 h-16 object-cover rounded-lg border border-[#E5E0D8]">
                        {% endfor %}
                    </div>
                </div>
                {% endif %}
            </div>

            <!-- Détails -->
            <div class="flex flex-col justify-between">
                <div>
                    <h1 class="text-3xl font-semibold text-[#4B5563] mb-2">{{ produit.nom }}</h1>
                    {% if produit.sku %}
                    <p class="text-sm text-[#6B7280] mb-1">ID produit : <span class="font-mono font-medium">{{ produit.sku }}</span></p>
                    {% endif %}
                    <span class="inline-flex px-2 py-1 rounded text-xs font-medium {{ produit.statutPublication.value == 'publie' ? 'bg-emerald-100 text-emerald-800' : 'bg-amber-100 text-amber-800' }} mb-2">
                        {{ produit.statutPublication.label }}
                    </span>
                    {% if produit.genereParIa %}
                        <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded text-sm font-medium bg-violet-50 text-violet-700 border border-violet-200 mb-3">Généré par l'IA</span>
                    {% endif %}
                    <div class="mb-6">
                        <span class="inline-block px-3 py-1 rounded-full bg-[#A7C7E7]/20 text-[#A7C7E7] text-sm font-medium">
                            {{ produit.categorie ? produit.categorie.label : '—' }}
                        </span>
                    </div>

                    {% if produit.description %}
                        <div class="mb-6">
                            <h2 class="text-sm font-medium text-[#4B5563] mb-2">Description</h2>
                            <p class="text-[#6B7280] leading-relaxed">{{ produit.description }}</p>
                        </div>
                    {% endif %}

                    <div class="grid grid-cols-2 gap-4 mb-6">
                        <div>
                            <p class="text-sm font-medium text-[#4B5563] mb-1">Prix</p>
                            <p class="text-2xl font-semibold text-[#A7C7E7]">{{ produit.prix|number_format(2, ',', ' ') }} dt</p>
                        </div>
                        <div>
                            <p class="text-sm font-medium text-[#4B5563] mb-1">Disponibilité</p>
                            <p class="text-lg font-semibold {{ produit.disponibilite ? 'text-emerald-600' : 'text-red-600' }}">
                                {{ produit.disponibilite ? 'Disponible' : 'Indisponible' }}
                            </p>
                        </div>
                    </div>
                </div>

                <div class="flex flex-wrap gap-3">
                    <a href="{{ path('admin_produit_edit', {id: produit.id}) }}" class="px-5 py-2.5 rounded-lg bg-[#A7C7E7] text-white font-medium hover:bg-[#B8D4ED] focus:outline focus:ring-2 focus:ring-[#A7C7E7] text-center">
                        Modifier
                    </a>
                    <a href="{{ path('admin_produit_index') }}" class="px-5 py-2.5 rounded-lg border border-[#E5E0D8] text-[#6B7280] font-medium hover:bg-[#F5F1EB] focus:outline focus:ring-2 focus:ring-[#A7C7E7] text-center">
                        Retour
                    </a>
                </div>
            </div>
        </div>

        {% if historique|default([])|length > 0 %}
        <div class="mt-8 pt-8 border-t border-[#E5E0D8]">
            <h2 class="text-lg font-semibold text-[#4B5563] mb-4">Historique des modifications</h2>
            <div class="space-y-2 max-h-64 overflow-y-auto">
                {% for h in historique %}
                <div class="flex items-start gap-3 p-3 bg-[#F5F1EB] rounded-lg text-sm">
                    <span class="text-[#6B7280] shrink-0">{{ h.createdAt|date('d/m/Y H:i') }}</span>
                    <span class="font-medium text-[#4B5563]">{{ h.champ }}</span>
                    <span class="text-[#6B7280]">{{ h.ancienneValeur ?? '—' }} → {{ h.nouvelleValeur ?? '—' }}</span>
                    {% if h.user %}
                    <span class="text-[#6B7280] ml-auto">{{ h.user.prenom }} {{ h.user.nom }}</span>
                    {% endif %}
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
{% extends 'layouts/admin.html.twig' %}

{% block title %}Modifier {{ produit.nom }} - AutiCare Admin{% endblock %}

{% block admin_content %}
<div class="max-w-2xl">
    <div class="mb-6 flex items-center gap-4">
        <a href="{{ path('admin_produit_show', {id: produit.id}) }}" class="inline-flex items-center gap-2 text-[#6B7280] hover:text-[#A7C7E7] focus:outline focus:ring-2 focus:ring-[#A7C7E7] rounded-lg">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
            Retour
        </a>
    </div>
    <h1 class="text-2xl font-semibold text-[#4B5563] mb-6">Modifier le produit</h1>

    {% if not produit.valide %}
    <div class="mb-6 p-4 bg-amber-50 border border-amber-200 rounded-lg flex items-center gap-3">
        <svg class="w-6 h-6 text-amber-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
        <div class="flex-1">
            <p class="font-medium text-amber-800">Produit en attente de validation</p>
            <p class="text-sm text-amber-700">Ce produit n'est pas encore visible pour les clients. Modifiez-le si nécessaire puis cliquez sur "Valider" pour le publier.</p>
        </div>
    </div>
    {% endif %}

    <div class="bg-white rounded-xl border border-[#E5E0D8] p-6 md:p-8">
        {{ form_start(form, {
            attr: { class: 'space-y-6', novalidate: 'novalidate' },
            label_attr: { class: 'block text-[#4B5563] font-medium mb-1' }
        }) }}
        <div class="grid grid-cols-1 gap-6">
            {{ form_row(form.nom) }}
            <div class="space-y-1">
                {{ form_label(form.description) }}
                <div class="flex gap-2 items-center mb-1">
                    <button type="button" id="suggest-description-btn"
                            class="px-3 py-1.5 text-sm rounded-lg bg-[#A7C7E7] text-white font-medium hover:bg-[#B8D4ED] focus:ring-2 focus:ring-[#A7C7E7] flex items-center gap-1.5">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                        Suggérer une description
                    </button>
                    <span id="suggest-description-loading" class="hidden text-sm text-[#6B7280]">Génération…</span>
                </div>
                {{ form_widget(form.description) }}
                {{ form_errors(form.description) }}
            </div>
            {{ form_row(form.categorie) }}
            {{ form_row(form.prix) }}
            <div class="flex items-center gap-2">
                {{ form_widget(form.disponibilite) }}
                {{ form_label(form.disponibilite) }}
                {{ form_errors(form.disponibilite) }}
            </div>
            {{ form_row(form.stock) }}
            {{ form_row(form.quantite) }}
            {{ form_row(form.image) }}
            
            {% if produit.images|length > 0 %}
            <div class="space-y-2">
                <label class="block text-[#4B5563] font-medium mb-2">Galerie actuelle</label>
                <div class="flex flex-wrap gap-2">
                    {% for img in produit.images %}
                    <img src="{{ asset(img.chemin) }}" alt="Galerie" class="w-20 h-20 object-cover rounded-lg border border-[#E5E0D8]">
                    {% endfor %}
                </div>
            </div>
            {% endif %}
            
            {% if produit.image %}
            <div class="space-y-2">
                <label class="block text-[#4B5563] font-medium mb-2">Image actuelle</label>
                <img id="current-image" src="{{ asset(produit.image) }}" alt="{{ produit.nom }}" class="w-32 h-32 object-cover rounded-lg border-2 border-[#E5E0D8]">
            </div>
            {% endif %}
            
            {% if produit.genereParIa %}
            <div class="space-y-4 p-4 bg-[#F5F1EB] rounded-lg border border-[#E5E0D8]">
                <div class="flex items-center justify-between">
                    <label class="block text-[#4B5563] font-medium">
                        <svg class="w-5 h-5 inline mr-2 text-[#A7C7E7]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                        </svg>
                        Rechercher des images (IA)
                    </label>
                </div>
                <div class="flex gap-2">
                    <input type="text" id="search-query" value="{{ produit.nom }}" 
                           class="flex-1 px-4 py-2 rounded-lg border border-[#E5E0D8] focus:ring-2 focus:ring-[#A7C7E7] focus:border-[#A7C7E7]"
                           placeholder="Nom du produit à rechercher...">
                    <button type="button" id="search-images-btn"
                            class="px-4 py-2 rounded-lg bg-[#A7C7E7] text-white font-medium hover:bg-[#B8D4ED] focus:ring-2 focus:ring-[#A7C7E7] flex items-center gap-2">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                        </svg>
                        Rechercher
                    </button>
                </div>
                
                <div id="search-loading" class="hidden text-center py-4">
                    <svg class="animate-spin h-8 w-8 mx-auto text-[#A7C7E7]" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                    </svg>
                    <p class="mt-2 text-[#6B7280]">Recherche d'images en cours...</p>
                </div>
                
                <div id="image-results" class="hidden">
                    <p class="text-sm text-[#6B7280] mb-3">Cliquez sur une image pour l'appliquer au produit :</p>
                    <div id="image-grid" class="grid grid-cols-2 md:grid-cols-4 gap-3"></div>
                </div>
                
                <div id="search-error" class="hidden bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg"></div>
                
                <div id="apply-loading" class="hidden text-center py-4">
                    <svg class="animate-spin h-8 w-8 mx-auto text-green-500" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                    </svg>
                    <p class="mt-2 text-[#6B7280]">Application de l'image...</p>
                </div>
                
                <div id="apply-success" class="hidden bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    <span>Image appliquée avec succès !</span>
                </div>
            </div>
            {% endif %}
        </div>
        <div class="flex flex-wrap gap-3 pt-4">
            <button type="submit" class="px-5 py-2.5 rounded-lg bg-[#A7C7E7] text-white font-medium hover:bg-[#B8D4ED] focus:outline focus:ring-2 focus:ring-[#A7C7E7]">
                Enregistrer les modifications
            </button>
            <a href="{{ path('admin_produit_show', {id: produit.id}) }}" class="px-5 py-2.5 rounded-lg border border-[#E5E0D8] text-[#6B7280] font-medium hover:bg-[#F5F1EB] focus:outline focus:ring-2 focus:ring-[#A7C7E7]">
                Annuler
            </a>
        </div>
        {{ form_end(form) }}
        
        {% if not produit.valide %}
        <div class="mt-6 pt-6 border-t border-[#E5E0D8]">
            <form action="{{ path('admin_produit_valider', {id: produit.id}) }}" method="post" class="flex items-center gap-4">
                <input type="hidden" name="_token" value="{{ csrf_token('valider' ~ produit.id) }}">
                <button type="submit" class="px-6 py-3 rounded-lg bg-green-500 text-white font-medium hover:bg-green-600 focus:outline focus:ring-2 focus:ring-green-400 flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                    </svg>
                    Valider et publier le produit
                </button>
                <span class="text-sm text-[#6B7280]">Le produit sera visible pour les clients</span>
            </form>
        </div>
        {% endif %}
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const suggestBtn = document.getElementById('suggest-description-btn');
    const nomInput = document.getElementById('produit_nom');
    const descInput = document.getElementById('produit_description');
    const suggestLoading = document.getElementById('suggest-description-loading');
    if (suggestBtn && nomInput && descInput) {
        suggestBtn.addEventListener('click', async function() {
            const nom = nomInput.value.trim();
            if (!nom) { alert('Saisissez d\'abord le nom du produit.'); return; }
            suggestBtn.disabled = true;
            suggestLoading.classList.remove('hidden');
            try {
                const fd = new FormData();
                fd.append('nom', nom);
                const r = await fetch('{{ path("admin_produit_suggerer_description") }}', { method: 'POST', body: fd, headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' } });
                const d = await r.json();
                if (d.description) descInput.value = d.description;
                else alert(d.error || 'Erreur lors de la suggestion');
            } catch (e) { alert('Erreur réseau'); } finally { suggestBtn.disabled = false; suggestLoading.classList.add('hidden'); }
        });
    }

    const searchBtn = document.getElementById('search-images-btn');
    if (!searchBtn) return;
    const searchQuery = document.getElementById('search-query');
    const searchLoading = document.getElementById('search-loading');
    const imageResults = document.getElementById('image-results');
    const imageGrid = document.getElementById('image-grid');
    const searchError = document.getElementById('search-error');
    const applyLoading = document.getElementById('apply-loading');
    const applySuccess = document.getElementById('apply-success');
    const currentImage = document.getElementById('current-image');
    
    const productId = {{ produit.id }};
    
    searchBtn.addEventListener('click', async function() {
        const query = searchQuery.value.trim();
        if (!query) return;
        
        searchLoading.classList.remove('hidden');
        imageResults.classList.add('hidden');
        searchError.classList.add('hidden');
        searchError.textContent = '';
        applySuccess.classList.add('hidden');
        
        try {
            const formData = new FormData();
            formData.append('query', query);
            
            const response = await fetch('{{ path("admin_produit_search_images", {id: produit.id}) }}', {
                method: 'POST',
                body: formData,
                credentials: 'same-origin',
                headers: {
                    'Accept': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                }
            });
            
            let data;
            try {
                data = await response.json();
            } catch (e) {
                throw new Error('Réponse serveur invalide (erreur ' + response.status + ')');
            }
            
            if (!response.ok) {
                throw new Error(data.error || 'Erreur serveur (' + response.status + ')');
            }
            
            if (data.error) {
                throw new Error(data.error);
            }
            
            if (data.images && data.images.length > 0) {
                renderImages(data.images);
                imageResults.classList.remove('hidden');
            } else {
                searchError.textContent = 'Aucune image trouvée pour "' + query + '"';
                searchError.classList.remove('hidden');
            }
        } catch (error) {
            searchError.textContent = error.message || 'Erreur lors de la recherche';
            searchError.classList.remove('hidden');
        } finally {
            searchLoading.classList.add('hidden');
        }
    });
    
    function renderImages(images) {
        imageGrid.innerHTML = '';
        
        images.forEach(function(img, index) {
            const card = document.createElement('div');
            card.className = 'relative group cursor-pointer rounded-lg overflow-hidden border-2 border-[#E5E0D8] hover:border-[#A7C7E7] transition-all';
            card.innerHTML = `
                <img src="${img.url}" alt="${img.title || 'Image'}" 
                     class="w-full h-24 object-cover"
                     onerror="this.parentElement.style.display='none'">
                <div class="absolute inset-0 bg-black bg-opacity-0 group-hover:bg-opacity-30 transition-all flex items-center justify-center">
                    <span class="text-white opacity-0 group-hover:opacity-100 text-sm font-medium">Appliquer</span>
                </div>
                <div class="p-2 bg-white">
                    <p class="text-xs text-[#6B7280] truncate">${img.source}</p>
                </div>
            `;
            
            card.addEventListener('click', function() {
                applyImage(img.url);
            });
            
            imageGrid.appendChild(card);
        });
    }
    
    async function applyImage(imageUrl) {
        applyLoading.classList.remove('hidden');
        imageResults.classList.add('hidden');
        applySuccess.classList.add('hidden');
        searchError.classList.add('hidden');
        
        try {
            const formData = new FormData();
            formData.append('image_url', imageUrl);
            
            const response = await fetch(`/admin/produits/${productId}/apply-external-image`, {
                method: 'POST',
                body: formData
            });
            
            const data = await response.json();
            
            if (data.error) {
                throw new Error(data.error);
            }
            
            if (currentImage) {
                currentImage.src = '/' + data.image_path + '?t=' + Date.now();
            } else {
                const imageContainer = document.querySelector('.space-y-2');
                if (imageContainer) {
                    const newImg = document.createElement('img');
                    newImg.id = 'current-image';
                    newImg.src = '/' + data.image_path + '?t=' + Date.now();
                    newImg.alt = '{{ produit.nom }}';
                    newImg.className = 'w-32 h-32 object-cover rounded-lg border-2 border-[#E5E0D8]';
                    imageContainer.appendChild(newImg);
                }
            }
            
            applySuccess.classList.remove('hidden');
            
            setTimeout(function() {
                applySuccess.classList.add('hidden');
            }, 3000);
            
        } catch (error) {
            searchError.textContent = error.message || 'Erreur lors de l\'application de l\'image';
            searchError.classList.remove('hidden');
        } finally {
            applyLoading.classList.add('hidden');
        }
    }
    
    searchQuery.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            searchBtn.click();
        }
    });
});
</script>
{% endblock %}
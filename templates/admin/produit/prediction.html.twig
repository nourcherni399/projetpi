{% extends 'layouts/admin.html.twig' %}

{% block title %}Intelligence commerciale & Prédictions - AutiCare Admin{% endblock %}

{% block admin_content %}
<div class="mb-6">
    <div class="flex items-center gap-3 flex-wrap">
        <h1 class="text-2xl md:text-3xl font-bold text-[#4B5563]">Intelligence commerciale & Prédictions</h1>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-violet-100 text-violet-700 border border-violet-200">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z" />
            </svg>
            Propulsé par IA
        </span>
    </div>
    <p class="text-[#6B7280] mt-1">Analyse intelligente des ventes · Prévisions IA · Prix conseillés · Stock à commander</p>
</div>

<div class="mb-6 flex flex-wrap gap-2">
    <a href="{{ path('admin_produit_index') }}" class="px-4 py-2.5 rounded-lg border border-[#E5E0D8] text-[#6B7280] font-medium hover:bg-[#F5F1EB] inline-flex items-center gap-2">
        ← Retour aux produits
    </a>
</div>

{% if predictions|length == 0 %}
    <section class="bg-white rounded-xl border border-[#E5E0D8] shadow-sm p-8 text-center text-[#6B7280]">
        Aucun produit à analyser.
    </section>
{% else %}
    {# ——— KPIs principaux ——— #}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="bg-gradient-to-br from-indigo-50 to-white rounded-xl border border-indigo-100 shadow-sm p-5">
            <h2 class="text-sm font-semibold text-indigo-700 uppercase tracking-wider">Chiffre d'affaires estimé</h2>
            <p class="text-2xl font-bold text-indigo-900 mt-1">{{ ca_estime_annee|number_format(2, ',', ' ') }} DT</p>
            <p class="text-sm text-indigo-600 mt-1">Année {{ annee_cible }} · Prévision IA</p>
        </div>
        <div class="bg-white rounded-xl border border-[#E5E0D8] shadow-sm p-5">
            <h2 class="text-sm font-semibold text-[#6B7280] uppercase tracking-wider">Ventes prévues (mois)</h2>
            <p class="text-2xl font-bold text-[#4B5563] mt-1">{{ total_ventes_prevu_mois }}</p>
            <p class="text-sm text-[#6B7280] mt-1">Mois {{ mois_cible }} · Analyse IA</p>
        </div>
        <div class="bg-white rounded-xl border border-[#E5E0D8] shadow-sm p-5">
            <h2 class="text-sm font-semibold text-[#6B7280] uppercase tracking-wider">Forte demande</h2>
            <p class="text-2xl font-bold text-emerald-600 mt-1">{{ byLabel.forte_demande|length }}</p>
            <p class="text-sm text-[#6B7280] mt-1">Produits qui vendent bien</p>
        </div>
        <div class="bg-white rounded-xl border border-[#E5E0D8] shadow-sm p-5">
            <h2 class="text-sm font-semibold text-[#6B7280] uppercase tracking-wider">Faible rotation</h2>
            <p class="text-2xl font-bold text-red-600 mt-1">{{ byLabel.faible_rotation|length }}</p>
            <p class="text-sm text-[#6B7280] mt-1">À surveiller ou promouvoir</p>
        </div>
    </div>

    {# ——— Recommandations stratégiques ——— #}
    <section class="mb-8">
        <h2 class="text-lg font-bold text-[#4B5563] mb-4">Recommandations stratégiques</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            <div class="bg-emerald-50 rounded-xl border border-emerald-200 p-4">
                <div class="w-full text-left px-4 py-2.5 rounded-lg bg-emerald-200 border border-emerald-400 text-emerald-900 font-semibold">
                    Produits star à promouvoir
                </div>
                <p class="text-sm text-emerald-700 mt-2">{{ byStrategic.star|length }} produit(s)</p>
                <ul class="mt-2 space-y-1 text-sm text-emerald-800 list-none p-0 m-0">
                    {% for row in byStrategic.star %}
                        <li><a href="{{ path('admin_produit_show', {id: row.produit.id}) }}" class="hover:underline">{{ row.produit.nom }}</a></li>
                    {% else %}
                        <li class="text-emerald-600">Aucun</li>
                    {% endfor %}
                </ul>
            </div>
            <div class="bg-amber-50 rounded-xl border border-amber-200 p-4">
                <div class="w-full text-left px-4 py-2.5 rounded-lg bg-amber-200 border border-amber-400 text-amber-900 font-semibold">
                    Produits à risque
                </div>
                <p class="text-sm text-amber-700 mt-2">{{ byStrategic.a_risque|length }} produit(s)</p>
                <ul class="mt-2 space-y-1 text-sm text-amber-800 list-none p-0 m-0">
                    {% for row in byStrategic.a_risque %}
                        <li><a href="{{ path('admin_produit_show', {id: row.produit.id}) }}" class="hover:underline">{{ row.produit.nom }}</a></li>
                    {% else %}
                        <li class="text-amber-600">Aucun</li>
                    {% endfor %}
                </ul>
            </div>
            <div class="bg-blue-50 rounded-xl border border-blue-200 p-4">
                <div class="w-full text-left px-4 py-2.5 rounded-lg bg-blue-200 border border-blue-400 text-blue-900 font-semibold">
                    Produits à relancer
                </div>
                <p class="text-sm text-blue-700 mt-2">{{ byStrategic.a_relancer|length }} produit(s)</p>
                <ul class="mt-2 space-y-1 text-sm text-blue-800 list-none p-0 m-0">
                    {% for row in byStrategic.a_relancer %}
                        <li><a href="{{ path('admin_produit_show', {id: row.produit.id}) }}" class="hover:underline">{{ row.produit.nom }}</a></li>
                    {% else %}
                        <li class="text-blue-600">Aucun</li>
                    {% endfor %}
                </ul>
            </div>
            <div class="bg-slate-100 rounded-xl border border-slate-300 p-4">
                <div class="w-full text-left px-4 py-2.5 rounded-lg bg-slate-300 border border-slate-500 text-slate-900 font-semibold">
                    Envisager retrait
                </div>
                <p class="text-sm text-slate-600 mt-2">{{ byStrategic.a_supprimer|length }} produit(s)</p>
                <ul class="mt-2 space-y-1 text-sm text-slate-700 list-none p-0 m-0">
                    {% for row in byStrategic.a_supprimer %}
                        <li><a href="{{ path('admin_produit_show', {id: row.produit.id}) }}" class="hover:underline">{{ row.produit.nom }}</a></li>
                    {% else %}
                        <li class="text-slate-500">Aucun</li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    </section>

    {# ——— Stock à commander ——— #}
    {% if needStock|default([])|length > 0 %}
    <section class="mb-8 bg-white rounded-xl border border-[#E5E0D8] shadow-sm overflow-hidden">
        <div class="px-6 py-4 bg-amber-50 border-b border-amber-100">
            <h2 class="text-lg font-bold text-amber-800">Stock à commander (éviter rupture)</h2>
            <p class="text-sm text-amber-700">Quantités à commander pour le mois {{ mois_cible }} selon les prévisions IA.</p>
        </div>
        <ul class="divide-y divide-[#E5E0D8]">
            {% for row in needStock %}
                <li class="px-6 py-3 flex flex-wrap items-center justify-between gap-2">
                    <a href="{{ path('admin_produit_show', {id: row.produit.id}) }}" class="font-medium text-[#4B5563] hover:text-[#A7C7E7]">{{ row.produit.nom }}</a>
                    <span class="text-amber-700 font-semibold">Commander <strong>{{ row.stock_to_order }}</strong> unité(s)</span>
                    <span class="text-sm text-[#6B7280]">Stock actuel : {{ row.produit.quantite }} · Prévision mois : {{ row.forecast_next_month|default(0) }}</span>
                </li>
            {% endfor %}
        </ul>
    </section>
    {% endif %}

    {# ——— Prévisions par produit ——— #}
    <section class="mb-8 bg-white rounded-xl border border-[#E5E0D8] shadow-sm overflow-hidden">
        <div class="px-6 py-4 bg-[#F5F1EB] border-b border-[#E5E0D8]">
            <h2 class="text-lg font-bold text-[#4B5563]">Prévisions des ventes par produit</h2>
            <p class="text-sm text-[#6B7280]">Mois prochain · Année {{ annee_cible }}</p>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm">
                <thead class="bg-[#F5F1EB] border-b border-[#E5E0D8]">
                    <tr>
                        <th class="px-6 py-3 font-semibold text-[#4B5563]">Produit</th>
                        <th class="px-6 py-3 font-semibold text-[#4B5563]">Vendu total</th>
                        <th class="px-6 py-3 font-semibold text-[#4B5563]">90 derniers jours</th>
                        <th class="px-6 py-3 font-semibold text-[#4B5563]">Stock</th>
                        <th class="px-6 py-3 font-semibold text-[#4B5563]">Segment</th>
                        <th class="px-6 py-3 font-semibold text-[#4B5563]">Prévision mois</th>
                        <th class="px-6 py-3 font-semibold text-[#4B5563]">Prévision {{ annee_cible }}</th>
                        <th class="px-6 py-3 font-semibold text-[#4B5563]">Tendance</th>
                        <th class="px-6 py-3 font-semibold text-[#4B5563]">Prix conseillé</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-[#E5E0D8]">
                    {% for row in predictions %}
                    <tr class="hover:bg-[#F9FAFB]">
                        <td class="px-6 py-3">
                            <a href="{{ path('admin_produit_show', {id: row.produit.id}) }}" class="font-medium text-[#4B5563] hover:text-[#A7C7E7]">{{ row.produit.nom }}</a>
                        </td>
                        <td class="px-6 py-3">{{ row.total_vendu }}</td>
                        <td class="px-6 py-3">{{ row.recent_vendu }}</td>
                        <td class="px-6 py-3">{{ row.produit.quantite }}</td>
                        <td class="px-6 py-3">
                            {% if row.label == 'forte_demande' %}<span class="px-2 py-0.5 rounded bg-emerald-100 text-emerald-800">Forte demande</span>
                            {% elseif row.label == 'faible_rotation' %}<span class="px-2 py-0.5 rounded bg-red-100 text-red-800">Faible rotation</span>
                            {% else %}<span class="px-2 py-0.5 rounded bg-amber-100 text-amber-800">Potentiel moyen</span>{% endif %}
                        </td>
                        <td class="px-6 py-3">{{ row.forecast_next_month|default(0) }}</td>
                        <td class="px-6 py-3">{{ row.forecast_next_year|default(0) }}</td>
                        <td class="px-6 py-3">
                            {% if row.trend|default('') == 'en_croissance' %}<span class="text-emerald-600">Croissance</span>
                            {% elseif row.trend|default('') == 'en_declin' %}<span class="text-red-600">Déclin</span>
                            {% else %}<span class="text-[#6B7280]">Stable</span>{% endif %}
                        </td>
                        <td class="px-6 py-3">{{ row.price_suggestion.texte|default('—') }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>

    {# ——— Détail par segment ——— #}
    <div class="space-y-8">
        <section class="bg-white rounded-xl border border-[#E5E0D8] shadow-sm overflow-hidden">
            <div class="px-6 py-4 bg-emerald-50 border-b border-emerald-100">
                <h2 class="text-lg font-bold text-emerald-800">Forte demande</h2>
                <p class="text-sm text-emerald-700">Réapprovisionner si besoin, maintenir la visibilité. Prix conseillé : augmentation possible (+5%).</p>
            </div>
            <ul class="divide-y divide-[#E5E0D8]">
                {% for row in byLabel.forte_demande %}
                    <li class="px-6 py-4 flex flex-wrap items-center justify-between gap-2">
                        <div>
                            <a href="{{ path('admin_produit_show', {id: row.produit.id}) }}" class="font-medium text-[#4B5563] hover:text-[#A7C7E7]">{{ row.produit.nom }}</a>
                            <p class="text-sm text-[#6B7280] mt-0.5">{{ row.recommandation }}</p>
                            <p class="text-xs text-[#9CA3AF] mt-1">{{ row.trend_detail|default('') }}</p>
                        </div>
                        <div class="text-sm text-[#6B7280] text-right">
                            <strong>Réel :</strong> Vendu {{ row.total_vendu }} · 90j {{ row.recent_vendu }} · Stock {{ row.produit.quantite }}<br>
                            <strong>Prévision :</strong> Mois {{ row.forecast_next_month|default(0) }} · Année {{ row.forecast_next_year|default(0) }} · {{ row.price_suggestion.texte|default('') }}
                        </div>
                    </li>
                {% else %}
                    <li class="px-6 py-4 text-[#6B7280]">Aucun produit dans cette catégorie.</li>
                {% endfor %}
            </ul>
        </section>

        <section class="bg-white rounded-xl border border-[#E5E0D8] shadow-sm overflow-hidden">
            <div class="px-6 py-4 bg-amber-50 border-b border-amber-100">
                <h2 class="text-lg font-bold text-amber-800">Potentiel moyen</h2>
                <p class="text-sm text-amber-700">Stable ou à promouvoir. Maintenir le prix ou petite promo.</p>
            </div>
            <ul class="divide-y divide-[#E5E0D8]">
                {% for row in byLabel.potentiel_moyen %}
                    <li class="px-6 py-4 flex flex-wrap items-center justify-between gap-2">
                        <div>
                            <a href="{{ path('admin_produit_show', {id: row.produit.id}) }}" class="font-medium text-[#4B5563] hover:text-[#A7C7E7]">{{ row.produit.nom }}</a>
                            <p class="text-sm text-[#6B7280] mt-0.5">{{ row.recommandation }}</p>
                            <p class="text-xs text-[#9CA3AF] mt-1">{{ row.trend_detail|default('') }}</p>
                        </div>
                        <div class="text-sm text-[#6B7280] text-right">
                            <strong>Réel :</strong> Vendu {{ row.total_vendu }} · 90j {{ row.recent_vendu }} · Stock {{ row.produit.quantite }}<br>
                            <strong>Prévision :</strong> Mois {{ row.forecast_next_month|default(0) }} · Année {{ row.forecast_next_year|default(0) }} · {{ row.price_suggestion.texte|default('') }}
                        </div>
                    </li>
                {% else %}
                    <li class="px-6 py-4 text-[#6B7280]">Aucun produit dans cette catégorie.</li>
                {% endfor %}
            </ul>
        </section>

        <section class="bg-white rounded-xl border border-[#E5E0D8] shadow-sm overflow-hidden">
            <div class="px-6 py-4 bg-red-50 border-b border-red-100">
                <h2 class="text-lg font-bold text-red-800">Faible rotation</h2>
                <p class="text-sm text-red-700">Éviter le surstock. Promotion recommandée (-10%) ou mise en avant.</p>
            </div>
            <ul class="divide-y divide-[#E5E0D8]">
                {% for row in byLabel.faible_rotation %}
                    <li class="px-6 py-4 flex flex-wrap items-center justify-between gap-2">
                        <div>
                            <a href="{{ path('admin_produit_show', {id: row.produit.id}) }}" class="font-medium text-[#4B5563] hover:text-[#A7C7E7]">{{ row.produit.nom }}</a>
                            <p class="text-sm text-[#6B7280] mt-0.5">{{ row.recommandation }}</p>
                            <p class="text-xs text-[#9CA3AF] mt-1">{{ row.trend_detail|default('') }}</p>
                        </div>
                        <div class="text-sm text-[#6B7280] text-right">
                            <strong>Réel :</strong> Vendu {{ row.total_vendu }} · 90j {{ row.recent_vendu }} · Stock {{ row.produit.quantite }}<br>
                            <strong>Prévision :</strong> Mois {{ row.forecast_next_month|default(0) }} · Année {{ row.forecast_next_year|default(0) }} · {{ row.price_suggestion.texte|default('') }}
                        </div>
                    </li>
                {% else %}
                    <li class="px-6 py-4 text-[#6B7280]">Aucun produit dans cette catégorie.</li>
                {% endfor %}
            </ul>
        </section>
    </div>
{% endif %}
{% endblock %}

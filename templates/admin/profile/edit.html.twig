{% extends 'layouts/admin.html.twig' %}

{% block title %}Mon profil - AutiCare Admin{% endblock %}

{% block admin_content %}
{% set cabinetBonus = 0 %}
{% if form.specialite is defined %}
    {% set cabinetBonus = (user.specialite|default('') != '' ? 10 : 0) + (user.nomCabinet|default('') != '' ? 10 : 0) %}
{% endif %}
{% set profileCompletion =
    (user.prenom ? 12 : 0) +
    (user.nom ? 12 : 0) +
    (user.email ? 12 : 0) +
    (user.telephone ? 12 : 0) +
    (user.image ? 12 : 0) +
    cabinetBonus
%}
{% set profileCompletion = profileCompletion > 100 ? 100 : profileCompletion %}
{% set sidebarRole = user.role ? user.role.value|replace({'ROLE_': ''}) : 'ADMIN' %}
{% set statA = user.produits|length %}
{% set statB = user.commentaires|length %}
{% set statC = user.blogs|length %}

<div class="max-w-7xl mx-auto py-10 px-4 sm:px-0">
    <div class="rounded-[30px] overflow-hidden border border-[#D5DDD8] bg-white shadow-2xl">
        <div class="grid lg:grid-cols-[360px_1fr]">
            <aside class="relative overflow-hidden bg-[#7E9C87] text-white p-10">
                <div class="absolute -top-24 -right-16 w-72 h-72 rounded-full bg-white/12"></div>
                <div class="absolute -top-10 -right-28 w-80 h-80 rounded-full bg-white/8"></div>
                <div class="absolute -bottom-24 -left-20 w-80 h-80 rounded-full bg-white/10"></div>

                <div class="relative z-10 flex flex-col h-full">
                    <div class="flex justify-center mb-7">
                        <div class="relative">
                            <div class="w-32 h-32 rounded-full overflow-hidden border-4 border-white/65 bg-white/30">
                                {% if user.image %}
                                    <img src="{{ asset(user.image) }}" alt="Photo de profil" class="w-full h-full object-cover">
                                {% else %}
                                    <div class="w-full h-full flex items-center justify-center text-5xl font-semibold text-white/90">
                                        {{ user.prenom ? user.prenom|slice(0,1)|upper : 'A' }}
                                    </div>
                                {% endif %}
                            </div>
                            <span class="absolute -bottom-1 -right-1 w-10 h-10 rounded-full bg-white text-[#7E9C87] flex items-center justify-center shadow-md">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 7a2 2 0 012-2h2l1.5-2h7L17 5h2a2 2 0 012 2v11a2 2 0 01-2 2H5a2 2 0 01-2-2V7z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 16a4 4 0 100-8 4 4 0 000 8z" />
                                </svg>
                            </span>
                        </div>
                    </div>

                    <div class="text-center mb-6">
                        <h2 class="text-[40px] leading-none font-semibold italic">{{ user.prenom }} {{ user.nom }}</h2>
                        <p class="mt-3 text-white/85 tracking-[0.18em] text-sm uppercase">{{ sidebarRole }}</p>
                    </div>

                    <div class="w-20 h-px bg-white/35 mx-auto mb-8"></div>

                    <div class="grid grid-cols-2 gap-4 mb-7">
                        <div class="rounded-2xl border border-white/20 bg-white/10 py-4 text-center">
                            <p class="text-4xl font-bold">{{ statA }}</p>
                            <p class="text-xs uppercase tracking-[0.18em] text-white/80 mt-1">Produits</p>
                        </div>
                        <div class="rounded-2xl border border-white/20 bg-white/10 py-4 text-center">
                            <p class="text-4xl font-bold">{{ statB }}</p>
                            <p class="text-xs uppercase tracking-[0.18em] text-white/80 mt-1">Commentaires</p>
                        </div>
                        <div class="rounded-2xl border border-white/20 bg-white/10 py-4 text-center">
                            <p class="text-4xl font-bold">{{ statC }}</p>
                            <p class="text-xs uppercase tracking-[0.18em] text-white/80 mt-1">Articles</p>
                        </div>
                        <div class="rounded-2xl border border-white/20 bg-white/10 py-4 text-center">
                            <p class="text-4xl font-bold">{{ user.id }}</p>
                            <p class="text-xs uppercase tracking-[0.18em] text-white/80 mt-1">ID</p>
                        </div>
                    </div>

                    <div class="mt-auto">
                        <div class="flex items-center justify-between text-sm text-white/90 mb-2">
                            <span>Profil complete</span>
                            <span>{{ profileCompletion }}%</span>
                        </div>
                        <div class="h-2 bg-white/25 rounded-full overflow-hidden">
                            <div class="h-full bg-white rounded-full" style="width: {{ profileCompletion }}%"></div>
                        </div>
                    </div>
                </div>
            </aside>

            <section class="bg-[#F6F8F6] p-8 md:p-12">
                <div class="flex items-start justify-between mb-8">
                    <div>
                        <h1 class="text-5xl font-serif text-[#2F3E36]">Modifier <span class="italic text-[#7E9C87]">mon profil</span></h1>
                        <p class="mt-2 text-[#6E7C74]">Mettez a jour vos informations en toute simplicite.</p>
                    </div>
                    <a href="{{ path('admin_dashboard') }}" class="text-[#6B7280] hover:text-[#7E9C87] text-3xl leading-none" aria-label="Fermer">×</a>
                </div>

                {% for message in app.flashes('success') %}
                    <div class="mb-6 p-4 bg-emerald-50 border border-emerald-200 rounded-xl flex items-center gap-3">
                        <span class="flex items-center justify-center w-10 h-10 rounded-full bg-emerald-100 text-emerald-600">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                        </span>
                        <p class="text-emerald-700 font-medium">{{ message }}</p>
                    </div>
                {% endfor %}

                {{ form_start(form, {'attr': {'class': 'space-y-8', 'novalidate': 'novalidate'}}) }}
                    {{ form_errors(form) }}

                    <div>
                        <h2 class="text-sm font-semibold tracking-[0.18em] uppercase text-[#5F7868] mb-4">Informations personnelles</h2>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                            <div>
                                {{ form_label(form.prenom, 'Prénom', {'label_attr': {'class': 'block text-[#4D5D55] font-medium mb-2'}}) }}
                                {{ form_widget(form.prenom) }}
                                {{ form_errors(form.prenom) }}
                            </div>
                            <div>
                                {{ form_label(form.nom, 'Nom', {'label_attr': {'class': 'block text-[#4D5D55] font-medium mb-2'}}) }}
                                {{ form_widget(form.nom) }}
                                {{ form_errors(form.nom) }}
                            </div>
                            <div class="md:col-span-2">
                                {{ form_label(form.email, 'Email', {'label_attr': {'class': 'block text-[#4D5D55] font-medium mb-2'}}) }}
                                {{ form_widget(form.email) }}
                                {{ form_errors(form.email) }}
                            </div>
                            <div class="md:col-span-2">
                                {{ form_label(form.telephone, 'Téléphone', {'label_attr': {'class': 'block text-[#4D5D55] font-medium mb-2'}}) }}
                                {{ form_widget(form.telephone) }}
                                {{ form_errors(form.telephone) }}
                            </div>
                        </div>
                    </div>

                    <div>
                        <h2 class="text-sm font-semibold tracking-[0.18em] uppercase text-[#5F7868] mb-4">Photo de profil</h2>
                        {{ form_label(form.image, null, {'label_attr': {'class': 'block text-[#4D5D55] font-medium mb-2'}}) }}
                        {{ form_widget(form.image) }}
                        {{ form_errors(form.image) }}
                        <p class="mt-2 text-xs text-[#7D8B84]">Formats: JPG, PNG, GIF, WebP (max 5 MB)</p>
                    </div>

                    {% if form.specialite is defined %}
                        <div>
                            <h2 class="text-sm font-semibold tracking-[0.18em] uppercase text-[#5F7868] mb-4">Informations cabinet</h2>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                                <div>
                                    {{ form_label(form.specialite, null, {'label_attr': {'class': 'block text-[#4D5D55] font-medium mb-2'}}) }}
                                    {{ form_widget(form.specialite) }}
                                    {{ form_errors(form.specialite) }}
                                </div>
                                <div>
                                    {{ form_label(form.nomCabinet, null, {'label_attr': {'class': 'block text-[#4D5D55] font-medium mb-2'}}) }}
                                    {{ form_widget(form.nomCabinet) }}
                                    {{ form_errors(form.nomCabinet) }}
                                </div>
                                <div>
                                    {{ form_label(form.telephoneCabinet, null, {'label_attr': {'class': 'block text-[#4D5D55] font-medium mb-2'}}) }}
                                    {{ form_widget(form.telephoneCabinet) }}
                                    {{ form_errors(form.telephoneCabinet) }}
                                </div>
                                <div>
                                    {{ form_label(form.tarifConsultation, null, {'label_attr': {'class': 'block text-[#4D5D55] font-medium mb-2'}}) }}
                                    {{ form_widget(form.tarifConsultation) }}
                                    {{ form_errors(form.tarifConsultation) }}
                                </div>
                                <div class="md:col-span-2">
                                    {{ form_label(form.adresseCabinet, null, {'label_attr': {'class': 'block text-[#4D5D55] font-medium mb-2'}}) }}
                                    {{ form_widget(form.adresseCabinet) }}
                                    {{ form_errors(form.adresseCabinet) }}
                                </div>
                            </div>
                        </div>
                    {% endif %}

                    <div class="pt-2 flex items-center gap-3 flex-wrap">
                        {{ form_widget(form.submit) }}
                        <a href="{{ path('admin_dashboard') }}" class="inline-flex items-center gap-2 px-4 py-3 rounded-xl border border-[#E5E0D8] text-[#6B7280] font-medium hover:bg-[#F5F1EB] transition-colors">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" /></svg>
                            Retour
                        </a>
                        <a href="{{ path('app_logout') }}" class="inline-flex items-center gap-2 px-4 py-3 rounded-xl border border-red-200 text-red-600 font-medium hover:bg-red-50 transition-colors">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                            </svg>
                            Se déconnecter
                        </a>
                    </div>
                {{ form_end(form) }}
            </section>
        </div>
    </div>
</div>
{% endblock %}

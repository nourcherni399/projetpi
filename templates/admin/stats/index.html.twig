{% extends 'layouts/admin.html.twig' %}

{% block title %}Statistiques Produits - AutiCare Admin{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="https://cdn.jsdelivr.net/npm/echarts@5.4.3/dist/echarts.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/echarts-gl@2.0.9/dist/echarts-gl.min.js"></script>
{% endblock %}

{% block admin_content %}
<div class="space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-2xl font-semibold text-[#4B5563]">Statistiques des Produits</h1>
        <div class="flex items-center gap-2 text-sm text-[#6B280]">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Dernière mise à jour: {{ "now"|date("d/m/Y H:i") }}
        </div>
    </div>

    <!-- Cartes statistiques principales -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white rounded-xl border border-[#E5E0D8] p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-[#6B280]">Total Produits</p>
                    <p class="text-2xl font-bold text-[#4B5563] mt-2">{{ totalProduits }}</p>
                </div>
                <div class="p-3 bg-blue-100 rounded-lg">
                    <svg class="w-6 h-6 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                    </svg>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl border border-[#E5E0D8] p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-[#6B280]">Produits Disponibles</p>
                    <p class="text-2xl font-bold text-green-600 mt-2">{{ produitsDisponibles }}</p>
                    <p class="text-xs text-[#6B280] mt-1">{{ totalProduits > 0 ? ((produitsDisponibles / totalProduits) * 100)|number_format(1) : 0 }}% du total</p>
                </div>
                <div class="p-3 bg-green-100 rounded-lg">
                    <svg class="w-6 h-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl border border-[#E5E0D8] p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-[#6B280]">Produits Indisponibles</p>
                    <p class="text-2xl font-bold text-red-600 mt-2">{{ produitsIndisponibles }}</p>
                    <p class="text-xs text-[#6B280] mt-1">{{ totalProduits > 0 ? ((produitsIndisponibles / totalProduits) * 100)|number_format(1) : 0 }}% du total</p>
                </div>
                <div class="p-3 bg-red-100 rounded-lg">
                    <svg class="w-6 h-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl border border-[#E5E0D8] p-6">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-[#6B280]">Paniers Actifs</p>
                    <p class="text-2xl font-bold text-[#A7C7E7] mt-2">{{ paniersActifs }}</p>
                    <p class="text-xs text-[#6B280] mt-1">sur {{ totalPaniers }} total</p>
                </div>
                <div class="p-3 bg-[#A7C7E7]/20 rounded-lg">
                    <svg class="w-6 h-6 text-[#A7C7E7]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                    </svg>
                </div>
            </div>
        </div>
    </div>

    <!-- Graphiques 3D -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- 3D - Quantité de produits par catégorie -->
        {% if produitsParCategorie is not empty %}
        <div class="bg-white rounded-xl border border-[#E5E0D8] p-6">
            <h2 class="text-lg font-semibold text-[#4B5563] mb-2 flex items-center gap-2">
                <svg class="w-5 h-5 text-[#A7C7E7]" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>
                Quantité de produits par catégorie
            </h2>
            <p class="text-xs text-[#6B7280] mb-3">Glissez avec la souris pour faire pivoter le graphique 3D</p>
            <div id="chart-3d-produits" style="width:100%; height:350px;"></div>
            <script type="application/json" id="data-produits-categorie">{{ produitsParCategorie|json_encode|raw }}</script>
        </div>
        {% endif %}

        <!-- 3D - Prix moyen par catégorie -->
        {% if prixMoyensParCategorie is not empty %}
        <div class="bg-white rounded-xl border border-[#E5E0D8] p-6">
            <h2 class="text-lg font-semibold text-[#4B5563] mb-2 flex items-center gap-2">
                <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                Prix moyen (dt) par catégorie
            </h2>
            <p class="text-xs text-[#6B7280] mb-3">Glissez avec la souris pour faire pivoter le graphique 3D</p>
            <div id="chart-3d-prix" style="width:100%; height:350px;"></div>
            <script type="application/json" id="data-prix-categorie">{{ prixMoyensParCategorie|json_encode|raw }}</script>
        </div>
        {% endif %}
    </div>

    <script>
    function initStats3DCharts() {
        if (typeof echarts === 'undefined') return;

        var dataProduits = [];
        try {
            var el1 = document.getElementById('data-produits-categorie');
            if (el1) dataProduits = JSON.parse(el1.textContent);
        } catch (e) {}
        var dataPrix = [];
        try {
            var el2 = document.getElementById('data-prix-categorie');
            if (el2) dataPrix = JSON.parse(el2.textContent);
        } catch (e) {}

        var colors = ['#A7C7E7', '#95d7b5', '#F39C12', '#9B59B6', '#E74C3C', '#1ABC9C', '#3498DB', '#e74c8c'];

        if (dataProduits.length > 0) {
            var elChart1 = document.getElementById('chart-3d-produits');
            if (elChart1) {
            var chart1 = echarts.init(elChart1);
            var cats = dataProduits.map(function(p) { return p.categorie; });
            var data1 = dataProduits.map(function(p, i) { return [i, 0, p.nombre]; });
            chart1.setOption({
                tooltip: { formatter: function(params) { var d = dataProduits[params.value[0]]; return (d ? d.categorie : '') + ': ' + (params.value[2] || 0) + ' produit(s)'; } },
                visualMap: { show: false, min: 0, max: Math.max.apply(null, dataProduits.map(function(p) { return p.nombre; })) || 1, inRange: { color: ['#A7C7E7', '#1a5fb4'] } },
                xAxis3D: { type: 'category', data: cats, axisLabel: { interval: 0, rotate: 30 } },
                yAxis3D: { type: 'category', data: [''] },
                zAxis3D: { type: 'value' },
                grid3D: { boxWidth: 150, boxDepth: 50, viewControl: { projection: 'perspective', autoRotate: false } },
                series: [{ type: 'bar3D', data: data1, shading: 'lambert', itemStyle: { opacity: 0.9 }, emphasis: { label: { fontSize: 14 } } }]
            });
            window.addEventListener('resize', function() { chart1.resize(); });
            }
        }

        if (dataPrix.length > 0) {
            var elChart2 = document.getElementById('chart-3d-prix');
            if (elChart2) {
            var chart2 = echarts.init(elChart2);
            var cats2 = dataPrix.map(function(p) { return p.categorie; });
            var data2 = dataPrix.map(function(p, i) { return [i, 0, p.prixMoyen]; });
            var maxPrix = Math.max.apply(null, dataPrix.map(function(p) { return p.prixMoyen; })) || 1;
            chart2.setOption({
                tooltip: { formatter: function(params) { var d = dataPrix[params.value[0]]; return (d ? d.categorie : '') + ': ' + (params.value[2] ? params.value[2].toFixed(2) : '') + ' dt'; } },
                visualMap: { show: false, min: 0, max: maxPrix, inRange: { color: ['#95d7b5', '#0d8050'] } },
                xAxis3D: { type: 'category', data: cats2, axisLabel: { interval: 0, rotate: 30 } },
                yAxis3D: { type: 'category', data: [''] },
                zAxis3D: { type: 'value' },
                grid3D: { boxWidth: 150, boxDepth: 50, viewControl: { projection: 'perspective', autoRotate: false } },
                series: [{ type: 'bar3D', data: data2, shading: 'lambert', itemStyle: { opacity: 0.9 }, emphasis: { label: { fontSize: 14 } } }]
            });
            window.addEventListener('resize', function() { chart2.resize(); });
            }
        }
    }
    document.addEventListener('DOMContentLoaded', initStats3DCharts);
    document.addEventListener('turbo:load', initStats3DCharts);
    </script>

    {% if produitsPlusChers is not empty or produitsMoinsChers is not empty or produitsPlusAjoutes is not empty %}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Top produits plus chers -->
        {% if produitsPlusChers is not empty %}
        <div class="bg-white rounded-xl border border-[#E5E0D8] p-6">
            <h2 class="text-lg font-semibold text-[#4B5563] mb-4 flex items-center gap-2">
                <svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                </svg>
                Top 5 Produits Plus Chers
            </h2>
            <div class="space-y-2">
                {% for produit in produitsPlusChers %}
                <div class="flex items-center justify-between p-2 border border-[#E5E0D8] rounded-lg">
                    <div class="flex-1">
                        <p class="text-sm font-medium text-[#4B5563] truncate">{{ produit.nom }}</p>
                        <p class="text-xs text-[#6B280]">{{ produit.categorie ? produit.categorie.label : 'N/A' }}</p>
                    </div>
                    <span class="text-sm font-bold text-red-600">{{ produit.prix|number_format(2, ',', ' ') }} dt</span>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        <!-- Top produits moins chers -->
        {% if produitsMoinsChers is not empty %}
        <div class="bg-white rounded-xl border border-[#E5E0D8] p-6">
            <h2 class="text-lg font-semibold text-[#4B5563] mb-4 flex items-center gap-2">
                <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6" />
                </svg>
                Top 5 Produits Moins Chers
            </h2>
            <div class="space-y-2">
                {% for produit in produitsMoinsChers %}
                <div class="flex items-center justify-between p-2 border border-[#E5E0D8] rounded-lg">
                    <div class="flex-1">
                        <p class="text-sm font-medium text-[#4B5563] truncate">{{ produit.nom }}</p>
                        <p class="text-xs text-[#6B280]">{{ produit.categorie ? produit.categorie.label : 'N/A' }}</p>
                    </div>
                    <span class="text-sm font-bold text-green-600">{{ produit.prix|number_format(2, ',', ' ') }} dt</span>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        <!-- Produits les plus ajoutés aux paniers -->
        {% if produitsPlusAjoutes is not empty %}
        <div class="bg-white rounded-xl border border-[#E5E0D8] p-6">
            <h2 class="text-lg font-semibold text-[#4B5563] mb-4 flex items-center gap-2">
                <svg class="w-5 h-5 text-[#A7C7E7]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                </svg>
                Top 5 Plus Ajoutés au Panier
            </h2>
            <div class="space-y-2">
                {% for item in produitsPlusAjoutes %}
                <div class="flex items-center justify-between p-2 border border-[#E5E0D8] rounded-lg">
                    <div class="flex-1">
                        <p class="text-sm font-medium text-[#4B5563] truncate">{{ item.nom }}</p>
                        <p class="text-xs text-[#6B280]">{{ item.prix|number_format(2, ',', ' ') }} dt</p>
                    </div>
                    <div class="text-right">
                        <span class="text-sm font-bold text-[#A7C7E7]">{{ item.totalQuantite }}</span>
                        <p class="text-xs text-[#6B280]">ajouté(s)</p>
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}
    </div>
    {% endif %}

    <!-- Statistiques des paniers -->
    <div class="bg-white rounded-xl border border-[#E5E0D8] p-6">
        <h2 class="text-lg font-semibold text-[#4B5563] mb-4">Statistiques des Paniers</h2>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div class="text-center p-4 bg-[#F5F1EB] rounded-lg">
                <p class="text-sm font-medium text-[#6B280]">Total Paniers</p>
                <p class="text-xl font-bold text-[#4B5563] mt-1">{{ totalPaniers }}</p>
            </div>
            <div class="text-center p-4 bg-[#F5F1EB] rounded-lg">
                <p class="text-sm font-medium text-[#6B280]">Paniers Actifs</p>
                <p class="text-xl font-bold text-[#A7C7E7] mt-1">{{ paniersActifs }}</p>
            </div>
            <div class="text-center p-4 bg-[#F5F1EB] rounded-lg">
                <p class="text-sm font-medium text-[#6B280]">Total Articles</p>
                <p class="text-xl font-bold text-[#4B5563] mt-1">{{ totalArticlesDansPaniers }}</p>
            </div>
            <div class="text-center p-4 bg-[#F5F1EB] rounded-lg">
                <p class="text-sm font-medium text-[#6B280]">Valeur Totale</p>
                <p class="text-xl font-bold text-green-600 mt-1">{{ valeurTotalePaniers|number_format(2, ',', ' ') }} dt</p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
# In all environments, the following files are loaded if they exist:
#  * .env
#  * .env.local
#  * .env.$APP_ENV
#  * .env.$APP_ENV.local
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE.
# Utilisez .env.local pour les clés secrètes (non versionné).
# https://symfony.com/doc/current/configuration/secrets.html

APP_URL=http://127.0.0.1:8000

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=3210a55f8500612c18b519d02d8beba1
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://root:@127.0.0.1:3306/pidb"
###< doctrine/doctrine-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
MAILER_DSN=smtp://localhost
MAILER_FROM=noreply@auticare.local
MAILER_FROM_NAME=AutiCare
###< symfony/mailer ###

###> Google Calendar API ###
GOOGLE_CALENDAR_CREDENTIALS=config/google-calendar-credentials.json
GOOGLE_CALENDAR_ID=
###< Google Calendar API ###

###> OAuth Google ###
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
###< OAuth Google ###

###> Zoom ###
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
###< Zoom ###

###> symfony/twilio-notifier ###
TWILIO_DSN=twilio://ACxxxx:xxxx@default?from=+0000000000
RAPPEL_SMS_DEFAULT_COUNTRY_CODE=33
RAPPEL_SMS_SANS_LIEN=0
###< symfony/twilio-notifier ###

###> LibreTranslate ###
# localhost = instance Docker (docker start emna). Mise en route 5–10 min (téléchargement modèles).
# Pour démarrer plus vite : docker run -d -p 5000:5000 -e LT_LOAD_ONLY=fr,en --name emna libretranslate/libretranslate
# Si local échoue, fallback auto vers l'API publique. Pour forcer l'API publique : https://libretranslate.com
LIBRETRANSLATE_URL=http://localhost:5000
LIBRETRANSLATE_CACHE_TTL=86400
LIBRETRANSLATE_API_KEY=
###< LibreTranslate ###

###> Cloudinary ###
CLOUDINARY_URL=
###< Cloudinary ###

###> Pexels ###
PEXELS_API_KEY=
###< Pexels ###


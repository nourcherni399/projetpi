# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

# -----------------------------------------------------------------------------
# APPLICATION DE BASE
# -----------------------------------------------------------------------------
###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=3210a55f8500612c18b519d02d8beba1
APP_URL=http://127.0.0.1:8000
###< symfony/framework-bundle ###

# -----------------------------------------------------------------------------
# BASE DE DONNÉES
# -----------------------------------------------------------------------------
###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
DATABASE_URL="mysql://root:@127.0.0.1:3306/pidb"
###< doctrine/doctrine-bundle ###

# -----------------------------------------------------------------------------
# FILE D'ATTENTE (MESSENGER)
# -----------------------------------------------------------------------------
###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

# -----------------------------------------------------------------------------
# ENVOI D'EMAILS
# -----------------------------------------------------------------------------
###> symfony/mailer ###
# Envoi des e-mails (récupération mot de passe) depuis amarahedil8@gmail.com
MAILER_DSN=smtp://amarahedil8@gmail.com:ihdv%20qimv%20lptx%20sodk@smtp.gmail.com:587?encryption=tls&auth_mode=login
###< symfony/mailer ###

###> Brevo API (envoi e-mails par API) ###
# Créer un compte sur https://www.brevo.com puis générer une clé API (SMTP & API)
# Si définis, les e-mails (vérification carte, mot de passe oublié) seront envoyés via l'API Brevo
# BREVO_API_KEY=
# BREVO_FROM_EMAIL=noreply@votredomaine.com
# BREVO_FROM_NAME=AutiCare
###< Brevo API ###

###> symfony/google-mailer ###
# Gmail SHOULD NOT be used on production, use it in development only.
# MAILER_DSN=gmail://USERNAME:PASSWORD@default
###< symfony/google-mailer ###

# -----------------------------------------------------------------------------
# AUTHENTIFICATION & OAUTH
# -----------------------------------------------------------------------------
###> OAuth Google (connexion avec Google) ###
# Créer des identifiants : https://console.cloud.google.com/apis/credentials
# Type "Application OAuth 2.0" (client ID pour application web).
# URI de redirection à ajouter dans la console Google : {APP_URL}/connect/google/check
# Définir APP_URL (ex. http://localhost:8000) pour éviter l'erreur redirect_uri_mismatch.
OAUTH_GOOGLE_CLIENT_ID=hHrLOmYEQMWKvOpx1kzz2Q
OAUTH_GOOGLE_CLIENT_SECRET=E67SEPumQQI1ZJgiVDuuzJf31lNqfKyU
###< OAuth Google ###

# -----------------------------------------------------------------------------
# VIDÉOCONFÉRENCE
# -----------------------------------------------------------------------------
###> Zoom (réunions en ligne pour événements) ###
# Créer une app "Server-to-Server OAuth" sur https://marketplace.zoom.us/
ZOOM_ACCOUNT_ID=sjECmyYCQGitjfAy2WWw2g
ZOOM_CLIENT_ID=hHrLOmYEQMWKvOpx1kzz2Q
ZOOM_CLIENT_SECRET=E67SEPumQQI1ZJgiVDuuzJf31lNqfKyU
###< Zoom ###

# -----------------------------------------------------------------------------
# INTELLIGENCE ARTIFICIELLE - SERVICES MULTIPLES
# -----------------------------------------------------------------------------
###> Chatbot IA - Groq (principal) ###
# Créez une clé sur https://console.groq.com/keys - GRATUIT
# Utilisé par : ChatApiService, GroqSummaryService, GroqModuleGeneratorService,
#              GroqBlogGeneratorService, GroqSpellCheckService, GroqHashtagGeneratorService,
#              ProductPriceSearchService, ImageAnalysisService, ProductDescriptionSuggestionService, AIPredictionService
# CHAT_API_KEY=
CHAT_API_URL=https://api.groq.com/openai
CHAT_API_BASE_URL=
CHAT_MODEL=llama-3.3-70b-versatile
###< Chatbot IA ###

###> OpenAI API (chatbot IA - génération fiches produit) ###
# 1. Créez un compte sur https://platform.openai.com
# 2. Allez sur https://platform.openai.com/api-keys
# 3. Cliquez "Create new secret key" et copiez la clé (format sk-proj-... ou sk-...)
# Utilisé par : ProductAiService, ProductConversationService, DemandeProduitEnrichmentService
# OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o
###< OpenAI API ###

###> Google Gemini (Vision IA) ###
# Créez une clé gratuite sur https://aistudio.google.com/apikey
# Utilisé par : ImageAnalysisService
# GEMINI_API_KEY=
###< Google Gemini ###

###> IA (Hugging Face) ###
# Clé API gratuite : https://huggingface.co/settings/tokens — pour résumé, sentiment, suggestion de description et génération d'images (affiches).
# HUGGINGFACE_API_KEY=
# Modèle chat (optionnel). Si "model not supported", activez des providers sur https://hf.co/settings/inference-providers
# puis testez un modèle (ex. google/gemma-2-2b-it:fastest, meta-llama/Llama-3.2-3B-Instruct:fastest).
# HUGGINGFACE_MODEL=google/gemma-2-2b-it:fastest
###< IA (Hugging Face) ###

###> IA externe (OpenRouter/OpenAI compatible) - Recommandations ###
# Pour utiliser un autre fournisseur compatible OpenAI
AI_RECOMMENDER_ENABLED=0
AI_RECOMMENDER_API_KEY=
AI_RECOMMENDER_MODEL=
AI_RECOMMENDER_BASE_URL=
###< IA externe ###

# -----------------------------------------------------------------------------
# TRADUCTION
# -----------------------------------------------------------------------------
###> LibreTranslate (traduction blog/modules) ###
# URL de l'API LibreTranslate
# Auto-hébergement Docker : http://libretranslate:5000 (même réseau) ou http://localhost:5000
# Hébergé payant : https://libretranslate.com (nécessite LIBRETRANSLATE_API_KEY)
LIBRETRANSLATE_URL=http://localhost:5000
LIBRETRANSLATE_CACHE_TTL=86400
# Clé API : requise pour libretranslate.com | vide pour instance auto-hébergée
LIBRETRANSLATE_API_KEY=
###< LibreTranslate ###

# -----------------------------------------------------------------------------
# IMAGES ET MÉDIAS
# -----------------------------------------------------------------------------
###> Pexels (images produits, modules, blog) ###
# Option 1 - Pexels (GRATUIT) : 200 req/h, 20k/mois
# 1. Créez un compte sur https://www.pexels.com
# 2. Demandez une clé API : https://www.pexels.com/api/
# 3. Collez la clé ci-dessous
# Utilisé par : ProductExternalApiService, ProductPriceSearchService, PexelsService
# PEXELS_API_KEY=
###< Pexels ###

###> RapidAPI (images produits - option payante) ###
# Option 2 - Amazon via RapidAPI (payant)
# Utilisé par : ProductExternalApiService, ProductPriceSearchService
# RAPIDAPI_KEY=
###< RapidAPI ###

